}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0361.uasset.csv","tags":[],"progress":{"translated":73,"length":73,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0371.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya","basename":"unique0371.uasset.csv","extension":"csv","filename":"unique0371.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0371.uasset.csv","data":[["unique0371","unique0371",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「まさか知らぬ間に、\\n　我が社が外注を抱えていたとは……」","「真没想到不知不觉间，\\n　我们公司居然有了外包人员……」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「そうなってしまうのでしょうか」","「会变成那样吗」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「……いけなかったでしょうか？\\n　私なりに何かしなければと思い」","「……我这么做不行吗？\\n　我以自己的方式觉得必须要做点什么」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「まあ、いけないって事は全然」","「哎呀，完全没有不行的意思」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「誰がいけないかと言われたら報連相を怠った、\\n　トモリのやつが一番悪いし」","「要说怪谁的话，那就是疏于汇报、联络、商量的\\n　灯那家伙最坏了」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「……いやあいつ、マジで悪いな。\\n　うん。帰ったら説教」","「……不，那家伙，真的坏啊。\\n　嗯。回家后得好好说教她」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「そ、そう言わないで下さいませ。\\n　悪いのは私ですので」","「请、请不要这样说。\\n　坏的是我才对」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「いや……祝には……悪いとかは言えない……」","「不……对祝……没法说坏什么的……」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「……何故でしょうか？」","「……这是为什么呢？」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「だってうちの近所からの評判が、\\n　超絶うなぎ上りなんだもの……」","「因为咱们在附近一带的风评，\\n　那简直是直线飙升啊……」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「この前なんてご近所さんから、\\n　ミカンのお裾分け貰っちゃったからね」","「前几天，还从邻居那里\\n　收到了人家送的橘子呢」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「今まではなんとなくいかがわしくて、\\n　怪しい連中として白い目で見られてたのに……」","「明明之前被人总觉得可疑，\\n　被当成怪人团伙冷眼相待的……」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「……ご近所付き合いは、\\n　ちゃんとしたほうがよろしいですよ？」","「……和邻居搞好关系，\\n　是件好事哦？」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「今朝も私は、\\n　町内会の皆さんとゴミ拾いしてきましたし」","「今天早上我也，\\n　和居委会的各位一起去捡了垃圾」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「……すごすぎる」","「……太厉害了」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「花火大会の良い場所のチケットを頂いたので、\\n　後で皆さんにお配りしますね」","「拿到了花火大会好位置的票，\\n　回头分给大家吧」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「マジにすごすぎる」","「真的太厉害了」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「それに雨どいの修理も完璧だったし、\\n　エアコンの清掃までしてくれちゃって」","「而且屋檐漏水也修得完美，\\n　连空调清洗都给做了」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「エアコンのフィルターは2週間に1回ほど、\\n　お掃除したほうがよろしいですよ？」","「空调的滤网，大概2周一次，\\n　还是清洗一下比较好哦？」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「そりゃよろしいかもしれんけどさ……」","「那倒可能是比较好啦……」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「いまだかつてエアコンのフィルターを\\n　日常的に掃除するやつを見たことがない」","「但我从没见过有谁\\n　会日常性地清洗空调滤网的」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「……」","「……」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「でも、居る所には居るんだよな」","「不过，有的地方还真就有这种人呢」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「喜んで頂けて恐縮です」","「能让你高兴，真让我诚惶诚恐」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「その社会スキルはどこから手に入れたんだ」","「你这社交技能是从哪学来的啊」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「……家……なのでしょうかね？\\n　自然と身についたものだとは思いますが」","「……是……家里吧？\\n　我觉得是自然而然掌握的」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「それで、いかがいたしましょう？」","「那么，该怎么办呢？」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「本来の責め苦があるのなら、\\n　そちらに戻るべきでしょうか」","「如果本来有责难，\\n　我是不是该回到那边去呢」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「いいや我が社は非常に助かっているし、\\n　給料はいらないと言うし、継続するしかない」","「不不，我们公司得到了很大帮助，\\n　你还说不要工资，只能继续这样了」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「まあ。それはよかった」","「哎呀。那太好了」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「それではこれからも、\\n　頑張らせていただきますわ♪」","「那么今后，\\n　也请让我继续努力吧♪」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「こちらこそよろしくお願いします」","「我们才是要请你多多关照」",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「ではとりあえず、帰ったら……」","「那么总之，回家后……」",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「とうもろこしのかき揚げでも、\\n　振る舞いましょうか」","「就来露一手，做个玉米天妇罗炸什锦\\n　怎么样」",null,null,null]],"type":"","context":[["unique0371.uasset.csv/row/104","unique0371.uasset.csv/row/115","unique0371.uasset.csv/row/126","unique0371.uasset.csv/row/137","unique0371.uasset.csv/row/148","unique0371.uasset.csv/row/159","unique0371.uasset.csv/row/170","unique0371.uasset.csv/row/181","unique0371.uasset.csv/row/192","unique0371.uasset.csv/row/203","unique0371.uasset.csv/row/214","unique0371.uasset.csv/row/225","unique0371.uasset.csv/row/236","unique0371.uasset.csv/row/247","unique0371.uasset.csv/row/258","unique0371.uasset.csv/row/269","unique0371.uasset.csv/row/280","unique0371.uasset.csv/row/291","unique0371.uasset.csv/row/302","unique0371.uasset.csv/row/313","unique0371.uasset.csv/row/324","unique0371.uasset.csv/row/335","unique03