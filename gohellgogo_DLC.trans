2AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/02_Arakasegi/02_Arakasegi03.uasset.csv","tags":[],"progress":{"translated":120,"length":120,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/02_Arakasegi/02_Arakasegi04.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/02_Arakasegi","basename":"02_Arakasegi04.uasset.csv","extension":"csv","filename":"02_Arakasegi04.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/02_Arakasegi/02_Arakasegi04.uasset.csv","data":[["02_Arakasegi04","02_Arakasegi04",null,null,null],["12_TEXT","12_TEXT",null,null,null],["「ほら、これそっち持ってけ。\\n　次はそれをそっち」","「来，这个你拿那边去。\\n　接着那个放那边」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「はいはい」","「好好」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「あーー違う！　それはこっちじゃなくて！\\n　あと置き方もちゃんと考えれ」","「啊——不对！那个不是放这边！\\n　还有放法也得好好想想！」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「……細かいやっちゃな。\\n　あくまで俺は善意で手伝ってんだぞ善意で」","「……真是个挑剔的家伙啊。\\n　说到底我可是出于好意才帮忙的，好意」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「善意だから適当な仕事で良いというのは、\\n　あんまりにも嫌な意見だと思わんか」","「因为是好意所以随便干干就行，\\n　你不觉得这种想法太让人讨厌了吗」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「……それはその通り。\\n　こっちだっけ？　この箱」","「……确实没错。\\n　是放这边吗？这个箱子」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「うむ。えらいぞ」","「嗯。真了不起」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「褒められると働こうという気持ちになる、\\n　単純な自分が我ながら可愛い」","「一被夸就有干劲了，\\n　连我自己都觉得我这单纯的性子挺可爱的」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「……言ってることきしょ」","「……你说的话好恶」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「目に見えて下がった、やる気が」","「干劲明显下降了」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「店の手伝いをしてくれる常連なんだから、\\n　もっと掌の上で転がしてくれよ」","「我可是帮你店里忙的常客啊，\\n　再把我玩弄于股掌之间一点嘛」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「……まあそのぐらいはしてやってもいいか」","「……好吧，这点程度倒也无妨」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「偉いぞ、ヤツシロ。がんばれ♪　がんばれ♪」","「了不起哦，8246。加油♪　加油♪」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「…………」","「…………」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「俺って単純すぎるかもな……」","「我可能真的太单纯了……」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「あ、ついでにこの張り紙もあっちに貼っといて」","「啊，顺便把这个告示也贴到那边去」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「了解、ボス」","「了解，老板」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「あれ？　てかアレ置いてないの。\\n　この前散々な目にあった、ぬるぬるのやつ」","「咦？话说那个没摆出来吗。\\n　就是之前让我倒大霉的，滑溜溜的那个」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「……あーあれ」","「……啊——那个啊」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「それが飛ぶように売れてな。\\n　なんで需要があんのかよーわからん」","「那个卖得飞快啊。\\n　也不知道哪里来的需求，真是搞不懂」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「売れるならいーじゃん。\\n　どんどん入荷して……」","「能卖掉不挺好嘛。\\n　不断进货……」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「やだよ！　普通にキモいし、\\n　変なこと思い出しちゃうし」","「不要啦！本来就够恶心的，\\n　还会想起些奇怪的事」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「売れることよりも、\\n　気分良く働ける方が大事」","「比起卖得好，\\n　心情愉快地工作更重要」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「いいねえーそういう気楽なやり方も」","「不错啊——这种轻松自在的搞法」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「でも売れるにこしたことはないだろ」","「但能卖掉总归是再好不过的吧」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「そりゃあね」","「那倒也是」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「だから俺は提案するんだけど、\\n　バニーガールの衣装を着たまま……」","「所以我有个提议，\\n　穿着兔女郎装就这样……」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「きも。誰がやるか。クソ提案」","「好恶。谁要干啊。垃圾提议」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「言い終わってないのにそこまで言うか」","「我话都还没说完就说到这份上啊」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「あ、でもアンタがバニー着て\\n　接客するってんなら許可するぞ。\\n　面白そうだから」","「啊，不过你要是穿上兔女郎装\\n　去接待客人的话，我倒可以批准。\\n　感觉会很有趣」",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「ぐっそれは流石にキツイ」","「唔，就这个实在有点……」",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「その場合アラカセギには、\\n　トップレスぐらいになってもらわないと、\\n　色々と釣り合わない……！」","「那样的话，荒稼不至少\\n　脱掉上衣的话，\\n　各方面可就太不平衡了……！」",null,null,null],["47_TEXT","47_TEXT",null,null,null],["「何が釣り合わないんだよ！？\\n　なめんな、アタシの美少女ボディを」","「什么叫不平衡啊！？\\n　少瞧不起人了，我这副美少女的身体！」",null,null,null],["48_TEXT","48_TEXT",null,null,null],["「バニーおっさんのキモさと、\\n　美少女のエロさが釣り合わないっつーんだ」","「就是说，兔男郎大叔的恶心感，\\n　和美少女的色气完全不平衡啊」",null,null,null],["49_TEXT","49_TEXT",null,null,null],["「あ、プラスとマイナスの釣り合いの話か」","「哦，是说正面和负面的平衡啊」",null,null,null],["50_TEXT","50_TEXT",null,null,null],["「……もしかしてヤツシロってアタシのこと、\\n　結構可愛いと思ってる？」","「……难道说，8246你觉得我，\\n　还挺可爱的？」",null,null,null],["51_TEXT","51_TEXT",null,null,null],["「そりゃずっとそうだろ」","「那不一直是这样吗」",null,null,null],["52_TEXT","52_TEXT",null,null,null],["「ふうーん。キモ」","「哦——。真恶心」",null,null,null],["53_TEXT","53_TEXT",null,null,null],["「答えただけなのにキモはマジか」","「我就是照实回答，居然说我恶心，你是认真的？」",null,null,null],["54_TEXT","54_TEXT",null,null,null],["「てか普通に忘れてた。\\n　俺、買い物に来たんだった」","「话说回来，我差点忘了。\\n　我是来买东西的啊」",null,null,null],["55_TEXT","55_TEXT",null,null,null],["「……いいけど。\\n　仕事はもうちょっと手伝ってけよ」","「……行吧。\\n　不过工作上再多帮我会儿啊」",null,null,null],["56_TEXT","56_TEXT",null,null,null],["「がんばった分、勉強してくれるなら」","「要是你干的活能换来学习的话」",null,null,null],["57_TEXT","57_TEXT",null,null,null],["「甘えるな。従業員割引も有給休暇も、\\n　うちにはねーんだ」","「少撒娇了。员工折扣也好，带薪休假也好，\\n　我们这儿可都没有」",null,null,null],["58_TEXT","58_TEXT",null,null,null],["「ぶ、ブラック……」","「黑、黑心企业啊……」",null,null,null]],"type":"","context":[["02_Arakasegi04.uasset.csv/row/96","02_Arakasegi04.uasset.csv/row/115","02_Arakasegi04.uasset.csv/row/126","02_Arakasegi04.uasset.csv/row/137","02_Arakasegi04.uasset.csv/row/148","02_Arakasegi04.uasset.csv/row/167","02_Arakasegi04.uasset.csv/row/178","02_Arakasegi04.uasset.csv/row/189","02_Arakasegi04.uasset.csv/row/200","02_Arakasegi04.uasset.csv/row/211","02_Arakasegi04.uasset.csv/row/222","02_Arakasegi04.uasset.csv/row/233","02_Arakasegi04.uasset.csv/row/244","02_Arakasegi04.uasset.csv/row/255","02_Arakasegi04.uasset.csv/row/266","02_Arakasegi04.uasset.csv/row/285","02_Arakasegi04.uasset.csv/row/296","02_Arakasegi04.uasset.csv/row/307","02_Arakasegi04.uasset.csv/row/318","02_Arakasegi04.uasset.csv/row/329","02_Arakasegi04.uasset.csv/