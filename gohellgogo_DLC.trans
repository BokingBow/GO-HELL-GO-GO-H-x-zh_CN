owInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/05_Kamase/unique1021.uasset.csv","tags":[],"progress":{"translated":55,"length":55,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/05_Kamase/unique1031.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/05_Kamase","basename":"unique1031.uasset.csv","extension":"csv","filename":"unique1031.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/05_Kamase/unique1031.uasset.csv","data":[["unique1031","unique1031",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「ふぅー……やっぱ美味いな、\\n　新しく入ったコーヒーメーカー」","「呼——……果然好喝啊，\\n　这新买的咖啡机」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「そんな味違うか？」","「味道能差那么多吗？」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「前のはプラスチックの味したからなあ。\\n　十数年モノだったみたいだし」","「因为之前那个有股塑料味嘛。\\n　好像用了十几年来着」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「いやあ仕事場でもそこそこのコーヒーが\\n　飲めるようになって良かったよ」","「哎呀，能在工作场所喝上\\n　像样点的咖啡，真是太好了」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「ふうん……まあそれなら、\\n　良かったんじゃないか」","「哼……嘛，既然如此，\\n　不是挺好的嘛」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「そういや、今責め苦の方は、\\n　誰か入ってるのか？」","「说起来，现在拷问室那边，\\n　有谁在吗？」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「ああ。ほら。\\n　あのイキってたやつ」","「啊啊。你看。\\n　就是那个之前很嚣张的家伙」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「あ…なんか噂は聞いたな。」","「啊……好像听过传闻呢。」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「今回はお試しで、例の奴を試すんだって」","「听说这次是试用，要试那个家伙」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「ああ、なんだっけ、あれ。確か……、\\n　……大随意圧地獄？」","「啊啊，叫什么来着，那个。好像是……、\\n　……大随意压地狱？」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「うぅーーっ！　ぐっ……ごっ……！\\n　こ、これ。ガチでッ！　ちょっとッ！」","「唔唔——！呃……咳……！\\n　这、这玩意儿。来真的啊！等一下！」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「あれってまだテスト段階じゃなかったっけ」","「那个不是还在测试阶段吗」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「そう。今回うまくいけば、\\n　新たに正式採用するんだと」","「对。说是这次如果顺利，\\n　就要正式启用了」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「ぐぶっ……ぉっ……苦し……ッ。\\n　も、もっと……力、よわ、めて……」","「咕噗……哦……难受……。\\n　再、再……力气，小、一点……」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「うまくいけばって、どういう状態が、\\n　うまいってことなんだよ？」","「说是顺利，到底什么状态\\n　才叫顺利啊？」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「えーとなんだ。\\n　うまく絞られたら？」","「嗯——是什么呢。\\n　被绞得恰到好处？」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「ぎゅぐっ……ぐっ……げふっげふっ……。\\n　ぁ……の……もう、やめ……ッ」","「咕唔……咳……咳咳……。\\n　求……你们……已经，住手……」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「絞られるってなんだよ」","「什么叫被绞啊」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「知らねーよ。その辺はお偉いさん達が\\n　判断すんじゃねえの知らんけど」","「谁知道呢。这种事，大概是大人物们\\n　来判断的吧，我也不清楚」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「ぉ……っ、ぉっ……あのっ……誰か……、\\n　本当に……もう、無理、で……ッ」","「啊……、呜……那个……谁来……、\\n　真的……已经，不行、了……」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「腹、その、すんません。なんか、出る、から。\\n　ぉっ……せめて、もっと、優しく……ッ」","「肚子，那个，对不起。好像有东西，要出来了。\\n　哦……至少，再轻一点……」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「うっ……あの……ほんと、ごめんなさい。\\n　あ、あたし……イキって、て……」","「呜……那个……真的，对不起。\\n　我、我……太嚣张、了……」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「アタシの、負け……ですっ……ぜったい。\\n　勝てないって、わかりました。だから」","「是我、输了……绝对。\\n　知道赢不了。所以」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「もう、勘弁してくだ……げふっ」","「请饶了我吧……咳咳」",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「それにしても振動激しいな。\\n　こっちに突き破ってくんなよ」","「话说回来，振动好剧烈啊。\\n　别撞破这边哦」",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「その辺考えてなさそ～」","「感觉根本没考虑到那方面～」",null,null,null],["48_TEXT","48_TEXT",null,null,null],["「だれ……か。おね、がい……おねが、いだから……。\\n　ごほっ……ごほっ……げえええっ」","「谁……来。求、求……求求你们了……。\\n　咳……咳……呃啊啊啊」",null,null,null],["49_TEXT","49_TEXT",null,null,null],["「しかし、なんだな……」","「不过，怎么说呢……」",null,null,null],["50_TEXT","50_TEXT",null,null,null],["「なに？」","「嗯？」",null,null,null],["51_TEXT","51_TEXT",null,null,null],["「げほっごほっ……たす、け……っ」","「咳咳咳……救、我……啊」",null,null,null],["52_TEXT","52_TEXT",null,null,null],["「お願い……誰かァ……たす、け……っ」","「求你们……谁来啊……救、我……啊」",null,null,null],["53_TEXT","53_TEXT",null,null,null],["「確かにうまいかも、このコーヒー」","「好像确实挺好喝，这咖啡」",null,null,null],["54_TEXT","54_TEXT",null,null,null],["「だろぉー？」","「对吧～？」",null,null,null],["57_TEXT","57_TEXT",null,null,null],["「ぉ……また、力強くなってぇ……っ。\\n　ムリムリムリムリこれ以上はム……ッ」","「呜……又、变强了……。\\n　不行不行不行不行再这样下去不行……了」",null,null,null],["58_TEXT","58_TEXT",null,null,null],["「おごっ……ごっ……ふーっ……ふーっ……ふーっ」","「呕……咳……呼——……呼——……呼——」",null,null,null],["60_TEXT","60_TEXT",null,null,null],["「……ぉっ」","「…………呜」",null,null,null],["64_TEXT","64_TEXT",null,null,null],["「…………」","「…………」",null,null,null],["67_TEXT","67_TEXT",null,null,null],["「お。おとなしくなった？\\n　様子でも見てくるか？」","「哦。安静下来了？\\n　要不去看看情况？」",null,null,null],["68_TEXT","68_TEXT",null,null,null],["「やだよこえーし。\\n　昼前に見たくねえだろ」","「讨厌啦好可怕。\\n　午饭前不想看到那种东西吧」",null,null,null],["69_TEXT","69_TEXT",null,null,null],["「そりゃそうか。先メシいこうぜ。\\n　今日、定食なんだっけ？」","「说的也是。先去吃饭吧。\\n　今天，是套餐来着？」",null,null,null],["70_TEXT","70_TEXT",null,null,null],["「あー。なんだっけ。確か――」","「啊——。是什么来着。好像是——」",null,null,null]],"type":"","context":[["unique1031.uasset.csv/row/104","unique1031.uasset.csv/row/115","unique1031.uasset.csv/row/126","unique1031.uasset.csv/row/137","unique1031.uasset.csv/row/148","unique1031.uasset.csv/row/159","unique1031.uasset.csv/row/170","unique1031.uasset.csv/row/181","unique1031.uasset.csv/row/192","unique1031.uasset.csv/row/203","unique1031.uasset.csv/row/246","unique1031.uasset.csv/row/257","unique1031.uasset.csv/row/268","unique1031.uasset.csv/row/279","unique1031.uasset.csv/row/290","unique1031.uasset.csv/row/301","unique1031.uasset.csv/row/320","unique1031.uasset.csv/row/331","unique1031.uasset.csv/row/342","unique1031.uasset.csv/row/361","unique1031.uasset.csv/row/372","unique1031.uasset.csv/row/383","unique1031.uasset.csv/row/394","unique1031.uasset.csv/row/413","unique1031.uasset.csv/row/432","unique1031.uasset.csv/row/443","unique1031.uasset.csv/row/462","unique1031.uasset.csv/row/473","unique1031.uasset.csv/row/484","unique1031.uasset.csv/row/