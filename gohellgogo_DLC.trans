B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0271.uasset.csv","tags":[],"progress":{"translated":63,"length":63,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0351.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya","basename":"unique0351.uasset.csv","extension":"csv","filename":"unique0351.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0351.uasset.csv","data":[["unique0351","unique0351",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「えっと……あの……その」","「那个……就是……呃」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「ごめんくださーい」","「打扰了——」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「……」","「……」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「あっ。ごめんなさいごめんなさい。\\n　ちょっと奥のお掃除をしてて」","「啊。对不起对不起。\\n我刚才在里面打扫卫生」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「はじめまして。祝と申します」","「初次见面，我叫祝」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「こ、これわこれわご丁寧に。\\n　……灯と申します」","「哎呀呀，您真是太客气了。\\n……我叫灯」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「えーっと。何かご用事ですか？」","「呃。请问有什么事吗？」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「……私は責め苦をおうべき身なのに、\\n　なぜかいきなり町中に放りだされてしまって」","「……我本是该背负罪责的人，\\n却不知为何，突然被扔到了镇上」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「あらまあ」","「哎呀呀」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「どうすべきか、随分、悩んでいたのですが」","「我苦恼许久，不知该如何是好」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「そうですね。私でも悩みますもん」","「是啊。换作是我也会苦恼呢」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「……思えば、真っ先にこちらに来るべきでした」","「……想来，我本该一开始就来这里的」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「なのに何だか怖くて、\\n　踏み出せずにいたのです」","「但莫名有些害怕，\\n迟迟没能迈出那一步」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「……ご迷惑をおかけして、\\n　申し訳ございません」","「……给您添麻烦了，\\n　实在抱歉。」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「そ、そんな謝ることなんてないですよぉ！\\n　悪いのはいつだって杜撰な管理側ですし」","「没、没有的事，哪有什么好道歉的呀！\\n　错的从来都是管理松散的上头嘛。」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「そういうわけにはいきません」","「话不能这么说。」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「私、外にいる時、悪いことをしている気がして、\\n　心がじくじく痛みましたもの」","「我在外面的时候，总感觉自己在做坏事，\\n　心里头就一阵阵地隐隐作痛。」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「悪いことはしないほうが良いのですわ」","「坏事还是不做为妙。」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「はー真面目なんですねー……」","「哇——你也太认真了吧……」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「どうなのでしょう。\\n　単に小心者なのかもしれません」","「这也是认真的吗？\\n　也许只是我胆子小罢了。」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「私だったら絶対そのまま逃げ出しちゃいます」","「换了我，肯定早就直接跑掉了。」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「あらあら。ふふ。ご共感頂いて、\\n　非常に光栄の至りですわ」","「哎呀呀。呵呵。能博您一感同身受，\\n　实在是荣幸之至啊。」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「……でも。そういうわけにはいきません。\\n　それが私のお役目だったんだもの」","「……但是。我不能就这么走了。\\n　因为那曾是我职责所在啊。」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「私も亡者として見習わなければ。\\n　……いや見習うのは絶対無理そうだけど」","「我们亡者也该向您学习学习。\\n　……不，学您是肯定学不来的。」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「？　あなた様も、亡者？　なのですか？」","「？您也是，亡者？吗？」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「では、責め苦の方もお受けに……？」","「那，您也受那份苦差了……？」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「あー……いや私は紆余曲折ありまして。\\n　ほんとはお受けになるべきらしいんですけど」","「啊……不，我这情况比较曲折。\\n　按说原本是该受着的。」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「今は流れでほぼ無給労働をしてます」","「现在嘛，就顺着事态干着几乎打白工的事。」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「ろうどう」","「劳动。」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「お茶くみしたり事務仕事したり\\n　モンスターを燃やしたり……」","「端茶倒水啦，干点杂务啦，\\n　再烧烧怪物什么的……」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「労働時間は長いし怪我はするのに\\n　危険手当はつかないし……」","「累死累活地做久了还会受伤，\\n　可补助一毛钱都没有……」",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「……はっ。これって殆ど、\\n　責め苦と変わらないのかもしれないっ」","「……啊。这么一看，\\n　跟受那份苦差简直就啥区别嘛！」",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「あら。何だか大変そうですのね」","「哎呀。听起来还真是辛苦呢。」",null,null,null],["47_TEXT","47_TEXT",null,null,null],["「うぅ。自分で自分が哀れになってきた」","「呜。连我自己都好可怜自己了。」",null,null,null],["48_TEXT","48_TEXT",null,null,null],["「まあでも、結構楽しい？　ですよ？」","「这个嘛，不过，其实还挺乐在其中的？对吧？」",null,null,null],["49_TEXT","49_TEXT",null,null,null],["「……そうですか。\\n　楽しいのは、いいことですね」","「……是这样啊。\\n　能乐在其中，那可是好事啊。」",null,null,null],["50_TEXT","50_TEXT",null,null,null],["「ではひとまずは私も、\\n　それを責め苦として受けましょうか」","「那暂且我也，\\n　就把这份乐事当做苦差来受着如何？」",null,null,null],["51_TEXT","51_TEXT",null,null,null],["「へ？」","「诶？」",null,null,null],["52_TEXT","52_TEXT",null,null,null],["「ヤツシロさんに本来の責め苦に戻れと\\n　言われたら、そうすればいいだけですし」","「如果8246叫我做回原本那份苦差，\\n　我再照做就是。」",null,null,null],["53_TEXT","53_TEXT",null,null,null],["「今までお休みしていた分、\\n　すぐにでも頑張らないといけませんから」","「毕竟我已经休息了那么久，\\n　得赶紧努力才行。」",null,null,null],["54_TEXT","54_TEXT",null,null,null],["「な、なるほど？」","「好、好有道理？」",null,null,null],["55_TEXT","55_TEXT",null,null,null],["「ご迷惑でしょうか？」","「会给你们添麻烦吗？」",null,null,null],["56_TEXT","56_TEXT",null,null,null],["「いえいえ全然！　ご迷惑という事は全く」","「不不不会！完全不麻烦！」",null,null,null],["57_TEXT","57_TEXT",null,null,null],["「でしたらまずは、トイレ掃除でもしましょうか」","「既然如此，要不先从打扫厕所开始。」",null,null,null],["58_TEXT","58_TEXT",null,null,null],["「あ、トイレはさっき終わらせたので……。\\n　うーんそうだなあ」","「啊，厕所我刚才弄完了……。\\n　嗯，还有什么呢。」",null,null,null],["59_TEXT","59_TEXT",null,null,null],["「何かお困り事などはありませんか？」","「有什么您正困扰的事吗？」",null,null,null],["60_TEXT","60_TEXT",null,null,null],["「お困り事かあ……うーん」","「困扰的事啊……嗯。」",null,null,null],["61_TEXT","61_TEXT",null,null,null],["「……昔は入ってたスカートが、\\n　最近少しだけきつくなってしまって」","「……以前穿着正好的裙子，\\n　最近穿起来有点紧了。」",null,null,null],["62_TEXT","62_TEXT",null,null,null],["「それは大変！　乙女の一大事ですね」","「这可糟了！是少女的头等大事呢。」",null,null,null],["63_TEXT","63_TEXT",null,null,null],["「分かってくれますか！」","「你能理解吗！」",null,null,null],["64_TEXT","64_TEXT",null,null,null],["「けれど、私個人の努力で解決できる問題だと\\n　非常に助かるのですけれど」","「不过，要是有什么我个人努努力就能解决的问题，\\n　那可就帮大忙了。」",null,null,null],["65_TEXT","65_TEXT",null,null,null],["「そ、そうですよねえたはは。\\n　そっちは私がしっかり頑張らねば」","「说、说得没错呀啊哈哈。\\n　这方面我是得自己好好加油咯。」",null,null,null],["66_TEXT","66_TEXT",null,null,null],["「あとは裏手の雨どいが壊れちゃって、\\n　修理の人呼ばなきゃーぐらいですかね？」","「然后后面的排水管坏了，\\n　得叫个修理师傅来，大概就这些吧？」",null,null,null],["67_TEXT","67_TEXT",null,null,null],["「そうですか。\\n　では工具をお借り出来ますか？」","「这样啊。\\n　那能借一下工具吗？」",null,null,null],["68_TEXT","68_TEXT",null,null,null],["「へっ」","「哎？」",null,null,null],["69_TEXT","69_TEXT",null,null,null],["「それでは責め苦の方、\\n　頑張らせていただきますね♪」","「那我也得努力承受一下，\\n　责罚之苦咯♪」",null,null,null]],"type":"","context":[["unique0351.uasset.csv/r