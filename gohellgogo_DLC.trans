T_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0471.uasset.csv","tags":[],"progress":{"translated":69,"length":69,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0551.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya","basename":"unique0551.uasset.csv","extension":"csv","filename":"unique0551.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0551.uasset.csv","data":[["unique0551","unique0551",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「もし。どなたか。失礼致します……」","「打扰了。有人在吗。失礼了……」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「あいあーい。あ、いらっしゃーい」","「来啦ー。啊，欢迎光临ー」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「どうも、こちらの方ですか？」","「你好，请问是这里的人吗？」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「厳密には違うけど対外的には、\\n　ここの方みたいなもんかな」","「严格来说不是，但对外的话，\\n　算是这里的人吧」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「なに？　ヤツシロに用事？」","「怎么？找8246有事？」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「あ、いえ。こちらの事務所の方であれば、\\n　どなたでも……」","「啊，不。只要是这个事务所的人，\\n　谁都行……」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「あのですね、私、亡者なのですけれど」","「是这样的，我呢，是个亡者」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「はいはい。あ、元々ここの？」","「好的好的。啊，原本是这里的？」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「責め苦が途中で止まってしまって、\\n　街に放り出されてしまって」","「责罚到一半停了下来，\\n　就被扔到街上了」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「へえー。ラッキーじゃん、\\n　なかなかないよそんなこと」","「嚯—。那不是很走运吗，\\n　这种事可很少见哦」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「エンジョイすれば？\\n　言うて地獄だけど」","「享受一下如何？\\n　虽说这里是地狱」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「……あ立場的には言えないのに、\\n　つい脳を経由せずに言葉が」","「……啊以我的立场不该说的，\\n　话却不经大脑就说出来了」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「ご進言ありがとうございます。\\n　……しかし、私は」","「感谢您的建议。\\n　……但是，我」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「受けなければならないのです、責めを！」","「必须接受才行，责罚！」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「へえ、その義務感はどこから？」","「嚯，这义务感从何而来？」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「えーっと。あの。その」","「呃—。那个。这个」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「……魂の欲求と言うか心の形と言うか、\\n　もはやどうにもならない渇望と言うか」","「……该说是灵魂的渴求，还是心灵的形状，\\n　又或者已是无法抑制的渴望」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「……ンン？」","「……嗯嗯？」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「い、一度味わってしまったら忘れられなくなるのです」","「一、一旦品尝过那滋味，就再也忘不掉了」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「数多の卑しい視線の中、\\n　苛烈な責めで惨めな姿を晒す自分の事が」","「在无数卑贱的视线中，\\n　自己因严厉的责罚而暴露凄惨模样的这件事」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「痛みや苦しみ悲しみという感情が我が胸を焦がす、\\n　あのどうしようもない屈辱感が……！」","「痛苦、折磨和悲伤的感情烧灼着我的胸膛，\\n　那无可救药的屈辱感……！」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「私をこの場所へと、\\n　導いてしまったのです！」","「正是它将我，\\n　引向了这个地方！」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「それもしかして責めを『受けなきゃいけない』じゃなくて、\\n　責めを『受けたい』っていう話？」","「你这话的意思，不是‘必须’接受刑罚，\\n　而是‘想’接受刑罚吗？」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「人間は水を『飲まなければいけない』から飲むのか、\\n　『飲みたい』から飲むのかという話に似ています」","「这就和人是‘必须喝’水才喝，\\n　还是因为‘想喝’才喝的问题很相似。」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「へえー。珍しい。\\n　亡者根性と言うかなんというか」","「呵——真稀奇。\\n　这就是所谓的死性不改吧，还是说……」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「間違っているのは私ではありません。\\n　世界のほうです」","「有错的不是我。\\n　而是这个世界。」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「……あまり遭遇したこと無いケースかも」","「……或许我很少碰到你这种情况吧。」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「はあはあ、これは確かに悲劇です。しかし地獄の\\n　下衆な要求を私が一身に受け止めることで」","「哈啊哈啊，这确实是场悲剧。但是，如果我以一己之身\\n　承受住地狱那下作的要求，」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「……救われる者が居る。と私は信じ、\\n　厭々と責苦を受けなければならないのです」","「……就能有人得救。我如此相信着，\\n　因此不得不一边厌恶着，一边承受这折磨。」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「……嫌々を装う事で、\\n　興奮のスパイスにしてる系のやつ？」","「……你其实是那种，把假装不情愿，\\n　当成兴奋的调味料的那种家伙？」",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「なんのことかわかりません」","「我不知道您在说什么。」",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「あはは。まあそんなに責め苦受けたいなら、\\n　庁の方に問い合わせてみようか？」","「啊哈哈。哎呀，你这么想受折磨的话，\\n　要我帮你问问厅里那边吗？」",null,null,null],["47_TEXT","47_TEXT",null,null,null],["「地獄にホトケとはこの事ですか！？」","「您是说地狱里真有菩萨吗！？」",null,null,null],["48_TEXT","48_TEXT",null,null,null],["「……どちらかと言うと鬼だけど」","「……硬要说的话，我是鬼。」",null,null,null],["49_TEXT","49_TEXT",null,null,null],["「ま、待って下さい。でしたら受ける責め苦の方、\\n　こちらでリクエストしても良いでしょうかっ」","「等、请等一下。要是那样的话，关于所受的刑罚，\\n　我可以在这边提点要求吗？」",null,null,null],["50_TEXT","50_TEXT",null,null,null],["「急に目が輝いた。\\n　でも良いよ。出来るなら協力してあげる」","「眼神突然就亮了。\\n　不过可以哦。能办到的我会帮你。」",null,null,null],["52_TEXT","52_TEXT",null,null,null],["「●●を執拗に責めるのとか、\\n　あとは全身の●●を●●する責め苦とか」","「比如被执拗地折磨●●，\\n　还有把全身的●●都●●的那种酷刑，」",null,null,null],["53_TEXT","53_TEXT",null,null,null],["「出来れば肉体系より屈辱を煽ってくれる、\\n　●●●●●で●●●●な●●がいいんですけど！」","「可以的话，比起肉体上的，我更想要那种能煽动屈辱感、\\n　●●●●●而又●●●●的●●！」",null,null,null],["54_TEXT","54_TEXT",null,null,null],["「ひ、ひえ～。……そういうの、何が良いわけ？」","「噫、噫～……那种东西，到底好在哪儿啊？」",null,null,null],["55_TEXT","55_TEXT",null,null,null],["「興味がおありですか？」","「您有兴趣吗？」",null,null,null],["56_TEXT","56_TEXT",null,null,null],["「べ、べつに」","「才、才没有！」",null,null,null],["57_TEXT","57_TEXT",null,null,null],["「例えば●●の時は羞恥と屈辱でクラクラする中で、\\n　ふっと見上げたら沢山の目が私をジっと見つめていて」","「比如说在●●的时候，在羞耻和屈辱中头昏脑涨，\\n　蓦地一抬头，发现无数的眼睛正紧盯着我看，」",null,null,null],["58_TEXT","58_TEXT",null,null,null],["「その獣のような瞳の熱に心臓が焦がれる程に跳ね、\\n　視線を受け入れる自分を感じて悶えるのです」","「心脏被那野兽般的目光之热烧得狂跳不止，\\n　我为那接纳了视线的自己而神魂颠倒。」",null,null,null],["59_TEXT","59_TEXT",null,null,null],["「…………ごくり」","「…………（咕噜）。」",null,null,null],["60_TEXT","60_TEXT",null,null,null],["「あとは●●だと●●が意外と●●で、\\n　これが単純にどうしようもないほど気持ちよかったり」","「还有在●●的时候，●●竟会出乎意料地●●，\\n　这其实单纯就是一种无可救药的舒服啊。」",null,null,null],["61_TEXT","61_TEXT",null,null,null],["「本当に！？　そんなのが！？」","「真的！？居然会那样！？」",null,null,null],["62_TEXT","62_TEXT",null,null,null],["「是非一度お試し下さい」","「请务必尝试一次。」",null,null,null],["63_TEXT","63_TEXT",null,null,null],["「い、いや。絶対試したりはしないけど……」","「不，不。我是绝对不会去试的……」",null,null,null],["64_TEXT","64_TEXT",null,null,null],["「……残念です。\\n　才能がありそうなのに……」","「……真遗憾。\\n　明明看起来很有天分的……」",null,null,null],["65_TEXT","65_TEXT",null,null,null],["「な、ない！　ないから！！」","「没，没有！我没有！」",null,null,null],["66_TEXT","66_TEXT",null,null,null],["「……庁には連絡したから表で待ってれば、\\n　迎えの者が連れてってくれると思う」","「……我已经联系过厅里了，你就在外面等着吧，\\n　应该会有人来接你过去的。」",null,null,null],["67_TEXT","67_TEXT",null,null,null],["「はい。お世話様でした。\\n　それではこれで、失礼致します。ぺこり」","「好的。真是多谢关照了。\\n那就这样，告辞了。（鞠躬）」",null,null,null],["72_TEXT","72_TEXT",null,null,null],["「……………………」","「……………………」",null,null,null],["73_TEXT","73_TEXT",null,null,null],["「そ、そんなにいいのかな。……どきどき」","「这、这样真的好吗？……（心跳加速）」",null,null,null]],"type":"","context":[["unique0551.uasset.csv/row/120","unique0551.uasset.csv/row/131","unique0551.uasset.csv/row/142","unique0551.uasset.csv/row/153","unique0551.uasset.csv/row/164","unique0551.uasset.csv/row/175","unique0551.uasset.csv/row/186","unique0551.uasset.csv/row/197","unique0551.uasset.csv/row/208","unique0551.uasset.csv/row/219","unique0551.uasset.csv/row/230","unique0551.uasset.csv/row/241","unique0551.uasset.csv/row/252","unique0551.uasset.csv/row/263","unique0551.uasset.csv/row/274","unique0551.uasset.csv/row/285","unique0551.uasset.csv/row/296","unique0551.uasset.csv/row/307","unique0551.uasset.csv/row/318","unique0551.uasset.csv/row/329","unique0551.uasset.csv/row/340","unique0551.uasset.csv/row/351","unique0551.uasset.csv/row/362","unique0551.uasset.csv/row/373","unique0551.uasset.csv/r