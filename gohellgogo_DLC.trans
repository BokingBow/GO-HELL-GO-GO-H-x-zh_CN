ext":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/05_Kamase/unique1011.uasset.csv","tags":[],"progress":{"translated":103,"length":103,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/05_Kamase/unique1021.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/05_Kamase","basename":"unique1021.uasset.csv","extension":"csv","filename":"unique1021.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/05_Kamase/unique1021.uasset.csv","data":[["unique1021","unique1021",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「あ、コーチ。見て下さい。\\n　あのかき氷、めっちゃ美味しそうだ！」","「啊，教练。您看。\\n　那个刨冰，看起来超级好吃啊！」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「お前なあ……聞いてる？」","「你这家伙……有在听吗？」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「獄卒のおじさん、めっちゃ困ってたぞ。\\n　お前の余りの体力おばけっぷりに」","「狱卒大叔，可是非常头疼呢。\\n　因为你那太过旺盛的体力怪物般的表现」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「毎日10キロ走ってるからな！　めらめら」","「因为我每天都跑10公里啊！熊熊燃烧」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「大丈夫？　靭帯の方は」","「没问题吗？你的韧带」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「そこは無理が出ないように」","「我会注意不勉强的」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「というかアタシの体力は中の下ってトコだから！\\n　鬼のひとたちが鍛えてないのが悪い」","「再说了，我的体力也就是中等偏下而已！\\n　是那些鬼们自己不锻炼的错」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「あんな非力っぷりじゃ、\\n　お箸も持ち上がらないだろうに」","「就他们那点力气，\\n　怕是连筷子都拿不起来吧」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「うーん扱いやすい亡者なんだか、\\n　それとも扱いにくいのか」","「唔—，这算是好处理的亡灵呢，\\n　还是难处理呢」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「いい感じに手ぇ抜いてやんないとさ、\\n　いつか痛いしっぺ返しを食うぞ」","「要是你不好好放放水的话，\\n　早晚会遭到狠狠的报复哦」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「しっぺ返し上等！\\n　その時こそ、熱いバトルが出来るってこと！」","「报复尽管来！\\n　那才意味着，能打一场热血之战！」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「はーっはっは！　そう思えば、\\n　今のうちに色んな所から買っておくべきか、恨み」","「哈—哈哈！这么想来，\\n　是不是该趁现在，从各处多买点怨恨备着？」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「少年漫画のバトルジャンキーみたいな\\n　思考してんなこいつ」","「这家伙的思考模式，\\n　跟少年漫画里的战斗狂似的」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「……今のうちに見どころのありそうな\\n　少年とかを育ててみても良いかも？」","「……趁现在，去培养一些\\n　看起来有点潜力的少年，或许也不错？」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「ふっふっふ美味しそうに実った少年と、\\n　血をたぎらせるようなバトル……燃えるぜ！」","「哼哼哼，和长得美味诱人的少年，\\n　来一场令人热血沸腾的战斗……燃起来了！」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「犯罪者ってこういう思考をしているのかも」","「犯罪者可能就是这种思维模式吧」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「アタシは全然、\\n　コーチとバトってもいいんですけどね？」","「我倒是完全不介意\\n　跟教练你打一场哦？」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「はいはい。遠慮しときますよって」","「好好好。我敬谢不敏啦」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「むぅ。その筋肉の付き方。\\n　隙の無さ。只者では無いとは思うんだが」","「唔。你这肌肉的附着方式，\\n　毫无破绽。我觉得你绝非等闲之辈啊」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「やろうぜ、コーチ！\\n　一緒に、バトルで地獄統一！」","「来打一架吧，教练！\\n　一起，用战斗统一地狱！」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「おめえ地獄をどんな戦国だと思ってんだよ」","「你把地狱当成什么战国时代了」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「めらめら！　あんな軟弱者ばかりの世界なら、\\n　実力だけで斬り伏せられるぜ！」","「熊熊燃烧！那种尽是软蛋的世界，\\n　光凭实力就能全都砍翻！」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「まあ、そう甘くは考えない方が良いと思うけど」","「嘛，我觉得还是别想得太简单为好」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「コーチは考える事が小さいなあ」","「教练你考虑的事情可真小家子气」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「うっせ、ガキ」","「啰嗦，小鬼」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「はーっはっは！　アタシを倒せるって奴がいんなら、\\n　どっからでもかかってこいやって話！」","「哈—哈哈！要是真有能打倒我的家伙，\\n　不管从哪儿来，尽管放马过来！」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「……なんか盛大に立ててない？　負けフラグ」","「……你是不是在疯狂立旗啊？败北的旗帜」",null,null,null]],"type":"","context":[["unique1021.uasset.csv/row/112","unique1021.uasset.csv/row/123","unique1021.uasset.csv/row/134","unique1021.uasset.csv/row/145","unique1021.uasset.csv/row/156","unique1021.uasset.csv/row/167","unique1021.uasset.csv/row/178","unique1021.uasset.csv/row/189","unique1021.uasset.csv/row/200","unique1021.uasset.csv/row/211","unique1021.uasset.csv/row/222","unique1021.uasset.csv/row/233","unique1021.uasset.csv/row/244","unique1021.uasset.csv/row/255","unique1021.uasset.csv/row/266","unique1021.uasset.csv/row/277","unique1021.uasset.csv/row/288","unique1021.uasset.csv/row/299","unique1021.uasset.csv/row/310","unique1021.uasset.csv/row/321","unique1021.uasset.csv/row/332","unique1021.uasset.csv/row/343","unique1021.uasset.csv/row/354","unique1021.uasset.csv/row/365","unique1021.uasset.csv/row/376","unique1021.uasset.csv/row/387","unique1021.uasset.csv/row/398"],["unique1021.uasset.csv/row/113"],["unique1021.uasset.csv/row/114"],["unique1021.uasset.csv/row/124"],["unique1021.uasset.csv/row/125"],["unique1021.uasset.csv/row/135"],["unique1021.uasset.csv/row/136"],["unique1021.uasset.csv/row/146"],["unique1021.uasset.csv/row/147"],["unique1021.uasset.csv/row/157"],["unique1021.uasset.csv/row/158"],["unique1021.uasset.csv/row/168"],["unique1021.uasset.csv/row/169"],["unique1021.uasset.csv/row/179"],["unique1021.uasset.csv/row/180"],["unique1021.uasset.csv/row/190"],["unique1021.uasset.csv/row/191"],["unique1021.uasset.csv/row/201"],["unique1021.uasset.csv/row/202"],["unique1021.uasset.csv/row/212"],["unique1021.uasset.csv/row/213"],["unique1021.uasset.csv/row/223"],["unique1021.uasset.csv/row/224"],["unique1021.uasset.csv/row/234"],["unique1021.uasset.csv/row/235"],["unique102