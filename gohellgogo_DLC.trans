2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0551.uasset.csv","tags":[],"progress":{"translated":109,"length":109,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0561.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya","basename":"unique0561.uasset.csv","extension":"csv","filename":"unique0561.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0561.uasset.csv","data":[["unique0561","unique0561",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「ふんふんふーん……♪」","「哼哼哼……♪」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「あれ、芽ヰじゃん。久しぶり」","「哎呀，这不是芽井吗。好久不见。」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「あらあらあらあら！　ヤツシロさん！\\n　こちらこそお久しぶりです」","「哎呀呀呀呀！八津先生！\\n我才是好久不见呢」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「なんか……ツヤツヤしてない？」","「怎么感觉……你容光焕发啊？」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「くす。分かってしまいますか。\\n　……戦う女性の、魂から出る美しさが」","「呼呼。被您看出来啦。\\n……那是战斗中的女性，灵魂深处迸发的美丽」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「先日から責め苦が再開されまして」","「前些日子，折磨又重新开始了」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「え、そうなの？」","「诶，是吗？」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「はい。それがテストに丁度良いと\\n　苛烈な責め苦に参加することになってしまって」","「是的。他们说这正好当作测试，\\n于是我就参加了那惨烈的折磨」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「へえ、そりゃ大変」","「嘿，那可够呛。」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「そう！　ほんっとーに大変なのです！\\n　全く困った話です」","「没错！真的是辛苦死了！\\n简直是让人头疼的要命」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「地獄の屈強な男たちが盛るように群がって、\\n　妙齢の生娘に向かってアレやコレや……」","「地狱里那些彪形大汉像发了情的野兽一样扑上来，\\n对我这妙龄黄花闺女做这做那……」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「しかし逃げたり泣いてるわけにはいきません。\\n　世界から苦しみを少しでも取り除くため」","「但我不能逃跑，也不能哭泣。\\n为了能让这世间少一分痛苦」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「私は謹んで引き受けて、\\n　様々な欲を一身に引き受けているのです」","「我谨怀敬畏之心承受这一切，\\n将四面八方的欲望集于一身」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「……あなた自分を正義の味方風に\\n　言う悪癖があるよね」","「……你这人，老爱把自己包装成正义伙伴的\\n坏毛病还是没改啊」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「……？　正義の味方ではなく、\\n　ただの悲劇のヒロインですが……？」","「……？不是正义的伙伴，\\n我不过是个悲剧的女主角罢了……？」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「このハッピーな思考回路、\\n　見習うべき物が無いとは言えないな……」","「你这盲目的乐天思考回路，\\n还真不能说没有值得学习的地方……」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「ああ、そんな目で見ないで下さいまし、ヤツシロさん！」","「啊，请不要用那种眼神看我，八津先生！」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「どんな目？」","「什么眼神？」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「断食明けの狼のような、\\n　欲で狂った瞳」","「就像断食已久的恶狼，\\n那双为欲望而疯狂的眼眸」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「もっぺんちゃんと見ろこの\\n　灰色の死んだ魚みてーな目を」","「你倒是给我好好看看\\n这双灰蒙蒙跟死鱼一样的眼睛」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「ヤツシロさんの元を離れ、\\n　私が恋しいのはわかります！」","「我知道您离开我身边之后，\\n一直对我恋恋不忘！」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「分かるな。ねーんだよそんな物はどこにも影も形も」","「你懂个球。压根就没有\\n一丝一毫那种东西」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「ですが今の私は、\\n　新しい道を歩みだしたところなのです！」","「但是如今的我，\\n正要踏上新的道路！」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「どうか私のことを想うのなら、\\n　……その涙をしまって下さい」","「若是您心里还牵挂着我，\\n……请收起您的泪水吧」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「ちょちょぎらしてねーわ涙。\\n　何なら砂漠ぐらいカラカラだわ」","「我挤不出半滴眼泪，干得跟沙漠似的」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「……ふっ。気丈な方」","「……呵。真是个坚强的人」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「無敵か？」","「无敌了是吧？」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「とにかく私は平気ですので！\\n　決して、助けようなんて思わないで下さいね！」","「总之我没事，请您放心！\\n千万不要想着来救我！」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「ああ……まあ……なんというか……」","「啊啊……这个嘛……该怎么说呢……」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「……相変わらずで？　……よかったよ」","「……看见你一如既往？……真是太好了」",null,null,null]],"type":"","context":[["unique0561.uasset.csv/row/104","unique0561.uasset.csv/row/115","unique0561.uasset.csv/row/126","unique0561.uasset.csv/row/137","unique0561.uasset.csv/row/148","unique0561.uasset.csv/row/159","unique0561.uasset.csv/row/170","unique0561.uasset.csv/row/181","unique0561.uasset.csv/row/192","unique0561.uasset.csv/row/203","unique0561.uasset.csv/row/214","unique0561.uasset.csv/row/225","unique0561.uasset.csv/row/236","unique0561.uasset.csv/row/247","unique0561.uasset.csv/row/258","unique0561.uasset.csv/row/269","unique0561.uasset.csv/row/280","unique0561.uasset.csv/row/291","unique0561.uasset.csv/row/302","unique0561.uasset.csv/row/313","unique0561.uasset.csv/row/324","unique0561.uasset.csv/row/335","unique0561.uasset.csv/row/346","unique0561.uasset.csv/row/357","unique0561.uasset.csv/row/368","unique0561.uasset.csv/row/379","unique0561.uasset.csv/row/390","unique0561.uasset.csv/row/401","unique0561.uasset.csv/row/412","unique0561.uasset.csv/row/423"],["unique0561.uasset.csv/row/105"],["unique0561.uasset.csv/row/106"],["unique0561.uasset.csv/row/116"],["unique0561.uasset.csv/row/117"],["unique0561.uasset.csv/row/127"],["unique0561.uasset.csv/row/128"],["unique0561.uasset.csv/row/138"],["unique0561.uasset.csv/row/139"],["unique0561.uasset.csv/row/149"],["unique0561.uasset.csv/row/150"],["unique0561.uasset.csv/row/160"],["unique0561.uasset.csv/row/161"],["unique0561.uasset.csv/row/171"],["unique0561.uasset.csv/row/172"],["unique0561.