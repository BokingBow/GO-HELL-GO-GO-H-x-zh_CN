ilt":false},"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0671.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya","basename":"unique0671.uasset.csv","extension":"csv","filename":"unique0671.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0671.uasset.csv","data":[["unique0671","unique0671",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「……そりゃ偶に奢るぐらいなら、\\n　まあ良いんだけどさ……」","「……话是这么说，偶尔请一次的话，\\n　倒也还行吧……」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「はぁー食った食った」","「呼~吃饱了吃饱了~」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「もう少し手加減してくんない！？\\n　毎回財布が空っぽになるんだけど！？」","「你就不能稍微手下留情吗！？\\n　我钱包每次都见底啊！！」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「アンタが貧乏なのがいけないんでしょー」","「还不是因为你自个儿穷嘛~」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「……お前をモンスターとして\\n　エンカウントしてやろうかソロソロ」","「……我是不是差不多该把你当成怪物\\n　来个遭遇战算了？」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「ご、ごめんって。\\n　ちゃんと感謝してるって。ゴチソウサマ」","「对、对不起嘛。\\n　我真的很感激啦。多谢款待。」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「でもあんたのせいでこんなひどい目に遭ってん\\n　だから、このぐらいは当然でしょ！」","「不过都是因为你我才倒这么大霉的，\\n　这点程度也是理所当然的吧！」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「別に俺のせいというわけではないんだが……」","「这又不是我的错……」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「はあ。あのねえ私だって大変なのよ最近」","「唉。你也替我想想，我最近也很不容易好吗。」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「ツケでばっか食べてたら\\n　最近はどの店も出禁になっちゃって」","「老是赊账吃饭，\\n　最近所有店都把我拉黑了……」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「へえ。辞書通りの因果応報じゃん」","「呵，这不就是字典级别的因果报应嘛。」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「ああ……もう、これからどうしたもんかしら」","「啊啊……真是的，以后可怎么办啊……」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「実は結構切実な悩みか」","「这还真是个挺实在的烦恼啊。」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「んじゃ食べなければ許さない系の地獄があるから、\\n　そういうのはどう」","「那，有个不吃东西就不饶你的地狱，\\n　你觉得那种地方咋样？」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「え！！　そんな都合の良い地獄があるの！？」","「咦！！还有这么合适的地狱吗！？」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「……いや別に都合は良くない。\\n　別に責め苦だし、苦しいし」","「……不，也没什么合适的。\\n　毕竟也是折磨，还挺痛苦的。」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「とにかくお腹いっぱい食べられんでしょ！？\\n　だったら別に気にしないわよ！」","「总之能吃饱肚子对吧！？\\n　那我才不在乎呢！」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「連れてって連れてって！」","「带我去带我去！」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「うーんまあそう言うなら良いけど」","「嗯~行吧，既然你这么想去的话。」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「あ、でも1つリクエスト。\\n　パンとかそういうしょぼいのはやだ」","「啊，不过有个要求。\\n　面包那种寒酸玩意儿我才不要。」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「肉とか海鮮系のガッツリ系もあって……。\\n　出来ればちゃんとしたシェフのいるところ！」","「要有肉啊海鲜那种硬菜……。\\n　最好是有正经大厨掌勺的那种地方！」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「そんなん俺が行きてえわ」","「我还想去这种地方呢。」",null,null,null]],"type":"","context":[["unique0671.uasset.csv/row/104","unique0671.uasset.csv/row/115","unique0671.uasset.csv/row/126","unique0671.uasset.csv/row/137","unique0671.uasset.csv/row/148","unique0671.uasset.csv/row/159","unique0671.uasset.csv/row/170","unique0671.uasset.csv/row/181","unique0671.uasset.csv/row/192","unique0671.uasset.csv/row/203","unique0671.uasset.csv/row/214","unique0671.uasset.csv/row/225","unique0671.uasset.csv/row/236","unique0671.uasset.csv/row/247","unique0671.uasset.csv/row/258","unique0671.uasset.csv/row/269","unique0671.uasset.csv/row/280","unique0671.uasset.csv/row/291","unique0671.uasset.csv/row/302","unique0671.uasset.csv/row/313","unique0671.uasset.csv/row/324","unique0671.uasset.csv/row/335"],["unique0671.uasset.csv/row/105"],["unique0671.uasset.csv/row/106"],["unique0671.uasset.csv/row/116"],["unique0671.uasset.csv/row/117"],["unique0671.uasset.csv/row/127"],["unique0671.uasset.csv/row/128"],["unique0671.uasset.csv/row/138"],["unique0671.uasset.csv/row/139"],["unique0671.uasset.csv/row/149"],["unique0671.uasset.csv/row/150"],["unique0671.uasset.csv/row/160"],["unique0671.uasset.csv/row/161"],["unique0671.uasset.csv/row/171"],["unique0671.uasset.csv/row/172"],["unique0671.uasset.csv/row/182"],["un