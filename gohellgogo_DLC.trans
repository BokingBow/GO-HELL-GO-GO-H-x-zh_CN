_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/06_Norimaki/unique1121.uasset.csv","tags":[],"progress":{"translated":59,"length":59,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/06_Norimaki/unique1131.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/06_Norimaki","basename":"unique1131.uasset.csv","extension":"csv","filename":"unique1131.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/06_Norimaki/unique1131.uasset.csv","data":[["unique1131","unique1131",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「ずびまぜんっ！\\n　これオフレコでお願いなのでずがっ！」","「对不起—！\\n　这句话请不要记录可以吗—！」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「あ、はい。なんですかー」","「啊，好的。什么事呀—」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「前回の水責め、苦しすぎたのでぇ！！\\n　今回は別のにしてもらっても良いですかぁ！？」","「上一次的水刑，实在是太痛苦了！！\\n　这次能不能给我换成别的啊！？」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「のりまき、もう水がギザトラウマでぇっ！？\\n　ちょっともう無理かなって思うのでちがっ」","「海苔卷对水已经超有阴影了！？\\n　感觉实在是有点办不到所以才——」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「あ。そうですかー。\\n　じゃ、別のご用意しますねー」","「啊。是这样啊—。\\n　那，我们这就给您准备别的—」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「え、出来るんだ逆にぃ！？」","「哎，这反而还能换的啊！？」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「もうちょっと押し問答とかしても良いんですよ？\\n　ミニゲームに勝てたら責め変更☆　とかぁ」","「你们再稍微跟我讨价还价一下也是可以的哦？\\n　比如通过小游戏获得胜利就能更改拷责☆　之类的」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「そういうサービスはうちでは\\n　行ってないですね」","「我们这里没有\\n　提供那种服务呢」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「ぎょぎょぎょ、業務的ぃー！\\n　地獄の人たち、真面目すぎか！？」","「哎哎哎，也太公事公办了吧—！\\n　地狱的家伙们，都这么死脑筋的吗！？」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「もっと肩の力抜いていいと思いますよっ！？\\n　のりまき体操踊ります！？」","「我觉得你们用不着那么紧绷绷的啦！？\\n　要我跳个海苔卷体操吗！？」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「はい、それでは責め苦の方、\\n　スタンバイよろしくおねがいしまーす」","「好了，那么关于刚才说的拷责，\\n　就麻烦您那边做好准备了—」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「し、塩ーっ」","「盐、盐刑啊—」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「にょーほほほ！　でもあまあまでもはや砂糖の\\n　のりまきにはそのぐらいの対応が\\n　ちょうどいいのであった！！」","「喵嚯嚯嚯！　不过对又甜又软的\\n　海苔卷来说，这种程度的应对\\n　刚刚好呢！！」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「うおおお！　アイドル根性全開！\\n　いってきまぁーーす！」","「呜哦哦哦！　偶像精神马力全开！\\n　我出发啦——！」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「…………」","「…………」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「元気な亡者だなあ」","「真是个精力充沛的亡灵啊」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「って、どういうヤツーーーーーっ！？！？」","「不对，你这到底是个什么鬼啊————！？」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「こういうの平成の漫画で見たことある！！\\n　ヒロインが砂時計の中にとらわれて、\\n　時間制限で窒息しちゃうーってやつ！！」","「这种情节我在平成的漫画里见过！！\\n　就是女主角被困在沙漏里，\\n　限时一到就会窒息而死——的那种！！」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「って、誰がアラサーにはキツイ衣装じゃ！？」","「话说，是谁说这对三十岁上下的人来说是很过分的服装啊！？」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「………………」","「………………」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「え、ちょっと待って。その。……これで？」","「呃，等一下。那个。……就这样吗？」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「これでのりまきは何してたらいいんですか！？」","「这样子我、海苔卷，该做些什么才好啊！？」",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「……ぺっ、ぺっ。この上から降ってくるの、\\n　一体、なんなんですかぁ……？」","「……呸、呸。这从上面掉下来的，\\n　到底是什么东西啊……？」",null,null,null],["47_TEXT","47_TEXT",null,null,null],["「牛乳にしては……ちょっと生臭いし……」","「要说是牛奶吧……又有点腥……」",null,null,null],["48_TEXT","48_TEXT",null,null,null],["「こ、これで……一体、どうしたらいいんでしょうか」","「就、就这样……我到底、该怎么办才好呢」",null,null,null],["49_TEXT","49_TEXT",null,null,null],["「なんかミニゲームが始まったり！\\n　クイズが始まったりは！？」","「会不会突然开始什么小游戏！\\n　或者问答环节什么的！？」",null,null,null],["50_TEXT","50_TEXT",null,null,null],["「……………………」","「……………………」",null,null,null],["54_TEXT","54_TEXT",null,null,null],["「えいく所までいったタイプのドッキリ！？」","「是那种能做到哪算哪的整人节目吗！？」",null,null,null],["55_TEXT","55_TEXT",null,null,null],["「もうコレで喜ぶのただのお笑いじゃ満足できなくなった、\\n　天上人的な人だけですやん！？」","「这玩意儿，现在还能乐在其中的，\\n 也就只剩下那些天人级别、\\n 普通搞笑已经满足不了的人了吧！？」",null,null,null],["56_TEXT","56_TEXT",null,null,null],["「あだったらもう鉄骨渡りとかしましょうか！？\\n　全然そっちの方がモチベあるんですけど！？」","「啊，要是那样的话，不如我们去走钢丝怎么样！？\\n　我反倒觉得那个更有动力啊！？」",null,null,null],["57_TEXT","57_TEXT",null,null,null],["61_TEXT","61_TEXT",null,null,null],["「あ、あのぉー……誰かぁー……？」","「那、那个……有人在吗……？」",null,null,null],["62_TEXT","62_TEXT",null,null,null],["「なんか……ちょっとずつ、水位上がってるし……」","「总感觉……水位一点一点地，在上涨啊……」",null,null,null],["63_TEXT","63_TEXT",null,null,null],["「その……」","「那个……」",null,null,null],["64_TEXT","64_TEXT",null,null,null],["「だ、誰か居ますよね！？\\n　のりまき、ひとりじゃないですよね！？」","「有、有人在的对吧！？\\n　海苔卷，不是孤单一个人对吧！？」",null,null,null],["65_TEXT","65_TEXT",null,null,null],["「あのぉ！　何求められてるかわからないのが、\\n　1番困っちゃうやつなんですけどぉ！？」","「我说啊！　不知道自己被要求做什么，\\n　这才是最要命的啊！？」",null,null,null],["66_TEXT","66_TEXT",null,null,null],["「あのぉーー……だれかぁーーー……？」","「那个——……有人在吗——……？」",null,null,null],["67_TEXT","67_TEXT",null,null,null],["71_TEXT","71_TEXT",null,null,null],["「これ……最後は……どうなっちゃうんですか……？」","「这个……最后到底……会变成什么样啊……？」",null,null,null],["72_TEXT","72_TEXT",null,null,null],["「あの……トイレ…………とかは……？」","「那个……厕所…………之类的……有吗……？」",null,null,null],["73_TEXT","73_TEXT",null,null,null],["「だ、……誰かぁ……」","「有、……有人吗……」",null,null,null],["74_TEXT","74_TEXT",null,null,null],["「誰かぁ…………っ！」","「来人啊…………啊！」",null,null,null],["75_TEXT","75_TEXT",null,null,null],["「助けてくださいーーーー！！！！」","「救命啊————！！！！」",null,null,null]],"type":"","context":[["unique1131.uasset.csv/row/104","unique1131.uasset.csv/row/115","unique1131.uasset.csv/row/126","unique1131.uasset.csv/row/137","unique1131.uasset.csv/row/148","unique1131.uasset.csv/row/159","unique1131.uasset.csv/row/170","unique1131.uasset.csv/row/181","unique1131.uasset.csv/row/192","unique1131.uasset.csv/row/203","unique1131.uasset.csv/row/214","unique1131.uasset.csv/row/225","unique1131.uasset.csv/row/236","unique1131.uasset.csv/row/247","unique1131.uasset.csv/row/266","unique1131.uasset.csv/row/277","unique1131.uasset.csv/