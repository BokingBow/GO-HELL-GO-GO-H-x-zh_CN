foText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0371.uasset.csv","tags":[],"progress":{"translated":69,"length":69,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0451.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya","basename":"unique0451.uasset.csv","extension":"csv","filename":"unique0451.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0451.uasset.csv","data":[["unique0451","unique0451",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「えーんえんえん……えんえん……。\\n　ひぐっぐすっどなたかぁ……」","「呜~呜呜呜……呜呜……。\\n　唏~古斯~有没有谁啊……」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「どなたが、いまぜんがぁ……っ。\\n　ぐすぐすっ……えーんっ……」","「有谁，来帮我一下啊……呜。\\n　抽抽搭搭……呜~呜……」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「現在、社長は不在です」","「现在，社长不在。」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「ぶえぇえん……私はもぉ終わりだぁぁあっ」","「呜哇啊啊……我完啦啊啊啊啊——！」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「社長は不在です、ご用があればこの私が」","「社长不在，有什么事的话就由我——」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「えーんえん……ぐすっずびっ……あのぉっ、\\n　私ぃっ……ぐずぐずっ……ずびっ……」","「呜……呜……吸溜，吸鼻涕……那个、\\n　我……吸溜吸溜……鼻涕……」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「とりあえず、ティッシュをお貸ししましょうか？」","「总之，我先借你张纸巾吧？」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「よろじぐおねがいじまずぅ……ずびっ」","「拜拖你了惹……吸鼻涕」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「――というわけでどういうわけだか\\n　私は責め苦から放たれたわけだが」","「――于是乎，虽然不知道是什么情况，\\n　我就这样从苦刑里被放出来了。」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「これは地獄の糸とカンダタの関係。\\n　原因Xによる正当な釈放と解釈し」","「这就好比地狱之丝与犍陀多的那个典故。\\n　可以解释为因未知因素X而获得的正当释放。」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「合法的に逃走し、\\n　街を放浪していたというわけだ」","「所以我合法地逃了出来，\\n　在街上一直流浪。」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「なるほど。委細承知致しました」","「原来如此。我已悉数了解。」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「しかしその法的解釈は余りに我田引水」","「但这种法律解释也太过自私自利了。」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「原因Xが法的正当性を含有しない限り、\\n　U乃様の行動にも正当性はありません」","「只要未知因素X不包含法律正当性，\\n　U乃小姐您的行为就没有正当性可言。」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「ぐぬ。完璧な理論による論破。\\n　……君、まさか出身は理系かい。敵だ」","「唔…被完美的理论驳倒了。\\n　……你，难道是理科出身？是敌人啊。」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「法学は一般的には文系学問に\\n　カテゴライズされます」","「法学通常会被归类到\\n　文科的学问范畴。」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「ぐぬぬ……私の論法は小難しい言葉で煙に巻いて\\n　自分に都合いいように話を進める詭弁の類だから」","「唔唔……毕竟我的论法就是用些艰涩难懂的词把人绕晕，\\n　然后顺理成章地把话题往对自己有利的方向扯的诡辩——」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「この手の理系の輩とは相性が悪いんだ」","「跟这种理科的家伙特别不对付啊。」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「文系理系で人の性質を分けるのは、\\n　視野狭窄的だし分断を招くので非推奨です」","「用文科理科来划分人的性质，\\n　会视野狭隘且招致分裂，不建议这么做。」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「ぎゃあ！　逃げ道まで潰された！」","「哎呀！连退路都给堵死了！」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「……？　当器は現状においてお客様の\\n　進行ルートを阻害していません」","「……？目前本器并没有阻挡\\n　客人的前进路线。」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「……ふふふ、君みたいな論客は初めてだ。\\n　恐れ入った。私の負けだよ」","「……呵呵呵，像你这样的论客我还是头一次见。\\n　甘拜下风。是我输了。」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「煮るなり焼くなりするがいい」","「要杀要剐都随你。」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「……？　必要性を感じません」","「……？我不认为有这个必要。」",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「完・全・敗・北！」","「完・全・败・北！」",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「ここまで綺麗に敗北すると、\\n　逆に清々しいものだなあ」","「输得这么干干净净，\\n　反倒让人神清气爽啊。」",null,null,null],["47_TEXT","47_TEXT",null,null,null],["「喜んで頂けたならとても光栄です」","「能让您满意，我感到非常荣幸。」",null,null,null],["48_TEXT","48_TEXT",null,null,null],["「まあとにかく私は責め苦からズルをして\\n　逃れたわけだが」","「算了，总之，我就是靠耍诈\\n　从苦刑里逃了出来——」",null,null,null],["49_TEXT","49_TEXT",null,null,null],["「当器は正しい文言だと判断致しました」","「本器判断这是正确的措辞。」",null,null,null],["50_TEXT","50_TEXT",null,null,null],["「あんな大変な責め苦をあと\\n　５６億年もやらされるとか絶対耐えられん！」","「那么痛苦的刑罚还要再挨\\n　56亿年，我绝对撑不住啊！」",null,null,null],["51_TEXT","51_TEXT",null,null,null],["「私は根性なしでビビりだから\\n　言葉の鎧で身を覆っている側面もあるんだ」","「我没骨气又胆小，\\n　所以也有用言语作铠甲武装自己的一面啦。」",null,null,null],["52_TEXT","52_TEXT",null,null,null],["「責め苦から逃げられたぞヤッターって\\n　ホームレス暮らしをしようとしたけど大変で大変で」","「想着‘总算从苦刑里逃出来啦，太好了’，\\n　就尝试去流浪过日子，但实在是苦得不行、累得够呛——」",null,null,null],["53_TEXT","53_TEXT",null,null,null],["「野犬には追いかけられるしモンスターは怖いし\\n　人の目は冷たいし辛くて辛くてもう」","「被野狗追着跑，又怕怪物，\\n　路人目光冷冰冰的，又苦又惨、真的撑不住了。」",null,null,null],["54_TEXT","54_TEXT",null,null,null],["「あっ思い出したらなんか泣けてきた……ひぐっ。\\n　あ、暖かいお茶が心にしみる……ぐす」","「啊，一回想起来就有点想哭了……呜咽。\\n　啊，这热茶真是暖到心坎儿里去了……抽泣」",null,null,null],["55_TEXT","55_TEXT",null,null,null],["「お茶はおかわりありますので、\\n　いつでもお申し付け下さい」","「茶可以续杯，\\n　请随时吩咐。」",null,null,null],["56_TEXT","56_TEXT",null,null,null],["「ひ、人の優しさ！\\n　これが人間讃歌の暖かさだよう……」","「人、人性的温柔！\\n　这就是人间赞歌的温暖啊……」",null,null,null],["57_TEXT","57_TEXT",null,null,null],["「当器は人ではないのですが……」","「本器具并非人类，您看……」",null,null,null],["58_TEXT","58_TEXT",null,null,null],["「メズさぁん……ぐすっ……も、もう嫌なんだぁっ。\\n　ホームレス暮らしはぁっ」","「梅兹亲……呜……我、我已经受够了啦。\\n　这流浪街头的生活啊！」",null,null,null],["59_TEXT","59_TEXT",null,null,null],["「どうか私を、おうちに帰してくれぇっ」","「求求你，让我回家吧！」",null,null,null],["60_TEXT","60_TEXT",null,null,null],["「助けて差し上げたいのも\\n　山々なのですが」","「说实在的，我也\\n　非常想帮您一把。」",null,null,null],["61_TEXT","61_TEXT",null,null,null],["「当器のスペックでは、\\n　そちらのお願いは叶えられません……」","「但以本器具的机能规格，\\n　无法实现您的这个愿望……」",null,null,null],["62_TEXT","62_TEXT",null,null,null],["「……やはり誰もこの地獄の脱し方を\\n　知らないのだね」","「……果然没人知道\\n　该怎么从这地狱里出去啊。」",null,null,null],["63_TEXT","63_TEXT",null,null,null],["「うーーんどうにも不自然。\\n　その辺りが謎を解く鍵なのか」","「嗯——这也太不自然了。\\n　难道这点就是解开谜题的关键所在？」",null,null,null],["64_TEXT","64_TEXT",null,null,null],["「だったら帰せないにしても、\\n　どうか私をかくまってぇ！」","「那就算不能送我回去，\\n　好歹也收留我一下吧！」",null,null,null],["65_TEXT","65_TEXT",null,null,null],["「……匿う、ですか？」","「……收留，是吗？」",null,null,null],["66_TEXT","66_TEXT",null,null,null],["「もう路地裏で怯えながら眠るのは嫌だぁ！\\n　毎日とは言わないから！　偶に部屋に泊まらせてぇ」","「我再也不要在小巷子里提心吊胆地睡觉了！\\n　不用天天住！偶尔让我在你房间里过夜就行！」",null,null,null],["67_TEXT","67_TEXT",null,null,null],["「当器の部屋でしたら、\\n　そちらは全然構いませんが」","「如果是本器具的房间，\\n　那倒是完全没问题。」",null,null,null],["68_TEXT","68_TEXT",null,null,null],["「まじですか！」","「真的假的！」",null,null,null],["69_TEXT","69_TEXT",null,null,null],["「はい。人類の皆様のお役に立つのが、\\n　当器が医療器具として作られた理由ですから」","「是的。本器具作为医疗器械被制造出来，\\n　其理由就是为人类各位服务。」",null,null,null],["70_TEXT","70_TEXT",null,null,null],["「か、神……！\\n　まさに地獄に仏とはこの事！？」","「神、神仙……！\\n　所谓绝处逢生（地狱遇佛）就是这么回事儿吧！？」",null,null,null],["71_TEXT","71_TEXT",null,null,null],["「それではお疲れのご様子ですし、\\n　お風呂の準備でも致しましょうか」","「看您好像很累了，\\n　那么，我先去给您放个洗澡水吧。」",null,null,null],["72_TEXT","72_TEXT",null,null,null],["「お召し物も汚れてらっしゃるので、\\n　お洗濯の方もさせていただきます」","「您的衣物也脏了，\\n　请让我也帮您洗一下吧。」",null,null,null],["73_TEXT","73_TEXT",null,null,null],["「きゅん……。もうなんか感謝を超えて、\\n　恋心さえ抱きそうになってきた」","「心动了……。怎么说呢，这种事情已经超越了感谢，\\n　感觉我都要爱上你了。」",null,null,null],["74_TEXT","74_TEXT",null,null,null],["「アレルギーなどはございますか？\\n　夕飯も食べていってください」","「您有什么过敏的吗？\\n　晚饭也请留下来吃吧。」",null,null,null],["75_TEXT","75_TEXT",null,null,null],["「あ、泣く。優しさに触れて泣く。\\n　な、涙がちょちょぎれて。我慢しろ。我慢しろ私」","「啊，我要哭了。被人这么温柔地对待，真的会哭的。\\n　　眼、眼泪都止不住地往外冒。忍住。我要忍住啊，我自己。」",null,null,null],["76_TEXT","76_TEXT",null,null,null],["「……？　人類にとっての涙は生理的な行為です。\\n　我慢する必要は無いと思われますが」","「……？对人类而言，流泪属于生理行为。\\n　我认为没有必要忍耐哦。」",null,null,null],["77_TEXT","77_TEXT",null,null,null],["「うえええーーんっ。\\n　メズさん、めっちゃ好き～～～～！！」","「呜哇哇哇——！\\n　　梅兹亲，我超爱你～～～～！！」",null,null,null]],"type":"","context":[["unique0451.uasset.csv/row/104","unique0451.uasset.csv/row/115","unique0451.uasset.csv/row/126","unique0451.uasset.csv/row/137","unique0451.uasset.csv/row/148","unique0451.uasset.csv/row/159","unique0451.uasset.csv/row/170","unique0451.uasset.csv/row/181","unique0451.uasset.csv/row/256","unique0451.uasset.csv/row/267","unique0451.uasset.csv/row/278","unique0451.uasset.csv/row/289","unique0451.uasset.csv/row/300","unique0451.uasset.csv/row/311","unique0451.uasset.csv/row/322","unique0451.uasset.csv/row/333","unique0451.uasset.csv/row/344","unique0451.uasset.csv/row/355","unique0451.uasset.csv/row/366","unique0451.uasset.csv/row/377","unique0451.uasset.csv/row/388","unique0451.uasset.csv/row/399","unique0451.uasset.csv/row/410","unique0451.uasset.csv/row/421","unique0451.uasset.csv/row/432","unique0451.uasset.csv/row/443","unique0451.uasset.csv/row/454","unique0451.uasset.csv/row/465","unique0451.uasset.csv/row/476","unique0451.uasset.csv/row/487","unique0451.uasset.csv/row/498","unique0451.uasset.csv/row/509","unique0451.uasset.csv/row/520","unique0451.uasset.csv/row/531","unique0451.uasset.csv/row/542","unique0451.uasset.csv/row/553","unique0451.uasset.csv/row/564","unique0451.uasset.csv/row/575","unique0451.uasset.csv/row/586","unique0451.uasset.csv/row/597","unique0451.uasset.csv/row/608","unique0451.uasset.csv/row/619","unique0451.uasset.csv/row/630","unique0451.uasset.csv/row/641","unique0451.uasset.csv/row/652","unique0451.uasset.csv/row/663","unique0451.uasset.csv/row/674","unique0451.uasset.csv/row/685","unique0451.uasset.csv/row/696","unique0451.uasset.csv/row/707","unique0451.uasset.csv/row/718","unique0451.uasset.csv/row/729","unique0451.uasset.csv/row/7