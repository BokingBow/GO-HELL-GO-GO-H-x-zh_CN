end/01/DataTable/Scenario/02_Arakasegi/02_Arakasegi01.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/02_Arakasegi","basename":"02_Arakasegi01.uasset.csv","extension":"csv","filename":"02_Arakasegi01.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/02_Arakasegi/02_Arakasegi01.uasset.csv","data":[["02_Arakasegi01","02_Arakasegi01",null,null,null],["12_TEXT","12_TEXT",null,null,null],["「うーす。金落としに来てやったぞー」","「哟呵——。本大爷来给你们送钱啦——。」",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「……ん。誰も居ないのか」","「……嗯。一个人都没有吗。」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「不用心な。俺が正義のココロを持っていたから\\n　良かったものの」","「真够不小心的。要不是我这人天生正义感爆棚，\\n　那还得了。」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「今なら万引きし放題。\\n　勝手にスーパーボール持ってっちゃお」","「现在的话，随便偷都行。\\n　顺手拿几颗弹力球走吧」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「100円に犯罪歴を賭ける覚悟が\\n　俺にないからやらんけど」","「虽然我没有那个胆子，\\n　会为了100日元赌上犯罪前科」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「おうーい。アラカセギー。どこだー？」","「喂——。荒稼——。在哪儿呢——？」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「ただ物を買うだけって言うのは、\\n　どうにも味気なくてな」","「光说买东西吧，\\n　总觉得太没劲了啊」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「ン？　あっちから、なんか音」","「嗯？那边好像，有什么动静」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「お。何してんのこんなトコで」","「哦。你在这儿干嘛呢，这种地方」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「あ？　おめー入ってくんなよな。\\n　店のバックヤードまで」","「啊？你可别给我进来啊。\\n　连店铺的后仓都敢闯」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「お得意さんゆえの気さくな\\n　距離の詰め方じゃろがい」","「这正说明我是老主顾，\\n　所以才这么不见外地套近乎嘛」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「いるよな……店員と仲良くなったと勘違いして、\\n　ただの無礼を働いているイタイ客」","「真有那种人啊……自以为跟店员混熟了，\\n　结果干出些很没礼貌的事，尬到爆的客人」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「……若干身の振り方を考えさせられた」","「……听得我都有点反省自己的行为了」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「ンでマジで何してんの。\\n　……そんな格好で」","「所以说你到底在干嘛啊。\\n　……还穿成这副样子」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「見たら分かんだろー」","「看了还不明白吗——」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「童心に戻ってビニールプールで遊びたい気持ちも\\n　分かるが、せめて勤務外にしたらどうだ？」","「我懂你想回归童心，\\n　在充气泳池里玩水，但能不能至少在下班后再搞？」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「しょーもねえことほざくなカス」","「别在这儿说这些不着调的屁话，废物」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「店のモンを洗ってんの。\\n　綺麗にしてないと売れるモンも売れんだろ」","「我在洗店里的东西。\\n　不弄干净的话，能卖出去的货也卖不掉吧」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「へえ。……確かにこの店、\\n　誰が買うんだコレってモンが、\\n　埃かぶりまくってることあるよな」","「哦——。……说起来这店确实，\\n　有些让人怀疑谁会买的东西，\\n　经常积满了灰呢」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「自称お得意さんが全部買い占めてくれたら、\\n　こっちとしても楽出来るんだけどねえ」","「要是自称老主顾的你肯全包圆了，\\n　我们这边也能轻松不少啊」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「若いモンが楽ばかりしようとするのは\\n　よくないぜ。苦労は買ってでもせんとな」","「年轻人想方设法图省事\\n　可不好。吃苦可是要花钱也去买的」",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「う、うぜえ」","「呃，烦死了」",null,null,null],["48_TEXT","48_TEXT",null,null,null],["「てかもうどっか行けよ、\\n　掃除の邪魔だから」","「话说你给我上别处去啦，\\n　碍着我搞卫生了」",null,null,null],["49_TEXT","49_TEXT",null,null,null],["「あー。そのつもりだったんだけど」","「啊——。我本来是这么打算的」",null,null,null],["50_TEXT","50_TEXT",null,null,null],["「あに」","「咋」",null,null,null],["51_TEXT","51_TEXT",null,null,null],["「……なんか、格好、エロくね？」","「……不过话说，你这打扮，是不是有点色啊？」",null,null,null],["52_TEXT","52_TEXT",null,null,null],["「………………」","「………………」",null,null,null],["54_TEXT","54_TEXT",null,null,null],["「……んあっ！？」","「……嗯啊！？」",null,null,null],["55_TEXT","55_TEXT",null,null,null],["「まず何なのよその飾り気の無さすぎる、\\n　紺一色のスク水は」","「首先那一身毫无装饰、\\n　纯藏蓝色的死库水算怎么回事」",null,null,null],["56_TEXT","56_TEXT",null,null,null],["「こ、こ、これはガキの頃の……、\\n　ってどうでもいいだろそんなこと！？」","「这，这，这是小时候的……，\\n　那又有什么要紧的啊！？」",null,null,null],["57_TEXT","57_TEXT",null,null,null],["「……ガキの頃の水着が、\\n　今でも普通に入るのか」","「……小时候的泳装，\\n　现在居然还能正常穿进去啊」",null,null,null],["58_TEXT","58_TEXT",null,null,null],["「あ？　ンだこら喧嘩かこの野郎。\\n　テメおしゃれな反語で人の肉体\\n　いじくってんじゃねえぞテメこら」","「啊？想干架吗你这混蛋。\\n　你小子别用这种花里胡哨的反问句\\n　来拿老子的身体开涮啊，你丫的」",null,null,null],["59_TEXT","59_TEXT",null,null,null],["「水着が今でも普通に入るのか。\\n　いわんや、入るのがおかしくないか。\\n　じゃねえだろがこの野郎」","「小时候的泳装现在还能正常穿进去。\\n　或者说，能穿进去本身难道不奇怪吗。\\n　能他妈这么说吗你个混蛋」",null,null,null],["60_TEXT","60_TEXT",null,null,null],["「アラカセギって綺麗な体してるよな」","「不过荒稼你的身材是真好啊」",null,null,null],["61_TEXT","61_TEXT",null,null,null],["「き、キメぇーーーーーーーっ！？\\n　マジムリ。え。なんなん。こわ」","「恶，恶心死了————！？\\n　真的不行。呃。什么情况。好吓人」",null,null,null],["62_TEXT","62_TEXT",null,null,null],["「なんかこういい具合のデカさ、\\n　収まりのよさと言うか」","「怎么说呢，就是这样恰到好处的大小，\\n　该说是安分得恰到好处吗」",null,null,null],["63_TEXT","63_TEXT",null,null,null],["「はえー。改めて見ると、\\n　こんなびしょう……エロかったとは」","「哈啊——。这么仔细一看，\\n　这么微小……居然这么色啊」",null,null,null],["64_TEXT","64_TEXT",null,null,null],["「今、美少女だったとはって言いかけただろ！？\\n　何でそっちでいかなかったんだよ！！\\n　言いかけて悪い方に舵切ったんだよ！」","「你刚才肯定想说‘没想到现在居然这么漂亮’是吧！？\\n　那你刚才为什么不走那个路线啊！！\\n　都说到一半了才强行拐弯往坏了说！」",null,null,null],["65_TEXT","65_TEXT",null,null,null],["「アラカセギがこんなに\\n　可愛かったとは」","「没想到荒稼居然\\n　这么可爱」",null,null,null],["66_TEXT","66_TEXT",null,null,null],["「終わってる！」","「没救了！」",null,null,null],["67_TEXT","67_TEXT",null,null,null],["「……はー？　なに？　なに急に？\\n　どういうアレ？　くどいてんの？　キモ」","「……啊——？　干嘛？　这突然闹哪出？\\n　这算什么？　你在泡我吗？　真恶心」",null,null,null],["68_TEXT","68_TEXT",null,null,null],["「お前ホントこういう、\\n　変なカッコ好きよな。ほんとキモ」","「你这家伙还真是\\n　喜欢这种怪打扮啊。真的太恶心了」",null,null,null],["69_TEXT","69_TEXT",null,null,null],["「俺が好きなのはその格好じゃなくて」","「我喜欢的不是这身打扮」",null,null,null],["70_TEXT","70_TEXT",null,null,null],["「アラカセギ本人。……だゼ？」","「是荒稼本人。……对吧？」",null,null,null],["76_TEXT","76_TEXT",null,null,null],["「――ボケコラッ！」","「――你这笨蛋看招！」",null,null,null],["77_TEXT","77_TEXT",null,null,null],["「ぎゃあ！　目が！」","「哎呀！　眼睛！」",null,null,null],["78_TEXT","78_TEXT",null,null,null],["「お前よォ！　雑にいじるな！\\n　こっちが照れくさい時に限って、\\n　目を爛々輝かせがってよォ！」","「你这家伙！　别瞎碰我！\\n　偏偏在人家害羞的时候，\\n　你就两眼放光地扑上来！」",null,null,null],["82_TEXT","82_TEXT",null,null,null],["「ちょっ、待っ、水圧強ッ」","「等、等一下，水压太强了——」",null,null,null],["83_TEXT","83_TEXT",null,null,null],["「弄ンな！　乙女心を雑に弄ンな！\\n　てめえ如き甲斐性なしのぼんくらが！」","「别瞎碰！　别粗暴地玩弄少女心！\\n　就凭你这个没出息、没本事的窝囊废！」",null,null,null],["84_TEXT","84_TEXT",null,null,null],["「すいませんすいません！\\n　俺が悪かったんです！」","「对不起对不起！\\n　是我错了！」",null,null,null],["85_TEXT","85_TEXT",null,null,null],["「テメこっちがこの手のこと慣れてねーからって、\\n　調子乗ってんじゃねえぞこの野郎！\\n　マジでいつか出るトコ出るからな！　コラッ！」","「你别因为老子不习惯这种事，\\n　就在那儿蹬鼻子上脸啊你这混账！\\n　小心我真跟你没完，直接找你算总账！　混球！」",null,null,null],["86_TEXT","86_TEXT",null,null,null],["「出るトコ出てないから、\\n　昔の水着を着れるわけだが……」","「就是因为没有闹到那个地步，\\n　所以才能穿上以前的泳衣吧……」",null,null,null],["87_TEXT","87_TEXT",null,null,null],["「ああああああああ！！　言ったな！\\n　今言ったなてめえ！」","「啊啊啊啊啊！！　你说了！\\n　你刚才说了吧你这混蛋！」",null,null,null],["88_TEXT","88_TEXT",null,null,null],["「今日でその目ん玉、\\n　お役ごめんにしてやる～～！」","「今天我就让你这对眼珠子，\\n　直接退休～～！」",null,null,null],["98_TEXT","98_TEXT",null,null,null],["「……はあ。どっと疲れた」","「……唉。累死我了」",null,null,null],["99_TEXT","99_TEXT",null,null,null],["「うぅ……激しい水圧で眼球が圧迫され\\n　すぎて、前がよく見えない」","「呜……眼球被超强的水压\\n　压迫得太厉害，前面都看不清了」",null,null,null],["100_TEXT","100_TEXT",null,null,null],["「今は仕事中だから笑ってるけど、\\n　まだちゃんと許してないぞ普通に」","「现在是因为在上班所以跟你嘻嘻哈哈，\\n　我可还没真的原谅你呢」",null,null,null],["102_TEXT","102_TEXT",null,null,null],["「ンで？　なんか買い物あんだっけ。\\n　さっさと買って帰ってくれー」","「所以呢？　你是要买什么东西来着。\\n　赶紧买完就回去吧——」",null,null,null]],"type":"","context":[["02_Arakasegi01.uasset.csv/row/96","02_Arakasegi01.uasset.csv/row/107","02_Arakasegi01.uasset.csv/row/118","02_Arakasegi01.uasset.csv/row/129","02_Arakasegi01.uasset.csv/row/140","02_Arakasegi01.uasset.csv/row/151","02_Arakasegi01.uasset.csv/row/162","02_Arakasegi01.uasset.csv/row/181","02_Arakasegi01.uasset.csv/row/280","02_Arakasegi01.uasset.csv/row/291","02_Arakasegi01.uasset.csv/row/302","02_Arakasegi01.uasset.csv/row/313","02_Arakasegi01.uasset.csv/row/324","02_Arakasegi01.uasset.csv/row/335","02_Arakasegi01.uasset.csv/row/346","02_Arakasegi01.uasset.csv/row/357","02_Arakasegi01.uasset.csv/row/368","02_Arakasegi01.uasset.csv/row/379","02_Arakasegi01.uasset.csv/row/390","02_Arakasegi01.uasset.csv/row/401","02_Arakasegi01.uasset.csv/row/412","02_Arakasegi01.uasset.csv/row/423","02_Arakasegi01.uasset.csv/row/450","02_Arakasegi01.uasset.csv/row/461","02_Arakasegi01.uasset.csv/row/472","02_Arakasegi01.uasset.csv/row/483","02_Arakasegi01.uasset.csv/row/494","02_Arakasegi01.uasset.csv/