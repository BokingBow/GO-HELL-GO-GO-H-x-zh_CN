,[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0871.uasset.csv","tags":[],"progress":{"translated":49,"length":49,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/06_Norimaki/unique1101.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/06_Norimaki","basename":"unique1101.uasset.csv","extension":"csv","filename":"unique1101.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/06_Norimaki/unique1101.uasset.csv","data":[["unique1101","unique1101",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「――というわけであんたは、\\n　地獄の亡者になっちまったんだ」","「――所以说，你啊，\\n　已经成了地狱里的亡者了。」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「……」","「……」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「ショックだろうけど、\\n　気を強く持って……」","「我知道你肯定很受打击，\\n　但要坚强起来啊……」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「――あ、そゆ設定の感じなんですね。\\n　はいはい、了解でーす（小声）」","「――啊，是这种设定是吧。\\n　好好，了解了解（小声说）」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「はい？」","「嗯？」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「はぁーい♪　ぽんぱんわーっ♪♪」","「嗨~♪　大家安安~♪♪」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「まじかるえんじぇの、のりまき☆\\n　壇上！　だおーっ☆」","「我乃魔法天使海苔卷☆\\n　闪亮登坛！哒哦~☆」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「ちょいちょーいっ！　ディレクターのお兄さん！\\n　そこは『壇上じゃなくて参上な！』でそー！」","「喂喂——！导演大哥！\\n　那里应该是‘不是登坛，是登场啦！’才对吧——！」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「……何？　この惨状は」","「……什么？这惨状是怎么回事。」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「ほええーんっ！　のりまきぃ、\\n　地獄ってトコに落とされちゃったんだってーっ」","「呜喂——！海苔卷我啊，\\n　听说是掉进一个叫地狱的地方了——！」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「怖いお、怖いおーっ」","「好可怕哦，好可怕哦——！」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「…………チラっ」","「……（偷瞄）」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「えっ」","「诶」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「ギザ怖ゆす～」","「超可怕的说~」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「ギザ怖ゆす！？」","「超可怕的说！？」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「さっきから何なんすかその薄ら寒い、\\n　大げさなキャラクター作りは……？」","「从刚才开始，你那个让人起鸡皮疙瘩、\\n　夸张的装模作样是怎么回事……？」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「ちょいちょーいっ！\\n　誰がキャラ作りだーっ！」","「喂喂——！\\n　谁说是在演人设啦——！」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「のりまきはぁー、天使の国の魔法少女っ☆\\n　悪を駆逐するために、テレビの中にやってきたのだーっ」","「海苔卷是~，来自天使国的魔法少女☆\\n　为了铲除邪恶，而来到电视机里面的哒——！」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「……てれび？」","「……电视机里？」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「ちょっとちょっと。段取りしっかりやって下さいよ。\\n　素人のADってわけでもないんだから」","「稍等稍等。麻烦你按流程来好吗。\\n　你又不是门外汉的助理。」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「……地声、低いっすね？」","「……你的本音，很低沉啊？」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「いやこっちは良いんですけど。\\n　私時給は結構高めに貰ってるし（小声）」","「不不我这倒没事。\\n　毕竟我这边的时薪挺高的（小声说）」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「出来るだけ良いもん作りたい気持ちがあるから、\\n　なるだけスムーズに進めたいんだけどぉ」","「毕竟我也想努力做出好东西，\\n　所以想尽量顺利地进行下去啊。」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「プロ意識、しっかりしてる人だった……」","「是个职业意识很强的人啊……」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「もしかしてドッキリとかだと思ってる？\\n　いや、これ、ガチの地獄ですからね」","「你难道以为这是什么整人节目吗？\\n　不是啦，这，可是真正的地狱哦。」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「………………」","「………………」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「（こくりと頷く）」","「（轻轻点头）」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「えーっ！？　地獄ーっ！？\\n　こ、これぇ……ドッキリなんじゃないですかぁ……？」","「诶——！？地狱——！？\\n　这、这个……难道不是整人节目吗……？」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「ふえーんっ。のりまき、こわいよぉー。\\n　えん☆　えんっ☆」","「呜喂——。海苔卷我好怕哦——。\\n　救☆　救☆！」",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「プロ意識が凄すぎて、\\n　話が通じないみたいだ」","「职业意识太强过头，\\n　感觉没法沟通了。」",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「これからのりまき、どうなっちゃうのーっ！？」","「接下来海苔卷，会变成什么样啊——！？」",null,null,null],["47_TEXT","47_TEXT",null,null,null],["「……まあ、暴れられるよりは良いか」","「……算了，总比她大吵大闹要好。」",null,null,null],["48_TEXT","48_TEXT",null,null,null],["「これからのりまきさんには、\\n　地獄の責め苦を受けて貰います」","「接下来，海苔卷小姐，\\n　要请你体验一下地狱的折磨了」",null,null,null],["49_TEXT","49_TEXT",null,null,null],["「せ、せめく～～～っ！\\n　何だか響きが怖いおーっ」","「折、折磨～～～！\\n　总觉得这个词听起来好可怕哦——」",null,null,null],["50_TEXT","50_TEXT",null,null,null],["「にょーほほほ！　でも大丈夫！\\n　のりまきはスーパーエンジェル」","「哎——呀呀呀！不过没事！\\n　海苔卷可是超级天使」",null,null,null],["51_TEXT","51_TEXT",null,null,null],["「説明しよう！　のりまきは――」","「让我说明一下！海苔卷就是――」",null,null,null],["52_TEXT","52_TEXT",null,null,null],["「人間の87倍の硬度を持つセラミックボディで、\\n　大抵の衝撃なら無効化してしまうのだ！」","「拥有相当于人类87倍硬度的陶瓷身体，\\n　一般的冲击对她根本无效！」",null,null,null],["53_TEXT","53_TEXT",null,null,null],["「銃弾でも大砲でも持ってこんかい！　ワレぃ！」","「子弹也好大炮也好，尽管放马过来！\\n　我呸！」",null,null,null],["54_TEXT","54_TEXT",null,null,null],["「ぜ、全然設定がわかんねえけど、\\n　この人が出てた番組見て～～～！」","「完、完全搞不懂这是什么设定，\\n　好想看这个人出场的节目——！」",null,null,null],["55_TEXT","55_TEXT",null,null,null],["「そんじゃ、移動入りまーす」","「那咱们就准备挪地方啦——」",null,null,null],["56_TEXT","56_TEXT",null,null,null],["「はぁーい♪♪」","「好——♪♪」",null,null,null],["57_TEXT","57_TEXT",null,null,null],["「……ぁ、隠しカメラってあそこの茂みとかですか？\\n　なるだけ意識しないようにしてますけど」","「……啊，隐藏摄像头是那边树丛里吗？\\n　我会尽量装作没注意到的」",null,null,null],["58_TEXT","58_TEXT",null,null,null],["「あ、ディレクターさん、\\n　今日はよろしくおねがいしますね（小声）」","「啊，导演，\\n　今天还请多多关照（小声）」",null,null,null],["59_TEXT","59_T