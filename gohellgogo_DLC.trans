8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/05_Kamase/unique1031.uasset.csv","tags":[],"progress":{"translated":83,"length":83,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/05_Kamase/unique1041.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/05_Kamase","basename":"unique1041.uasset.csv","extension":"csv","filename":"unique1041.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/05_Kamase/unique1041.uasset.csv","data":[["unique1041","unique1041",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「えーんえんえん。えーんえんえん」","「呜呜呜。呜呜呜」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「なあ。もうそろそろ、\\n　泣き止んでもらえんもんか」","「喂。差不多，\\n　能不能别哭了啊」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「コーチぃいい！　ぐすっ。\\n　アタシほんと、やばくてーっ！」","「教练——！呜。\\n　我真的，太糟糕了——！」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「めっちゃ痛いしっ。めっちゃ苦しいしっ。\\n　もうダメかと思ったんだからぁっ！！」","「超级疼啊！而且超级难受啊！\\n我还以为真的不行了啊！！」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「がんばったがんばった。\\n　あれが地獄のマジってやつよ」","「辛苦啦辛苦啦。\\n那就是地狱的真本事那种东西啦」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「うぅ……正直なめてたぜ、地獄の鬼を」","「呜……说实话我小看了，地狱的鬼」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「ってかアレは流石にバケモンすぎない！？\\n　あんなん素手じゃ勝てなくて当然なんだけど！」","「话说那家伙也太怪物了吧！？\\n那种东西空手打不过当然很正常啊！」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「……む？　確かにそうか。気づいてみれば」","「……嗯？确实是这样呢。仔细一想」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「何に気がついてしまったと言うんだ」","「你说你发现了什么」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「バットがなければ野球はできぬ！\\n　そうだアタシには武器が必要なんだ」","「没有球棒就打不了棒球！\\n对呀我需要武器啊」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「あんなにデカい化物が相手でも、\\n　同じぐらいデカいチェーンソウでもあれば……ふふふ」","「就算对手是那么巨大的怪物，\\n只要有同样巨大的电锯的话……嘿嘿嘿」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「……バトルの算段立ててない？　既に」","「……已经在盘算战斗策略了？就现在」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「そりゃあそう！　だってアタシの辞書に\\n　負けっぱなしって言葉はねーんだぜ！！」","「那当然！因为在我的字典里\\n没有认输这种词啊！！」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「マジかこいつ」","「这家伙是来真的」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「確かに怖かったし泣いたし叫んだけど、\\n　これで終わりってわけじゃない！」","「虽然确实很害怕也哭了也叫了，\\n但这不代表就这么结束了！」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「いまに見てろよあんな怪物！\\n　地獄制覇の道の第一歩にしてやんよ！」","「走着瞧吧那种怪物！\\n要把它变成称霸地狱之路的第一步！」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「なんて強いメンタルしてるんだ」","「这精神力是有多强啊」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「問題は武器。\\n　ぐぬぬ……どうやって調達するか」","「问题是武器。\\n唔唔唔……要怎么弄到手呢」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「……じぃー」","「……盯——」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「な、何故こっちを見る」","「为、为什么往这边看」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「だってぇ……コーチなら地獄に詳しいしぃ……、\\n　責め苦にも隠して持ち込めるじゃないかぁ……」","「因为呀……教练对地狱很熟嘛……\\n就算是拷问道具也能偷偷带进去的吧……」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「な、何故急にくねくねして女を見せてくる」","「为、为什么突然扭扭捏捏地展露女性魅力」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「アタシの１番の武器は、\\n　底なしの元気！　だけどぉー」","「我的第一武器是，\\n用不完的活力！不过呢——」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「２番目の武器は……ね？\\n　分かるだろ……？」","「第二武器是……呐？\\n你懂的吧……？」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「ご、ごくり」","「咕、咕噜」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「ねーえー……コーチー……。\\n　アタシ、２人っきりでぇ……」","「呐——……教练——……。\\n我们两个人单独……」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「手取り足取り、\\n　コーチング……してほしいなって……ぇ」","「手把手地……\\n指导人家嘛……呐」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「……………………」","「……………………」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「ああああああ！　誰がやるかそんなこと！\\n　やばすぎる橋に俺を誘惑するなあ！」","「啊啊啊啊啊啊！谁会做那种事啊！\\n别诱惑我过这种太危险的桥啊！」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「とか言って、押したらいけそー。\\n　虎視眈々とがんばっちゃお」","「嘴上这么说，感觉再推一把就行。\\n虎视眈眈地加油吧」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「……マジに強いやつだよ、おまえ……」","「……真是个强得不得了的家伙啊，你……」",null,null,null]],"type":"","context":[["unique1041.uasset.csv/row/104","unique1041.uasset.csv/row/115","unique1041.uasset.csv/row/126","unique1041.uasset.csv/row/137","unique1041.uasset.csv/row/148","unique1041.uasset.csv/row/159","unique1041.uasset.csv/row/170","unique1041.uasset.csv/row/181","unique1041.uasset.csv/row/192","unique1041.uasset.csv/row/203","unique1041.uasset.csv/row/214","unique1041.uasset.csv/row/225","unique1041.uasset.csv/row/236","unique1041.uasset.csv/row/247","unique1041.uasset.csv/row/258","unique1041.uasset.csv/row/269","unique1041.uasset.csv/row/280","unique1041.uasset.csv/row/291","unique1041.uasset.csv/row/302","unique1041.uasset.csv/row/313","unique1041.uasset.csv/row/324","unique1041.uasset.csv/row/335","unique1041.uasset.csv/row/346","unique1041.uasset.csv/row/357","unique1041.uasset.csv/row/368","unique1041.uasset.csv/row/379","unique1041.uasset.csv/row/390","unique1041.uasset.csv/row/401","unique1041.uasset.csv/row/412","unique1041.uasset.csv/row/423","unique1041.uasset.csv/row/434"],["unique1041.uasset.csv/row/105"],["unique1041.uasset.csv/row/106"],["unique1041.uasset.csv/row/116"],["unique1041.uasset.csv/row/117"],["unique1041.uasset.csv/row/127"],["unique1041.uasset.csv/row/128"],["unique1041.uasset.csv/row/138"],["unique