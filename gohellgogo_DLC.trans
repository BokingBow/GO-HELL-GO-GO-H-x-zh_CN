B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/02_Arakasegi/02_Arakasegi05.uasset.csv","tags":[],"progress":{"translated":97,"length":97,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/02_Arakasegi/02_Arakasegi06.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/02_Arakasegi","basename":"02_Arakasegi06.uasset.csv","extension":"csv","filename":"02_Arakasegi06.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/02_Arakasegi/02_Arakasegi06.uasset.csv","data":[["02_Arakasegi06","02_Arakasegi06",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「そういやうちの店、\\n　クーポンを取り扱うようになったから」","「说起来我们家店，\\n　已经开始提供优惠券兑换服务了」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「へえ、クーポン」","「哦，优惠券」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「不要なものとクーポンを交換してやるから」","「我用东西跟你交换不需要的杂物和优惠券」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「一定数貯めると良いものになって\\n　返ってくる可能性があるぞ」","「攒够一定数量的话，说不定还能\\n　换到好东西返还给你呢」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「なに。可能性って。\\n　良くないものになる可能性もあるのか？」","「啥。什么叫说不定。\\n　也就是说也有可能换到烂东西咯？」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「そうさなあ……まあ」","「差不多吧……嗯」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「ふわふわの便座カバーとかの\\n　可能性もあるからな」","「因为也有可能会是\\n　毛茸茸的马桶座圈套之类的嘛」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「確かに人によっては全然要らないモノだ」","「这确实是对某些人来说完全用不上的东西」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「カップ麺の上に置くフィギュアとかな」","「或者放在泡面上的手办之类的」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「人によってはありすぎて困ってるモノだ」","「这是对某些人来说多到发愁的东西」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「プロテイン5kgとかな」","「或者5公斤的蛋白粉之类的」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「人によってはただの土嚢になるモノだ」","「这是对某些人来说纯粹就是个沙袋的东西」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「まあ便利な物をやる可能性もあるから。\\n　どうせいらんもんなら持ってきたら」","「不过嘛也有可能给你好用的东西。\\n　反正都是你不要的废物，拿来试试呗」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「ゴミ捨ての代わりになると思えば良いか……」","「就当是代替扔垃圾好了……」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「それならポッケに入ってた、\\n　レシートだった物体をやろう」","「那这个原本可能是收据的东西，\\n　之前放口袋里，就拿去丢吧」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「不用品以下のゴミはいらん」","「连废品都不如的垃圾我才不要」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「ポッケにはもう一つ、\\n　干からびた四葉のクローバーもあるんだが……？」","「我口袋里还有个东西，\\n　是已经干掉的四叶草哦……？」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「だが……？　じゃねえんだわ全然。\\n　煽るなその程度で期待感を」","「「哦」？哦你个头啦。\\n　别想拿这点程度的东西吊我胃口」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「あといい年したおっさんが\\n　忍ばせるな四葉のクローバーを」","「而且都一把年纪的大叔了，\\n　口袋里别藏什么四叶草啊」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「ね、年齢差別……！」","「你、你年龄歧视……！」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「年相応」","「这叫符合年龄」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「まあ、クーポンの説明はしたからな。\\n　ところで普通に買い物もしていけよ」","「好啦，优惠券说明也给你了。\\n　对了，东西也顺便正常买点回去啊」",null,null,null]],"type":"","context":[["02_Arakasegi06.uasset.csv/row/104","02_Arakasegi06.uasset.csv/row/115","02_Arakasegi06.uasset.csv/row/126","02_Arakasegi06.uasset.csv/row/137","02_Arakasegi06.uasset.csv/row/148","02_Arakasegi06.uasset.csv/row/159","02_Arakasegi06.uasset.csv/row/170","02_Arakasegi06.uasset.csv/row/181","02_Arakasegi06.uasset.csv/row/192","02_Arakasegi06.uasset.csv/row/203","02_Arakasegi06.uasset.csv/row/214","02_Arakasegi06.uasset.csv/row/225","02_Arakasegi06.uasset.csv/row/236","02_Arakasegi06.uasset.csv/row/247","02_Arakasegi06.uasset.csv/row/258","02_Arakasegi06.uasset.csv/row/269","02_Arakasegi0