foText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0451.uasset.csv","tags":[],"progress":{"translated":115,"length":115,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0461.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya","basename":"unique0461.uasset.csv","extension":"csv","filename":"unique0461.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0461.uasset.csv","data":[["unique0461","unique0461",null,null,null],["12_TEXT","12_TEXT",null,null,null],["「うぅ……お外怖い……がくがくぶるぶる」","「唔……外面好可怕……瑟瑟发抖，抖个不停。」",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「あれ。U乃じゃん。大丈夫？」","「哎呀，这不是U乃嘛。没事吧？」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「！」","「！」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「だ、だ、大丈夫とはまた随分な質問だね。\\n　この私が大丈夫でない日など宇宙開闢以来ないよ」","「没、没、这「没事吧」问得可真够随意的。\\n　　自天地开辟以来，本小姐可就没有过不没事的日子哦。」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「それはよかった。ほんじゃ」","「那真是太好了。先走啦。」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「まあ待ちなさいまあ待ちなさい」","「且慢且慢，你给我站住！」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「……何？」","「……干嘛？」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「この明らかに強がっているいたいけな少女に\\n　もっとあるんじゃないの正しい反応が」","「对于我这个明显是在逞强的无辜少女，\\n　　你就没点儿更正确的反应吗！」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「どう見ても足が震えてるよねえ！？\\n　どう見ても大丈夫じゃないよねえ！？」","「怎么看我这双腿都在打颤吧！？\\n　　怎么看都不像没事的样子吧！？」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「言語外に隠されたハイコンテクストな感情に\\n　ちゃんと気が付けないの大丈夫そ！？」","「人家话里藏着的那些高语境情绪，\\n　你完全察觉不到，真的没问题吗！？」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「……結局、何が言いたいわけ」","「……所以，你到底想说什么」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「何が言いたいとかじゃなくてねえ！\\n　私は寧ろ心配をしている立場なわけ」","「我不是想说什么呀！\\n　我反倒是在担心你的那个立场上啊」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「袖擦れ合うのも他生の縁。\\n　その隠喩さえ汲み取れない鈍感さで」","「相逢即是有缘，\\n　你连这点隐喻都听不出来的迟钝劲儿」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「この魑魅魍魎が跋扈する現代社会を\\n　生き残っていけるのかなあって憂えてるわけ！？」","「在这个魑魅魍魉横行的现代社会，\\n　你还能不能活下去啊，我是在替你发愁啊！？」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「全然俺の事は心配せんでもろて」","「我的事你完全不用操心」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「まあまあまあまあ聞き給え聞き給え」","「哎呀呀呀呀，你且听我说，你且听我说」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「なんとこちらの美少女もう1日何も食べて無くて、\\n　喉もカラカラで限界らしいよ。やったね」","「你看啊，这位美少女已经整整一天没吃东西了，\\n　嗓子也干得冒烟，好像到极限了哦。太棒了」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「……何が『やった』ね？」","「……什么叫‘太棒了’？」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「だってこの私に恩を売れるという、\\n　素晴らしい機会に恵まれたのだから」","「因为，这可是个能让本小姐欠你一个人情，\\n　天大的好机会砸到头上了嘛」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「ふふ……幸運だね☆」","「呵呵……真走运呢☆」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「ほんじゃ、おつかれっしたー」","「那就这样，辛苦咯——」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「ああ、ごめんなさいごめんなさい！\\n　プライド高くてごめんなさい！」","「啊，对不起对不起！\\n　我自尊心高真是对不起！」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「土下座でも何でもするから、\\n　どうか助けてーーーー！！」","「要下跪还是怎样我都干，\\n　求求你救救我吧————！！」",null,null,null]],"type":"","context":[["unique0461.uasset.csv/row/96","unique0461.uasset.csv/row/107","unique0461.uasset.csv/row/118","unique0461.uasset.csv/row/129","unique0461.uasset.csv/row/140","unique0461.uasset.csv/row/151","unique0461.ua