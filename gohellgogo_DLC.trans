ext":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/06_Norimaki/unique1131.uasset.csv","tags":[],"progress":{"translated":85,"length":85,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/06_Norimaki/unique1141.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/06_Norimaki","basename":"unique1141.uasset.csv","extension":"csv","filename":"unique1141.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/06_Norimaki/unique1141.uasset.csv","data":[["unique1141","unique1141",null,null,null],["12_TEXT","12_TEXT",null,null,null],["「まさかあの牛乳瓶が、\\n　あんな事になってしまうとはぁ……」","「万万没想到那个牛奶瓶，\\n　竟然会变成那种样子啊……」",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「あてち、超超おどろき桃の木山椒の木！\\n　さんしょの木って何なんですかね！？」","「偶呢，超超大吃一惊吓掉下巴跌破眼镜！\\n　话说回来，跌破眼镜到底是什么鬼啊！？」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「とゆーわけで様々な困難を乗り越えた美少女、\\n　のりまきは！　更に一皮剥けて、\\n　大人への階段を登ったのであった！」","「就这样，克服了重重困难的美少女，\\n　海苔卷！　又蜕了一层皮，\\n　在通往大人的阶梯上更进了一步！」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「って、誰がとっくの昔に妙齢やねん！？」","「喂，谁早就是一把年纪了啊！？」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「お疲れ。ジュース飲む？」","「辛苦了。喝果汁吗？」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「あ、ども。ってかもうカットかかってたヤツです？\\n　もぉー言って下さいよぉ」","「啊，多谢。话说，刚才那段早就喊卡了吗？\\n　真是的，您倒是跟我说一声啊」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「あたしまた、全力でやっちゃったじゃないですかあ」","「我这不是又、使出全力来演了嘛」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「実はまだカメラ回ってるとしたらどうする」","「要是其实摄像机还在转呢，你怎么办」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「……！　もぉー！　ぷんすこ！\\n　だめなんですよぉディレクターさん！」","「……！　真是的——！　气呼呼！\\n　这样不行啦，导演！」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「乙女の秘密を覗き込むのは！\\n　ぷりちーびーむでおちおき、だゾ☆」","「窥探少女的秘密可是重罪！\\n　看我用可爱光束惩罚你，的唷☆」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「ひえー。すごいプロ根性だなあ」","「哎呀呀。真是了不起的职业精神啊」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「でも再三言ってるけど\\n　ここ地獄だからあんま意味ないよ」","「不过我说了好几次了\\n　这里是地狱所以没什么意义啦」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「あははーもう、ディレクターさんも、\\n　プロ根性すごいんだからぁ～」","「啊哈哈真是的，导演先生也，\\n　职业精神真是太了不起了啦～」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「…………………………」","「…………………………」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「え、ほんとに違いますよね？」","「诶，真的不是假的吗？」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「流石に責め苦？　っていうの、\\n　人体に使って良いレベルを超えてるなって。\\n　普通に闇案件かなって」","「怎么说呢，这折磨戏？已经超越了\\n　能对人使用的级别了吧。\\n　这妥妥是黑心项目了吧」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「それに道行く人も変な格好の人見るし。\\n　皆、ここが地獄だって言うし」","「而且路上行人也都穿得奇装异服。\\n　大家都说，这里是地狱」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「……違い……ますよね……？」","「……不……不是假的……对吧……？」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「違わないよ」","「不是假的哦」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「………………」","「………………」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「ま、またまた～」","「哎呀、又开玩笑～」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「それで、明日の撮影の予定はなんなんですか？」","「那么，明天的拍摄计划是什么啊？」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「明日も責め苦だよ」","「明天也是折磨戏哦」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「…………なんのために？\\n　もぉ、その絵は撮ったじゃないですかー」","「…………为了什么啊？\\n　真是的，那段画面不是已经拍过了嘛──」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「だって地獄だから。普通に」","「因为这里是地狱啊。很普通地」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「明日も明後日も明々後日も、\\n　その先も延々責め苦だよ」","「明天、后天、大后天，\\n　再往后也要一直一直搞折磨戏哦」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「……まさか。あの。……これって。\\n　変なテレビの設定とかじゃなくて」","「……不会吧。那个。……这该不会。\\n　不是什么奇怪的电视节目设定」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「……ガチの地獄、ってやつですか？」","「……而是货真价实的地狱，那种情况吧？」",null,null,null]],"type":"","context":[["unique1141.uasset.csv/row/96","unique1141.uasset.csv/row/107","unique1141.uasset.csv/row/118","unique1141.uasset.csv/row/129","unique1141.uasset.csv/row/140","unique1141.uasset.csv/row/151","unique1141.uasset.csv/row/162","unique1141.uasset.csv/row/173","unique1141.uasset.csv/row/184","unique1141.uasset.csv/row/195","unique1141.uasset.csv/row/206","unique1141.uasset.csv/row/217","unique1141.uasset.csv/row/228","unique1141.uasset.csv/row/239","unique1141.uasset.csv/row/250","unique