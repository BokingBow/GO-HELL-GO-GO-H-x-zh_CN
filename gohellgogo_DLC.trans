232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/04_Oshi/unique0911B.uasset.csv","tags":[],"progress":{"translated":69,"length":69,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/04_Oshi/unique0921.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/04_Oshi","basename":"unique0921.uasset.csv","extension":"csv","filename":"unique0921.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/04_Oshi/unique0921.uasset.csv","data":[["unique0921","unique0921",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「全く！　何なんでありますか、この場所はぁ！」","「真是够了！这地方到底算什么嘛！」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「そんで、どう。慣れてきた？　この町にも」","「然后呢，怎么样？习惯了吗？对这个镇子」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「全然慣れてません！　あそこの天ぷら屋さんは、\\nごぼう天が絶品でしたが！」","「完全没习惯！虽然那边那家天妇罗店的\\n牛蒡天妇罗堪称一绝呢！」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「ちょっとは満喫してそうで何より」","「你能稍微享受其中，那就再好不过了」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「……これからまた、\\n別の地獄に行くんでしたっけ？」","「……接下来，是要去\\n别的什么地狱来着？」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「そうそう。抵抗は諦めてもろて」","「没错没错。抵抗就请你放弃吧」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「うぅ……小市民はいつだって、\\n権力に逆らえないのであります……」","「呜呜……我们小市民，无论何时\\n都无法违抗强权啊……」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「そういや、お椎は生前は何してたの」","「对了，小椎你生前是做什么的啊」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「地下アイドルのプロデュースをしていました」","「我在做地下偶像的制作人」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「なんかな……」","「怎么说呢……」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「何でありますか！？」","「怎么说是什么意思啊！？」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「世に悪人の栄えた試し無く、\\n地下アイドルのPに上等な人間が居た\\nことはない」","「这世上恶人就没一个得善终的，\\n地下偶像的制作人里也从来没出过\\n一个像样的东西」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「ひ、ひえ～～。恐ろしい程の偏見。\\n何たる人権意識の低さ。これが地獄」","「咿、咿耶～～。可怕到极点的偏见。\\n何等低下的人权意识。这就是地狱啊」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「地下アイドルじゃなくてPって言うのも、\\nなんか半端なんだよな……何なんだろうな？」","「不当地下偶像非要叫什么'P'，\\n感觉总是半吊子啊……到底算什么呢？」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「自分に聞かないで下さい！」","「这种事别问我啊！」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「おお、こんな所で奇遇だね。\\nん？　そちらに居るのは一ノ瀬くん……」","「哦哦，在这种地方碰到可真巧。\\n嗯？站在那边的是不是一之濑……」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「ではないであります！\\nここ数日で十回ぐらい間違えられましたが！」","「才不是！这几天我已经\\n被认错十几次了！」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「そうです課長。こちら一ノ瀬のパチモ……、\\n　じゃなくて海賊ば……じゃなくて……」","「没错课长。这位是冒……\\n不对，是海盗……也不对……」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["（いつか絶対殺す）","（总有一天绝对要宰了你）",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「ああ、ああ。聞いてるよ。\\n　へえー。キミが例の……」","「啊啊，嗯嗯。我听说了哦。\\n嚯——。你就是传闻中的那个……」",null,null,null],["47_TEXT","47_TEXT",null,null,null],["「れ、例ってなんすか。（ぶるる）」","「传、传闻是啥啊。（抖抖抖）」",null,null,null],["48_TEXT","48_TEXT",null,null,null],["「うんうん、私もね、キミには期待してたんだよ」","「对对，我也对你抱有很大期望呢。」",null,null,null],["49_TEXT","49_TEXT",null,null,null],["「よく分からないけど、\\n期待されるの自体は好きであります」","「虽然不太明白，但本人\\n倒是挺喜欢被人期望的。」",null,null,null],["50_TEXT","50_TEXT",null,null,null],["「でも、実物を見てみると、うーーーーん」","「但是，亲眼见到真人以后，嗯————」",null,null,null],["51_TEXT","51_TEXT",null,null,null],["「確かに惜しいな……」","「确实有点可惜啊……」",null,null,null],["52_TEXT","52_TEXT",null,null,null],["「何だこいつ。目も口も頭もキモい」","「这家伙怎么回事。眼睛嘴巴脑袋都让人发毛。」",null,null,null],["53_TEXT","53_TEXT",null,null,null],["「おしとやかさがな……無いんだよな……。\\n諸処から漏れる細やかさが……」","「就是没有那种……优雅端庄感啊……。\\n从各个角落漏出来的那种细腻劲儿……」",null,null,null],["54_TEXT","54_TEXT",null,null,null],["「座る時、足開いて座るしな……」","「毕竟坐下的时候，腿都是一直大张着的……」",null,null,null],["55_TEXT","55_TEXT",null,null,null],["「うるさいな！　本当に！\\n変なトコ見ないで下さい！」","「烦死了！真是的！\\n别老盯着奇怪的地方看行不行！」",null,null,null],["56_TEXT","56_TEXT",null,null,null],["「ひとつ心理テストをしよう」","「来做个心理测验吧。」",null,null,null],["57_TEXT","57_TEXT",null,null,null],["「は、はい」","「好、好的。」",null,null,null],["58_TEXT","58_TEXT",null,null,null],["「キミには大切な人がいるとする。\\n大切な人のために、君は悪漢に脅されるとする」","「假设你有一个很重要的人。\\n为了这个重要的人，你被坏人威胁了。」",null,null,null],["59_TEXT","59_TEXT",null,null,null],["「そんな時、君ならどうする……？」","「这种时候，你会怎么做……？」",null,null,null],["60_TEXT","60_TEXT",null,null,null],["「……？　脅しの証拠を作るか捏造して、\\n揺すってたかる……？」","「……？　是先捏造个被威胁的证据，\\n然后反过去勒索敲诈他一笔……？」",null,null,null],["61_TEXT","61_TEXT",null,null,null],["「まあ基本！　出たとこ勝負で！\\nぜってーーーーーに泣かすであります！！」","「反正基本靠临场发挥！\\n绝对要把他揍到哭爹喊娘！！！」",null,null,null],["62_TEXT","62_TEXT",null,null,null],["「…………0点！」","「…………零分！」",null,null,null],["63_TEXT","63_TEXT",null,null,null],["「なんだァ？　このハゲ」","「你什么毛病？啊？死秃子。」",null,null,null],["64_TEXT","64_TEXT",null,null,null],["「俺はプロデューサーらしい強かさを感じて、\\nむしろちょっと好感度は上がりましたが」","「我倒是从他身上感受到了制作人特有的狠劲儿，\\n好感度反而稍微上升了一点。」",null,null,null],["65_TEXT","65_TEXT",null,null,null],["「まあ、それはそれで……使い道が……」","「嘛，这点倒是也有这点……的用处……」",null,null,null],["66_TEXT","66_TEXT",null,null,null],["「はい？？」","「哈？？」",null,null,null],["67_TEXT","67_TEXT",null,null,null],["「これから、責め苦だよね」","「接下来就是，折磨拷问了对吧。」",null,null,null],["68_TEXT","68_TEXT",null,null,null],["「はい」","「是。」",null,null,null],["69_TEXT","69_TEXT",null,null,null],["「……それじゃあまた、後で会おうか」","「……那咱们就，回头再见吧。」",null,null,null],["73_TEXT","73_TEXT",null,null,null],["「何だか嫌な予感だけが猛烈にするであります」","「我只有一种非常强烈的不祥预感啊。」",null,null,null],["74_TEXT","74_TEXT",null,null,null],["「ま……なんていうか」","「哎呀……该怎么说呢。」",null,null,null],["75_TEXT","75_TEXT",null,null,null],["「今日の昼飯は奢ろうか？　天丼」","「今天的午饭我请客吧？吃炸虾盖饭。」",null,null,null],["76_TEXT","76_TEXT",null,null,null],["「うわぁ～ん！　絶対なんか嫌なことあるんだ～！」","「呜哇～！肯定没好事儿～！」",null,null,null]],"type":"","context":[["unique0921.uasset.csv/row/120","unique0921.uasset.csv/row/131","unique0921.uasset.csv/row/142","unique0921.uasset.csv/row/153","unique0921.uasset.csv/row/164","unique0921.uasset.csv/row/175","unique0921.uasset.csv/row/186","unique0921.uasset.csv/row/197","unique0921.uasset.csv/row/208","unique0921.uasset.csv/row/219","unique0921.uasset.csv/row/230","unique0921.uasset.csv/row/241","unique0921.uasset.csv/row/252","unique0921.uasset.csv/row/263","unique0921.uasset.csv/row/274","unique0921.uasset.csv/row/373","unique0921.uasset.csv/row/384","unique0921.uasset.csv/row/395","unique0921.uasset.csv/row/406","unique0921.uasset.csv/row/417","unique0921