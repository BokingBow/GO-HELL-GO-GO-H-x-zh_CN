Text":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/01_Main/01_03_Jigoku.uasset.csv","tags":[],"progress":{"translated":141,"length":141,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/01_Main/01_04_MEzz.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/01_Main","basename":"01_04_MEzz.uasset.csv","extension":"csv","filename":"01_04_MEzz.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/01_Main/01_04_MEzz.uasset.csv","data":[["01_04_MEzz","01_04_MEzz",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「ごくごく。はー麦茶はいつの季節でも\\n　アベレージ出してくるよな」","「咕嘟咕嘟。啊——麦茶这玩意儿，真是不分季节的稳定发挥啊」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「我は麦茶に砂糖を入れたやつがすき」","「吾喜欢往麦茶里加糖的那种」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「糖尿の恐ろしさを知らんと見える」","「看来你不知糖尿病的可怕啊」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「知っておるぞ！　あれだろ？　甘い果物だけを\\n　美少女に食べさせて尿の味をあまくするやつ」","「我知道的啦！就是那个吧？只给美少女吃甜水果，让尿变甜的那个吧」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「うーん全然違う」","「嗯——完全不对」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「失礼しますヤツシロ様。お茶をお持ちしました」","「打扰了，8246大人。我给您奉茶来了」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「……もう飲んでいらっしゃいませんか」","「……您已经喝上了吗」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「……見ての通りでございます」","「……如您所见」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「ヤツシロ様。お茶のご用意などは\\n　お任せ下さいませ」","「8246大人。准备茶水这类事，请务必交给我来做」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「そう言われても。\\n　麦茶をコップにつぐだけだしなあ」","「话虽这么说，不过就是往杯子里倒杯麦茶而已嘛」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「その僅かな些事が積み重なって、\\n　行方は巨大な雑務の山に」","「那点微不足道的小事积少成多，前方便是堆积如山的杂务」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「何事も、コツコツとが大事です」","「凡事，都贵在一点一滴的累积」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「それだけじゃありません。\\n　洗濯機、回しましたよね」","「还不止这些。洗衣机，您转了吧」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「……ちょっとカップ麺を\\n　ひっくり返してしまったから」","「……因为我把杯面打翻了一点」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「使ったお皿を水につけましたよね」","「用过的盘子您也泡在水里了吧」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「……汚れがこびりつかない方が、\\n　皿洗いが楽だと思ったから」","「……我想着，趁污渍还没干结粘住，洗碗会更轻松」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「トイレの便座も上げましたよね！」","「马桶圈您也掀起来了对吧！」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「それは流石に別にいいだろ！？」","「那个就别管了不行吗！？」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「差し出がましい事を言うようなら、\\n　だめです。当器の業務をとらないで下さい」","「如果您要说这是多事的话，那可不行。请别抢走本器的工作」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「ヤツシロ様のお世話をすることが使命であり生きがい。\\n　本当だったら歯も磨かせて頂きたいのに」","「侍奉8246大人是我的使命，也是生存的意义。说真的，我甚至想连刷牙都代劳呢」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「ほんとそこまでしなくて良いから」","「真的，不用做到那个份上啦」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「ご飯も全部、あーんで食べさせるというのは、\\n　いかがでしょう」","「那么，每口饭都由我来「啊——」地喂您吃，您觉得如何」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「面倒過ぎるだろそれ！\\n　自分で食った方が絶対早いぞ」","「那样也太麻烦了吧！自己吃绝对更快好吧」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「確かに効率の面では些か問題がありますね」","「的确，从效率上来说，是有点小问题呢」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「では効率化のためにこういうのはどうでしょう」","「那么，为了提高效率，您看这样如何」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「当器が食物を口に含み嚥下しやすいように\\n　咀嚼した上で、口腔による交換を行うと言うのは」","「由本器将食物含入口中，为方便您吞咽事先咀嚼好，再通过口腔进行交接——如何」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「ぜ、全部口移しで食べるのはどう？\\n　と聞いている？」","「你、你是问，全都嘴对嘴喂着吃怎么样？对吧？」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「噛み砕いて言うとそうなります。\\n　うまいことも言ってしまいました」","「通俗地说，就是这么回事。还顺手说了个俏皮话呢」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「…………ごくり」","「…………（咕噜）。」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「ヤツシロのすけべー」","「8246你个色胚——」",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「ちゃ、ちゃうわいちゃうわい！\\n　一瞬考えてしまっただけだわい！」","「不、不是！才不是呢！我只是稍微想了一下而已啊！」",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「とは言えヤツシロ様はこの頃、\\n　ちゃんとしすぎだと思います」","「不过话说回来，8246大人最近，我觉得您太过规矩了」",null,null,null],["47_TEXT","47_TEXT",null,null,null],["「いっつもいっつもいっつもいっつも\\n　お世話を全然させてくれなくて」","「老是、老是、老是、老是，完全不让我照顾您」",null,null,null],["48_TEXT","48_TEXT",null,null,null],["「……メズ？　大丈夫か？」","「……梅兹？你没事吧？」",null,null,null],["49_TEXT","49_TEXT",null,null,null],["「このような事が、これからも続くようでしたら」","「如果今后，这样的情况继续下去的话」",null,null,null],["51_TEXT","51_TEXT",null,null,null],["「ヤツシロ様。……これ、ですので」","「8246大人。……那就，这个了」",null,null,null],["52_TEXT","52_TEXT",null,null,null],["「こ、これ？」","「这、这个？」",null,null,null],["54_TEXT","54_TEXT",null,null,null],["「これ、です」","「就是这个」",null,null,null],["55_TEXT","55_TEXT",null,null,null],["「な、なに！？　怖いんだけど！？\\n　その含みとこの空気は何なわけ！？」","「怎、怎么回事！？ 好可怕啊喂！？\\n  你这暗示和这气氛到底是怎么回事！？」",null,null,null],["56_TEXT","56_TEXT",null,null,null],["「当器は人のためひいてはヤツシロ様の\\n　役に立つために業務を行ってきたつもりです」","「本器自认为一直是为了人类、进而为了8246大人\\n  效力而去进行业务的。」",null,null,null],["57_TEXT","57_TEXT",null,null,null],["「その当器から業務を奪うと言うことは、\\n　今までの結果を踏みにじる行為と同義」","「要夺走本器的业务这种说法，\\n  等同于践踏至今为止的成果。」",null,null,null],["60_TEXT","60_TEXT",null,null,null],["「それは看過することは出来ません」","「这我无法坐视不理。」",null,null,null],["61_TEXT","61_TEXT",null,null,null],["「ひっ目が本気すぎる」","「咿，眼神太认真了……」",null,null,null],["62_TEXT","62_TEXT",null,null,null],["「――これ、ですので」","「――所以说，就是这个。」",null,null,null],["63_TEXT","63_TEXT",null,null,null],["「ナ、何かの選択肢を間違えてしまったら、\\n　命の危うささえ感じるのが分かった」","「我明白了，如果搞错了某个选项，\\n  甚至会有生命危险。」",null,null,null],["65_TEXT","65_TEXT",null,null,null],["「そんなそんな。ヤツシロ様の\\n　身を損ねるような事は絶対にしません」","「哪里哪里。我绝不会做出\\n  有损8246大人贵体的事来。」",null,null,null],["66_TEXT","66_TEXT",null,null,null],["「ただ、――これ、をするだけですので」","「只是――做这个，而已。」",null,null,null],["67_TEXT","67_TEXT",null,null,null],["「これってなに！？　されたらどうなるの！？\\n　俺は無事で生きて帰れるの！？」","「这是什么啊！？ 被做了会怎么样！？\\n  我能平安活着回去吗！？」",null,null,null],["68_TEXT","68_TEXT",null,null,null],["「詳細は諸々伏せさせていただきます」","「详细情况恕不奉告。」",null,null,null],["69_TEXT","69_TEXT",null,null,null],["「わけわからなすぎて強すぎる……」","「完全搞不懂，搞得也太强势了……」",null,null,null],["71_TEXT","71_TEXT",null,null,null],["「わはは、これ、だの！　これ！」","「哇哈哈，是这个啊！　就是这个！」",null,null,null],["72_TEXT","72_TEXT",null,null,null],["「おめーは分かってんのか、公使」","「你懂了吗，公使！」",null,null,null],["73_TEXT","73_TEXT",null,null,null],["「わからん！」","「不懂！」",null,null,null],["74_TEXT","74_TEXT",null,null,null],["「こっちもなるだけそっちに寄り添うけど」","「虽然我也会尽力向你那边靠拢……」",null,null,null],["75_TEXT","75_TEXT",null,null,null],["「食事を全部食べさせるとか、\\n　歯を磨かせるとかは無しだからな！？」","「但像逼着人把饭全吃光、\\n  硬叫人刷牙之类的可免谈啊！？」",null,null,null],["77_TEXT","77_TEXT",null,null,null],["「……わかりました。一線は引きましょう」","「……我知道了。那就划清界线吧。」",null,null,null],["78_TEXT","78_TEXT",null,null,null],["「ではヤツシロ様。見ていて下さいませ」","「那么8246大人。请看着吧。」",null,null,null],["82_TEXT","82_TEXT",null,null,null],["83_TEXT","83_TEXT",null,null,null],["「ぐぉ……………………ッッ」","「唔……………………呃呃」",null,null,null],["85_TEXT","85_TEXT",null,null,null],["「……分かって頂けましたか？」","「……您能理解了吗？」",null,null,null],["86_TEXT","86_TEXT",null,null,null],["「分かった！　分かった分かった！\\n　何でも言う事聞きます逆らいません！」","「理解了！ 理解理解了！\\n  我什么都听你的绝不反抗！」",null,null,null],["87_TEXT","87_TEXT",null,null,null],["「何がわかったのだ！？」","「你懂什么了啊！？」",null,null,null],["88_TEXT","88_TEXT",null,null,null],["「お、お前アレ見て何も感じないのか！？\\n　男がアレに逆らうのは無理な圧だ」","「你、你看了那个就没感觉吗！？\\n  作为男人违抗那个是不可能的，压力太大了。」",null,null,null],["89_TEXT","89_TEXT",null,null,null],["「分かって頂けたら良いのです」","「您能理解就太好了。」",null,null,null],["90_TEXT","90_TEXT",null,null,null],["「歯も磨かせて頂けますね？」","「牙也能让我帮你刷吧？」",null,null,null],["91_TEXT","91_TEXT",null,null,null],["「磨かせる磨かせる！　俺の歯は好きにしてくれ！\\n　歯石を取ってくれてもいいから！！」","「你刷你刷！ 我的牙随你处置！\\n  甚至给我把牙结石也除掉也行！！」",null,null,null],["93_TEXT","93_TEXT",null,null,null],["「承知致しました」","「我明白了。」",null,null,null],["94_TEXT","94_TEXT",null,null,null],["「ふおおおお！　すごい！\\n　あのヤツシロがまるで操り人形のように！」","「呜噢噢噢噢！ 好厉害！\\n  那个8246简直就像个提线木偶一样！」",null,null,null],["95_TEXT","95_TEXT",null,null,null],["「どうやるのだ！？　我もやりたい我も！」","「要怎么做到！？　我也想玩我也要！」",null,null,null],["96_TEXT","96_TEXT",null,null,null],["「ではご飯の時の、あーーんは？」","「那吃饭时的，「啊——」呢？」",null,null,null],["97_TEXT","97_TEXT",null,null,null],["「それはさすがにめんどくさ……」","「那实在是有点太麻烦……」",null,null,null],["100_TEXT","100_TEXT",null,null,null],["「………………」","「………………」",null,null,null],["101_TEXT","101_TEXT",null,null,null],["「あああああ！　大丈夫です大丈夫です！\\n　ぜひこちらからよろしくお願いします！」","「啊啊啊啊啊！ 没问题没问题！\\n  务必让我来拜托您这么做！」",null,null,null],["103_TEXT","103_TEXT",null,null,null],["「分かって頂き、感謝至極です」","「您能理解，真是万分感谢。」",null,null,null],["104_TEXT","104_TEXT",null,null,null],["「では、これからもヤツシロ様のお世話、がんばりますね」","「那么今后我也会继续努力照顾8246大人的。」",null,null,null],["112_TEXT","112_TEXT",null,null,null],["「はあはあはあ、脳味噌が溶け果てるかと思った」","「哈啊哈啊哈啊，我都以为脑浆子要彻底化掉了。」",null,null,null],["113_TEXT","113_TEXT",null,null,null],["「はえーまだまだこの世界には、\\n　未知の部分があるんだなあ」","「哈啊～，在这个世界上，\\n  还有太多未知的领域等着我们去发现呢～。」",null,null,null],["114_TEXT","114_TEXT",null,null,null],["「申し訳ありません。\\n　少し暴走気味になってしまいました」","「非常抱歉。我刚才似乎有些失控了。」",null,null,null],["115_TEXT","115_TEXT",null,null,null],["「気味か。……気味なのか」","「有些？……只是‘有些’吗。」",null,null,null],["116_TEXT","116_TEXT",null,null,null],["「……でもそこまで追い詰めちゃって、\\n　俺もごめんな」","「……不过把你逼到那个份上，\\n  我也该说声抱歉。」",null,null,null],["117_TEXT","117_TEXT",null,null,null],["「いえ、そんな」","「不，哪有。」",null,null,null],["118_TEXT","118_TEXT",null,null,null],["「……私のほうこそ、その」","「……我才是，那啥。」",null,null,null],["120_TEXT","120_TEXT",null,null,null],["「ヤツシロ様のことを考えていると、\\n　お世話をしたすぎて、おかしくなってしまって」","「我一想到8246大人你，\\n　就忍不住想照顾你，连自己都变得怪怪的了。」",null,null,null],["121_TEXT","121_TEXT",null,null,null],["「そっちもちょっと手加減してね。\\n　俺も寄り添うようにはするから」","「你那边也稍微手下留情点啊。\\n　我也会努力去迁就你的。」",null,null,null],["122_TEXT","122_TEXT",null,null,null],["「はい！　ありがとうございます、ヤツシロ様！」","「是！谢谢你，8246大人！」",null,null,null],["123_TEXT","123_TEXT",null,null,null],["「これ！　……ええい、出よ！　これぇ！」","「哎！……嘿，出来！嘿！」",null,null,null]],"type":"","context":[["01_04_MEzz.uasset.csv/row/104","01_04_MEzz.uasset.csv/row/115","01_04_MEzz.uasset.csv/row/126","01_04_MEzz.uasset.csv/row/137","01_04_MEzz.uasset.csv/row/148","01_04_MEzz.uasset.csv/row/175","01_04_MEzz.uasset.csv/row/186","01_04_MEzz.uasset.csv/row/197","01_04_MEzz.uasset.csv/row/208","01_04_MEzz.uasset.csv/row/219","01_04_MEzz.uasset.csv/row/230","01_04_MEzz.uasset.csv/row/241","01_04_MEzz.uasset.csv/row/252","01_04_MEzz.uasset.csv/row/263","01_04_MEzz.uasset.csv/row/274","01_04_MEzz.uasset.csv/row/285","01_04_MEzz.uasset.csv/row/296","01_04_MEzz.uasset.csv/row/307","01_04_MEzz.uasset.csv/row/318","01_04_MEzz.uasset.csv/row/329","01_04_MEzz.uasset.csv/row/340","01_04_MEzz.uasset.csv/row/351","01_04_MEzz.uasset.csv/row/362","01_04_MEzz.uasset.csv/row/373","01_04_MEzz.uasset.csv/row/384","01_04_MEzz.uasset.csv/row/395","01_04_MEzz.uasset.csv/row/406","01_04_MEzz.uasset.csv/row/417","01_04_MEzz.uasset.csv/row/428","01_04_MEzz.uasset.csv/row/439","01_04_MEzz.uasset.csv/row/450","01_04_MEzz.uasset.csv/row/461","01_04_MEzz.uasset.csv/row/472","01_04_MEzz.uasset.csv/row/483","01_04_MEzz.uasset.csv