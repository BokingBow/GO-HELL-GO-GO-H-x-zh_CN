wInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/01_Main/01_01_Tomori.uasset.csv","tags":[],"progress":{"translated":177,"length":177,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/01_Main/01_02_Ichinose.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/01_Main","basename":"01_02_Ichinose.uasset.csv","extension":"csv","filename":"01_02_Ichinose.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/01_Main/01_02_Ichinose.uasset.csv","data":[["01_02_Ichinose","01_02_Ichinose",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「くっ……さっさと諦めろっての！　ていてい」","「啧……快点给我放弃啊！嘿咻嘿咻」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「うわセコ！　画面端でボムハメやめろ」","「哇靠好阴！别在屏幕边上卡我炸弹啊」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「はい、これで……トドメ！\\nはい弱かったー。もしかして負けるの好きなん？」","「好了，这就送你……上路！\\n哈，真弱啊。难不成你其实喜欢输啊？」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「次はマジの装備で殺す」","「下回我换上真装备杀爆你」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「負け犬が大口叩くの、恥ずかし」","「败家犬嘴还这么硬，真不害臊」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「くっそ……。あ、おいきりく。\\nおめ、全部食ったんか、ポテチ」","「可恶……。啊，喂切陆。\\n你这家伙，把薯片全吃光了？」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「もぐもぐ。……だって食べていいっていったじゃん」","「嚼嚼嚼。……可是你说了可以吃的啊」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「……ふぅー。この部屋さ、\\nせめて座椅子とか置かない？」","「……呼——。这个房间啊，\\n好歹放个榻榻米椅子之类的吧？」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「なんで」","「为什么？」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「いやこの体勢でゲームしてるとさ……、\\n　腰と首が……いたた」","「哎哟，一直用这个姿势打游戏啊……，\\n腰和脖子……疼疼疼」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「へえー。まあ少し分かる。\\n歳食ったよなあ、俺達」","「嘿——。嘛，我稍微能懂。\\n咱们都上年纪了啊」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「…………………………」","「…………………………」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「昔は何時間この体勢でも、\\n全然平気だったのに。寄る年波には勝てんなあ」","「以前用这姿势玩几小时，\\n都完全没事的。真是岁月不饶人啊」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「とってないが」","「我可没上年纪」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「なに」","「什么」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「や、ヤツシロはジジイかもしれんけど。\\n私は全然、取ってないから。歳」","「你、你8246或许是个糟老头子了。\\n但我完全、没上年纪。完全没」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「時の流れは皆に平等じゃよ」","「时间流逝对每个人都是公平的哟」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「ほらその証拠に、きりくは全然平気」","「喏，证据就是，切陆就完全没事」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「ん？　まあね。腰とかいためたことないけど」","「嗯？算是吧。我还没腰疼过呢」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「…………歳じゃないから」","「…………那是因为还没上年纪」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「この前、目が霞むとか言ってなかった？」","「你前阵子不是说过眼睛发花了吗？」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「ねえわ！　舐めるな！\\n私まだ、全然JKって言っても通じるし」","「我才没有！少瞧不起人！\\n我这长相，现在说是正经女高也完全没问题」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「なんならJCでもいけるくらい」","「甚至说是初中生都行」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「はっ、大口叩きよる（笑）」","「哈，吹牛皮不打草稿（笑）」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「み、見てろよ。\\nちょちょいと証明してやるから」","「你、你给我瞧着。\\n看我随随便便就证明给你看」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「無理しなくていいから。\\nほら、買いに行こう、老眼鏡」","「不用勉强自己啦。\\n来，我们去买吧，老花镜」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「み……見てろぉ～～～～！！」","「看……看着吧哦哦哦哦～～～～！！」",null,null,null],["53_TEXT","53_TEXT",null,null,null],["「どぉーーーだーーーーー！？！？」","「怎——么——样——！？！？」",null,null,null],["54_TEXT","54_TEXT",null,null,null],["「…………」","「…………」",null,null,null],["55_TEXT","55_TEXT",null,null,null],["「どぉーだー！？　ヤツシロ！\\nぜ、全然大丈夫でしょぉー言ったじゃん」","「怎么样！？8246！\\n完、完全没事吧～不是说了吗」",null,null,null],["56_TEXT","56_TEXT",null,null,null],["「大丈夫、とは……？\\n俺には致死寸前にしか見えないが」","「没事，是指……？\\n在我看来就像快要死了一样啊」",null,null,null],["57_TEXT","57_TEXT",null,null,null],["「誰が死にかけのセミだ」","「谁是垂死的蝉啊」",null,null,null],["58_TEXT","58_TEXT",null,null,null],["「んで、何できりくも着替えてんの」","「话说，怎么切陆你也换了衣服」",null,null,null],["59_TEXT","59_TEXT",null,null,null],["「他に着る服なかった」","「没别的衣服穿」",null,null,null],["60_TEXT","60_TEXT",null,null,null],["「それはそうか。どう、感想としては」","「这倒也是。怎么样，感觉如何」",null,null,null],["61_TEXT","61_TEXT",null,null,null],["「なんか。……すかすかしてる」","「感觉。……空荡荡的」",null,null,null],["62_TEXT","62_TEXT",null,null,null],["「今はこっちに集中しろ？」","「现在给我把注意力放这边来？」",null,null,null],["63_TEXT","63_TEXT",null,null,null],["「すいません。見るに耐えなくて」","「抱歉。实在看不下去了」",null,null,null],["66_TEXT","66_TEXT",null,null,null],["「すかすか……」","「空荡荡的……」",null,null,null],["67_TEXT","67_TEXT",null,null,null],["「いやいや全然いけてるでしょ。\\n自分でも驚いたもん現役すぎて」","「哎呀哎呀，完全没问题的吧。\\n我自己都吓了一跳，太有现役感了」",null,null,null],["68_TEXT","68_TEXT",null,null,null],["「ふふ、どうする？　この格好で夜歩いたら。\\n普通に補導とかされちゃうんじゃない」","「呵呵，怎么办？穿成这样晚上出去逛的话。\\n普通会被带去辅导吧」",null,null,null],["69_TEXT","69_TEXT",null,null,null],["「特殊なプレイか痛いコスプレイヤーと\\n思われるかどっちか」","「要么被当成特殊玩法，\\n要么被当成雷人的coser吧」",null,null,null],["70_TEXT","70_TEXT",null,null,null],["「またまた照れちゃって。\\n可愛い幼馴染に素直になれないアレ？」","「又在害羞了。\\n是那种对可爱的青梅竹马坦率不起来的那个吧？」",null,null,null],["73_TEXT","73_TEXT",null,null,null],["「ほらどう？　こんな感じで、\\nツインテにしても可愛くない？」","「你看怎么样？像这样，\\n扎个双马尾也很可爱吧？」",null,null,null],["74_TEXT","74_TEXT",null,null,null],["「あーーーー…………」","「啊ーーーー…………」",null,null,null],["75_TEXT","75_TEXT",null,null,null],["「どうしよう」","「怎么办」",null,null,null],["76_TEXT","76_TEXT",null,null,null],["「悩むな」","「好纠结啊」",null,null,null],["77_TEXT","77_TEXT",null,null,null],["78_TEXT","78_TEXT",null,null,null],["「本気で声のかけ方悩んでない！？\\nいや、絶対照れてるだけだよ」","「你是不是真的在纠结该怎么开口！？\\n不，绝对是害羞而已啦」",null,null,null],["81_TEXT","81_TEXT",null,null,null],["「ほらほら、絶対可愛いでしょ？　ね。\\nなんかこうしてたら、アイドルみたいじゃない？」","「你看你看，绝对很可爱吧？是吧。\\n这样看着，是不是有点像偶像？」",null,null,null],["82_TEXT","82_TEXT",null,null,null],["「……俺は常日頃正直で居たいと思っている」","「……我一直以来都想诚实做人」",null,null,null],["83_TEXT","83_TEXT",null,null,null],["「他人よりもむしろ自分に対して」","「比起对别人，更想对自己诚实」",null,null,null],["84_TEXT","84_TEXT",null,null,null],["「嫌な前フリやめろよ」","「别来这种讨厌的铺垫啊」",null,null,null],["85_TEXT","85_TEXT",null,null,null],["「だけど今日はあえて、\\nその信念を曲げようと思う」","「不过今天，我要斗胆，\\n违背这个信念」",null,null,null],["86_TEXT","86_TEXT",null,null,null],["「……可愛いよ、一ノ瀬！　似合ってる！」","「……很可爱哦，一之濑！很合适！」",null,null,null],["87_TEXT","87_TEXT",null,null,null],["「えへへ。でしょー？」","「嘿嘿。对吧ー？」",null,null,null],["88_TEXT","88_TEXT",null,null,null],["91_TEXT","91_TEXT",null,null,null],["「おいそれ！　全然褒めてねえだろ！」","「喂你！根本就没夸奖吧！」",null,null,null],["92_TEXT","92_TEXT",null,null,null],["「信念を曲げるな！　正直に言え正直に！」","「别违背信念！老实说！老实说！」",null,null,null],["93_TEXT","93_TEXT",null,null,null],["「落ち目のグラビアアイドルの\\n決死のIV撮影を見てる居た堪れない気分」","「像是在看过气写真偶像\\n拼死拍IV的那种坐立不安的心情」",null,null,null],["94_TEXT","94_TEXT",null,null,null],["「グーでいこうか！？」","「要用拳头招呼你吗！？」",null,null,null],["95_TEXT","95_TEXT",null,null,null],["「正直に言えって言ったのに……」","「明明是你让我老实说的……」",null,null,null],["96_TEXT","96_TEXT",null,null,null],["「そんな事全然ないから！\\n似合いすぎてちょっと怖いぐらいだから！」","「根本没那回事好吧！\\n合适得都让人觉得有点可怕了！」",null,null,null],["97_TEXT","97_TEXT",null,null,null],["「ね、そうだよねえきりく！\\n私これ、似合ってるよね！？","「是吧，你说对吧切陆！\\n我穿这件，很合适吧！？」",null,null,null],["99_TEXT","99_TEXT",null,null,null],["「……さあ。わかんないけど、\\nもっと脂肪はおとしたほうがいいんじゃない」","「……谁知道。我不清楚，\\n不过再把脂肪减减可能更好吧」",null,null,null],["102_TEXT","102_TEXT",null,null,null],["「てかおい！　ヤツシロ！　あんたずっと、\\n半笑いなのなに！！」","「话说喂！8246！你从刚才就，\\n一直在那儿似笑非笑是什么情况！！」",null,null,null],["103_TEXT","103_TEXT",null,null,null],["「笑う以外にどうしろと」","「除了笑你还要我怎么样」",null,null,null],["104_TEXT","104_TEXT",null,null,null],["「俺も泣きたい気分だけど、\\n泣いたって誰も救われないだろ！」","「我也很想哭啊，\\n但就算哭了也没人能得救吧！」",null,null,null],["105_TEXT","105_TEXT",null,null,null],["「泣きたいのもおかしいだろ！\\n泣きたいのはこっちだよ！」","「想哭才奇怪吧！\\n想哭的是我这边啊！」",null,null,null],["106_TEXT","106_TEXT",null,null,null],["「いい歳して尺の足りない制服着て、\\n痛めの手ツインテまでやってるんだよ！」","「都一把年纪了还穿尺寸不够的制服，\\n还扎着土到爆的双马尾！」",null,null,null],["107_TEXT","107_TEXT",null,null,null],["「せめて可愛いぐらい言ってもらわないと、\\nもうこっちだって引けないんだよ！」","「至少也得说我可爱才对，\\n否则我这口气可咽不下去！」",null,null,null],["108_TEXT","108_TEXT",null,null,null],["「言え！　可愛いって！」","「快说！我很可爱！」",null,null,null],["109_TEXT","109_TEXT",null,null,null],["「…………可愛い……ぞ！」","「……可爱……啦！」",null,null,null],["110_TEXT","110_TEXT",null,null,null],["「ど、同情するなーーーー！！」","「别、别同情我啊——！！」",null,null,null],["111_TEXT","111_TEXT",null,null,null],["「どうしろって言うんだよ！」","「那你到底要我怎么办！」",null,null,null]],"type":"","