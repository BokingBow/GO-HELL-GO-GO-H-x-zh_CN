4_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/05_Kamase/unique1001.uasset.csv","tags":[],"progress":{"translated":75,"length":75,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/05_Kamase/unique1011.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/05_Kamase","basename":"unique1011.uasset.csv","extension":"csv","filename":"unique1011.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/05_Kamase/unique1011.uasset.csv","data":[["unique1011","unique1011",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「そんじゃ、こいつのこと頼みます」","「那么，这家伙就拜托了」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「はい。預かりました」","「好的。我收下了」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「うおおおおおおおお！！\\n　今日はよろしくお願いします！　めらめら」","「呜哦哦哦哦哦哦哦！！\\n　今天请多关照！　熊熊燃烧」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「……えらく元気のいい亡者だな」","「……真是个精神头好得不得了的亡者啊」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「えーっと今日の責め苦は。\\n　Oh……突き地獄か」","「呃，今天的折磨是……。\\n　Oh……是刺穿地狱啊」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「突き地獄？　それってなんだ？」","「刺穿地狱？那是什么？」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「屈強なたくさんの鬼たちに責め立てられる、\\n　地獄でも屈指のキツさを誇る地獄です」","「就是被众多彪悍的恶鬼们围追猛攻，\\n　以严酷程度在地狱里数一数二而闻名的地方」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「……？　よくわかんないけど屈指って言葉は燃える。\\n　やってやろうぜ！　って気になるぜ！」","「……？虽然不太明白，但‘数一数二’这个词让我燃起来了。\\n 放马过来吧！就是这种感觉！」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「ははは。その元気が、\\n　最後まで残っていたらいいですがね」","「哈哈哈。但愿您这股干劲，\\n　能一直保持到最后吧」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「そ、そんなにきついの。ちょっと怖くなってきた」","「有、有那么严酷吗。我开始有点害怕了」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「それじゃあ、いこっか」","「那我们走吧」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「よ、よろしくお願いします！\\n　うおおおお、カマセ、入ります！！」","「请、请多关照！\\n　呜哦哦哦，要去，进去了！！」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「な、なんだこいつら！？」","「这、这些家伙是怎么回事！？」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「……ほう。えらくかわいい姉ちゃんが\\n　来ちまったじゃねえの」","「……嚯。这还真是来了个\\n　相当可爱的小妞啊」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「ヒェッヒェッヒェッ！　可哀想に！\\n　今日で笑ってられるのも最後だねえ！」","「嘻嘻嘻！真可怜啊！\\n　今天就是你最后一天能笑出来的日子啦！」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「くっ……」","「呃……」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「さあ、聞かせてみな！\\n　少女の悲鳴の夜想曲を！」","「来吧，让我听听！\\n　少女悲鸣的夜想曲吧！」",null,null,null],["48_TEXT","48_TEXT",null,null,null],["「はぁー大変だったー。\\n　いやあ皆さんお疲れー」","「哈啊——累坏了——。\\n　哎呀，大家辛苦了——」",null,null,null],["49_TEXT","49_TEXT",null,null,null],["「きゅう……」","「啾……」",null,null,null],["50_TEXT","50_TEXT",null,null,null],["「全員ぶっ倒れちゃったし、\\n　アタシの勝ちってことでいいんかな？」","「所有人都被打趴下了，\\n　是不是就算我赢了呀？」",null,null,null],["51_TEXT","51_TEXT",null,null,null],["「こ、これは……」","「这、这是……」",null,null,null],["52_TEXT","52_TEXT",null,null,null],["「あ、入口のおじさん。\\n　おつかれーっす」","「啊，门口的大叔。\\n　辛苦啦——」",null,null,null],["54_TEXT","54_TEXT",null,null,null],["「いやあ。久々に運動したんで、\\n　流石に汗かいちゃって。暑いなあ」","「哎呀。好久没这么运动了，\\n　到底是出了一身汗。真热啊。」",null,null,null],["55_TEXT","55_TEXT",null,null,null],["「こ、これ全部、あなたが……？」","「这、这些全都是，你一个人……？」",null,null,null],["57_TEXT","57_TEXT",null,null,null],["「え？　はい。流石にこの数を相手にするのは、\\n　かなり堪えはしたんだけど」","「嗯？是啊。不过毕竟要对付这么多人，\\n　确实是相当够呛的呢。」",null,null,null],["58_TEXT","58_TEXT",null,null,null],["「皆さん、思ったより体力ないね笑。\\n　案外すぐにノビちゃって」","「大家，体力比想象中差啊笑。\\n　没想到这么快就全歇菜了。」",null,null,null],["59_TEXT","59_TEXT",null,null,null],["「あ、いえいえ。全然手強かったんだけどさ！\\n　もうダメかって思ったときも何度もあったし」","「啊，不不不。其实还是很难缠的啦！\\n　有好多次我都觉得要完蛋了呢。」",null,null,null],["60_TEXT","60_TEXT",null,null,null],["「いい熱血バトルができたぜ！\\n　対戦ありがとうございます」","「真是一场精彩的热血战斗啊！\\n　多谢指教！」",null,null,null],["61_TEXT","61_TEXT",null,null,null],["「ひ……ひえ～……」","「咿……咿呀——……」",null,null,null],["63_TEXT","63_TEXT",null,null,null],["「はぁ～……あっつぅ……。\\n　ここ、冷房とか効かないんすか？」","「哈啊——……热死了……。\\n　这儿，不开冷气吗？」",null,null,null],["64_TEXT","64_TEXT",null,null,null],["「……すいません。\\n　これでも結構、ガンガンなんですけど」","「……抱歉。\\n　其实这已经开得挺足的了。」",null,null,null],["65_TEXT","65_TEXT",null,null,null],["「あぁー。そっか。運動したからなあ。\\n　はー疲れた。スポドリとか貰える？」","「啊啊——。也是。毕竟刚运动完嘛。\\n　哈——累死了。能来瓶运动饮料不？」",null,null,null],["66_TEXT","66_TEXT",null,null,null],["「……すいません。\\n　実は時間的には未だ責め苦の最中で」","「……对不起。\\n　其实按时间来说，现在应该还身处煎熬之中。」",null,null,null],["67_TEXT","67_TEXT",null,null,null],["「えっ」","「诶」",null,null,null],["68_TEXT","68_TEXT",null,null,null],["「……時間、まだ半分以上残ってるのに、\\n　職員全員潰されるなんて想定外でして」","「……明明时间还剩一半以上，\\n　没想到全体员工都被打倒了，这属实是意料之外。」",null,null,null],["69_TEXT","69_TEXT",null,null,null],["「そうなんだ？　あーっ。すいませんっ。\\n　アタシ、またやりすぎちゃったかな」","「是这样啊？啊——。对不起啦。\\n　我是不是又做过头了呀。」",null,null,null],["70_TEXT","70_TEXT",null,null,null],["「こういうこと、よくあるんだよなあ。\\n　アタシ……元気だけが取り柄だから」","「这种事，常有的啦。\\n　我呢……也就浑身使不完的劲儿算是个优点了。」",null,null,null],["71_TEXT","71_TEXT",null,null,null],["「だったらぁ……」","「那样的话呀……」",null,null,null],["73_TEXT","73_TEXT",null,null,null],["「――おじさんが相手、してくれますか？」","「――大叔你来陪我，玩玩好吗？」",null,null,null],["74_TEXT","74_TEXT",null,null,null],["「ひ、ひぃっ」","「咿、咿——！」",null,null,null],["75_TEXT","75_TEXT",null,null,null],["「おじさん１人でもぉ……。\\n　３分は遊んでくれるよな……？」","「就算只有大叔一个人……。\\n　陪我玩个3分钟，总可以吧……？」",null,null,null],["76_TEXT","76_TEXT",null,null,null],["「勘弁してくれぇ！\\n　お、俺には家族がいるんだあ！」","「饶了我吧！\\n　我、我可是有家室的人啊！」",null,null,null],["77_TEXT","77_TEXT",null,null,null],["「なあんだ。つまんない」","「什么嘛。真没劲。」",null,null,null],["78_TEXT","78_TEXT",null,null,null],["「じゃあもう、バトルはおわりか？」","「那，战斗这就结束啦？」",null,null,null],["79_TEXT","79_TEXT",null,null,null],["「……仕方がないですね。終了にしましょう」","「……没办法呢。就这么结束吧。」",null,null,null],["80_TEXT","80_TEXT",null,null,null],["「最後に、記念写真だけ良いですか」","「最后，能拍张纪念照吗？」",null,null,null],["81_TEXT","81_TEXT",null,null,null],["「あ、お願いしまーす」","「啊，麻烦啦——」",null,null,null],["86_TEXT","86_TEXT",null,null,null],["「カマセ、大学２年でーす。\\n　完全勝利のピーーす♪」","「我是要去，大学二年级～。\\n　完胜的Peace——♪」",null,null,null],["87_TEXT","87_TEXT",null,null,null],["「地獄の鬼さんよわよわだったのでぇ、\\n　ちょっと期待外れだったかも？」","「地狱的鬼先生们太弱——啦，\\n　感觉有点期望落空了哦？」",null,null,null],["88_TEXT","88_TEXT",null,null,null],["「次はぁ……もっと強い人との、\\n　対戦、期待していまーす」","「接下来呢……期待着能和，\\n　更强的人，切磋一下——」",null,null,null],["90_TEXT","90_TEXT",null,null,null],["「いえいいえーーい♪」","「耶——耶——♪」",null,null,nu