2AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0771.uasset.csv","tags":[],"progress":{"translated":81,"length":81,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0851.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya","basename":"unique0851.uasset.csv","extension":"csv","filename":"unique0851.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0851.uasset.csv","data":[["unique0851","unique0851",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「はあ……はあ……どなたかいませんかー？」","「呼啊……呼啊……有没有哪位好心人在呀ー？」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「ン？　なんだ。\\n　……ああ、チンドン屋か。間に合ってまーす」","「嗯？什么啊。\\n　　……啊啊，搞推销的吧。我们家不搞了ー」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「ちがわい！　何でみんなそういうの！？」","「才不是呢！为什么大家都这么说！？」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「あのーぅ……私、観光客だったのですがー……。\\n　激しい流れでえらい事になってまして」","「那个ー……我，本来是个观光客来着ー……。\\n  被湍急的水流给冲得不成样子了」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「へえ、地獄に観光。物好きなやつも居るもんだねえ」","「嘿，来地狱观光。还真有这种怪人啊」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「ええ、まあ。……でも変な事に巻き込まれて、\\n　調査とか言ってられない状況で……」","「嗯，算是吧。……不过卷进了麻烦事，\\n  现在可不是说什么调查的时候啊……」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「調査？」","「调查？」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「いえすいませんこっちの話です」","「不，对不起，当我没说」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「こっちの話ついでに聞きますが、\\n　チャミアホロムって名前に聞き覚えは？」","「顺便当我没问哈，\\n  你听过查米亚霍洛姆这名字吗？」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「聞いたこと無いゲームだな。機種なに？」","「没听过这游戏啊。哪个平台的？」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「いえ、なんでもありませんし、\\n　ゲネシスでもありません」","「不，没什么事，\\n  也不是MD平台的」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「……まあ考えれば責め苦？　というものからも\\n　開放されたようですし……」","「……嗯，换个角度想，那些折磨？也算是\\n　　告一段落了吧……」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「やっと調査に集中出来るとも言えますね……」","「也可以说是总算能集中精力调查了……」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「あーん？　よくわかんねえけど。\\n　……茶でも出そうか」","「啊ー嗯？虽然听不太懂。\\n　　……我给你倒杯茶吧」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「あ、お構いなくお構いなく（ソファに座る）」","「啊，别张罗，别张罗（坐上沙发）」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「ずず……あ、この粗茶美味しいですね」","「嘶嘶……啊，这杯粗茶真好喝啊」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「あんま言わないからな、貰った側が、\\n　粗茶とかって」","「一般可不会由喝茶的人，\\n  自己说这是粗茶什么的啊」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「で、アンタは？　社長の友達？」","「那么，您是？社长的朋友？」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「友達というかなんというか、\\n　一方的に虐げられたというか」","「说是朋友倒也谈不上，\\n  应该说是我单方面被他虐待吧」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「少なくともいつかは、\\n　復讐しようとは決めてます！」","「至少，迟早总有一天，\\n  我一定要找他报仇！」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「従業員的にはギリ聞き逃がせねえ話だな！？」","「作为员工，这话我可没法当没听见啊！？」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「え、そうですか！？\\n　聞き逃して下さい！」","「诶，是吗！？\\n  拜托您就当没听见吧！」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「なんて軽率なやつ」","「真是个口无遮拦的家伙」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「こんなのが地獄に観光なんか来て、\\n　大丈夫なんか……？」","「就你这德性还跑来地狱观光，\\n  真的没问题吗……？」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「一体、どんなん見に来たの」","「你到底来看什么呀」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「……いっぱいのワニとか？」","「……很多鳄鱼之类的？」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「そんなんいたっけ」","「有那玩意儿吗」",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「あ、あとカボスとかが美味しいですよね」","「啊，还有卡波斯很好吃呢」",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「そうだったっけ」","「是吗」",null,null,null],["47_TEXT","47_TEXT",null,null,null],["「ま、まぁー良いじゃないですかー\\n　あはは」","「嘛，嘛~有什么不好的嘛~\\n　啊哈哈」",null,null,null],["48_TEXT","48_TEXT",null,null,null],["「そこはかとなく怪しいやつ」","「总觉得你这家伙有点可疑啊」",null,null,null],["49_TEXT","49_TEXT",null,null,null],["「…………ヘルメットとても格好良くて、\\n　すっごくお似合いですね？」","「…………头盔非常帅气，\\n　跟你特别配呢？」",null,null,null],["50_TEXT","50_TEXT",null,null,null],["「だが、センスはいいやつ！」","「不过，品味不错！」",null,null,null],["51_TEXT","51_TEXT",null,null,null],["「お煎餅食べるか？　シケってるかもだけど、\\n　確かここに残ってたような……あれ、ない」","「吃煎饼吗？　可能有点受潮了，\\n　记得应该还有剩的……咦，没了」",null,null,null],["52_TEXT","52_TEXT",null,null,null],["「あ、いえ。全然お構いなく」","「啊，不用。您别费心了」",null,null,null],["53_TEXT","53_TEXT",null,null,null],["「それにしても大変だったって？\\n　一体、何があったの」","「话说回来听说你倒了大霉？\\n　到底发生什么事了」",null,null,null],["54_TEXT","54_TEXT",null,null,null],["「それがですねえ。私ただの観光人なのに、\\n　急に亡者とか良くわからないこと言って捕まえられて」","「这个嘛。我只是个普通游客，\\n　却突然被说什么亡者之类莫名其妙的话给抓了起来」",null,null,null],["55_TEXT","55_TEXT",null,null,null],["「えっ」","「诶」",null,null,null],["56_TEXT","56_TEXT",null,null,null],["「へっ」","「哎？」",null,null,null],["57_TEXT","57_TEXT",null,null,null],["「亡者だったの？」","「你是亡者吗？」",null,null,null],["58_TEXT","58_TEXT",null,null,null],["「い、いや。違うんですよー……。\\n　もう違うって分かったって言うかー？」","「不、不是啦。不是那样的啦……。\\n　应该说现在已经搞清楚我不是了啦—？」",null,null,null],["59_TEXT","59_TEXT",null,null,null],["「もしかして、逃げ出したとか？」","「你该不会是，逃出来的吧？」",null,null,null],["60_TEXT","60_TEXT",null,null,null],["「ぎくぅっ！！」","「咯噔！！」",null,null,null],["61_TEXT","61_TEXT",null,null,null],["「…………」","「…………」",null,null,null],["62_TEXT","62_TEXT",null,null,null],["63_TEXT","63_TEXT",null,null,null],["「ちちち、違いますよぉ。\\n　大使館と連絡が取れてぇ、話がついて」","「不不不，不是啦。\\n　是因为联系上了大使馆，把事情谈妥了」",null,null,null],["64_TEXT","64_TEXT",null,null,null],["「無罪放免。謝罪まで頂いて、\\n　晴れて自由の身になったわけです」","「无罪释放。还收到了道歉，\\n　总算重获自由身了嘛」",null,null,null],["65_TEXT","65_TEXT",null,null,null],["「……ふぅーん。ま、そういうこともあるか」","「……唔—嗯。嘛，倒也有这种事吧」",null,null,null],["66_TEXT","66_TEXT",null,null,null],["（てかまずい？　私ここに居たら）","「（话说现在不妙吧？　我待在这儿的话）」",null,null,null],["67_TEXT","67_TEXT",null,null,null],["（ドサクサに紛れて逃げた事が\\n　バレたら、また捕まっちゃう！？）","「（要是被人发现我是\\n　趁乱逃出来的，又会被抓的！）」",null,null,null],["68_TEXT","68_TEXT",null,null,null],["「あ、そうだそうだ。煎餅は無くても、\\n　冷蔵庫にまんじゅうがあったような」","「啊，对了对了。就算没有煎饼，\\n　我记得冰箱里好像有包子来着」",null,null,null],["69_TEXT","69_TEXT",null,null,null],["「すいません！　私、そろそろ行かなければ！」","「抱歉！　我差不多该走了！」",null,null,null],["70_TEXT","70_TEXT",null,null,null],["「え、そう？\\n　社長になんか用事でもあるのかと」","「诶，这就要走啊？\\n　我还以为你找社长有什么事呢」",null,null,null],["71_TEXT","71_TEXT",null,null,null],["「ちょ、ちょっと事情が変わりまして！」","「事、事情稍微有点变化！」",null,null,null],["72_TEXT","72_TEXT",null,null,null],["「え。この短い時間で？」","「诶。就这么一会儿工夫？」",null,null,null],["73_TEXT","73_TEXT",null,null,null],["「それでは！　これにて失礼致しますー！」","「那么！　就此告辞了—！」",null,null,null],["77_TEXT","77_TEXT",null,null,null],["「……なんだったんだ」","「……搞什么啊」",null,null,null],["78_TEXT","78_TEXT",null,null,null],["「しかしあいつ、公使と同じような\\n　カッコしてたなあ」","「不过那家伙，穿着跟公使\\n　差不多的衣服啊」",null,null,null],["79_TEXT","79_TEXT",null,null,null],["「もしかして、どこぞの界隈では、\\n　流行ってんのかな……？」","「难不成，在哪儿的小圈子里，\\n　正流行那种打扮吗……？」",null,null,null]],"type":"","context":