6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0461.uasset.csv","tags":[],"progress":{"translated":47,"length":47,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0471.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya","basename":"unique0471.uasset.csv","extension":"csv","filename":"unique0471.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0471.uasset.csv","data":[["unique0471","unique0471",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「むう。川辺に来てみたはいいものの」","「唔。虽说来到了河边，可这……」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「……大分、深いな」","「……相当深啊」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「対岸まで200mちょいぐらいか。\\n　……プールだったら泳げない事はない距離」","「到对岸大概有200来米吧。\\n　……这距离要是在游泳池，倒也不是游不过去」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「……中学生の頃は泳げた！」","「……我上初中的时候是会游泳的！」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「あれから、ひぃふぅみぃ……。\\n　……どれだけ経ったか考えるのはやめよ」","「打那以后，一、二、三……\\n　……过了多久还是不数了吧」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「運動不足と筋肉の衰えで大分キツイが、\\n　必死バフでギリいけるはず」","「缺乏运动加上肌肉衰退，会很吃力，\\n　但靠拼命的增益效果，应该勉强能行」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「ふふふ、文系らしい大雑把な計算。\\n　我ながら、嫌いじゃあないぜ」","「嘿嘿，真是文科生风格的粗略计算。\\n　我自己倒也不讨厌」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「理論的に生きるなんてごめんこうむる。\\n　詩的に死んでいかんとさあ！」","「按理论活着这种事，我敬谢不敏。\\n　必须得诗意地去死才行啊！」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「……私の地政学的人類社会学的、\\n　都市計画デザイン的考えによれば」","「……根据本人的地缘政治学、人类社会学的、\\n　以及都市规划设计学的观点来看」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「恐らく、この川を越えれば、\\n　地獄を脱出する事が出来る筈」","「恐怕，只要越过这条河，\\n　应该就能逃离地狱了」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「例によって確信たり得る証拠は無いが……。\\n　……非常に勘と経験則によるものだが……」","「虽然照例没有能确信的证据……\\n　……这非常依赖直觉和经验法则……」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「……そんな曖昧な可能性に、\\n　今から命かけるの？　わたし」","「……为了这么个模糊的可能性，\\n　现在就要赌上性命吗？　我啊」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「ええい！　どうせこのまま地獄なんぞに居たら、\\n　狂ってしまって死ぬだけよ！」","「哎呀！　反正继续待在这种地狱里，\\n　也只会发疯然后死掉！」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「行け！　行くのだ私！\\n　トビウオの如く川を駆け抜けよ！」","「走！　给我上啊，我！\\n　像飞鱼一样驰骋过河去吧！」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「……………………」","「……………………」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「ひぃ～～っ。この川流れ早くて怖っ。\\n　今の時期、絶対に冷たいし！」","「咿～～。这河水流得好快，好吓人。\\n　现在这个季节，肯定也冷得要命！」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「……ええい、ままよっ！」","「……算了，管不了那么多了！」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「ぎゃあ！　ちべたいっ！\\n　ってか深っ流れ早っ」","「呀啊！好凉！\\n　话说又深水流又急啊！」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「うおおおお！　見よ私の全力バタフライ！\\n　……ぜ、ぜんぜん進まん！」","「唔哦哦哦哦！看我的全力蝶泳！\\n　……完、完全没前进！」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「てか何で私、服を来たまま泳いじゃってるの！？\\n　ふふ、ドジっ子な自分が少し愛おしい」","「话说我为什么穿着衣服就在游啊！？\\n　嘿嘿，有点喜欢这个冒冒失失的自己呢」",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「って、ぎゃーーー！！\\n　人類の川流れーーーー！！」","「不对，呀啊啊啊啊！！\\n　人类的漂流而下啊啊啊啊！！」",null,null,null],["58_TEXT","58_TEXT",null,null,null],["「……という事があったのだよ。\\n　がくがくぶるぶる」","「……发生过这样一件事。\\n　浑身哆嗦瑟瑟发抖」",null,null,null],["59_TEXT","59_TEXT",null,null,null],["「へえ。そりゃあ大変だったねえ。\\n　俺が通りがかってなかったら」","「嚯。那可真是够呛啊。\\n　要是没我正好路过的话」",null,null,null],["60_TEXT","60_TEXT",null,null,null],["「ふふ海の藻屑ならぬ川の藻屑だ。\\n　淡水魚たちのいいおやつになるとこだった」","「嘿嘿，不是海里的海草碎片，是河里的河草碎片呢。\\n　差点就成了淡水鱼们的好点心」",null,null,null],["61_TEXT","61_TEXT",null,null,null],["「へくち」","「阿嚏」",null,null,null],["62_TEXT","62_TEXT",null,null,null],["「ほらお湯湧いたから、\\n　これ飲んで温まりな」","「来，热水烧好了，\\n　把这个喝了暖暖身子吧」",null,null,null],["63_TEXT","63_TEXT",null,null,null],["「ありがとぉ……ずびび……」","「谢谢……吸溜……」",null,null,null],["64_TEXT","64_TEXT",null,null,null],["「しかしあんた、なんかやるにしても、\\n　もっと計画ってもんをさあ」","「不过你啊，不管做什么事，\\n　好歹也得有点计划性吧」",null,null,null],["65_TEXT","65_TEXT",null,null,null],["「それは本当にそう」","「这倒确实没错」",null,null,null],["66_TEXT","66_TEXT",null,null,null],["「プランニングなんぞ理系の遊びと\\n　馬鹿にしていたが……」","「之前还笑话规划什么的是理科生的游戏，\\n　看不起它……」",null,null,null],["67_TEXT","67_TEXT",null,null,null],["「私も少しは、数字の勉強をしようかなあ」","「我是不是也该，稍微学学数学呢」",null,null,null],["68_TEXT","68_TEXT",null,null,null],["「何でそうなるのかは結構、謎」","「为什么会想到那一步，还真挺迷」",null,null,null],["69_TEXT","69_TEXT",null,null,null],["「ねー。わかる。私も我ながら不思議な感情。\\n　ふふ、これも1つのもののあわれだね」","「是吧。我懂。我自己也觉得这感情很不可思议。\\n　嘿嘿，这也是某种物哀呢」",null,null,null],["70_TEXT","70_TEXT",null,null,null],["「……はあ。早くお家帰りたいなあ」","「……唉。好想早点回家啊」",null,null,null]],"type":"","context":[["unique0471.uasset.csv/row/112","unique0471.uasset.csv/row/123","unique0471.uasset.csv/row/134","unique0471.uasset.csv/row/145","unique0471.uasset.csv/row/156","unique0471.uasset.csv/row/167","unique0471.uasset.csv/row/178","unique0471.uasset.csv/row/189","unique0471.uasset.csv/row/200","unique0471.uasset.csv/row/211","unique0471.uasset.csv/row/222","unique0471.uasset.csv/row/233","unique0471.uasset.csv/row/244","unique0471.uasset.csv/row/255","unique0471.uasset.csv/row/266","unique0471.uasset.csv/row/277","unique0471.uasset.csv/row/288","unique0471.uasset.csv/row/379","unique0471.uasset.csv/row/398","unique0471.uasset.csv/row/409","unique0471.uasset.csv/row/428","unique0471.uasset.csv/row/527","unique0471.uasset.csv/row/538","unique0471.uasset.csv/row/549","unique0471.uasset.csv/row/560","unique0471.uasset.csv/row/571","unique0471.uasset.csv/row/582","unique0471.uasset.csv/row/593","unique0471.uasset.csv/row/604","unique0471.uasset.csv/row/615","unique0471.uasset.csv/row/626","unique0471.uasset.csv/row/637","unique0471.uasset.csv/row/648","unique0471.uasset.csv/row/659"],["unique0471.uasset.csv/row/113"],["unique0471.uasset.csv/row