"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0851.uasset.csv","tags":[],"progress":{"translated":118,"length":118,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0861.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya","basename":"unique0861.uasset.csv","extension":"csv","filename":"unique0861.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0861.uasset.csv","data":[["unique0861","unique0861",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「さて、開放もされたことだし、\\n　今日もしっかり地獄の調査！」","「好了，既然被释放了，\\n　今天也要好好调查地狱！」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「自らの責務を果たすため、\\n　しっかり頑張らないとね」","「为了完成自己的职责，\\n　得好好加油才行呢」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「それじゃあまずはあ……。\\n　……あの石焼き芋ってなにかしら」","「那首先呢……。\\n　……那个石烤地瓜是什么呀」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「お、おいし～～！　外はパリッと中はねっとり。\\n　お芋だけなのにこの甘さはなに！？」","「好、好好吃～～！　外皮酥脆里面软糯。\\n　明明只是地瓜怎么会这么甜啊！？」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「問題は『石焼き』って何なのかって事。\\n　『タコ焼き』は中にタコが入ってるからなのに」","「问题在于这个『石烤』是什么。\\n　明明『章鱼烧』是因为里面有章鱼才对」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「お芋の中に石は入ってないし……。\\n　ぐぬぬ……なんて未知だらけの世界！」","「地瓜里面并没有石头啊……。\\n　唔唔唔……真是个充满了未知的世界！」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「はっ。もしかしてあそこに居るのはシバイヌ！？\\n　ネットで見たことある！」","「哈。难道那边的是柴犬！？\\n　我在网上看到过！」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「きゃーーかわいいーーー！！」","「呀——好可爱呀——！！！」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「……なんか、すげー楽しそうな人がいるな」","「……总觉得，有个超级开心的人在这儿呢。」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「ぎゃ！　あなたはいつぞやの地獄の悪魔！」","「呀！你是上次那个地狱的恶魔！」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「強いて言うなら鬼な。\\n　んで、何してんの」","「硬要说的话，是鬼吧。\\n　然后呢，你在干嘛？」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「見てわかりませんか？　調査です！」","「看不出来吗？我在调查！」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「……かき氷食って、お土産沢山持って、\\n　楽しそうに目ェキラキラ輝かせて……？」","「……吃着刨冰，拎着一堆土特产，\\n　两眼放着光，看着特高兴……？」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「ちょ、調査です」","「欸、我这是在调查啦。」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「……ぅっ。頭、キーンてする。痛いぃ」","「……唔。头、好冰。好痛。」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「急いでかき氷食うからだよ」","「谁让你着急忙慌地吃刨冰啊。」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「暖かいもの食べたくなってきた……」","「突然好想吃点热乎的东西……」",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「本当に調査なのか？」","「你这真是调查吗？」",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「ちょ、調査ですよ！　とても重要で、\\n　しかも公的な調査です」","「是、是调查啦！是非常重要、\\n　而且还是公务性质的调查！」",null,null,null],["47_TEXT","47_TEXT",null,null,null],["「……前は観光だって言ってなかった？」","「……上次你不还说是观光吗？」",null,null,null],["48_TEXT","48_TEXT",null,null,null],["「あっ……」","「啊……」",null,null,null],["49_TEXT","49_TEXT",null,null,null],["「チャーミング・マンさあ。時々心配になる、\\n　迂闊さしてるよ」","「你这魅力十足的男人啊。有时候真让人担心，\\n　太冒失了。」",null,null,null],["50_TEXT","50_TEXT",null,null,null],["「誰が魅力的な男性ですか！？\\n　私はチャミアバックです！」","「谁是魅力十足的男人啊！？\\n　我是查米亚巴克！」",null,null,null],["51_TEXT","51_TEXT",null,null,null],["「まあ、アンタが何してようと、\\n　どうでもいいんだが」","「嘛，不过你在干什么，\\n　我倒也无所谓。」",null,null,null],["52_TEXT","52_TEXT",null,null,null],["「あそこのコンビニのおでんは旨いから、\\n　マジでオススメ」","「那边便利店的关东煮很好吃，\\n　真心推荐。」",null,null,null],["53_TEXT","53_TEXT",null,null,null],["「えっ。おでんって聞いたことある。\\n　丁度良すぎる暖かい食べ物！」","「诶。我听说过关东煮。\\n　这来得也太巧了的热乎食物！」",null,null,null],["54_TEXT","54_TEXT",null,null,null],["「それはいますぐ買いに行かなくては！」","「那我必须立刻去买来尝尝！」",null,null,null],["58_TEXT","58_TEXT",null,null,null],["「……大丈夫なんかね？\\n　あの御仁は……」","「……真的没事吧？\\n　那位大人……」",null,null,null]],"type":"","context":[["unique0861.uasset.csv/row/128","unique0861.uasset.csv/row/139","unique0861.uasset.csv/row/150","unique0861.uasset.csv/row/209","unique0861.uasset.csv/row/220","unique0861.uasset.csv/row/231","unique0861.uasset.csv/row/242","unique0861.uasset.csv/row/253","unique0861.uasset.csv/row/312","unique0861.uasset.csv/row/323","unique0861.uasset.csv/row/334","unique0861.uasset.csv/row/345","unique0861.uasset.csv/row/356","unique0861.uasset.csv/row/367","unique0861.uasset.csv/row/378","unique0861.uasset.csv/row/389","unique0861.uasset.csv/row/400","unique0861.uasset.csv/row/411","unique0861.uasset.csv/row/422","unique0861.uasset.csv/row/433","unique0861.uasset.csv/row/444","unique0861.uasset.csv/row/455","unique0861.uasset.csv/row/466","unique0861.uasset.csv/row/477","unique0861.uasset.csv/row/488","unique0861.uasset.csv/row/499","unique0861.uasset.csv/row/510","unique0861.uasset.csv/row/545"],["unique0861.uasset.csv/row/129"],["unique0861.uasset.csv/row/130"],["unique0861.uasset.csv/row/140"],["unique0861.uasset.csv/row/141"],["unique0861.uasset.csv/row/151"],["unique0861.uasset.csv/row/152"],["unique0861.uasset.csv/row/210"],["unique0861.uasset.csv/row/211"],["unique0861.uasset.csv/row/221"],["unique0861.uasset.csv/row/222"],["unique0861.uasset.csv/row/232"],["unique0861.uasset.csv/row/233"],["unique0861.uasset.csv/row/243"],["unique0861.uasset.csv/row/244"],["unique0861.uasset.csv/row/254"],["unique0861.uasset.csv/row/255"],