_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/06_Norimaki/unique1171.uasset.csv","tags":[],"progress":{"translated":61,"length":61,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/05_Kamase/unique1001.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/05_Kamase","basename":"unique1001.uasset.csv","extension":"csv","filename":"unique1001.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/05_Kamase/unique1001.uasset.csv","data":[["unique1001","unique1001",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「な、なにィー！？\\n　アタシは死んで亡者になって、\\n　ここは地獄の底だってー！？」","「什、什么——！？\\n  原来我已经死了变成了亡灵，\\n  这里竟是地狱的最底层——！？」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「ああ、そうなんだ。お悔やみ言っとく。\\n　気落ちすると思うけど……」","「啊，没错。请节哀顺变。\\n  虽然肯定会很难受……」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「……まあ」","「……唉」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「うん、そういう事もあるか！\\n　へへ。ここが地獄かー案外普通なんだなあ」","「嗯，原来还有这种情况啊！\\n  嘿嘿。这里就是地狱啊——比想象中普通嘛」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「……あ。こういうの結構、\\n　すっと受け入れるタイプの人？」","「……啊。难道你是那种，什么事情都能\\n  很快就看开接受的人？」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「くよくよしたってしゃーなしだからな！\\n　楽しんでいこー！　がアタシのモットー！」","「老是愁眉苦脸也不是办法啊！\\n　　尽情享受吧！这就是我的座右铭！」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「地獄かあ。何が理由なんだろ？\\n　おばあちゃんちのスズメバチを全滅させたこと？\\n　海水浴場に迷い込んだサメを返り討ちにしたこと？」","「地狱啊。我到底是因为什么来的呢？\\n  是因为我把奶奶家的马蜂给一窝端了？\\n  还是我反击迷路闯进海水浴场的鲨鱼那件事？」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「確かに、一部の虫にも五分の魂って言うもんな！\\n　ごめん今まで叩き落としてきた蚊とか蝿とか！」","「确实，都说就连一只小虫子也有一条命嘛！\\n  对不起啦，至今为止被我拍死的那些蚊子和苍蝇们！」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「うおおお！　アタシは一生懸命頑張って、\\n　この地獄で改心するぜえーー！！」","「呜哦哦哦！我要拼尽全力，\\n　　就在这地狱里洗心革面重新做人——！！」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「あ、暑苦しいやつ……」","「哇，好烦人的家伙……」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「めらめら」","「熊熊燃烧」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「それで、最初は何をするんだ！？\\n　地獄初心者だから、右も左もわからないぜ！」","「那么，首先我该干什么！？\\n  我可是地狱小白，完全分不清东南西北啊！」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「任せろ。そのために俺がいるんだ」","「交给我吧。我就是为了这个而来的」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「おお……！　アタシを導いてくれるもの！\\n　つまりアンタが、コーチってわけだな！」","「哦哦……！指引我的东西！\\n 也就是说，你就是教练了！」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「！　コーチ」","「！教练」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「……よく聞く敬称ではあるけど、\\n　自分が呼ばれることは無いと思ってたから、\\n　ちょっとうれしい」","「……虽然这是个常听到的敬称，\\n　但我从没想过会被人这么叫，\\n　有点开心呢」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「よろしくだぜ、コーチ！」","「请多关照啦，教练！」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「カマセのそのテンションを見るに、\\n　生前はスポーツとかやってたわけ」","「看要去你这股兴奋劲儿，\\n　你生前是搞体育的吧」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「美術部だぜッ！」","「我是美术社的！」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「文化系なのかよ」","「原来是文化社团的啊」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「でもガッコでは1番足が早かったぜ！！」","「但我可是全校跑得最快的！」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「もったいな。陸上やればよかったのに」","「真可惜。当初去搞田径多好」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「やってたけど靭帯をやっちまってな。\\n　あれは中学最後の大会でのことだった……」","「我搞过啊，但是把韧带搞坏了。\\n　那是在初中最后一次大赛上的事了……」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「あ悲しい過去があるやつ。\\n　ごめんねデリカシーないこと言って」","「啊，是有悲伤往事的那种人。\\n　抱歉，我说了这么没神经的话」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「全然気にしてないよ。\\n　美術部は辛かったけど楽しかったし」","「我完全没在意啦。\\n　虽然美术社很辛苦，但也很快乐」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「部活中は水分補給が禁止でな……。\\n　ふふ、熱血してた」","「社团活动的时候禁止补充水分……。\\n　嘿嘿，可热血了」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「文化部のくせに！？」","「你们明明是文化社团啊！？」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「あと朝は5時に来て先輩の\\n　パレットを洗ったり」","「还有啊，早上要5点到校\\n　给学长洗调色盘」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「1年は絵筆を握るのが禁止だったなァ」","「一年级的时候是禁止握画笔的」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「文化部なのに……？」","「明明是个文化社团……？」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「というわけでしごかれることには慣れてるぜ！\\n　ビシバシ指導の方、よろしくお願いします！」","「所以，我很习惯被人操练啦！\\n　魔鬼指导什么的，尽管放马过来吧！」",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「うむ。ではスクワット500回！」","「嗯。那么，深蹲500次！」",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「1万回でもいけるぜ！\\n　うおおおおおおおお！！」","「就是一万次我也行！\\n　呜哦哦哦哦哦哦哦！！」",null,null,null],["47_TEXT","47_TEXT",null,null,null],["「って、すまんすまん。\\n　余りの運動部的エナジーに呑まれて、\\n　無意味なスクワットをさせるトコだった」","「啊，抱歉抱歉。\\n　差点被你过剩的运动社团能量给带偏，\\n　刚想让你做毫无意义的深蹲来着」",null,null,null],["48_TEXT","48_TEXT",null,null,null],["「そこは普通にしっかりしてほしい……」","「那种地方我希望你能正常一点……」",null,null,null],["50_TEXT","50_TEXT",null,null,null],["「それじゃ、行こうか。責め苦」","「那我们去进行‘折磨’吧」",null,null,null],["51_TEXT","51_TEXT",null,null,null],["「うおおお！！\\n　ヤリでもタマでも、降ってこいやあ！」","「呜哦哦哦！！\\n　不管是枪还是球，都尽管来吧！」",null,null,null]],"type":"","context":[["unique1001.uasset.csv/row/112","unique1001.uasset.csv/row/123","unique1001.uasset.csv/row/134","unique1001.uasset.csv/row/145","unique1001.uasset.csv/row/156","unique1001.uasset.csv/row/167","unique1001.uasset.csv/row/178","unique1001.uasset.csv/row/189","unique1001.uasset.csv/row/200","unique1001.uasset.csv/row/211","unique1001.uasset.csv/row/222","unique1001.uasset.csv/row/233","unique1001.uasset.csv/row/244","unique1001.uasset.csv/row/255","unique1001.uasset.csv/row/266","unique1001.uasset.csv/row/277","unique1001.uasset.csv/row/288","unique1001.uasset.csv/row/299","unique1001.uasset.csv/row/310","unique1001.uasset.csv/row/321","uni