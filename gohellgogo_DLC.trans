,[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/03_Kenne/03_Kenne03.uasset.csv","tags":[],"progress":{"translated":80,"length":80,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/03_Kenne/03_Kenne04.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/03_Kenne","basename":"03_Kenne04.uasset.csv","extension":"csv","filename":"03_Kenne04.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/03_Kenne/03_Kenne04.uasset.csv","data":[["03_Kenne04","03_Kenne04",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「……しかし、相変わらず誰もいないねえ、ここ」","「……不过，果然还是一个人都没有啊，这里」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「うちがおるじゃろがい」","「我不是在这么」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「懸衣サン以外、ここで誰か、\\n　見たことないんだけど？」","「除了悬衣小姐，\\n　我没在这见过其他人哦？」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「……人手がいるもんは、\\n　奥の方でやっちゃるけんのぉ」","「……需要人手的事，\\n　都在里头干着呢嘛」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「逆に処長が、\\n　いつもこんな無駄にくっちゃべってて良いの」","「反倒是处长，\\n　总是这样没完没了地瞎聊，没问题吗」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「あぁー？　きさんこの宇と宙に、\\n　無駄じゃ言わんもんが、あると思っとるンけ？」","「啊ー？　你觉得这天地间，\\n　有一样不是浪费的东西吗？」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「まァー真の話はァ、\\n　うちは対外的にやる事の方が多くてのぉ」","「嘛啊ー说正经的吧，\\n　我对外的事反倒更多呢」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「表をほっつく機会があるちゅー話じゃの」","「那就是说有机会在外面闲逛咯」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「へえ。対外的。お客の会話相手とか？」","「嘿。对外。陪客人聊天啥的？」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「カカ。おどれを客と思った事はない。\\n　キッチンの鼠に餌付けする気分よ」","「喀喀。我从没把你当过客人。\\n　就是给厨房老鼠喂食的心情」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「暇つぶし相手にされてたのか、俺……」","「我被当成打发时间的对象了啊，我……」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「分かったら芸でもせぇ。芸」","「明白了就来点才艺。才艺」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「しねえわ」","「我才不干呢」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「ならうちが仕込むか、この鼠に芸を」","「那老子来练练你怎么样，给这老鼠教点才艺」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「乳首から血ぃ吹いて絵を描くんはどうじゃろ。\\n　ぎゃはは。ほんでよぉ」","「从乳头喷血来画画怎么样。\\n　嘎哈哈。然后啊」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「おどれは社会の被害者でござい、みたいな、\\n　泣ける絵画にポエミーなタイトルつけてよぉ」","「给你整成那种，我是社会的受害者，\\n　哭兮兮的画再配上诗意的标题哦」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「けらけらけら。絶対おもろいじゃろそんなん！\\n　やろ、ヤツシロくん、やろ。人体改造は任せぇんさい！」","「喀啦喀啦喀啦。那绝对会好玩死的吧！\\n　搞吧，8264小哥，搞吧。人体改造就包在我身上啦！」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「相変わらず笑いのセンスが共感出来ないし、\\n　人体改造は絶対にさせんわ！」","「你的搞笑品味我还是没法共鸣，\\n　而且人体改造我绝对不让搞！」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「……つまらん！」","「……真没劲！」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「代わりになんぞ、愉快な話でもないんけ？」","「有没有啥别的，有意思的事啊？」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「いやあ懸衣サンのお眼鏡に叶うような、\\n　イかれた話はないなあ」","「哎呀，能入得了悬衣小姐眼的，\\n　那种疯癫事儿可没有啊」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「あ、そういや気になってた話。\\n　ちょっと聞こうと思ってたんだけど」","「啊，说起来有件事我一直挺在意。\\n　正想问问你呢」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「言うてみい」","「说说看」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「復活した亡者って、\\n　別の場所で責め苦を受けてんだよね」","「那些复活的亡者，\\n　是在别的地方受苦对吧」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「公共工事とか別業者への再割り当てとか、\\n　そういう風に聞いてるけど」","「我听说是会被分配到公共工程，\\n　或者重新分配到别的业者那边」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「ンじゃのう」","「是那么回事嘞」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「俺、見かけた事なくてさ」","「我，从没见过呢」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「還処に行ってから、出てきたやつ」","「去了还处之后，又出来的家伙」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「…………」","「…………」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「巡り合わせが悪いとか、\\n　そんな感じなんすかね」","「是运气不好还是怎么着，\\n　就那种感觉吗」",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「……きさんが接している地獄なんぞ、\\n　ごく一部ちゅーことかのー」","「……你能接触到的地狱，\\n　不过是极小一部分吧」",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「そりゃそう。俺の生活圏なんて、\\n　会社と商店街の往復だし」","「那倒是。我的活动范围，\\n　也就是公司和商店街两头跑」",null,null,null],["47_TEXT","47_TEXT",null,null,null],["「……」","「……」",null,null,null],["49_TEXT","49_TEXT",null,null,null],["「ま……あんま考えんとき」","「嘛……别想太多了」",null,null,null],["50_TEXT","50_TEXT",null,null,null],["「ただでさえつまらん浮世じゃろォ。\\n　せめて頭ァ愉快な事でいっぱいにせんとなあ」","「反正这浮生本来就够无聊了。\\n　至少把脑袋用开心事塞满才成啊」",null,null,null],["51_TEXT","51_TEXT",null,null,null],["「はあ……つまらん。……つまらんのぉ……」","「啊……真没劲。……真没劲啊……」",null,null,null]],"type":"","context":[["03_Kenne04.uasset.csv/row/120","03_Kenne04.uasset.csv/row/131","03_Kenne04.uasset.csv/row/142","03_Kenne04.uasset.csv/row/153","03_Kenne04.uasset.csv/row/164","03_Kenne04.uasset.csv/row/175","03_Kenne04.uasset.csv/row/186","03_Kenne04.uasset.csv/row/197","03_Kenne04.uasset.csv/row/208","03_Kenne04.uasset.csv/row/219","03_Kenne04.uasset.csv/row/230","03_Kenne04.uasset.csv/row/241","03_Kenne04.uasset.csv/row/252","03_Kenne04.uasset.csv/row/263","03_Kenne04.uasset.csv/row/274","03_Kenne04.uasset.csv/row/285","03_Kenne04.uasset.csv/row/296","03_Kenne04.uasset.csv/row/307","03_Kenne04.uasset.csv/row/318","03_Kenne04.uasset.csv/row/329","03_Kenne04.uasset.csv/row/340","03_Kenne04.uasset.csv/row/351","03_Kenne04.uasset.csv/row/362","03_Kenne04.uasset.csv/row/373","03_Kenne04.uasset.csv/row/384","03_Kenne04.uasset.csv/row/395","03_Kenne04.uasset.csv/row/406","03_Kenne04.uasset.csv/row/417","03_Kenne04.uasset.csv/row/428","03_Kenne04.uasset.csv/row/439","03_Kenne04.uasset.csv/row/450","03_Kenne04.uasset.csv/row/461","03_Kenne04.uasset.csv/row/472","03_Kenne04.uasset.csv/row/491","03_Kenne04.uasset.csv/row/502","03_Kenne04.uasset.csv/row/513"],["03_Kenne04.uasset.csv/row/121"],["03_Kenne04.uasset.csv/row/122"],["03_Ken