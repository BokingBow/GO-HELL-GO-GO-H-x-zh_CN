"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/04_Oshi/unique0941.uasset.csv","tags":[],"progress":{"translated":53,"length":53,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/04_Oshi/unique0951.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/04_Oshi","basename":"unique0951.uasset.csv","extension":"csv","filename":"unique0951.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/04_Oshi/unique0951.uasset.csv","data":[["unique0951","unique0951",null,null,null],["12_TEXT","12_TEXT",null,null,null],["「失礼しま～す。ヤツシロ殿ー。\\n　いないでありますかー？」","「打扰啦。8246大人～。\\n不在吗～？」",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「うーんいないのかな。\\n　いるとしたらここだと思ったんだけど」","「嗯～不在吗。\\n我还以为如果他在的话一定会在这里的」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「急に街に放り出されて、\\n　文句の１つでも……もとい、\\n　救援の１つでも受取に来たのですが」","「突然被丢到街上，\\n我还想来听他发句牢骚……不对，\\n是来接受一下救援什么的呢」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「うーん。待ってたらどなたか、\\n　来ますかね……？」","「嗯～。在这里等着的话，会不会有人\\n过来呢……？」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「……お。誰か、近づいてきてるみたいだし」","「……哦。感觉好像有人走过来了」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「ヤツシロいるー？\\n　言われたもん、もってきたけど――」","「8246在吗～？\\n你要的东西，我拿来了哦――」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「…………」","「…………」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「も、も、も、もしかして……あなたが……」","「难、难、难、难道说……你就是……」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「へ？」","「诶？」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["（……誰？　このコ。なんとなく私に近いと言うか）","（……谁呀？这孩子。总觉得感觉跟我有点像）",null,null,null],["26_TEXT","26_TEXT",null,null,null],["（あ絶対そうだ。皆が言ってる人、このヒトだ！\\n　確か名前は……）","（啊绝对没错。大家说的那个人，就是这个人！\\n我记得名字好像是……）",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「えーっと」","「那个」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「……一ノ瀬さん、でありますか？」","「……是一之濑小姐，对吧？」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「えっ」","「诶」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["（えもしかして私のファン？\\n　いやそんなことないか）","（咦，难道她是我的粉丝？\\n不对，应该不可能吧）",null,null,null],["31_TEXT","31_TEXT",null,null,null],["（でもなんでも無く偶々私に似てるだけの人だったら、\\n　今の私の思考めっちゃ自意識過剰だな……）","（但如果只是一个偶然长得像我的人，\\n那我刚才的想法也太自作多情了……）",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「申し訳ないんだけど、\\n　どこかでお会いしたことが……？」","「不好意思，\\n我们是不是在哪里见过……？」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「……そっちは知らないのでありますね」","「……看来你不认识我呢」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["（え、なにが）","（诶，什么意思）",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「まあ……それならそれで良いと思います。\\n　悪気が無いのも重々承知の上なので」","「算了……那样也好。\\n我也很清楚你并非出于恶意」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「わ、悪気ってなに？　私なにかしちゃった？」","「恶、恶意？什么啊？我做了什么吗？」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「いいのですいいのです。いつの時代も、\\n　雑草を踏む人に罪などないのです」","「没关系，没关系的。无论什么时代，\\n踩踏杂草的人都是无罪的」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["（うわー、絶対私がなんかしちゃったやつだ！\\n　でもマジでなんも覚えてね～～）","（哇啊，这绝对是我做了什么对不起她的事那种情况！\\n但我真的一点都不记得了啊～～）",null,null,null],["39_TEXT","39_TEXT",null,null,null],["（かくなる上は、とりあえず褒め殺し）","（既然如此，只好先用这招，把她往死里夸了）",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「そ、それにしてもお綺麗ですねー。\\n　髪もとってもサラサラで」","「话、话说回来，您可真漂亮啊～。\\n头发也超级柔顺呢」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["（やば。私今自分のことがめっちゃ\\n　好きな人みたいになってない？）","（糟糕。我现在是不是变得像个\\n超级自恋的人一样了？）",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「あははー……ありがとうございますー……」","「啊哈哈……谢谢……夸奖……」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「まあ全然……一ノ瀬さんには、\\n　敵わないんですけどね……」","「不过完全……比不上\\n一之濑小姐您就是了……」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["（何で私地雷踏んだみたいになってるの！？）","（为什么搞得像是我踩了雷一样啊！？）",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「いいなァー……“本物”は……」","「真好啊……‘真货’就是……」",null,null,null],["46_TEXT","46_TEXT",null,null,null],["（これ何？　ホラー映画か何か？）","（这算什么？是恐怖片还是什么？）",null,null,null],["47_TEXT","47_TEXT",null,null,null],["「……いっそ……ここで」","「……干脆……就在这里……」",null,null,null],["48_TEXT","48_TEXT",null,null,null],["「ひっ普通に命の危機を感知」","「咿——普通的感知到了生命危险！」",null,null,null],["49_TEXT","49_TEXT",null,null,null],["「まあまあどなたか知らないけれど、\\n　落ち着いて落ち着いて」","「哎呀哎呀，虽然不知道您是哪位，\\n　冷静一下，先冷静一下」",null,null,null],["50_TEXT","50_TEXT",null,null,null],["「何か嫌な事があったかわからないけど、\\n　自暴自棄になってはだめ」","「虽然不知道你遇到了什么烦心事，\\n　但可不能自暴自弃哦」",null,null,null],["51_TEXT","51_TEXT",null,null,null],["「明日は明日の風が吹く。\\n　きっといつか良いことあるわ」","「明天又会刮明天的风。\\n　总有一天会有好事发生的」",null,null,null],["52_TEXT","52_TEXT",null,null,null],["「い、一ノ瀬さん……」","「一、一之濑小姐……」",null,null,null],["53_TEXT","53_TEXT",null,null,null],["「そうでありますよね。一ノ瀬さんは、\\n　何も悪くないって自分は知っていたのに……」","「您说得没错。自己明明知道，\\n一之濑小姐一点错都没有的……」",null,null,null],["54_TEXT","54_TEXT",null,null,null],["「いっそここで命を賭して背後からずぶりと\\n　いこうとしてしまっていました」","「却差点想干脆就在这里拼上性命，\\n从背后一下子捅过去」",null,null,null],["55_TEXT","55_TEXT",null,null,null],["「もう計画があったの頭に。やめてよ」","「脑子里都已经有计划了。快住手吧」",null,null,null],["56_TEXT","56_TEXT",null,null,null],["「でもこれだけ！\\n　１つだけ、ケリをつけさせてほしいのです」","「但是就这一件事！\\n我只求你让我做个了断」",null,null,null],["57_TEXT","57_TEXT",null,null,null],["「……なに？　ちょっと怖いけど」","「……什么啊？虽然有点吓人」",null,null,null],["58_TEXT","58_TEXT",null,null,null],["「――お胸のサイズは」","「――你的胸围是」",null,null,null],["59_TEXT","59_TEXT",null,null,null],["「……はい？」","「……嗯？」",null,null,null],["60_TEXT","60_TEXT",null,null,null],["「――お胸のサイズは？」","「――你的胸围是多少？」",null,null,null],["61_TEXT","61_TEXT",null,null,null],["「……………………」","「……………………」",null,null,null],["62_TEXT","62_TEXT",null,null,null],["「それ、そんな必死の形相で\\n　聞くほどのことなわけ？」","「这事，值得你一副拼了命的表情\\n追着问吗？」",null,null,null],["63_TEXT","63_TEXT",null,null,null],["「（ぶんぶんと頷く）」","「（猛点头）」",null,null,null],["64_TEXT","64_TEXT",null,null,null],["65_TEXT","65_TEXT",null,null,null],["「壁に耳あり障子に目あり。\\n　……なので、ちょっとお耳を貸してね」","「隔墙有耳，屏风有眼。\\n……所以呢，请把耳朵凑过来一下」",null,null,null],["66_TEXT","66_TEXT",null,null,null],["「は、はいっ」","「好、好的」",null,null,null],["68_TEXT","68_TEXT",null,null,null],["「……ごにょごにょ……センチ」","「……叽里咕噜……厘米」",null,null,null],["70_TEXT","70_TEXT",null,null,null],["「………………！！」","「………………！！」",null,null,null],["71_TEXT","71_TEXT",null,null,null],["「やはり自分の……完敗であります……えん」","「果然是我……彻底输了……呜咽」",null,null,null],["72_TEXT","72_TEXT",null,null,null],["「良くわかんないんだけど……泣くほど？」","「虽然不太明白……至于哭吗？」",null,null,null]],"type":"","context":[["unique0951.uasset.csv/row/96","unique0951.uasset.csv/row/107","unique0951.uasset.csv/row/118","unique0951.uasset.csv/row/129","unique0951.uasset.csv/row/156","unique0951.uasset.csv/row/175","unique0951.uasset.csv/row/186","unique0951.uasset.csv/row/197","unique0951.uasset.csv/row/208","unique0951.u