B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0351.uasset.csv","tags":[],"progress":{"translated":114,"length":114,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0361.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya","basename":"unique0361.uasset.csv","extension":"csv","filename":"unique0361.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0361.uasset.csv","data":[["unique0361","unique0361",null,null,null],["12_TEXT","12_TEXT",null,null,null],["「あらあら、こんなにおまけもたくさん。\\n　いつもありがとうございます」","「哎呀呀，还给了我这么多赠品。\\n　每次都这么客气，太感谢了」",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「え？　今度商店街の皆さんで、\\n　一緒にバーベキュー？　素敵ですね」","「咦？下次商店街的大家，\\n　一起去烧烤？真不错啊」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「ではお友達の少女サッカーチームの皆さんも\\n　お誘いして、ぜひ参加させていただきますね」","「那把我朋友她们少女足球队的孩子们\\n　也叫上，务必让我也参加哦」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「……そこはかとなく、\\n　地獄に馴染んでいる奴が居るな」","「……隐隐约约，好像\\n　有个很适应地狱的家伙在啊」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「あらヤツシロさん。ご無沙汰しております」","「哎呀，8246先生。好久不见」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「皆様優しい人ばかりで、\\n　良くして頂く日々ですわ」","「大家都是很好的人，\\n　平日里对我特别照顾」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「……バーベキュー……するわけ？\\n　商店街の人たちと？」","「……烧烤……要去搞吗？\\n　和商店街的人？」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「はい。前に流しそうめんパーティで、\\n　とても仲良くして頂けまして」","「是的。上次流水素面派对的时候，\\n　大家就玩得非常开心来着」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「す、すげー。これがガチの社交力なのか」","「厉、厉害。这就是真正的社交能力吗」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「優しい方々に甘えてばかりの日々です」","「每天都在享受着大家的厚爱呢」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「そうだ。ヤツシロさんはスポーツなどは\\n　されないのですか？」","「对了。8246先生平时\\n　不做做运动什么的吗？」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「少年少女サッカーチームと、\\n　テニスチームとちびっこ剣道道場が」","「听说少年少女足球队，\\n　还有网球队和小小剑道道场」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「コーチを探してらっしゃるとの事なのですが」","「好像正在找教练呢」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「……俺には絶対無理な話かも」","「……这事我绝对干不来」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「あ、そうだ。今日は八百屋さんから、\\n　とうもろこしを分けて貰いましたの」","「啊，对了。今天蔬菜铺的老板\\n　分了些玉米给我」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「良ければ幾つか、貰って頂けませんか？」","「方便的话，带几个回去\\n　尝尝怎么样？」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「いいの？」","「可以吗？」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「はい。嬉しいことは皆で分け合ったほうが、\\n　もっと嬉しくなれますもの」","「当然啦。开心的事大家一起分享，\\n　才会变得更开心嘛」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「しゃ、社交力のバケモンか？\\n　こっちまで若干絆されそうになる」","「社、社交怪物啊？\\n　我这边都快有点被带跑了」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「最近とうもろこし揚げが美味しくて。\\n　作ってみたことはありますか？」","「最近我迷上炸玉米了。\\n　你做过吗？」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「ないけどうまそうだなあそれ」","「没做过，但听着就好吃啊」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「でしたら今度作った時、\\n　ヤツシロさんの分も作りますので」","「那下次我做的时候，\\n　也给你带一份」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「ぜひ、食べてみてくださいね」","「请一定尝尝看」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「ひえ～～っ！　絆される～～！」","「咿呀——！要被带偏啦——！」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「そうだ、代わりに商工会のイベントに、\\n　参加して頂けたら嬉しいです」","「对了，作为交换，要是能来参加\\n　商工会的活动那我就高兴了」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「……圧倒的光属性に、\\n　色々浄化されてしまいそうだ」","「……这压倒性的光明属性，\\n　总感觉会被彻底净化啊」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「それより、荷物多いな。食材の買い出し中？」","「话说回来，你东西真多。在买菜的路上？」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「あ、そうでした」","「啊，差点忘了」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「灯さんに言付かって、\\n　備品を買い足しに行かなければ」","「灯托我捎口信，\\n　得去补买些备品才行」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「えっ灯？」","「咦，灯？」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「それでは責め苦の最中ですので、\\n　これにて」","「我正该去受责罚了，\\n　那就此告辞」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「……責め苦？」","「……责罚？」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「失礼致します。ぺこり」","「告辞了。一鞠躬」",null,null,null],["47_TEXT","47_TEXT",null,null,null],["「……どういうこと？」","「……究竟是怎么回事？」",null,null,null],["49_TEXT","49_TEXT",null,null,null],["「そのとうもろこしは茹でてもいいですが、\\n　バターと醤油で焼いても美味しいですよ♪」","「那玉米煮着吃也很棒，\\n　不过抹上黄油和酱油烤一烤也很好吃哦♪」",null,null,null],["50_TEXT","50_TEXT",null,null,null],["「……それは帰ったら絶対食べるけどさ！？」","「……那个我说了回家绝对会吃的啊！？」",null,null,null]],"type":"","context":[["unique0361.uasset.csv/row/96","unique0361.uasset.csv/row/107","unique0361.uasset.csv/row/118","unique0361.uasset.csv/row/129","unique0361.uasset.csv/row/140","unique0361.uasset.csv/row/151","unique0361.uasset.csv/row/162","unique0361.uasset.csv/row/173","unique0361.uasset.csv/row/184","unique0361.uasset.csv/row/195","unique0361.uasset.csv/row/206","unique0361.uasset.csv/row/217","unique0361.uasset.csv/row/228","unique0361.uasset.csv/row/239","unique0361.uasset.csv/row/250","unique0361.uasset.csv/row/261","unique0361.uasset.csv/row/272","unique0361.uasset.csv/row/283","unique0361.uasset.csv/row/294","unique0361.uasset.csv/row/305","unique0361.uasset.csv/row/316","unique0361.uasset.csv/row/327","unique0361.uasset.csv/row/338","unique0361.uasset.csv/row/349","unique0361.uasset.csv/row/360","unique0361.uasset.csv/row/371","unique0361.uasset.csv/row/382","unique0361.uasset.csv/row/393","unique0361.uasset.csv/row/404","unique0361.uasset.csv/row/415","unique0361.uasset.csv/row/426","unique0361.uasset.csv/row/437","unique0361.uasset.csv/row/448","unique0361.uasset.csv/row/475","unique0361.uasset.csv/row/494","unique0361.uasset.csv/row/505"],["unique0361.uasset.csv/row/97"],["unique0361.uasset.csv/row/98"],["unique0361.uasset.csv/row/108"],["unique0361.uasset.c