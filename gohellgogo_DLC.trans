TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0861.uasset.csv","tags":[],"progress":{"translated":57,"length":57,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0871.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya","basename":"unique0871.uasset.csv","extension":"csv","filename":"unique0871.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0871.uasset.csv","data":[["unique0871","unique0871",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「ふんふふんふ～ん♪」","「哼哼哼哼～嗯♪」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「ああ、今日はどこ行こっかなー」","「啊啊，今天去哪儿逛逛呢～」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「おお。チャターボックス。\\n　昨日は楽しかったな」","「哦哦。话匣子。\\n　昨天玩得挺开心啊。」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「誰がおしゃべりな人ですか！\\n　私はチャミアバックです！」","「谁是话多的人啊！\\n　我是查米亚巴克！」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「はあ、でも確かに昨日は楽しかったですね。\\n　現地の居酒屋での現地の人々との交流」","「唉，不过昨天确实很开心呢。\\n　在当地居酒屋和本地人的交流。」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「あの……あんきも？　というのも美味しかったし、\\n　知らないお酒も沢山飲めました」","「那个……叫什么来着，鮟鱇鱼肝？也特别好吃，\\n　还喝了好多没见过的酒。」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「意外と良い飲みっぷりしてんだもんなあ」","「没想到你还挺能喝啊。」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「女将さんの作ってくれた\\n　おばんざい、また食べたい……」","「老板娘做的那些\\n　家常小菜，好想再吃啊……」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「……今日も行っちゃおうかな」","「……今天要不要也去一趟呢。」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「……マジで楽しんでるよね、地獄暮らしを」","「……你这不纯粹在享受嘛，在地狱的日子。」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「たたたた楽しんでないですが！\\n　私は天竺に赴く三蔵法師のつもりで！」","「我我我我才没有享受！\\n　我可是抱着前往天竺的三藏法师那样的觉悟！」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「……まあ？　たしかに今のところ調査というより、\\n　漫遊記に近いですが。しかも記してないし」","「……嗯？确实到目前为止，比起调查，\\n　更像是漫游散记。而且我还没记下来。」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「じゃあただの漫遊じゃん」","「那不就只是纯粹的漫游嘛。」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「それはそうかも！！」","「好像还真是！！」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「………………」","「………………」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「…………それはそうかも……」","「……好像还真是……」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「自らの真実に気づいてしまって、\\n　ショックを受けているな……」","「意识到自己的真相后，\\n　她受打击了呢……」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「あー！　だめだめ！\\n　私には大切な役目があるんだから！」","「啊——！不行不行！\\n　我可是肩负着重要使命的！」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「ヤツハシさん！\\n　チャミアホロムって名前に聞き覚えは！？」","「八桥先生！\\n　您听说过查米亚霍洛姆这个名字吗！？」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「誰が銘菓だ。ヤツシロな？\\n　ンでそんなトンチキな名前のヤツは知らん」","「谁说我是名产了。是8246啦？\\n　我才不认识名字那么莫名其妙的家伙。」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「うぅ……これだけ歩き回っても会えないなんて\\n　深い場所にいるのかあるいは別のどこかか」","「呜……走了这么多路都见不到面，\\n　要么是在很深的地方，要么就是在别处了吧。」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「なんだか続編でもない限り、\\n　会えない気がしてきた……」","「总感觉，除非出续篇，\\n　否则都见不着了……」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「……なんていうか……ガンバロ！」","「……该怎么说……加把劲！」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「うええーーんっ」","「呜哇啊啊——！」",null,null,null]],"type":"","context":[["unique0871.uasset.csv/row/104","unique0871.uasset.csv/row/115","unique0871.uasset.csv/row/126","unique0871.uasset.csv/row/137","unique0871.uasset.csv/row/148","unique0871.uasset.csv/row/159","unique0871.uasset.c