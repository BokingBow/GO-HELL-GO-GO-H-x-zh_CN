ll,null],["16_TEXT","16_TEXT",null,null,null],["「あれ？　あのお兄さんは？」","「咦？那个小哥呢？」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「あっはい、社長ですか？」","「啊，嗯。是社长吗？」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「ンあー、そう。作業着の。\\n　ヤレヤレ系主人公みたいな」","「嗯啊——，对。穿工装的。\\n一副‘真拿你没办法’主角样儿的」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「あったぶん社長です」","「多半就是社长了」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「へえ社長なんだ。\\n　の割に狭くない？　心の器が」","「嚯，原来他是社长啊。\\n不过这地方也太窄了吧？心胸也是」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「……お茶でも飲みますか？」","「……要不，您先喝杯茶？」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「うちさー、あン人にいきなし亡者って\\n　言われて連れ回されて」","「我跟你说啊，突然就被那家伙叫成亡者\\n然后硬拖着到处转」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「そっから結局町中に放り出されて」","「结果呢，最后又把我给扔大街上不管了」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「普通にめっちゃ大変なんですけどぉ！」","「这一路可是实打实的累死个人啊——！」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「……お、お茶菓子もつけますね」","「……茶、茶点我也给您配上」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「右も左もツテもないし？\\n　でもまああたし経験はあるから？」","「人生地不熟的，连个门路也没有？\\n不过嘛，我好歹也算有点经验？」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「世渡りはやってこれたんだけどさ」","「好歹是靠自己活过来了」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「……今まではどんなことを\\n　やってらっしゃったんですか？」","「……您之前都是靠什么\\n谋生的呀？」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「ビニ便漁ったり、農家の野菜を盗んだり……」","「翻便利店扔的便当、偷农家种的菜……」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「アライグマみたいな世の渡り方してたんですね」","「你这谋生方式跟浣熊似的啊」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「頑張ってたの！\\n　でも結局地獄じゃん怖ェじゃん！」","「我超努力的好吧！\\n可到头来这不还是地狱吗！吓死人了啊！」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「何か嫌な思いしたんですか？」","「是遇到什么糟心事了吗？」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「ちょーー！　聞いてよ！　まーじでそれで」","「超——！你听我说啊！真是别提了」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「さっきもさあ普通に横断歩道が\\n　青に変わるの待ってたら」","「就刚才啊，我老老实实等着\\n人行道变绿灯」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「急に隣に全裸の中年男性が立ってて」","「旁边冷不丁站了个全裸的中年男人」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「ええ！　それで！？」","「哎哎！然后呢！？」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「いやそれだけなんだけどさあ！\\n　怖くね！？　何で全裸！？　何があったん！」","「不，就这事儿啊！\\n不吓人吗！？为啥全裸啊！到底发生什么了！」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「あ待ってそれだけじゃなかったわ。\\n　あれも怖かった」","「哦等等，不止这个。\\n那个也挺吓人的」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「なんです？」","「什么事？」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「そのおっさん、手首のリスカ痕エグかった」","「那大叔手腕上，割腕的疤瘆人得很」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「こ、こわ～～～～……」","「好、好吓人~~~~……」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「ちゃんと日常に根付いた、\\n　オチのない怖い話ですね……」","「这还真是扎根日常生活、\\n收尾不收的恐怖故事啊……」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「まあそれだけじゃないにしても、\\n　いい加減屋根のあるトコで寝たいし……」","「唉，就算不说这些，\\n我也真想找个有屋顶的地儿睡一觉了……」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「地獄だからか知らんけど、\\n　なんか皆めっちゃ冷たいし！」","「不知道是不是地狱都这样，\\n反正大家都超冷漠的！」",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「あー……わかりますわかります。\\n　地獄は亡者に冷たいですよね……」","「啊……我懂我懂。\\n地狱嘛，对亡者都很冷漠的……」",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「え。アンタも亡者なの。\\n　へえーわかんないもんだね」","「咦。你也是亡者啊。\\n嘿——真看不出来啊」",null,null,null],["47_TEXT","47_TEXT",null,null,null],["「はいー。ヤツシロさんに\\n　雇って貰っていまして」","「是的——。承蒙八津先生\\n收留了我」",null,null,null],["48_TEXT","48_TEXT",null,null,null],["「マジ！　うちも雇ってもらえんかな」","「真的假的！那也能不能雇我啊」",null,null,null],["49_TEXT","49_TEXT",null,null,null],["「どうなんですかね……？　なんか私が\\n　雇ってもらってるのも実際はナシとか」","「这个嘛……？说起来，我现在\\n到底算不算是被雇了都还不一定呢」",null,null,null],["50_TEXT","50_TEXT",null,null,null],["「でも流れでなんだかんだ収まるところに\\n　収まってしまったというか……」","「不过就这么顺着，不知不觉就\\n安顿在这个地方了……」",null,null,null],["51_TEXT","51_TEXT",null,null,null],["「うちもそれ狙うっきゃねーな。\\n　……いっそ登るか、玉の輿」","「那我也只能盯着这个路子走了。\\n……干脆，我也攀个高枝儿算了」",null,null,null],["53_TEXT","53_TEXT",null,null,null],["「うーん玉と言う程立派な輿ではないような。\\n　言って精々、河原の砂利？」","「嗯——说‘玉’倒也算不上那么气派的轿子。\\n　充其量，就是河滩上的碎石吧？」",null,null,null],["54_TEXT","54_TEXT",null,null,null],["「ここではどんな仕事してん。\\n　データ整理？　とか？」","「在这里都做些什么工作呀？\\n　整理数据？之类的？」",null,null,null],["55_TEXT","55_TEXT",null,null,null],["「うちのおかんもやってたし、\\n　そういうのなら出来る気がする」","「我妈以前也做过，\\n　要是那种我大概能行」",null,null,null],["56_TEXT","56_TEXT",null,null,null],["「私の業務は結構、\\n　体を使う系が多いですね」","「我的业务嘛，\\n　体力活类的比较多呢」",null,null,null],["57_TEXT","57_TEXT",null,null,null],["「カラダを！　へえそりゃ意外。\\n　人は見かけによらないというか」","「用身体的！哎哟，那可真意外。\\n　该说是人不可貌相吗」",null,null,null],["58_TEXT","58_TEXT",null,null,null],["「……むしろこういうタイプは、\\n　人気がでやすいのか？」","「……倒不如说这种类型，\\n　反而更容易有高人气？」",null,null,null],["59_TEXT","59_TEXT",null,null,null],["「な、なんですかじろじろ見て」","「你、你干嘛这么盯着看啊」",null,null,null],["60_TEXT","60_TEXT",null,null,null],["「いや別に。可愛いなと思って」","「没事啦。就觉得你好可爱」",null,null,null],["61_TEXT","61_TEXT",null,null,null],["「てへへ」","「嘿嘿」",null,null,null],["62_TEXT","62_TEXT",null,null,null],["「その笑顔、絶対人気だわ～。\\n　もしかしてナンバー１？」","「这笑容，绝对会大受欢迎啊～。\\n　莫非你是头牌？」",null,null,null],["63_TEXT","63_TEXT",null,null,null],["「……まあうちも、カラダぐらいなら良いか。\\n　背に腹は代えられん。生きるのが1番大事」","「……也罢，就算要我出卖身体也行吧。\\n　顾不了那么多了。活下去最重要」",null,null,null],["64_TEXT","64_TEXT",null,null,null],["「仕事は具体的にはどんな？\\n　マッサージとかするタイプのヤツ？」","「具体到底是什么样的工作？\\n　那种做按摩之类的？」",null,null,null],["65_TEXT","65_TEXT",null,null,null],["「火炎放射器でゴミ……モンスターと戦ったりですかね」","「用火焰放射器对付垃圾……呃，怪物之类打打杀杀的吧」",null,null,null],["66_TEXT","66_TEXT",null,null,null],["「…………」","「…………」",null,null,null],["67_TEXT","67_TEXT",null,null,null],["「思ってたやつと大分違かった」","「跟我想象的差了十万八千里」",null,null,null],["68_TEXT","68_TEXT",null,null,null],["「あ、安心して下さい。1人でじゃないですよ。\\n　皆と協力して」","「啊，请放心。我不是一个人。\\n　是和大家一起合作的」",null,null,null],["69_TEXT","69_TEXT",null,null,null],["「……そこは安心出来るポイントか？」","「……那是能让人放心的地方吗？」",null,null,null],["70_TEXT","70_TEXT",null,null,null],["「それって、安全は保証されてるの」","「那个，有安全保障吗」",null,null,null],["71_TEXT","71_TEXT",null,null,null],["「いや全然。ちゃんと怪我もしますよ。\\n　危険手当もでませんし」","「不，完全没有。也会好好受伤的哦。\\n　还拿不到危险津贴」",null,null,null],["72_TEXT","72_TEXT",null,null,null],["「後は亡者の方をバッグに入れたり。\\n　結構人体の重量ってキツイんですよね」","「之后还要把亡者塞进背包里。\\n　人体的分量，说真的，相当累人」",null,null,null],["73_TEXT","73_TEXT",null,null,null],["「そのくせ物凄く歩かせるから、\\n　働き始めた頃は毎晩足に豆が出来て」","「偏偏还要让人走那么多路，\\n　刚开始干那阵子，每晚脚上都磨出水泡」",null,null,null],["74_TEXT","74_TEXT",null,null,null],["「……」","「……」",null,null,null],["75_TEXT","75_TEXT",null,null,null],["「あ、すいません忘れてました。\\n　お茶、すぐに持ってきますね」","「啊，对不起我忘了。\\n　茶马上给您端来」",null,null,null],["82_TEXT","82_TEXT",null,null,null],["「そう言えばお客さん、\\n　以前どこかでお見かけしたような」","「说起来，这位客人，\\n　总觉得以前在哪里见过似的」",null,null,null],["83_TEXT","83_TEXT",null,null,null],["「……あれ、居ない」","「……咦，不在了」",null,null,null],["94_TEXT","94_TEXT",null,null,null],["「ただいまー。……ン、お茶？\\n　客がいたのか」","「我回来啦——。……嗯，茶？\\n　有客人来过吗」",null,null,null],["95_TEXT","95_TEXT",null,null,null],["「うーん。多分ひやかし……ですかね？」","「嗯——。多半是来随便逛逛……的吧？」",null,null,null]],"type":"","context":[["unique0151.uasset.csv/row/104","unique0151.uasset.csv/row/115","unique0151.uasset.csv/row/126","unique0151.uasset.csv/row/137","unique0151.uasset.csv/row/148","unique0151.uasset.csv/row/159","unique0151.uasset.csv/row/170","unique0151.uasset.csv/row/181","unique0151.uasset.csv/row/192","unique0151.uasset.csv/row/203","unique0151.uasset.csv/row/214","unique0151.uasset.csv/row/225","unique0151.uasset.csv/row/236","unique0151.uasset.csv/row/247","unique0151.uasset.csv/row/258","unique0151.uasset.csv/row/269","unique0151.uasset.csv/row/280","unique0151.uasset.csv/row/291","unique0151.uasset.csv/row/302","unique0151.uasset.csv/row/313","unique0151.uasset.csv/row/324","unique0151.uasset.csv/row/335","unique0151.uasset.csv/row/346","unique0151.uasset.csv/row/357","unique0151.uasset.csv/row/368","unique0151.uasset.csv/row/379","unique0151.uasset.csv/row/390","unique0151.uasset.csv/row/401","unique0151.uasset.csv/row/412","unique0151.uasset.csv/row/423","unique0151.uasset.csv/row/434","unique0151.uasset.csv/row/445","unique0151.uasset.csv/row/456","unique0151.uasset.csv/row/467","unique0151.uasset.csv/row/478","unique0151.uasset.csv/row/489","unique0151.uasset.csv/row/500","unique0151.uasset.csv/row/511","unique0151.uasset.csv/row/522","unique0151.uasset.csv/row/541","unique015