9B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/01_Main/01_02_Ichinose.uasset.csv","tags":[],"progress":{"translated":149,"length":149,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/01_Main/01_03_Jigoku.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/01_Main","basename":"01_03_Jigoku.uasset.csv","extension":"csv","filename":"01_03_Jigoku.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/01_Main/01_03_Jigoku.uasset.csv","data":[["01_03_Jigoku","01_03_Jigoku",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「ふわーぁー……ねむ」","「呼啊～……好困……」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「寝る前に一旦ゲームのレアドロ狙おうと思ったけど、\\n眠すぎて集中力ないわ」","「睡前本来想刷个稀有掉落，\\n但太困了根本集中不了注意力。」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「よく考えたらゲームでレアアイテム持ってても、\\nなんの意味も持たないしな」","「仔细想想，就算游戏里拿着稀有道具，\\n其实也什么用都没有。」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「いやそれを言い出したらこの目に映るもの、\\n全てにそもそも意味なんてないのか……？」","「不，要是这么一说，眼前看到的这一切，\\n难道本来也就毫无意义……？」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「なんて思考に至ったら眠気が限界な証拠。\\nおやすみ世界」","「能想到这种地步，就证明困到极点了。\\n晚安，世界。」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「……」","「……」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「…………」","「…………」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["（ふふふ、おじゃましまぁーす）","（呵呵呵，打扰啦～）",null,null,null],["33_TEXT","33_TEXT",null,null,null],["（よく寝ておるわ、無警戒に。\\nこれぞまな板の上のシャケ）","（睡得好熟，警惕性真差。\\n这简直就是砧板上的鲑鱼。）",null,null,null],["34_TEXT","34_TEXT",null,null,null],["（む？　なまずだっけ？）","（嗯？是鲶鱼来着？）",null,null,null],["35_TEXT","35_TEXT",null,null,null],["（まな板の上に……シャケは……でかいような……）","（砧板上的……鲑鱼……好像有点大……）",null,null,null],["36_TEXT","36_TEXT",null,null,null],["（まあいいかシャケでも寒ブリでも）","（算了，不管是鲑鱼还是寒鲥鱼都行）",null,null,null],["37_TEXT","37_TEXT",null,null,null],["（……ぬきあし、さしあし……）","（……蹑手蹑脚、轻手轻脚……）",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「どりゃー！」","「嘿呀！」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「ぎゃあ！　なんだ！？」","「哇啊！怎么回事！？」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「ふははは！　今日こそ、ねんぐの収め時！」","「哈哈哈哈！今天就是收年贡的时候！」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「ねんぐって何だ！？」","「你说的年贡是什么啊！？」",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「公使！　おめえよう！\\nまた入り込んできやがって！」","「公使！又是你这家伙！\\n又钻进来了！」",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「入り込むとはなんだ人をコバエみたいに」","「什么叫钻进来啊，说得人跟小飞虫似的」",null,null,null],["47_TEXT","47_TEXT",null,null,null],["「まあまあ、理解っている理解っている」","「行啦行啦，我懂的我懂的」",null,null,null],["48_TEXT","48_TEXT",null,null,null],["「何がだよ！？」","「你懂什么啊！？」",null,null,null],["49_TEXT","49_TEXT",null,null,null],["「ヤツシロのようなヤツのこと、\\nツンデレと言うのだろ？」","「像8246这样的家伙，\\n就是所谓的傲娇吧？」",null,null,null],["50_TEXT","50_TEXT",null,null,null],["「気になるあの子にかまってもらえて嬉しいのに、\\n素直に喜べないかわいいヤツ」","「明明很高兴在意的人搭理自己，\\n却没法坦率高兴起来的可爱家伙。」",null,null,null],["51_TEXT","51_TEXT",null,null,null],["「なんだこいつ」","「这家伙在说什么。」",null,null,null],["52_TEXT","52_TEXT",null,null,null],["「我の魅惑なボディにメロメロで、\\n本当はヨバイされたいのに」","「被我这魅惑的身体迷得神魂颠倒，\\n其实很想夜袭我的吧。」",null,null,null],["53_TEXT","53_TEXT",null,null,null],["「どうしても強がっちゃうんだよね、\\n　理解る理解る」","「可就是忍不住逞强嘛，\\n　我懂我懂。」",null,null,null],["54_TEXT","54_TEXT",null,null,null],["「はんっ誰がおめーみたいなお子様体型に」","「哼，谁会对你这幼儿体型」",null,null,null],["56_TEXT","56_TEXT",null,null,null],["「一体何の騒ぎなんですかー」","「到底在吵什么啊～」",null,null,null],["57_TEXT","57_TEXT",null,null,null],["「きゃー！　何深夜にくっついてるんですか二人共！\\n　ハレンチー！」","「呀—！你们俩大半夜的贴在一起做什么！\\n 不知羞耻—！」",null,null,null],["58_TEXT","58_TEXT",null,null,null],["「はいはい、もうそれはいいから」","「好了好了，那种事就别提了。」",null,null,null],["59_TEXT","59_TEXT",null,null,null],["「お約束だからやっておこうかと」","「因为像是定番的桥段，就想着得做一做。」",null,null,null],["60_TEXT","60_TEXT",null,null,null],["「こんなガキが夜に部屋を来た事なんて\\n　昼下がりのティータイムぐらいなんでもない事だぞ」","「像这样的小鬼晚上跑来我房间，\\n就跟午后喝茶一样不值一提。」",null,null,null],["61_TEXT","61_TEXT",null,null,null],["「ふむ？　だが良いのか？　ヤツシロ。そんな態度で」","「嗯？但这样好吗？8246。这种态度。」",null,null,null],["62_TEXT","62_TEXT",null,null,null],["「なにぃ？」","「什么？」",null,null,null],["66_TEXT","66_TEXT",null,null,null],["「我もあと数年、いやさ或いは数ヶ月あれば、\\n街を行く全ての男が振り返るバインバインに」","「我呀，再过几年，不，甚至几个月，\\n就能长成街上所有男人都会回头的凹凸有致。」",null,null,null],["67_TEXT","67_TEXT",null,null,null],["「この小さなボディに無限大の可能性。\\nふはは、そうなったらやばいぞ」","「这副娇小身躯拥有无限可能。\\n哈哈哈，到那时候可就不妙了哦。」",null,null,null],["68_TEXT","68_TEXT",null,null,null],["「『お、お願いだ公使！　俺にかまってくれー！』\\nなどと無様に懇願するサマが目に浮かぶぞ」","「『哦、哦，求你了，公使！　多搭理搭理我吧！』\\n他那副狼狈恳求的惨样，我都能想象出来」",null,null,null],["69_TEXT","69_TEXT",null,null,null],["「『ふぅ……ごめんなさいねヤツシロさん。\\n今日は他の方とのヨバイの予定があるの』」","「『唉……对不起啊，8246。\\n今天我已经预定要和别人夜袭了』」",null,null,null],["70_TEXT","70_TEXT",null,null,null],["「『もうこのバインバインは\\nあなただけのものではないの……ヨ』」","「『这对波涛汹涌的宝贝\\n已经不是你一个人的了……哟』」",null,null,null],["71_TEXT","71_TEXT",null,null,null],["「『そ、そんなぁあ！\\n俺を！　俺を許してくれぇえええええ！！』」","「『怎、怎么会这样！\\n求求你了！　原谅我吧啊啊啊啊啊！！』」",null,null,null],["72_TEXT","72_TEXT",null,null,null],["「ふふふ、どうしようかなあ許そうかなあ。\\nそれもこれも今のヤツシロの態度次第！」","「嘿嘿嘿，怎么办呢，要不要原谅他呢。\\n这一切，都看你现在的态度了，8246！」",null,null,null],["75_TEXT","75_TEXT",null,null,null],["「なんて図々しい妄想を膨らませている、\\n身の丈知らずのガキがいるわけだが」","「然而，有个不知天高地厚的小鬼，\\n居然膨胀出如此厚颜无耻的妄想」",null,null,null],["76_TEXT","76_TEXT",null,null,null],["「どんだけ成長の二文字に期待を抱いてんだ。\\nアヒルは育っても白鳥にはなれないぞ」","「他对「成长」这两个字抱了多大期待啊。\\n鸭子再怎么长，也变不成白天鹅哦」",null,null,null],["77_TEXT","77_TEXT",null,null,null],["「取り逃がした魚はデカいというやつだ。\\nたぶん寒ブリ」","「这就叫，跑掉的鱼总是觉得特别大。\\n大概说的是寒鰤鱼吧」",null,null,null],["78_TEXT","78_TEXT",null,null,null],["「そ、そうですよヤツシロさん！\\n女の子の可能性はムゲンダイなんですからね！」","「对、对啊8246先生！\\n女孩子的可能性，可是无限大的啊！」",null,null,null],["79_TEXT","79_TEXT",null,null,null],["「あ、そっち側の人」","「啊，你是站她那边的」",null,null,null],["80_TEXT","80_TEXT",null,null,null],["「はぁー。我の足元に惨めに這いつくばって、\\n寵愛を懇願する姿が見える見える」","「哈啊～。我能看到，能看到你\\n可怜兮兮地匍匐在我脚下，乞求宠爱的模样」",null,null,null],["81_TEXT","81_TEXT",null,null,null],["「どんな美女が相手でも\\nそこまではしねえわ」","「就算对方是再美的美女，\\n我也绝对做不出那种事」",null,null,null],["82_TEXT","82_TEXT",null,null,null],["「我にはしてしまうの。\\nだって傾国してしまうレベルの美女だから」","「对我你就会哦。\\n因为我是那种会让你倾国倾城级别的大美女嘛」",null,null,null],["83_TEXT","83_TEXT",null,null,null],["「ず、図々しい～～」","「好、好厚的脸皮～～」",null,null,null],["84_TEXT","84_TEXT",null,null,null],["「まあ確かにそこまでバインバインになれば、\\n俺も態度を改める必要があるが」","「嘛，要是真能变得那么波涛汹涌，\\n我倒也确实得改变下态度了」",null,null,null],["85_TEXT","85_TEXT",null,null,null],["「うーん正直」","「唔，真老实啊」",null,null,null],["86_TEXT","86_TEXT",null,null,null],["「なにせ現状がこのちんちくちんどん屋だしなあ。\\nにんともかんとも」","「毕竟现在这副德性，就是个敲锣打鼓的小不点嘛。\\n真是让人无可奈何」",null,null,null],["87_TEXT","87_TEXT",null,null,null],["「ふふふ、そうは言っているがなあ、ヤツシロ」","「呵呵呵，话虽这么说，8246啊」",null,null,null],["93_TEXT","93_TEXT",null,null,null],["「我はこれも知っているのだ」","「我也知道这个哦」",null,null,null],["94_TEXT","94_TEXT",null,null,null],["「お子様体型だちんちくりんだと\\n斜に構えておるが」","「说什么「幼儿体型」「矮冬瓜」，\\n摆出一副不以为然的冷淡样子」",null,null,null],["95_TEXT","95_TEXT",null,null,null],["「実は結構しっかり反応している事を！」","「其实啊，身体反应还是挺老实的！」",null,null,null],["96_TEXT","96_TEXT",null,null,null],["「な、なにぃー！」","「什、什么——！」",null,null,null],["97_TEXT","97_TEXT",null,null,null],["「リアクション役しなくて良いから」","「你不用跑出来当吐槽役啦」",null,null,null],["98_TEXT","98_TEXT",null,null,null],["「大体、そんな証拠はない！\\n確かにちょっとばかりストライクゾーンは広いが」","「总之，你没证据！\\n确实我的好球带是稍微宽了那么一点啦」",null,null,null],["99_TEXT","99_TEXT",null,null,null],["「ほれそのクローゼットの隙間に隠してある本。\\n　なんといったかな、ぷち……」","「瞧，藏在你那个壁橱缝隙里的书。\\n叫什么来着，小……噗嗤」",null,null,null],["100_TEXT","100_TEXT",null,null,null],["「ぎゃー！　プライバシーノー！」","「呀啊！　我的隐私荡然无存——！」",null,null,null],["101_TEXT","101_TEXT",null,null,null],["「……ヤツシロさん？」","「……8246先生？」",null,null,null],["102_TEXT","102_TEXT",null,null,null],["103_TEXT","103_TEXT",null,null,null],["「ふはは、本当は我のようなお子様体型が、\\n目ん玉ひん剥くぐらい好きなくせにー」","「噗哈哈，其实你啊，喜欢我这种幼儿体型，\\n喜欢到眼珠子都要掉出来了，还在这儿装！」",null,null,null],["104_TEXT","104_TEXT",null,null,null],["105_TEXT","105_TEXT",null,null,null],["「灯！　さりげにガード固めてんじゃねえ！」","「阿灯！　你别若无其事地加强防守！」",null,null,null],["106_TEXT","106_TEXT",null,null,null],["「こやつはバインバインでもお子様でも構わん、\\n節操なしというわけだな」","「这家伙，是波涛汹涌也好，幼儿体型也罢，都无所谓，\\n真是个毫无节操的家伙啊」",null,null,null],["107_TEXT","107_TEXT",null,null,null],["「仕方がないなあ。\\n今の我と未来の我で、両方欲を満たしてやるとするか」","「真拿你没办法啊。\\n那就让现在的我和未来的我，一起满足你的欲望吧」",null,null,null],["108_TEXT","108_TEXT",null,null,null],["「うるせえよ！」","「吵死了！」",null,null,null],["109_TEXT","109_TEXT",null,null,null],["「……節操なし」","「……毫无节操」",null,null,null]],"type":"","context":[["01_03_Jigoku.uasset.csv/row/104","01_03_Jigoku.uasset.csv/row/115","01_03_Jigoku.uasset.csv/row/126","01_03_Jigoku.uasset.csv/row/137","01_03_Jigoku.uasset.csv/row/148","01_03_Jigoku.uasset.csv/row/239","01_03_Jigoku.uasset.csv/row/258","01_03_Jigoku.uasset.csv/row/277","01_03_Jigoku.uasset.csv/row/288","01_03_Jigoku.uasset.csv/row/299","01_03_Jigoku.uasset.csv/row/310","01_03_Jigoku.uasset.csv/row/321","01_03_Jigoku.uasset.csv/row/332","01_03_Jigoku.uasset.csv/row/343","01_03_Jigoku.uasset.csv/row/378","01_03_Jigoku.uasset.csv/row/389","01_03_Jigoku.uasset.csv/row/400","01_03_Jigoku.uasset.csv/row/411","01_03_Jigoku.uasset.csv/row/422","01_03_Jigoku.uasset.csv/row/433","01_03_Jigoku.uasset.csv/row/444","01_03_Jigoku.uasset.csv/row/455","01_03_Jigoku.uasset.csv/row/466","01_03_Jigoku.uasset.csv/row/477","01_03_Jigoku.uasset.csv/row/488","01_03_Jigoku.uasset.csv/row/499","01_03_Jigoku.uasset.csv/row/510","01_03_Jigoku.uasset.csv/row/529","01_03_Jigoku.uasset.csv/row/540","01_03_Jigoku.uasset.csv/row/551","01_03_Jigoku.uasset.csv/row/562","01_03_Jigoku.uasset.csv/row/573","01_03_Jigoku.uasset.csv/row/584","01_03_Jigoku.uasset.csv/row/595","01_03_Jigoku.uasset.csv/row/630","01_03_Jigoku.uasset.csv/row/641","01_03_Jigoku.uasset.csv/row/652","01_03_Jigoku.uasset.csv/row/663","01_03_Jigoku.uasset.csv/row/674","01_03_Jigoku.uasset.csv/row/685","01_03_Jigoku.uasset.csv/row/696","01_03_Jigoku.uasset.csv/row/723","01_03_Jigoku.uas