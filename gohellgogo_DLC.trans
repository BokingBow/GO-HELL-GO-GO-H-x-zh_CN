t":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/03_Kenne/03_Kenne01.uasset.csv","tags":[],"progress":{"translated":115,"length":115,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/03_Kenne/03_Kenne02.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/03_Kenne","basename":"03_Kenne02.uasset.csv","extension":"csv","filename":"03_Kenne02.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/03_Kenne/03_Kenne02.uasset.csv","data":[["03_Kenne02","03_Kenne02",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「ひぃー小便小便」","「咻——小便小便」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「この前は変な姉ちゃんに邪魔されたからな。\\n　次こそは新築のトイレを味わう」","「上次被奇怪的姐们儿给搅和了。\\n　下次一定要享受下崭新的厕所」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「ここは公衆便所ではないがのぉ」","「这儿可不是公共厕所啊」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「げぇ！　懸衣サン！」","「嘎！　悬衣大姐！」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「……ふふ」","「……呵呵」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「何でご機嫌なんですか？」","「您心情怎么这么好啊？」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「顔を見られただけで悲鳴。\\n　人に畏怖されるのはたまらん事よ。違うか？」","「光是被看到脸就听到惨叫。\\n　被人畏惧可是件爽得不行的事。不是吗？」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「……結構、エスの人なんすね」","「……您挺S的啊」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「性的アプローチの話ならドが付くMよ。\\n　痛いのとかより精神的に心折られるのに来る」","「要是说性方面的，我可是超M。\\n　比起肉体疼痛，我更对精神上被彻底击垮这种事有感觉」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「凄えなこの人無敵かよ」","「厉害啊这人无敌的吗」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「性的な話題なら今一番気になっている事が\\n　あるんじゃがのぉ」","「说到性话题啊，现在最在意的事情\\n　人家倒是有哦～」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「広げるな広げるなそのTalk Themeを」","「别扩散别扩散那个谈话主题」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「うちは童貞を煽られる性的な\\n　展開が基本的に大好きじゃろ？」","「咱啊，最喜欢那种被人拿处男开涮的\\n　色色的展开了吧？」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「知らねえよ。あのほんと。知らねえ」","「不知道啦。啊那个真的。不知道」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「っぱ男連中はよぉ、脱童貞をしちまうと、\\n　童貞煽りに興奮しなくなっちまうんけ？」","「就是说啊，男人这种东西啊，\\n　一脱了处，不就没法靠被处男怼兴奋了嘛？」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「ほいじゃあつまらんよのぉ！\\n　童貞卒業と引き換えに童貞煽りを失うなんてよぉ！」","「那不就无聊死了嘛！\\n　毕业处男换来失去处男梗什么的！」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「ひぃいーーっ。この人こわすぎるずっと」","「噫咿咿——。这人一直都太可怕了」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「はぁー。うちは女でよかった。\\n　童貞を失う事はないけのぉ」","「哈——。咱当女人真好。\\n　才不会丢了处男之身啊」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「恐ろしい程の矛盾を感じやすが、\\n　まースルーします」","「感觉能感受到可怕的矛盾，\\n　不过我就先无视吧」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「そうだ、ヤツシロくん。じゃったろ？\\n　あの後、おどれの事ォ調べたんじゃがの」","「对了，八津同学。是吗？\\n　那之后啊，我查了一下你的事呢」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「きさんのトコから流れてくる亡者は、興味を惹く」","「从你那块儿流过来的亡者，勾起了我的兴趣」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「……へ？」","「……哈？」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「面白いものが多いけ。\\n　なかなかに、気に入った」","「因为有意思的家伙很多嘛。\\n　很合我胃口」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「なぜか女子に偏っているところの\\n　事情はわからんがのー」","「虽然不知为什么偏向女性那边是\\n　什么情况啦～」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「それは俺のポリシーなんで」","「那是我的原则」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「自己規範か。よい。\\n　おどれの中に境界の無い者は霞と変わらん」","「自我规范吗。挺好。\\n　你里面没有边界的东西就跟雾一样没两样」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「それよか、ヤツシロくん。\\n　何かここに用事があるんやないんけ」","「比起那个，八津同学。\\n　你在这边有什么要办的事吗」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「あ、そうでした。トイレを借りようと思ってて」","「啊，没错。我想借用一下厕所」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「真に便所だけを借りに来たんけ。\\n　妙な奴じゃのう」","「还真的就只来借个厕所啊。\\n　怪人一个啊」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「便所はこっちじゃ。行こか」","「厕所这边。走吧」",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「……何で懸衣サンも来るんすか」","「……为什么悬衣小姐您也跟来啊」",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「ン？　そう言えば人間が小便する所を、\\n　観察したことないなーと思って」","「嗯？这么说起来，人类撒尿的地方，\\n　我好像从来没观察过，这么一想」",null,null,null],["47_TEXT","47_TEXT",null,null,null],["「見せないよ！？　どんな行動原理だよ！？」","「不会给你看的好吗！？什么行动原理啊！？」",null,null,null],["48_TEXT","48_TEXT",null,null,null],["「感情としてはバードウォッチングとか\\n　工場見学に近い」","「心情上近似于观鸟或者\\n　参观工厂」",null,null,null],["49_TEXT","49_TEXT",null,null,null],["「ひっ。強い動機ですらない」","「咿。连强大的动机都算不上啊」",null,null,null],["50_TEXT","50_TEXT",null,null,null],["「あと、今日の絵日記に描く、\\n　エピソードも何かほしかったし」","「还有，今天要写的绘画日记，\\n　也缺了点想画的段子」",null,null,null],["51_TEXT","51_TEXT",null,null,null],["「す、すんません。やっぱトイレは良いっすわ！\\n　これにて失礼しますー！」","「不、不好意思。我还是不用厕所了！\\n　就此告辞——！」",null,null,null]],"type":"","context":[["03_Kenne02.uasset.csv/row/112","03_Kenne02.uasset.csv/row/123","03_Kenne02.uasset.csv/row/142","03_Kenne02.uasset.csv/row/153","03_Kenne02.uasset.csv/row/164","03_Kenne02.uasset.csv/row/175","03_Kenne02.uasset.csv/row/186","03_Kenne02.uasset.csv/row/197","03_Kenne02.uasset.csv/row/208","03_Kenne02.uasset.csv/row/219","03_Kenne02.uasset.csv/row/230","03_Kenne02.uasset.csv/row/241","03_Kenne02.uasset.csv/row/252","03_Kenne02.uasset.csv/row/263","03_Kenne02.uasset.csv/row/274","03_Kenne02.uasset.csv/row/285","03_Kenne02.uasset.csv/row