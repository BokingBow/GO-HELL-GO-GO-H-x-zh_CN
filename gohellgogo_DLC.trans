,[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/06_Norimaki/unique1111.uasset.csv","tags":[],"progress":{"translated":100,"length":100,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/06_Norimaki/unique1121.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/06_Norimaki","basename":"unique1121.uasset.csv","extension":"csv","filename":"unique1121.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/06_Norimaki/unique1121.uasset.csv","data":[["unique1121","unique1121",null,null,null],["12_TEXT","12_TEXT",null,null,null],["「ぜえ……ぜえ……ぜえ……。\\n　いかん。ガチで。ガチで逝くかと思った……」","「呼……呼……呼……。\\n　不行了。真的。真的差点以为要过去了……」",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「お、のりまき。戻ってきたんか。\\n　お疲れ～」","「哦，海苔卷。回来了啊。\\n　辛苦了～」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「お、お疲れ様です……ディレクターさん……。\\n　このロケ、ちょっと過酷過ぎませんか」","「辛、辛苦了……导演……。\\n　这个外景，是不是有点太残酷了」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「これ実はロケじゃなくて、\\n　ガチの地獄なんよね」","「其实这根本不是外景，\\n　是真的地狱哦」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「えっ」","「诶」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「きょろきょろ」","「东张西望」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「ま、まさかまだカメラ回ってます……？」","「该、该不会摄影机还开着……？」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「……大変だなあ、\\n　日頃からドッキリかけられまくってる人たちって」","「……真辛苦啊，\\n　那些整天被人各种整蛊的人」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「カメラとかはないよ」","「没有摄影机什么的哦」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「……あ、そうなんだ」","「……啊，是吗」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「なんかがっかりしてるな」","「怎么感觉你有点失望啊」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「……カメラがあったら今のくだりも、\\n　実は美味しいと思ってた？」","「……要是有摄像机的话，刚才那段，\\n　其实你是觉得很好吃吧？」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「はい！　この手のキャラは、\\n　本人が意図的に演じているという構造が\\n　崩れた瞬間が1番面白いですからね！」","「对！毕竟这种角色啊，\\n　一旦自己刻意在演的结构\\n　崩坏的那一瞬间才是最有趣的嘛！」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「じ、自己分析までバッチリなのかよ……」","「你、你居然连自我分析都那么透彻啊……」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「いやあしかしさっきのドッキリびびりましたよ。\\n　あんな大掛かりなモノ久々に見ました」","「哎呀不过刚才的整人环节可把我吓坏了。\\n　好久没见到那么大阵仗的东西了」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「……ガチで死ぬかと思いましたけど。\\n　あれ、専門家の指導入ってるんです？」","「……我还真以为自己要死了。\\n　那个，是有专家指导的吗？」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「あー、まあ。\\n　責め苦の専門家が作ったヤツだとは思うけど」","「啊，算是吧。\\n　我想那大概是拷问专家做出来的玩意」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「ヒエ～～。ガチなんですね、やばー」","「咿——。来真的啊，太吓人了吧」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「やっぱああいうのってやられてる最中は\\n　マジでスタッフ側に殺意湧くんですけど」","「果然在被搞那种东西的时候啊，\\n　真的会想对工作人员冒出杀意的」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「終わってみると、\\n　やり遂げた多幸感でいっぱいになりますね」","「不过结束后一看，\\n　又会充满了完成任务般的幸福感呢」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「あたし、この時の為にテレビでてるな、って思います」","「我就觉得，我上电视就是为了这一刻啊」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「……俺はもしかして、\\n　とんでもない才能人と接しているのか？　今」","「……我该不会，\\n　正在和一个超级有才的人打交道吧？现在」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「ディレクターさんから見て、\\n　どうでしたか？　私のリアクション！」","「从导演的角度来看，\\n　觉得怎么样？我给出的反应！」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「カメラの位置分からなかったので、\\n　結構手探りだったんですが」","「因为不知道摄像机的位置，\\n　所以基本都是凭感觉摸索的来着」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「……良かったんじゃないかな……？\\n　いや、うん。あんまりわからんけど」","「……不是挺好的吗……？\\n　哎呀，嗯。我也不太懂啦」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「だってここテレビじゃなくて、\\n　ガチの地獄の責め苦だし」","「毕竟这又不是上电视，\\n　而是真真正正的地狱拷责啊」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「あはは！　設定しっかりしてますねー！\\n　あたし、そういうの大好きですよ！」","「啊哈哈！你这设定做得还挺认真啊—！\\n　我啊，最喜欢这种了哦！」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「これからも一緒に、\\n　がんばっていきましょー！」","「今后也让我们一起，\\n　加油努力吧—！」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「まあ頑張ってくれるなら、\\n　なんでもいいっちゃいいんだけどさ」","「哎，只要你肯好好干的话，\\n　我倒是怎么样都无所谓的」",null,null,null]],"type":"","context":[["unique1121.uasset.csv/row/96","unique1121.uasset.csv/row/107","unique1121.uasset.csv/row/118","unique1121.uasset.csv/row/129","unique1121.uasset.csv/row/140","unique1121.uasset.csv/row/151","unique1121.uasset.csv/row/162","unique1121.uasset.csv/row/173","unique1121.uasset.csv/row/184","unique1121.uasset.csv/row/195","unique1121.uasset.csv/row/206","unique1121.uasset.csv/row/217","unique1121.uasset.csv/row/228","unique1121.uasset.csv/row/239","unique1121.uasset.csv/row/250","unique1121.uasset.csv/row/261","unique1121.uasset.csv/row/272","unique1121.uasset.csv/row/283","unique1121.uasset.csv/row/294","unique1121.uasset.csv/row/305","unique1121.uasset.csv/row/316","unique1121.uasset.csv/row/327","unique1121.uasset.csv/row/338","unique1121.uasset.csv/row/349","unique1121.uasset.csv/row/360","unique1121.uasset.csv/row/371","unique1121.uasset.csv/row/382","unique1121.uasset.csv/row/393","unique1121.uasset.csv/row/404"],["unique1121.uasset.csv/row/97"],["unique1121.uasset.csv/row/98"],["unique1121.uasset.csv/row/108"],["unique1121.uasset.csv/row/109"],["unique1121.uasset.csv/row/119"],["unique1121.uasset.csv/row/120"],["unique1121.uasset.csv/row/130"],["unique1121.uasset.csv/row/131"],["unique1121.uasset.csv/row/141"],["unique1121.uasset.csv/row/142"],["unique1121.uasset.csv/row/152"],["unique1121.uasset.csv/row/153"],["unique1121.uasset.csv/row/163"],["unique1121.uasset.csv/row/164"],["unique1121.uasset.csv/row/174"],["unique1121.uasset.csv/row/175"],["unique1121.uasset.csv/row/185"],["unique1121.uasset.csv/row/186"],["unique1121.uasset.csv/row/196"],["unique1121.uasset.csv/row/197"],["unique1121.uasset.csv/row/207"],["unique1121.uasset.csv/row/208"],["unique1121.uasset.csv/row/218"],["unique1121.uasset.csv/row/219"],["unique1121.uasset.csv/row/229"],["unique1121.uasset.csv/row/230"],["unique1121.uasset.csv/row/240"],["unique1121.uasset.csv/row/241"],["unique1121.uasset.csv/row/251"],["unique1121.uasset.csv/row/252"],["unique1121.uasset.csv/row/262"],["unique1121.uasset.csv/row/263"],["unique1121.uasset.csv/row/273"],["unique1121.uasset.csv/row/274"