"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/03_Kenne/03_Kenne05.uasset.csv","tags":[],"progress":{"translated":129,"length":129,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/03_Kenne/03_Kenne06.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/03_Kenne","basename":"03_Kenne06.uasset.csv","extension":"csv","filename":"03_Kenne06.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/03_Kenne/03_Kenne06.uasset.csv","data":[["03_Kenne06","03_Kenne06",null,null,null],["12_TEXT","12_TEXT",null,null,null],["「や……やっと、出来たぞ……！」","「终……终于，成了……！」",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「新築ピカピカの便所で！\\n　思う存分の排泄がー！」","「在崭新的亮晶晶的厕所里！\\n　尽情地排泄——！」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「そんな喜ぶことけ？」","「至于高兴成这样吗？」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「ぎゃ！　懸衣サン！\\n　だってアンタ、いつもいるから！」","「哇！悬衣小姐！\\n　还不是因为，你老在啊！」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「ここは公衆便所ではないんやがのう」","「这里可不是公共厕所啊」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「……くっ……ぷぷっ」","「……噗……噗噗」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「え、どこで笑ってるんすか」","「呃，你在笑什么啊」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「ふふ、いやー？　別に。ま、おどれで話して、\\n　アホかと思うてしもうたわい」","「呵呵，没有啦——？没什么。就是听你小子这么说，\\n　觉得太蠢了罢了」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「ここが公衆便所と、\\n　ふふ…なんぞ違うんか思うてのぉ……ふふ」","「这地方跟公共厕所有啥区别吗，\\n　噗……我这么想着就……噗噗」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「……マジで笑いのツボ、謎だな……この人」","「……笑点真心成谜啊……这人」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「謎なのは笑いのツボだけかい。\\n　おどれも難儀なやつじゃのぉ」","「你唯一令人费解的地方就是笑点。\\n　你这家伙也是个难缠的主儿啊。」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「…………」","「…………」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「おい、ヤツシロくん。\\n　ちょっと一服でも付き合わんか」","「喂，8246老弟。\\n　陪老朽去歇口气抽根烟如何？」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「一服も何も、ずっと吸ってるだろ？」","「什么歇口气，你不是一直在抽吗？」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「はは。煙を呑む事だけが、\\n　一服じゃあ思っとるんか。かわいいのう」","「哈哈。你以为只有吞云吐雾，\\n　才算歇口气吗？真是可爱啊。」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「ほら、行くぞ」","「行了，跟我来。」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「……ふぅーーー」","「……呼——」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「げほっげほっ」","「咳咳、咳咳！」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「なんだら？　きさん、煙ぃ食うんは初めてけ」","「咋啦？你小子，头一回抽烟啊？」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「初めてじゃないんだけど。\\n　久々に吸ったから」","「倒不是头一回。\\n　只是好久没抽了。」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「まずいなータバコ」","「真难抽啊，这烟。」",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「カッカッカ」","「嘎嘎嘎。」",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「のぉー。最近の巷は愉快じゃあ思わんか」","「我说啊。你不觉得最近这世道很有意思吗？」",null,null,null],["47_TEXT","47_TEXT",null,null,null],["「……そっすか？」","「……有吗？」",null,null,null],["48_TEXT","48_TEXT",null,null,null],["「誰かさんのせいかの……。\\n　地獄の空気が、変わってきたかもしれん」","「大概是托某个人的福吧……。\\n　这地狱的空气，或许开始变了。」",null,null,null],["49_TEXT","49_TEXT",null,null,null],["「はは、そうかあ？　まあでも、だとしても」","「哈哈，是这样吗？嘛，不过，即便是这样。」",null,null,null],["50_TEXT","50_TEXT",null,null,null],["「共犯ではあるくね？」","「你也算同谋吧？」",null,null,null],["51_TEXT","51_TEXT",null,null,null],["「うちはなんもしとらん。\\n　何かヤツシロくんとか言うやつに脅されただけで」","「我可什么都没干。\\n　只是被一个叫什么8246的家伙给胁迫了而已。」",null,null,null],["52_TEXT","52_TEXT",null,null,null],["「相変わらず責任は俺だけの物なんだ！？」","「到头来责任还全是我的啊！？」",null,null,null],["53_TEXT","53_TEXT",null,null,null],["「ンで？」","「所以呢？」",null,null,null],["54_TEXT","54_TEXT",null,null,null],["「きさんの目的は、結局なんなん」","「你小子搞这么多事，到底图个啥。」",null,null,null],["55_TEXT","55_TEXT",null,null,null],["「目的？」","「图个啥？」",null,null,null],["56_TEXT","56_TEXT",null,null,null],["「地獄をなんぞしたいのか。\\n　理、言うンが気に入らんのけ？」","「你想对地狱做什么吗。\\n　是看不惯所谓的‘理’吗？」",null,null,null],["57_TEXT","57_TEXT",null,null,null],["「ああー。そういうやつ？」","「啊啊。你问这个啊？」",null,null,null],["58_TEXT","58_TEXT",null,null,null],["「いや、俺は……別に……」","「不，我呢……倒也没特别……」",null,null,null],["59_TEXT","59_TEXT",null,null,null],["「難しい事は、しらんけど。\\n　だるいし。真面目な話はさあ……」","「太复杂的事，我不懂啦。\\n　而且也好麻烦。正经话题什么的……」",null,null,null],["60_TEXT","60_TEXT",null,null,null],["「まあでも」","「不过呢。」",null,null,null],["61_TEXT","61_TEXT",null,null,null],["「楽しい方が、良くね？」","「开心点，不是更好吗？」",null,null,null],["62_TEXT","62_TEXT",null,null,null],["「……」","「……」",null,null,null],["63_TEXT","63_TEXT",null,null,null],["「あんたも好きだろ、そういう方が」","「你也喜欢的吧，更开心点。」",null,null,null],["64_TEXT","64_TEXT",null,null,null],["「ふん」","「哼。」",null,null,null],["65_TEXT","65_TEXT",null,null,null],["「あんたも、もっと、そうしたら」","「你要是，也再放开些，那样的话。」",null,null,null],["66_TEXT","66_TEXT",null,null,null],["「…………すぅーー……はあ」","「…………嘶——……唉。」",null,null,null],["67_TEXT","67_TEXT",null,null,null],["「うちは、つまらん事は好かん。\\n　きっと、おどれと同じじゃろ。……じゃけどねぇ」","「老朽啊，不喜欢无聊的东西。\\n　想必，你也一样。……但是啊。」",null,null,null],["68_TEXT","68_TEXT",null,null,null],["「つまらん事を一切なくしてしまったら、\\n　全部がつまらんくなっちまうんよ」","「要是把无聊的事儿全给消灭了，\\n　那一切反而都会变得无聊透顶啊。」",null,null,null],["69_TEXT","69_TEXT",null,null,null],["「どっかでよぉ。線は引かにゃぁねぇ」","「总得有个度啊。\\n　得画条界线才行。」",null,null,null],["70_TEXT","70_TEXT",null,null,null],["71_TEXT","71_TEXT",null,null,null],["「だからよぉ、ヤツシロくん。\\n　おどれは、楽しいことをやりなよ」","「所以说啊，8246老弟。\\n　你呀，尽管去做些开心的事就好。」",null,null,null],["72_TEXT","72_TEXT",null,null,null],["「うちはここで、\\n　つまらんことをやり続けるさ」","「老朽呢，就在这里，\\n　继续做那些无聊的事吧。」",null,null,null],["73_TEXT","73_TEXT",null,null,null],["「……そっか」","「……这样啊。」",null,null,null],["74_TEXT","74_TEXT",null,null,null],["「大変だな、あんたって」","「你这人也真够辛苦的。」",null,null,null],["75_TEXT","75_TEXT",null,null,null],["「まあのう。そりゃ、互いにのう。だがよぉ」","「嘛，谁说不是呢。彼此彼此吧。不过啊。」",null,null,null],["76_TEXT","76_TEXT",null,null,null],["「大変じゃないやつなんてのが、\\n　この狂った浮世の、どこにおんのけ？」","「有不辛苦的人存在吗？\\n　在这疯狂的浮世之中，哪儿能找到呢？」",null,null,null],["77_TEXT","77_TEXT",null,null,null],["「そういうもんか」","「是这么回事吗。」",null,null,null],["78_TEXT","78_TEXT",null,null,null],["「どうかの。適当こいただけじゃけのう」","「谁知道呢。我也是随口瞎说的罢了。」",null,null,null],["79_TEXT","79_TEXT",null,null,null],["80_TEXT","80_TEXT",null,null,null],["「すぅー……はあ」","「嘶——……唉。」",null,null,null],["81_TEXT","81_TEXT",null,null,null],["「やっぱまずいわ。タバコって」","「果然不好抽啊。这烟。」",null,null,null]],"type":"","context":[["03_Kenne06.uasset.csv/row/96","03_Kenne06.uasset.csv/row/107","03_Kenne06.uasset.csv/row/118","03_Kenne06.uasset.csv/row/129","03_Kenne06.uasset.csv/row/140","03_Kenne06.uasset.csv/row/151","03_Kenne06.uasset.csv/row/162","03_Kenne06.uasset.csv/row/173","03_Kenne06.uasset.csv/row/184","03_Kenne06.uasset.csv/row/195","03_Kenne06.uasset.csv/row/206","03_Kenne06.uasset.csv/row/217","03_Kenne06.uasset.csv/row/228","03_Kenne06.uasset.csv/row/239","03_Kenne06.uasset.csv/row/250","03_Kenne06.uasset.csv/row/261","03_Kenne06.uasset.csv/row/368","03_Kenne06.uasset.csv/row/379","03_Kenne06.uasset.csv/row/390","03_Kenne06.uasset.csv/row/401","03_Kenne06.uasset.csv/row/412","03_Kenne06.uasset.csv/row/423","03_Kenne06.uasset.csv/row/434","03_Kenne06.uasset.csv/row/445","03_Kenne06.uasset.csv/row/456","03_Kenne06.uasset.csv/row/467","03_Kenne06.uasset.csv/row/478","03_Ken