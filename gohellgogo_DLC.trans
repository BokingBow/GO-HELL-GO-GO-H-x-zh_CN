_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/02_Arakasegi/02_Arakasegi06.uasset.csv","tags":[],"progress":{"translated":45,"length":45,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/01_Main/01_01_Tomori.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/01_Main","basename":"01_01_Tomori.uasset.csv","extension":"csv","filename":"01_01_Tomori.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/01_Main/01_01_Tomori.uasset.csv","data":[["01_01_Tomori","01_01_Tomori",null,null,null],["12_TEXT","12_TEXT",null,null,null],["「えへへーどら焼きおまけしてもらっちゃった。\\nあんこにチョコにカスタード～♪」","「嘿嘿嘿～铜锣烧还多送了我一个。\\n　红豆、巧克力、卡仕达酱～♪」",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「ヤツシロさんにも、お裾分けしちゃおっかなー」","「也分一点给8246大哥吧～」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「なんだかんだ、お世話になってるし。\\n最近、頑張ってるみたいだしー」","「毕竟受了您不少照顾。\\n　而且最近，看你好像也挺努力的嘛～」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「そろそろ戻ってくるかな？\\n先にお茶、煎れといてあげよー」","「差不多该回来了吧？\\n　我先去把茶泡好等他～」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「あ、きた――」","「啊，来了――」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「はい、どうどう。止まれーい」","「好了，吁——吁。给我停下」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「ぜえ……はあ……おらついたぞ事務所……。\\nさっさと、背中から降りろー」","「呼哧……呼……咱可算到事务所了……。\\n　赶紧的，快从我背上下来」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「いやじゃんけんに勝った方が10分馬って\\nルールだったでしょまだ早い」","「不行，赢的人当十分钟马，\\n　规则是这么定的吧，时间还没到呢」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「ほら、進め馬車馬～」","「来来，走起来啊，累死马儿～」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「………………」","「………………」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「はぁーきっつ。\\nお、トモリなに持ってんの。うまそ」","「哈——累死了。\\n　哦，灯你拿着什么啊。看起来好好吃」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「……ヤツシロさんには、あげません」","「……我不会分给8246你的」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「強奪するつもりはなかったけど、\\nそう言われると欲しくなる」","「虽然我没打算硬抢，\\n　但你这么一说我就反而想要了」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「なに、あんた。お腹すいてんの。\\nほら、飴ちゃんあるけど食べる？　あーん」","「怎么，你肚子饿啦？\\n　给，我这有糖，吃吗？啊——」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「さんきゅ。ころころ」","「谢了。嘎啦嘎啦」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「……！」","「……！」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「ヤツシロさん！　事務所では乗馬厳禁ですよ！\\n常識で考えて下さい常識で」","「8246先生！事务所内严禁骑马！\\n　请你用常识想想好不好，常识」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「確かに、そろそろ10分経つしな。\\nおら、降りろ」","「说的也是，差不多也快十分钟了。\\n　喂，给我下来」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「ぎゃっ。急に手を離すなっ」","「呀啊。你怎么突然撒手啊」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「ほら、どら焼きも分けてあげますから。\\n感謝して食べて下さい」","「你看，铜锣烧也会分给你的。\\n　给我感恩戴德地吃掉吧」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「さんきゅ。うまっ」","「谢啦。好吃」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「あ、ほら食べ残しついてますよ。\\nもーこういうとこ子どもみたいなんだから」","「啊，你看嘴上沾到东西了。\\n　真是的，这点跟个孩子似的」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「動かないでくださいねー。\\nはい、ふきふき」","「不要动哦。\\n　来，我给你擦擦」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「ヤツシロさあ、今夜暇？\\n美味しいご飯屋さん教えてもらったの。付き合え」","「话说8246啊，你今晚有空吗？\\n　有个朋友介绍了家好吃的店，陪我去吧」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「へえー、めずらしっ。まぁいいけど……」","「哦——，真少见啊。嗯也行吧……」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「ま、待って下さいヤツシロさん」","「请等一下，8246」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「今日私、2日間寝かせた、\\n最強のビーフシチューを作ったトコでして」","「我啊，今天刚好做好了，\\n　那个放了整整两天的，最强炖牛肉」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「……！　噂で聞いたことがある。\\n伝説の、あのシチュー……！？」","「……！我曾经听过传闻。\\n　传说级的那个炖牛肉……！？」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「今晩が一番美味しい所なのですが、\\nお外に行ってしまうんですか……？」","「今晚可是最美味的时候哦，\\n你难道要出去吗……？」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「ぐぬぬ……」","「唔唔唔……」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「……どっちにするの？　ヤツシロ。\\nまさか幼馴染を放っておかないよね」","「……你选哪边？8246。\\n总不会丢下青梅竹马不管吧？」",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「そうですよ。まさか大切な従業員を、\\nないがしろにしたりしないですよね」","「就是啊。总不会把重要的员工\\n不当一回事吧？」",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「な、なんだこの圧」","「这、这压力是怎么回事……」",null,null,null],["47_TEXT","47_TEXT",null,null,null],["「じゃあ間を取って、\\n3人で飯にするというのは……」","「那不如折中一下，\\n我们三个人一起吃饭如何……」",null,null,null],["48_TEXT","48_TEXT",null,null,null],["「はあああ？　あんたね、\\nどんだけ優柔不断なのよ！」","「哈啊啊啊？我说你啊，\\n得是有多优柔寡断啊！」",null,null,null],["49_TEXT","49_TEXT",null,null,null],["「そうですよ！　どっちにするのか、\\nちゃんと考えて選んで下さい！」","「就是啊！到底选哪边，\\n你给我好好想清楚了再选！」",null,null,null],["50_TEXT","50_TEXT",null,null,null],["「圧が……え、なに、この」","「压力……呃、什么啊、这是……」",null,null,null],["51_TEXT","51_TEXT",null,null,null],["「一ノ瀬さんはいつもずるいですよ！\\n何かにつけて幼馴染カード持ち出して！」","「一之濑你总是耍赖！\\n动不动就搬出青梅竹马这张牌！」",null,null,null],["52_TEXT","52_TEXT",null,null,null],["「はあああ！？　文句言いたいのは\\nこっちなんだけどね！」","「哈啊啊啊！？该抱怨的是\\n我这边好不好！」",null,null,null],["53_TEXT","53_TEXT",null,null,null],["「１つ同じ屋根の下で暮らして、\\n爛れた生活送ってるくせに！」","「明明你们住在同一个屋檐下，\\n过着那么糜烂的生活！」",null,null,null],["54_TEXT","54_TEXT",null,null,null],["「た、た、た、爛れてなんていません！」","「才、才、才、才没有糜烂！」",null,null,null],["55_TEXT","55_TEXT",null,null,null],["「まあまあ、落ち着けってお二人さん」","「好啦好啦，两位都冷静一点。」",null,null,null],["56_TEXT","56_TEXT",null,null,null],["「優柔不断のヤツシロさんは黙ってて下さい！」","「优柔寡断的8246你给我闭嘴！」",null,null,null],["57_TEXT","57_TEXT",null,null,null],["「そうよ、どっちつかずの男は黙ってろー！」","「没错，摇摆不定的男人给我闭嘴！」",null,null,null],["58_TEXT","58_TEXT",null,null,null],["「ひっ」","「噫！」",null,null,null],["59_TEXT","59_TEXT",null,null,null],["「……そろそろ、決着をつける必要がありそうね」","「……看来差不多该做个了断了。」",null,null,null],["60_TEXT","60_TEXT",null,null,null],["「……望むところです！」","「……正合我意！」",null,null,null],["65_TEXT","65_TEXT",null,null,null],["「らぁああああ！」","「啦啊啊啊啊！」",null,null,null],["67_TEXT","67_TEXT",null,null,null],["「とぉおおおお！」","「托噢噢噢噢！」",null,null,null],["76_TEXT","76_TEXT",null,null,null],["「なんでそうなるんだよおお！！」","「为什么会变成这样啊啊！！」",null,null,null],["77_TEXT","77_TEXT",null,null,null],["「だって良く考えたら、\\n全部ヤツシロさんのせいじゃないですかー！」","「因为仔细想想，\\n这不全都是8246你的错吗！」",null,null,null],["78_TEXT","78_TEXT",null,null,null],["「悪は成敗、しないとね！」","「恶即应斩，当然不能放过！」",null,null,null],["79_TEXT","79_TEXT",null,null,null],["「そのレスリングウェアは、\\nどこから生えてきたんだよ！？」","「你们那身摔跤服，\\n是从哪里冒出来的啊！？」",null,null,null],["80_TEXT","80_TEXT",null,null,null],["「はあああ！？　私達今、\\nそんな話してないんですけど！」","「哈啊啊啊！？我们现在\\n不是在聊那个好吗！」",null,null,null],["81_TEXT","81_TEXT",null,null,null],["「いっつもそうですよね！\\n曖昧な態度と話題転換でごまかして！」","「你每次都这样！\\n用暧昧的态度和转移话题来糊弄过去！」",null,null,null],["84_TEXT","84_TEXT",null,null,null],["「あががががが。し、締めすぎ締めすぎ……」","「啊嘎嘎嘎嘎。勒、勒太紧了勒太紧了……」",null,null,null],["85_TEXT","85_TEXT",null,null,null],["「そうだそうだー！」","「说得对说得对！」",null,null,null],["87_TEXT","87_TEXT",null,null,null],["「ぐええー！　逆！　足が逆に！\\nそっちは人間が曲げられる方向じゃないから！」","「呃诶诶！反了！脚反了！\\n那边不是人类能弯过去的方向啊！」",null,null,null],["88_TEXT","88_TEXT",null,null,null],["「今日が年貢の納め時なんじゃない？\\nいい加減、はっきりしたら！」","「今天是不是该算总账了？\\n差不多该给我说清楚了吧！」",null,null,null],["89_TEXT","89_TEXT",null,null,null],["「ぐ……ぐごご……ぐご……」","「咕……咕呃呃……咕呃……」",null,null,null],["90_TEXT","90_TEXT",null,null,null],["「あー！　さっきまで流暢に喋ってたのに、\\n急に苦しいふりしてるー！」","「啊！明明刚刚还说得那么流畅，\\n突然就装出一副难受的样子！」",null,null,null],["92_TEXT","92_TEXT",null,null,null],["「この女の敵、\\n流石に限界まで締め上げる必要がありそう」","「这个女人的敌人，\\n看来有必要把你绞到极限才行。」",null,null,null],["93_TEXT","93_TEXT",null,null,null],["「えぎっ、いや、違っ」","「呃唧、不是、不」",null,null,null],["96_TEXT","96_TEXT",null,null,null],["「おー！　ギブ！　ギブギブギブ！\\nロープ掴んだ！　掴んだから！」","「哦！认输！认输认输认输！\\n我碰到擂台绳了！碰到了啦！」",null,null,null],["97_TEXT","97_TEXT",null,null,null],["「ギブとかないですから！　ヤツシロさんに\\n残された選択肢は、“決断”それだけ！」","「没有认输这回事！留给8246你的\\n选项只有‘做出决断’这一个！」",null,null,null],["98_TEXT","98_TEXT",null,null,null],["「当然、こっちにするよね？\\nじゃないとこのアキレス腱をぉ……！」","「当然，你会选这边对吧？\\n不然你这跟腱，我可就要……！」",null,null,null],["101_TEXT","101_TEXT",null,null,null],["「ぎゃーーー！！　やめろー！」","「嘎啊啊！！住手啊！」",null,null,null],["102_TEXT","102_TEXT",null,null,null],["「いいえ、こっちですよね？\\nじゃないとこの頸動脈をぉ……！」","「不对，是这边对吧？\\n不然你的颈动脉可就……！」",null,null,null],["103_TEXT","103_TEXT",null,null,null],["「じゃあもう選択したら駄目じゃん俺！\\n選んだ瞬間どっちかの急所を失うじゃん！」","「那我不是根本没得选吗！\\n选完的瞬间两边都会没命啊！」",null,null,null],["104_TEXT","104_TEXT",null,null,null],["「全部、今までやってきたことの、\\nツケですからーーー！！」","「这一切，都是我之前所作所为的，\\n报应啊——！！」",null,null,null],["105_TEXT","105_TEXT",null,null,null],["「ぐ、ぐう……最初もちもちの肌に\\n触れられた時はラッキーな予感がしてたのに」","「呜、呜呜……一开始碰到那软弹的肌肤时，\\n我还以为要走桃花运了呢」",null,null,null],["106_TEXT","106_TEXT",null,null,null],["「結局こんな役回りかよ～～！」","「结果到头来居然是这种角色～～！」",null,null,null],["107_TEXT","107_TEXT",null,null,null],["「……なんか時間稼ぎしてません？　ずっと」","「……我说，你是不是一直在拖延时间啊？」",null,null,null],["108_TEXT","108_TEXT",null,null,null],["「…………シテナイヨ」","「…………才没有呢」",null,null,null],["109_TEXT","109_TEXT",null,null,null],["「も、もうゆるさーん！！」","「我、我饶不了你——！！」",null,null,null],["114_TEXT","114_TEXT",null,null,null],["「ぐぶっ」","「咕噗」",null,null,null],["116_TEXT","116_TEXT",null,null,null],["「抵抗は無駄ですよ！\\nこれが年貢の納め時ですから」","「抵抗是没用的！\\n因为现在该是你还债的时候了」",null,null,null],["117_TEXT","117_TEXT",null,null,null],["「ぐぶぶぶ……」","「咕噗噗噗……」",null,null,null],["119_TEXT","119_TEXT",null,null,null],["「さあ言ってください、\\n俺は灯を選ぶ一緒に生きていこうって」","「好了快说啊，\\n说你要选灯，和我一起活下去」",null,null,null],["121_TEXT","121_TEXT",null,null,null],["「ぐぶぶ……」","「咕噗噗……」",null,null,null],["124_TEXT","124_TEXT",null,null,null],["「べ、別に私も嫌々ですけど\\n吝かではなくしゃーなし付き合ってあげ……」","「我、我也不是非要怎样啦，\\n但也不是不能勉为其难地跟你交往一下……」",null,null,null],["127_TEXT","127_TEXT",null,null,null],["「……」","「……」",null,null,null],["128_TEXT","128_TEXT",null,null,null],["「……ヤツシロ、泡吹いてない？」","「……8246，你是不是在吐白沫了？」",null,null,null],["129_TEXT","129_TEXT",null,null,null],["「ほえ」","「诶」",null,null,null],["131_TEXT","131_TEXT",null,null,null],["「ひゃー！　大丈夫ですかー！？\\nちょ、ちょっと！　息、してくださーい！」","「呜哇——！你没事吧——！？\\n喂、喂！快呼吸啊——！」",null,null,null],["132_TEXT","132_TEXT",null,null,null],["「気を失ってまで、\\n優柔不断を貫くとは……」","「没想到你宁可昏过去，\\n也要把优柔寡断贯彻到底……」",null,null,null],["133_TEXT","133_TEXT",null,null,null],["「敵ながら、あっぱれなやつ……」","「虽然是敌人，倒也是条汉子……」",null,null,null]],"type":"","context":[["01_01_Tomori.uasset.csv/row/96","01_01_Tomori.uasset.csv/row/107","01_01_Tomori.uasset.csv/row/118","01_01_Tomori.uasset.csv/row/129","01_01_Tomori.uasset.csv/row/140","01_01_Tomori.uasset.csv/row/1