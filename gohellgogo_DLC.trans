"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/02_Arakasegi/02_Arakasegi04.uasset.csv","tags":[],"progress":{"translated":89,"length":89,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/02_Arakasegi/02_Arakasegi05.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/02_Arakasegi","basename":"02_Arakasegi05.uasset.csv","extension":"csv","filename":"02_Arakasegi05.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/02_Arakasegi/02_Arakasegi05.uasset.csv","data":[["02_Arakasegi05","02_Arakasegi05",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「……とかなんとか言ってたのに。\\n　今じゃこんな状況に」","「……虽然之前那样说。\\n　现在却落得这步田地」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「はあ、はあ」","「哈啊，哈啊」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「腐れ縁と言うか、\\n　どうしようもねーというか……」","「该说是孽缘呢，\\n　还是说真没救了……」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「くぉらアラカセギ！\\n　黄昏れてないで、お前も運ぶの手伝えや！」","「喂，荒稼！\\n　别在那儿发呆了，你也来帮忙搬啊！」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「うっさい。元凶のくせに。\\n　おめーがせこせこ働くんだよ！」","「吵死了。明明你才是罪魁祸首。\\n　你这家伙赶紧去埋头干活啦！」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「ちくしょー、なんでこんな事に」","「可恶，为什么会变成这样」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「絶対こっちの台詞だからな！？\\n　地獄ぶっ壊したお前のせいじゃ！」","「这绝对是该我说的台词吧！？\\n　还不都是你把地狱搞坏了的错！」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「アタシは順調に、\\n　お店の経営してたのによぉ！」","「我本来可是顺风顺水，\\n　好好地经营着店的啊！」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「それはゴメンつっただろー」","「关于那个我都道过歉了吧——」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「マジで殴ってやんなかっただけでも、\\n　感謝してほしいぐらいだぞ」","「我没真的揍你一顿，\\n　你都得好好感谢我了」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「とか言ってー。こっち来て初めて偶然会った時、\\n　俺の顔見て安心して泣いちゃったくせに」","「你嘴上这么说——。刚来这儿偶然碰见的时候，\\n　一看到我的脸你不就安心得哭了吗」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「殴って記憶飛ばそっかな」","「要不我揍到你失忆吧」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「脳味噌の構造ってそんなアニメみたいな\\n　感じじゃないから」","「脑子的构造才没那么像动画片里\\n　那样呢」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「こっちの仕事もなんだかんだ順調だし、\\n　新しい住処も見つかったしいいじゃん」","「这边的工作也进行得挺顺利的，\\n　还找到了新住处，不挺好的嘛」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「……まあなあ。あの時地獄から出た、\\n　アタシの判断は間違ってなかった、ガチで」","「……说得也是啊。那时候离开地狱，\\n　我的判断果然没错，真的」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「地獄の珍しいモンが現世でバカ高く売れるから、\\n　資産だけなら前よりずっと増えたし」","「地狱里的稀罕玩意儿，在现世能卖出天价，\\n　光是资产这块儿，就比以前富裕多了」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「やばめのコレクターの売買だから、\\n　あんまり表沙汰にはできないけどな」","「因为是卖给些不太妙的收藏家，\\n　所以不太好太张扬就是了」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「それが結構キツイんだよなあ」","「就这点最要命了啊」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「色々逃げたり隠れながらだから、\\n　落ち着けない毎日だし……」","「因为一路都在东躲西藏，\\n　每天都过不安稳嘛……」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「……やっぱり、地獄を出るべきじゃなかったか？」","「……果然，当初不该离开地狱吗？」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「どうどう、迷うな迷うな！」","「喂喂，别迷惘别迷惘！」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「言うて、信用出来るパートナーもいるだろ！？」","「说起来，你不是有可靠的搭档吗！？」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「はあ……まあね」","「唉……算是吧」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「語気が怖いのは何でだよ！？」","「你那语气凶得吓人是怎样啦！？」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「こんなん、アタシの計画に全然なかったからだ！」","「因为这种事，根本就不在我的计划之内啊！」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「はあ……アタシは小さくても落ち着ける、\\n　自分だけの城を持ちたかったのに」","「唉……我本来只想有个小小的、能安稳度日的，\\n　只属于自己的城堡而已啊」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「何でこんなヘンテコな連れ合いまで、\\n　できちまったのかなあ」","「怎么会连这种奇怪的同伴，\\n　都凑到一起了啊」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「誰がへんてこだ誰が」","「你说谁奇怪啊你说」",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「アタシの全ての選択は間違ってなかった。\\n　現状にもまあまあ満足はしてる」","「我的所有选择都没错。\\n　对现状嘛，也还算满意」",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「でもまあ……はあ……ヤツシロかあ……」","「不过嘛……唉……8246啊……」",null,null,null],["47_TEXT","47_TEXT",null,null,null],["「こ、このやろう」","「你、你这个混蛋」",null,null,null],["48_TEXT","48_TEXT",null,null,null],["「だったら俺1人で独立してやろうか、ああん？\\n　こちとら会社立ち上げても良いんだぞ！」","「那要不要老子一个人去单干啊，啊嗯？\\n　逼急了我自己去开公司也不是不行！」",null,null,null],["49_TEXT","49_TEXT",null,null,null],["「……それはいやだ。\\n　ちゃんとずっといっしょにいろ」","「……那个就免了。\\n　给我好好一直待在一起」",null,null,null],["50_TEXT","50_TEXT",null,null,null],["「やっぱさあ……ツンデレなんじゃないのこの人」","「我就说吧……这人根本就是傲娇嘛」",null,null,null],["51_TEXT","51_TEXT",null,null,null],["「人をそういう風にカテゴライズするのがキモい」","「把人用那种方式归类真让人恶心」",null,null,null],["52_TEXT","52_TEXT",null,null,null],["「まあ……わからんでもないけど」","「嘛……也不是不能理解就是了」",null,null,null],["53_TEXT","53_TEXT",null,null,null],["「こいつ、俺のこと結構好きなんだな……」","「这家伙，还蛮喜欢我的嘛……」",null,null,null],["54_TEXT","54_TEXT",null,null,null],["「キモ。ばか。カス。木偶の坊」","「恶心。笨蛋。废物。呆子」",null,null,null],["55_TEXT","55_TEXT",null,null,null],["「な、なんだァてめー！」","「你、你说什么你这混蛋！」",null,null,null],["56_TEXT","56_TEXT",null,null,null],["「いいからさっさと働けー。馬車馬の如く」","「废话少说赶紧去干活。当牛做马地干」",null,null,null],["57_TEXT","57_TEXT",null,null,null],["「くっそいつか下剋上してやる！」","「可恶总有一天我要翻身做主！」",null,null,null],["58_TEXT","58_TEXT",null,null,null],["「はは。まあ今日の晩飯当番は期待してろ。\\n　良いレシピを教えて貰ったんだ」","「哈哈。总之你就期待今天的晚饭轮值吧。\\n　我弄到了很棒的食谱」",null,null,null],["59_TEXT","59_TEXT",null,null,null],["「この前見つけたドラマの続きでも見ながら、\\n　うまい鍋でもつつこ」","「一边看上次找到的电视剧的后续，\\n　一边围炉吃好吃的火锅吧」",null,null,null],["60_TEXT","60_TEXT",null,null,null],["「くっそ……やる気が出ること言ってくれる」","「可恶……真会挑让人有干劲的话说」",null,null,null],["61_TEXT","61_TEXT",null,null,null],["「もしかして、良い上司か？」","「莫非，你是个好上司？」",null,null,null],["62_TEXT","62_TEXT",null,null,null],["「うーん、ちょろい部下」","「嗯哼，好糊弄的部下」",null,null,null],["63_TEXT","63_TEXT",null,null,null],["「ほら行けー！　はいやー！」","「快走——！驾——！」",null,null,