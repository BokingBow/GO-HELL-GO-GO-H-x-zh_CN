_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0671.uasset.csv","tags":[],"progress":{"translated":45,"length":45,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0751.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya","basename":"unique0751.uasset.csv","extension":"csv","filename":"unique0751.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0751.uasset.csv","data":[["unique0751","unique0751",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「がちゃ」","「咔嚓」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「きょろきょろ」","「东张西望」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「お兄ちゃん。いるー？」","「哥哥~。在不在呀~？」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「……」","「……」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「おるすかな？」","「是出门了吗？」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「勝手にはいっちゃお」","「那就不客气地进来啦。」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「らんたったー♪　るんたっるー♪」","「啦嘀嗒~♪　噜嗒噜~♪」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「おじゃましまーす」","「打搅啦~」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「む。ソファーかたい……。\\n　あんまり好きじゃないやつだ」","「唔。这沙发好硬……。\\n　不是我喜欢的那种。」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「……！　おせんべあった。\\n　たべちゃお～～」","「……！　有仙贝诶。\\n　偷偷吃掉~~」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「ぱりぱり……う～、しけしけ……」","「嘎嘣嘎嘣……唔~，都受潮了……」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「なんだか、おとなのばしょってかんじ。\\n　かっこいいな～」","「总觉得，这里是大人才会来的地方。\\n　好酷啊~」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「……ん？」","「……嗯？」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「………………」","「………………」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「ご、ごめんなさいっ。勝手にはいって……」","「对、对不起。我不该擅自进来……」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「………………こんにちは？」","「………………你好？」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「…………」","「…………」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「おっきな……お人形さん……？\\n　お話は、できないのかな」","「好大……的娃娃……？\\n　你，不会说话吗？」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「おーーい。お人形さーーん。\\n　こんにちはー」","「喂——。娃娃大人——。\\n　你好呀——。」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「おっぱい、おっきいね。\\n　どうやったらそんなに大きくなるの？」","「胸好大哦。\\n　要怎样才能变得这么大呀？」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「……すずの頭ぐらいある！」","「……都有铃的脑袋这么大了！」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「ずっと光ってるけど……。\\n　お喋りは……できないのかな……」","「一直在发光呢……。\\n　你该不会……不会说话吧……」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「あなたは１人で、おるすばんなの？」","「你是一个人，在看家吗？」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「えらいね」","「真乖呢。」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「すず、おるすばんにがてだもん。\\n　１人でいると、さびしくならない？」","「铃，我看家不行的嘛。\\n　一个人的话，不会寂寞吗？」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["45_TEXT","45_TEXT",null,null,null],["『だいじょうぶだよーすずちゃんっ。\\n　ボクひとりでもさびしくないよっ』","『没关系的啦～小铃。\\n　我一个人也不会寂寞哟』",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「ふふ、そうなんだ、そうなんだ。\\n　えらいねー」","「呵呵，是这样啊，是这样啊。\\n　真乖呢～」",null,null,null],["47_TEXT","47_TEXT",null,null,null],["「いいこにはごほうびに、\\n　おいしいごはん作ってあげるからねー」","「我会给好孩子做奖励，\\n　做好吃的饭哦～」",null,null,null],["49_TEXT","49_TEXT",null,null,null],["『すずちゃんありがとーっ』","『谢谢你，小铃～』",null,null,null],["50_TEXT","50_TEXT",null,null,null],["51_TEXT","51_TEXT",null,null,null],["「ここだったら……。\\n　お兄ちゃんいると……おもったのになあ……」","「本想着在这里……\\n　哥哥会在的……」",null,null,null],["52_TEXT","52_TEXT",null,null,null],["「……よしっ」","「……好了」",null,null,null],["53_TEXT","53_TEXT",null,null,null],["「ばいばい、お人形ちゃんっ。\\n　いっしょにあそべて、たのしかったよ」","「拜拜，小娃娃。\\n　能和你一起玩，很开心哦」",null,null,null],["54_TEXT","54_TEXT",null,null,null],["「またこんど、あそぼーね！」","「下次再一起玩吧～！」",null,null,null],["58_TEXT","58_TEXT",null,null,null],["59_TEXT","59_TEXT",null,null,null],["65_TEXT","65_TEXT",null,null,null],["「はあ、疲れた。ただいまー」","「哈啊，累死了。我回来了～」",null,null,null],["66_TEXT","66_TEXT",null,null,null],["「データベースに登録されたユーザーの熱源を探知。\\n　スリープモードを解除します」","「侦测到数据库中已注册用户的热源。\\n　解除睡眠模式」",null,null,null],["67_TEXT","67_TEXT",null,null,null],["「おかえりなさい、ヤツシロ様」","「欢迎回来，8246大人」",null,null,null],["68_TEXT","68_TEXT",null,null,null],["「……ン？」","「……嗯？」",null,null,null],["69_TEXT","69_TEXT",null,null,null],["「いかがなさいましたか？」","「请问怎么了？」",null,null,null],["70_TEXT","70_TEXT",null,null,null],["「ここに、誰か客でも来た？」","「这里，有谁来过吗？」",null,null,null],["71_TEXT","71_TEXT",null,null,null],["「いえ。どなたも来客はなかったと、\\n　記録されています」","「不，记录显示，\\n　并没有任何访客到来」",null,null,null],["72_TEXT","72_TEXT",null,null,null],["「ふうん……じゃあ、何の匂いだろ？」","「唔……那，这是什么味道？」",null,null,null],["73_TEXT","73_TEXT",null,null,null],["「なんか……花みたいな匂いしない？」","「总感觉……有股花一样的味道，你没有闻到吗？」",null,null,null],["74_TEXT","74_TEXT",null,null,null],["「臭気の分析を開始。これは」","「开始分析气味。这是」",null,null,null],["75_TEXT","75_TEXT",null,null,null],["「鈴蘭の香りに酷似しています」","「与铃兰的香气极为相似」",null,null,null],["76_TEXT","76_TEXT",null,null,null],["「そんな香水つけてる、うちにいたっけ？」","「我们家有用那种香水的人吗？」",null,null,null],["77_TEXT","77_TEXT",null,null,null],["「記録にはございませんが」","「记录里并没有」",null,null,null],["78_TEXT","78_TEXT",null,null,null],["「ふうん……」","「唔……」",null,null,null],["79_TEXT","79_TEXT",null,null,null],["80_TEXT","80_TEXT",null,null,null],["「何か、気になりますか？」","「您在意什么吗？」",null,null,null],["81_TEXT","81_TEXT",null,null,null],["「いや、こんな感じの匂いの知り合いが、\\n　居たな……って思い出しただけ」","「不，只是想起来，以前有个熟人，\\n　就带着这种味道……」",null,null,null],["82_TEXT","82_TEXT",null,null,null],["「ま、いいや。今日の仕事に戻ろう」","「算了。继续今天的工作吧」",null,null,null],["83_TEXT","83_TEXT",null,null,null],["「了解致しました」","「了解」",null,null,null]],"type":"","context":[["unique0751.uasset.csv/row/112","unique0751.uasset.csv/row/123","unique0751.uasset.csv/row/134","unique0751.uasset.csv/row/145","unique0751.uasset.csv/row/156","unique0751.uasset.csv/row/167","unique0751.uasset.csv/row/178","unique0751.uasset.csv/row/189","unique0751.uasset.csv/row/216","unique0751.uasset.csv/row/227","unique0751.uasset.csv/row/238","unique0751.uasset.csv/row/249","unique0751.uasset.csv/row/260","unique0751.uasset.csv/row/271","unique0751.uasset.csv/row/282","unique0751.uasset.csv/row/293","unique0751.uasset.csv/row/304","unique0751.uasset.csv/row/315","unique0751.uasset.csv/row/326","unique0751.uasset.csv/row/337","unique0751.uasset.csv/row/348","unique0751.uasset.csv/row/359","unique0751.uasset.csv/row/370","unique0751.uasset.csv/row/381","unique0751.uasset.csv/row/392","unique0751.uasset.csv/row/403","unique0751.uasset.csv/row/414","unique0751.uasset.csv/row/425","unique0751.uasset.csv/row/444","unique0751.uasset.csv/row/455","unique0751.uasset.csv/row/466","unique0751.uasset.csv/row/485","unique0751.uasset.csv/row/496","unique0751.uasset.csv/row/507","unique0751.uasset.csv/row/518","unique0751.uasset.csv/row/529","unique0751.uasset.csv/row/540","unique0751.uasset.csv/row/575","unique0751.uasset.csv/row/586","unique0751.uasset.csv/row/637","unique0751.uas