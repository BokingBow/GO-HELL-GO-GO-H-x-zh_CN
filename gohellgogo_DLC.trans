name":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya","basename":"unique0661.uasset.csv","extension":"csv","filename":"unique0661.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0661.uasset.csv","data":[["unique0661","unique0661",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「はー！？　なに？　ここクレカ無理なの！？\\n　いまどき！？　ありえないんですけどー！」","「啊——！？什么？这里不能用信用卡！？\\n　都什么年代了！？真是难以置信！」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「お。あそこでデカい声を出しているのは……」","「哦。那边那个大声嚷嚷的是……」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「無理無理！　現金なんて持ち歩いてないし！\\n　てかそれ店の責任じゃない？」","「不行不行！谁还会随身带现金啊！\\n　话说这是你们店的责任吧？」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「……」","「……」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「あんたらがカードに対応したら、\\n　また払い直しに来てあげるわよ！」","「等你们支持刷卡了，\\n　我再过来付钱就是啦！」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「大体、最初に言わない方が悪いんじゃない！？」","「说到底，不早点说清楚的才不对吧！？」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「……絶対かかわらない方が吉だな。\\n　君子危うきに近寄らず～」","「……绝对别扯上关系比较好。\\n　君子不立危墙之下～」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「あっ」","「啊。」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「げっ」","「呕。」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「おーーい！　ヤツシロー！　こっちこっち！\\n　おい！　こっち！　逃げんなって！　こっち！」","「喂——！8246！这边这边！\\n　喂！这里！不许跑！这边！」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「……報復が怖いから行くしかないか」","「……怕被报复，只能过去了啊」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「あんだよ」","「干嘛」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「こいつこいつ！　こいつが払うから！」","「他他他！他来付钱啦！」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「何でだよ！？」","「凭什么啊！？」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「はああ！？　あんたねえ！\\n　私にどんだけ借りがあるか分かってるわけ？」","「哈啊——！？我说你啊！\\n　知不知道你欠了我多少人情？」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「色々連れ回したり変なことしたり！\\n　円にして億ぐらいの借りが溜まってンだから！」","「拉着我到处转悠，还做各种奇怪的事！\\n　换成钱都欠了我快上亿了！」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「……択をミスった。\\n　見えないふりして逃げればよかった」","「……选错了。假装没看见逃掉就好了」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「なぁーにをケツの穴の小さい事言ってるわけ？」","「你叨逼些什么小家子气的话呢？」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「男だったら潔く、\\n　ドンと格好良く払いなさいよ！」","「是男人就给我干脆点，\\n　大方帅气地把钱付了！」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「流石に心が醜すぎる……」","「实在丑态毕露……」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「……ほろり」","「……（滴答滴答）」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「なんで泣いてるの？」","「怎么哭了？」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「余りの哀れさに。その育ちの悪さ、\\n　きっと境遇最悪だったんだろうな」","「太可悲了。教养这么差，\\n　一定成长环境非常糟糕吧。」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「は、はあ！？」","「哈、哈啊！？」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「店員さん、俺が支払いはします。\\n　許して下さい、可哀想な子なんです」","「店员，我来付钱。\\n　请原谅她吧，这孩子很可怜的。」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「やぁめろー！　可愛そうな子扱いするなー！」","「快住手——！别拿可怜当借口——！」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「……だったらお前が支払いするか？」","「……那你自己付钱？」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「……私は可愛そうな子なので、\\n　昼食代17800円を支払って下さい」","「……我是可怜的孩子，所以\\n　请替我付这17800日元的午餐费。」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「おっけおっけ」","「好嘞好嘞」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「………………」","「………………」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「はああああああああ！？\\n　お前いま何て言った！？　いちまんななせん！？」","「哈啊啊啊啊啊啊啊啊！？\\n　你刚才说什么！？一万八！？」",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「えここ高級フレンチとかじゃないよね！？\\n　町の小さな中華料理屋だよね！？」","「喂这边不是高级法餐吧！？\\n　只是街边的小中餐馆对吧！？」",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「つい食べすぎちゃって、餃子」","「一不小心吃多了，饺子。」",null,null,null],["47_TEXT","47_TEXT",null,null,null],["「おま何十枚食ったら2万円近くいくんだよ！？」","「你得吃了好几十个才能花到快两万块吧！？」",null,null,null],["48_TEXT","48_TEXT",null,null,null],["「はあでもよかったー。\\n　友達が支払いをしてくれることになって」","「啊不过太好了——。\\n　朋友要替我付钱了。」",null,null,null],["49_TEXT","49_TEXT",null,null,null],["「…………」","「…………」",null,null,null],["50_TEXT","50_TEXT",null,null,null],["「男に二言はないわよね？」","「男人说话一言九鼎对吧？」",null,null,null],["51_TEXT","51_TEXT",null,null,null],["56_TEXT","56_TEXT",null,null,null],["「あああああああああ！！　逃げたぁああ！！\\n　コラ待て！　店員さん！　追うわよ！」","「啊啊啊啊啊啊啊啊！！他跑了！！\\n　喂站住！店员！追上去！」",null,null,null],["57_TEXT","57_TEXT",null,null,null],["「待てこらぁあああああああああああ！！」","「给我站住啊啊啊啊啊啊啊啊啊啊啊啊啊啊！！」",null,null,null]],"type":"","context":[["unique0661.uasset.csv/row/104","unique0661.uasset.csv/row/123","unique0661.uasset.csv/row/134","unique0661.uasset.csv/row/145","unique0661.uasset.csv/row/156","unique0661.uasset.csv/row/167","unique0661.uasset.csv/row/178","unique0661.uasset.csv/row/189","unique0661.uasset.csv/row/200","unique0661.uasset.csv/row/211","unique0661.uasset.csv/row/222","unique0661.uasset.csv/row/233","unique0661.uasset.csv/row/244","unique0661.uasset.csv/row/255","unique0661.uasset.csv/row/266","unique0661.uasset.csv/row/277","unique0661.uasset.csv/row/288","unique0661.uasset.csv/row/299","unique0661.uasset.csv/row/310","unique0661.uasset.csv/row/321","unique0661.uasset.csv/row/332","unique0661.uasset.csv/row/343","unique0661.uasset.csv/row/354","unique0661.uasset.csv/row/365","unique0661.uasset.csv/row/376","unique0661.uasset.csv/row/387","unique0661.uasset.csv/row/398","unique0661.uasset.csv/row/409","unique0661.uasset.csv/row/420","unique0661.uasset.csv/row/431","unique0661.uasset.csv/row/442","unique0661.uasset.csv/row/453","unique0661.uasset.csv/row/464","unique0661.uasset.csv/row/475","unique0661.uasset.csv/row/486","unique0661.uasset.csv/row/497","unique0661.uasset.csv/row/508","unique0661.uasset.csv/row/519","unique0661.uasset.csv/row/562","unique0661.uasset.csv/row/573"],["unique0661.uasset.csv/row/105"],["unique0661.uasset.csv/row/106"],["unique0661.uasset.csv/row/124"],["unique0661.uasset.csv/row/125"],["unique0661.uasset.csv/row/135"],["unique0661.uasset.csv/row/136"],["unique0661.uasset.csv/row/146"],["unique0661.uasset.csv/row/147"],["unique0661.uasset.csv/row/157"],["unique0661.uasset.csv/row/158"],["unique0661.uasset.csv/row/168"],["unique0661.uasset.csv/row/169"],[