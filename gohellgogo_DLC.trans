2AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/05_Kamase/unique1061.uasset.csv","tags":[],"progress":{"translated":70,"length":70,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/05_Kamase/unique1071.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/05_Kamase","basename":"unique1071.uasset.csv","extension":"csv","filename":"unique1071.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/05_Kamase/unique1071.uasset.csv","data":[["unique1071","unique1071",null,null,null],["12_TEXT","12_TEXT",null,null,null],["「はぁー……凹むわ～……」","「哈啊——……真受打击啊～……」",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「どうしたんだカマセ。\\n　珍しく元気がないな」","「怎么了，要去。\\n　难得见你这么没精神」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「あのさあアタシ、前、とある責苦で、\\n　ボコボコにされて……」","「那个啊，我之前，因为某场拷问，\\n　被狠狠揍了一顿……」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「アタシの負けです。負け犬のくせに、\\n　調子乗ってすいませんって、\\n　泣きながら謝るまでしたんだけどさ」","「是我输了。明明只是条败犬，\\n　却不知天高地厚，对不起，\\n　我甚至哭着道歉了来着」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「……それを平然と話せるお前が怖い」","「……能若无其事说出这种话的你，真让人害怕」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「でも負けっぱなしは許せないだろ！？」","「但是光挨打不还手，我可咽不下这口气对吧！？」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「だからアタシもっかい戦いたくて、\\n　カチコミかけたんだけどー」","「所以我就想再打一场，\\n　跑去砸场子了——」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「へえーホントこわコイツ」","「嘿——这家伙真够吓人的」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「もぉーボッコボコにされた。\\n　ガチ、今度は泣いて土下座しながら許しを請うて、\\n　ギリギリ逃げ出してきたんだよ、昨日」","「结果又被揍得——稀巴烂。\\n　真的，这次是哭着跪地求饶，\\n　好不容易才逃出来的，就在昨天」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「昨日なのかよ！\\n　そんでいま平然としてるのかよ！」","「原来是昨天啊！\\n　那你现在还能这么若无其事啊！」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「はぁー……凹む。\\n　アタシ、地元じゃ最強だったのにな」","「哈啊——……真受打击。\\n　我在老家明明是最强的」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「もっと鍛錬、がんばんないと！\\n　このままじゃできないぞ、天下統一！」","「不更加努力训练的话！\\n　这样下去可没法实现啊，天下统一！」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「でっかい夢を抱えてンなあ……」","「你还真揣着这么大的梦想啊……」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「だからコーチも一緒に、\\n　バトルの日々を過ごそうぜ！」","「所以教练也一起，\\n　共度战斗的每一天吧！」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「だから嫌だよそういうのは！」","「所以我不是说讨厌这种事了吗！」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「まあいいや。じゃあせめて、\\n　アタシの鍛錬に付き合ってよ」","「算了算了。那至少，\\n　陪我的训练吧」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「そのぐらいなら良いか。\\n　一応コーチと呼ばれているし」","「就这点程度的话还行吧。\\n　好歹我也被人叫做教练」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「よっしゃー！　夕日に向かって走れー！」","「太好啦——！　朝着夕阳奔跑吧——！」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「おー！」","「哦——！」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「おーとか言ったけど、どこまで走んの」","「嘴上说哦，到底要跑到哪里去啊」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「今日はあと、30km走る予定だぜ！」","「今天还预定，要跑30公里呢！」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「…………」","「…………」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「行くぞコーチ！　夕日に向かって走れー！」","「要走了教练！　朝着夕阳奔跑吧——！」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「コーチ！　あれ？　コーチ？\\n　……は？　いないんだけど！」","「教练！　咦？　教练？\\n　……啊？　不见了！」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「おいこらコーチ逃げんな！！\\n　一緒に走り続けるんだよー！！」","「喂喂教练别跑啊！！\\n　要一直一起跑下去的啊——！！」",null,null,null]],"type":"","context":[["unique1071.uasset.csv/row/96","unique1071.uasset.csv/row/107","unique1071.uasset.csv/row/118","unique1071.uasset.csv/row/129","unique1071.uasset.csv/row/140","unique1071.uasset.csv/row/151","unique1071.uasset.csv/row/162","unique1071.uasset.csv/row/173","unique1071.uasset.csv/row/184","unique1071.uasset.csv/row/195","unique1071.uasset.csv/row/206","unique1071.uasset.csv/row/217","unique1071.uasset.csv/row/228","unique1071.uasset.csv/row/239","unique1071.uasset.csv/row/250","unique1071.uasset.csv/row/261","unique1071.uasset.csv/row/272","unique1071.uasset.csv/row/283","unique1071.uasset.csv/row/294","unique1071.uasset.csv/row/305","unique1071.uasset.csv/row/316","unique1071.uasset.csv/row/327","unique1071.uasset.csv/row/362","unique1071.uasset.csv/row/373","unique1071.uasset.csv/row/384"],["unique1071.uasset.csv/row/97"],["unique1071.uasset.csv/row/98"],["unique1071.uasset.csv/row/108"],["unique1071.uasset.csv/row/109"],["unique1071.uasset.csv/row/119"],["unique1071.uasset.csv/row/120"],["unique1071.uasset.csv/row/130"],["unique1071.uasset.csv/row/131"],["unique1071.uasset.csv/row/141"],["unique1071.uasset.csv/row/142"],["unique1071.uasset.csv/row/152"],["unique1071.uasset.csv/row/153"],["unique1071.uasset.csv/row/163"],["unique1071.uasset.csv/row/164"],["unique1071.uasset.csv/row/174"],["unique1071.uasset.csv/row/175"],["unique1071.uasset.csv/row/185"],["unique1071.uasset.csv/row/186"],["unique1071.uasset.csv/row/196"],["unique1071.uasset.csv/row/197"],["unique1071.uasset.csv/row/207"],["unique1071.uasset.csv/row/208"],["unique1071.uasset.csv/row/218"],["unique1071.uasset.csv/row/219"],["unique1071.uasset.csv/row/229"],["unique1071.uasset.csv/row/230"],["unique1071.uasset.csv/row/240"],["unique1071.uasset.csv/row/