D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/04_Oshi/unique0971.uasset.csv","tags":[],"progress":{"translated":68,"length":68,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/03_Kenne/03_Kenne01.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/03_Kenne","basename":"03_Kenne01.uasset.csv","extension":"csv","filename":"03_Kenne01.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/03_Kenne/03_Kenne01.uasset.csv","data":[["03_Kenne01","03_Kenne01",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「へえー……ここが新還処か。\\n　出来てから入った事なかったな」","「哦——……这里就是新还处啊。\\n　建成之后我还没进来过呢」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「ふうん……でっかい建物だねえ」","「嗯……好大的建筑啊」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「折角だし新築のトイレでも借りてくか。\\n　新しいトイレは気分が良い」","「难得来一趟，就借用下新建的厕所吧。\\n　新厕所用起来心情就是好」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「…………」","「…………」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「しかし、誰も居らんな。\\n　今日は休み、とかじゃないだろうし」","「不过，还真是空无一人啊。\\n　今天应该不是休息日吧」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「こんだけ広くて人が居ないと、\\n　何故か運動してみたくなるな」","「这么宽敞却没人，\\n　不知怎的，突然就想活动活动了」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「かつて少年だった者の\\n　サガなのかもしれん」","「这或许就是曾为少年之人\\n　骨子里的秉性吧」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「クラウチングスタート……からの、\\n　猛ダッシュ！　うおおおおお！！」","「蹲踞式起跑……然后，\\n　全力冲刺！唔噢噢噢噢！！」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「……ふふ。謎に気分がいい」","「……呵呵。莫名觉得心情超好」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「なんじゃあ、われ？」","「搞什么啊，你这家伙？」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「ぎゃあ！　誰ぇ！？」","「呜哇！谁啊！？」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「なんぼけたことぬかしよるん、\\n　おどれんは」","「你在那儿胡扯些什么呢，\\n　你这家伙」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「それはうちの台詞じゃろが。\\n　それともあんた、ここのスタッフけ」","「那是我想问的吧。\\n　还是说，你是这儿的工作人员不成」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「え？　いや、俺は……」","「呃？不，我是……」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「どう見ても清掃業者じゃろな。\\n　じゃけん言うとるんよ、おどれが誰か」","「怎么看都是个清洁工吧。\\n　所以才问你，你到底是谁」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「処分する亡者共は庁の担当が引き取るし、\\n　清掃業者がわざわざここに何の用事よ」","「要处理的亡灵们有官署的人来接手，\\n　你一个清洁工特意跑这儿来有什么事」",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「ああ、すんません。\\n　ちょっとトイレでも借りようかと」","「啊，不好意思。\\n　我就是想借用下厕所」",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「はぁあん？\\n　小便なんぞ公園でしたらええじゃろうが」","「哈啊——？\\n　撒泡尿什么的，去公园里解决不就得了」",null,null,null],["48_TEXT","48_TEXT",null,null,null],["「カッカッカ！　畜生の如く電柱なんぞ\\n　使っても愉快かもしれんなぁ！」","「嘎嘎嘎！像畜生一样对着电线杆来一发，\\n　说不定还挺痛快的呢！」",null,null,null],["50_TEXT","50_TEXT",null,null,null],["「ふむ考えてみた事もなかった。何故我らは\\n　厠と言う特定の場所でしか用を足さんのけ」","「唔呣，这倒是从未想过。为何我等\\n　非得在厕所这种特定场所解手不可呢」",null,null,null],["51_TEXT","51_TEXT",null,null,null],["「倫理的規定を外れて進まねば見えぬ、\\n　道というのは決して少なくはないもの」","「不拘泥于伦理规定向前迈进才能看到，\\n　这世间道路绝非稀少」",null,null,null],["52_TEXT","52_TEXT",null,null,null],["「それすなわち外道なり。魔道なり。\\n　科学の輩としては見てみぬふりは出来んのう」","「那即是外道。即是魔道。\\n　身为科学之徒，可不能视而不见呐」",null,null,null],["54_TEXT","54_TEXT",null,null,null],["「今度うちもしてみるか、電柱で小便」","「下次我也试试吧，对着电线杆小便」",null,null,null],["55_TEXT","55_TEXT",null,null,null],["「ずっと何言ってるか分かんないけど、\\n　結論こわ」","「虽然一直搞不懂你在说什么，\\n　不过这结论好可怕」",null,null,null],["56_TEXT","56_TEXT",null,null,null],["「じゃ、行こっか？　連れション」","「那，走吧？一起去尿尿」",null,null,null],["57_TEXT","57_TEXT",null,null,null],["「お、俺も確定でする事になってるの嫌すぎる……」","「我、我也被板上钉钉地算进去了吗，太不情愿了……」",null,null,null],["58_TEXT","58_TEXT",null,null,null],["「すんません、俺、\\n　トイレが汚いのだけは避けたいポリシーなので」","「抱歉，我在政策上\\n　是希望尽可能避开脏厕所的」",null,null,null],["60_TEXT","60_TEXT",null,null,null],["「つまらん輩じゃのう。美醜なんぞ言うのは、\\n　社会が形成したくだらん観念でしかない」","「真是无趣的家伙。美丑之类，\\n　不过是社会构建出的无聊观念罢了」",null,null,null],["61_TEXT","61_TEXT",null,null,null],["「逸脱して、毀れて、ぶっ壊れた先にだけ、\\n　真の生長があるとは思わんのけ」","「只有在偏离、崩坏、彻底破碎之后，\\n　才会有真正的成长，你不觉得吗」",null,null,null],["62_TEXT","62_TEXT",null,null,null],["「……御高説賜り恐縮なんですが、\\n　尿意の我慢が限界でして」","「……感谢您的高见，恕我惶恐，\\n　但我憋尿已经到了极限」",null,null,null],["63_TEXT","63_TEXT",null,null,null],["「ふうん。漏らしたらいいのに。面白いから」","「唔嗯。漏出来不就好了。反正有意思」",null,null,null],["64_TEXT","64_TEXT",null,null,null],["「うんちおしっこで笑ってたら、\\n　小学生のツボなんだよな！」","「要是觉得屎尿屁好笑，\\n　那可就戳中小学生的笑点啦！」",null,null,null],["65_TEXT","65_TEXT",null,null,null],["「カッカッカッカ！　その通りじゃのぉ！！\\n　カーッカカ！　げふっ、げひっ。カカ！」","「嘎嘎嘎嘎！正是如此吶！！\\n　嘎——嘎嘎！咳呵、咳嘻。嘎嘎！」",null,null,null],["66_TEXT","66_TEXT",null,null,null],["「大便小便、ケツ、性器！　何ぞこんな愉快かの！\\n　理性の対極にあるからかの！　カッカ！」","「大便小便、屁股、生殖器！　这玩意儿咋就这么让人快活呢！\\n　因为处在理性的对立面吗！　嘎嘎！」",null,null,null],["67_TEXT","67_TEXT",null,null,null],["「それこそ我ら理性の動物たる所以じゃのう！\\n　カッカッカ！　これは愉快。愉快じゃのう！」","「这正是吾等身为理性动物的明证啊！\\n　嘎嘎嘎！　这可真快活。真是快活呀！」",null,null,null],["68_TEXT","68_TEXT",null,null,null],["「この人の笑いのツボ、ずっと分かんねえな」","「这人的笑点，我一直都没搞懂」",null,null,null],["69_TEXT","69_TEXT",null,null,null],["「えー。俺はヤツシロ。仰るとおり清掃業者です。\\n　そんで、トイレ借りても良いですか」","「呃。我叫八津。如您所说，是个清洁业者。\\n　然后，能借用下厕所吗」",null,null,null],["71_TEXT","71_TEXT",null,null,null],["「ほうかい、ヤツシロくん。\\n　うちは懸衣。この還処の処長じゃ」","「哦哦，八津小哥。\\n　我是悬衣。这个还处的处长」",null,null,null],["72_TEXT","72_TEXT",null,null,null],["「げえ！？　こ、ここで一番えらい方！？」","「诶诶！？　这、这里最大的头儿！？」",null,null,null],["73_TEXT","73_TEXT",null,null,null],["「コミュニティの序列には蚊程の興味もないがのぉ。\\n　あーつまらん。うちは嬢王蜂より蟋蟀でいたいけのぉ」","「我对社区的等级排位可完全没兴趣呀。\\n　啊——真是无聊。我才不要当蜂后，宁可当只蟋蟀呢」",null,null,null],["74_TEXT","74_TEXT",null,null,null],["（還処の立ち位置的にこの人は、\\n　地獄の中でも相当えらい立場の筈だ。げえ）","（以还处的地位来看，这个人，\\n　在地狱里也该是相当了不起的立场才对。这糟了）",null,null,null],["76_TEXT","76_TEXT",null,null,null],["「ほんで失禁せんなら、さっさと去ねや。\\n　おもしろ一発ギャグをしてくれてもいいぞ」","「那不尿裤子的话，就赶紧滚蛋吧。\\n　或者给我讲个爆笑段子也行」",null,null,null],["77_TEXT","77_TEXT",null,null,null],["「無茶苦茶だなこの人」","「这人真是乱来啊」",null,null,null],["79_TEXT","79_TEXT",null,null,null],["「面白かったら1万円やる。\\n　つまらなかったら肝臓」","「要是好笑就给你1万日元。\\n　不好笑的话，就肝臓」",null,null,null],["80_TEXT","80_TEXT",null,null,null],["「肝臓……を？　え、肝臓をどうするんすか」","「肝臓……？　呃，拿肝臓怎样啊？」",null,null,null],["82_TEXT","82_TEXT",null,null,null],["「ふふ」","「呵呵」",null,null,null],["83_TEXT","83_TEXT",null,null,null],["「……えー。用事を思い出しましたので、\\n　俺はさっさと消えることにします」","「……呃。我想起来还有事，\\n　我就先赶紧闪人了」",null,null,null],["85_TEXT","85_TEXT",null,null,null],["「ふん、度胸の足りん奴じゃの。\\n　そうして逃げ続けてつまらん日々でも送ってろ」","「哼，真是个没胆子的家伙。\\n　你就这么继续逃下去，过那无聊的日子吧」",null,null,null],["88_TEXT","88_TEXT",null,null,null],["「って、そうだ。特典のためにも、\\n　今後とも処分に励むんじゃぞー」","「哦，对了。为了特典，\\n　今后也要好好在处分上加油干啊—」",null,null,null],["89_TEXT","89_TEXT",null,null,null],["「……特典？　と言いますと？」","「……特典？　您说特典是？」",null,null,null],["90_TEXT","90_TEXT",null,null,null],["「は？　知らんのけ。この間の庁令よ」","「哈？ 你不知道？ 就是前阵子的署长令啊」",null,null,null],["91_TEXT","91_TEXT",null,null,null],["「亡者を処分に回した数だけ、\\n　特典を与えるっちゅーお上の号令があったじゃろ」","「上头不是有号令吗，说是\\n　根据把亡者送去处分的数量，给予特典」",null,null,null],["92_TEXT","92_TEXT",null,null,null],["「何それ知らねー……」","「还有这事，不知道啊——……」",null,null,null],["93_TEXT","93_TEXT",null,null,null],["「くそう住人が得する系のお役所サービスは、\\n　いつもさりげないんだよなあ」","「可恶，这种让居民得利的政府服务，\\n　总是来得这么不动声色啊」",null,null,null],["94_TEXT","94_TEXT",null,null,null],["「ちなみに特典は、こんな感じじゃからの」","「顺便一说，特典是这种感觉的哟」",null,null,null],["96_TEXT","96_TEXT",null,null,null],["「確認したか？　んじゃあ、さっさと消えい」","「看清楚了吧？　嗯那，赶紧消失吧」",null,null,null],["97_TEXT","97_TEXT",null,null,null],["「あざっしたー」","「谢啦—」",null,null,null]],"type":"","context":[["03_Kenne01.uasset.csv/row/104","03_Kenne01.uasset.csv/row/115","03_Kenne01.uasset.csv/row/126","03_Kenne01.uasset.csv/row/177","03_Kenne01.uasset.csv/row/188","03_Kenne01.uasset.csv/row/199","03_Kenne01.uasset.csv/row/210","03_Kenne01.uasset.csv/row/221","03_Kenne01.uasset.csv/row/280","03_Kenne01.uasset.csv/row/291","03_Kenne01.uasset.csv/row/334","03_Kenne01.uasset.csv/row/353","03_Kenne01.uasset.csv/row/364","03_Kenne01.uasset.csv/row/375","03_Kenne01.uasset.csv/row/386","03_Kenne01.uasset.csv/row/397","03_Kenne01.uasset.csv/row/408","03_Kenne01.uasset.csv/row/419","03_Kenne01.uasset.csv/row/438","03_Kenne01.uasset.csv/row/457","03_Kenne01.uasset.csv/row/468","03_Kenne01.uasset.csv/row/479","03_Kenne01.uasset.csv/row/498","03_Kenne01.uasset.csv/row/509","03_Kenne01.uasset.csv/row/520","03_Kenne01.uasset.csv/row/531","03_Kenne01.uasset.csv/row/542","03_Kenne01.uasset.csv/row/561","03_Kenne01.uasset.csv/row/572","03_Kenne01.uasset.csv/row/583","03_Kenne01.uasset.csv/row/594","03_Kenne01.uasset.csv/row/605","03_Kenne01.uasset.csv/row/616","03_Kenne01.uasset.csv/row/627","03_Kenne01.uasset.csv/row/638","03_Kenne01.uasset.csv/row/649","03_Kenne01.uasset.csv/row/660","03_Kenne01.uasset.csv/row/679","03_Kenne01.uasset.csv/row/690","03_Kenne01.uasset.csv/row/701","03_Kenne01.uasset.csv/row/712","03_Kenne01.uasset.csv/row/731","03_Kenne01.uasset.csv/row/742","03_Kenne01.uasset.csv/row/761","03_Kenne01.uasset.csv/row/772","03_K