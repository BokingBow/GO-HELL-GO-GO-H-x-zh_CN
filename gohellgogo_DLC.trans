":"unique1111.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/06_Norimaki/unique1111.uasset.csv","data":[["unique1111","unique1111",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「鬼のディレクターに連れられ、\\n　某所に連行されてしまったのりまき」","「被魔鬼导演带走，\\n　押送到了某个地方的海苔卷」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「メガトン怖いよぉ助けて偉い人っ。\\n　しかしああ無情、かよわき乙女に拒否権は無く」","「超大只超恐怖啊救命有大佬来救我吗。\\n　然而天意无情，弱女子根本没有拒绝权」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「あぁ昔こういう事あったなあ。\\n　コレ地方の局で無茶なロケした話なんですけどぉ……」","「啊这种事儿以前也经历过呢。\\n　这是地方电视台拍外景时乱来的故事啦……」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「まさかエピソードトークも得意なのか」","「难道连即兴小故事都这么拿手吗」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「のりまき、大喜利が得意です！」","「海苔卷，最擅长的就是即兴搞笑！」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「アイドルとかタレントの言う『大喜利が得意』、\\n　持ち上げなきゃいけない雰囲気がきちぃ」","「偶像啊艺人什么的说什么『擅长即兴搞笑』，\\n　那种必须捧场的氛围真让人吃不消」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「け、結構言いますねディレクターさん」","「你、你还真敢说啊导演」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「という訳で、こいつ頼んます」","「所以说，这家伙拜托你们了」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「ティーエルディーアールサービスさんトコは\\n　結構いつもだけど……」","「TLDR服务的活儿\\n　虽然一向都挺那个的……」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「今回のはまたアレですね」","「这次又是那个调调儿呢」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「ちょいちょいーっ！\\n　アレってなんですかー！？」","「喂喂喂——！\\n　你说那个是哪个啊——！？」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「こんな最強乙女を捕まえて失礼しちゃうワ！\\n　ぷんぷん！」","「居然敢抓我这种最强少女太没礼貌了哼！\\n　气鼓鼓！」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「クセ強めなんですがよろしくお願いします」","「个性有点强，还请大家多担待」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「はぁーい」","「好——」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「それじゃ、付いてきて下さいねー」","「那请跟我来吧——」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「えーん、えんえん！\\n　ギガント怖ゆす～～～～！！」","「呜——呜呜呜！\\n　超巨无霸好可怕——！！」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「あ、あのぉ……これぇ……？」","「那、那个……这个……？」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「はぁーい、大丈夫ですよー。\\n　そのまま動かないでくださーい」","「好——没问题的——\\n　就这样别乱动哦——」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「動かないでって、言われてもぉっ！」","「叫我别动，可是这也太——！」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「こ、これはちょっと、\\n　ギガントすぎじゃないですかぁ～～！？」","「这、这也未免，\\n　太巨无霸过头了吧——！？」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「それでは漬け地獄、回転始めまーす」","「那么渍地狱，现在开始旋转——」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「回転！？　回転ってな――」","「旋转！？什么旋转――」",null,null,null],["47_TEXT","47_TEXT",null,null,null],["「――うっぷすっ。ごぼぼぼぼぼぼっ」","「――唔噗。咕噜咕噜咕噜咕噜」",null,null,null],["48_TEXT","48_TEXT",null,null,null],["「ごぼぼぼぼぼっ」","「咕噜咕噜咕噜咕噜」",null,null,null],["50_TEXT","50_TEXT",null,null,null],["「ぷはっ！？　げほげほっ！\\n　おえっ。鼻にみずはいった」","「噗哈！？咳咳咳！\\n　呕。鼻子进水了」",null,null,null],["51_TEXT","51_TEXT",null,null,null],["「ちょ、ちょっとタンマタンマ！\\n　これやばすぎじゃないですか！？\\n　ちゃんとスタッフ事前テストしました！？」","「等、等一下暂停暂停！\\n　这危险程度也太离谱了吧！？\\n　工作人员之前真的有测试过吗！？」",null,null,null],["52_TEXT","52_TEXT",null,null,null],["「ちょっとガチで、ヤバいや――」","「讲真的，这要出人命了――」",null,null,null],["55_TEXT","55_TEXT",null,null,null],["「――うっぷす！　ごぼぼぼぼぼぼぼっ！！」","「――唔噗！咕嘟嘟嘟嘟嘟！！！」",null,null,null],["56_TEXT","56_TEXT",null,null,null],["「ぅううーーっ！！　ぃふっ！　ぃふっ！\\n　ぅうーー……ごぼぼぼ……ごぼぼぼ……」","「呜呜呜——！！咳噗！咳噗！\\n　呜呜——……咕嘟嘟……咕嘟嘟……」",null,null,null],["58_TEXT","58_TEXT",null,null,null],["「――マジありえん！　ふーふーっ！\\n　やりすぎ！！　やりすぎですッ！！」","「――简直太扯了！呼哈呼哈！\\n　做得太过了！！太过了呀！！」",null,null,null],["59_TEXT","59_TEXT",null,null,null],["「こんな過酷ロケ、サバンナにおにぎりだけ持たされて、\\n　2週間放置された以来なんですが！？」","「这么残酷的外景，也就只有上次把我丢到热带草原只给几个饭团、\\n　不管不顾两星期那回比得上了啊！？」",null,null,null],["60_TEXT","60_TEXT",null,null,null],["「あー！　待ってまだ文句言ってる！\\n　文句言ってるのに！！　み、水がぁ……」","「啊——！等等我还在抱怨呢！\\n　还在说话啊！！水、水要……」",null,null,null],["63_TEXT","63_TEXT",null,null,null],["「――うっぷす！　ごぼぼぼぼぼぼぼぼぼっっ！！」","「――唔噗！咕嘟嘟嘟嘟嘟嘟嘟嘟！！！」",null,null,null],["64_TEXT","64_TEXT",null,null,null],["「……………………………………」","「……………………………………」",null,null,null],["66_TEXT","66_TEXT",null,null,null],["「ぷはっ……ふーっふーっふーっふーっ！\\n　あのっ……すいませっ……これ、ホント、無理……」","「噗哈……呼哈呼哈呼哈呼哈！\\n　那个……对不起……这个，真的，不行了……」",null,null,null],["67_TEXT","67_TEXT",null,null,null],["「無理……な時こそ、笑う……ッ！\\n　私はバラエティのお姫様！　ぷりちー汚れ役、のりまき！」","「越是不……行的时候，越要笑……！\\n　我可是综艺节目的公主！可爱的自黑担当，海苔卷！」",null,null,null],["68_TEXT","68_TEXT",null,null,null],["「くっそぉおおおおおお！！\\n　もうあと何周でも、やったらんかい！」","「可恶啊啊啊啊啊！！\\n　不就是再来几圈吗，老娘陪你拼了！」",null,null,null],["71_TEXT","71_TEXT",null,null,null],["72_TEXT","72_TEXT",null,null,null],["「ごぼぼ……ごぼぼ…………ごぼ……ごぼ……」","「咕嘟嘟……咕嘟嘟…………咕嘟……咕嘟……」",null,null,null],["74_TEXT","74_TEXT",null,null,null],["「ぷはっ……すいま、せっ……やっぱ、むり……。\\n　これ、ちょっと、い、意識が……」","「噗哈……对不，起……果然，不行……。\\n　这个，稍微，意、意识有点……」",null,null,null],["75_TEXT","75_TEXT",null,null,null],["「ごめんな、さ……っ。ギブで……ギブでぇ……っ。\\n　おね、おねが……」","「抱歉了，啊……。我放弃……我认输了……。\\n　求你，求求……」",null,null,null],["78_TEXT","78_TEXT",null,null,null],["「――うっ……ごっ……ごぼっ……ごぼっ……」","「――唔……咕嘟……咕嘟……咕嘟……」",null,null,null],["79_TEXT","79_TEXT",null,null,null],["「……ごぼっ…………ごっ……ごっ……」","「……咕嘟…………咕嘟……咕嘟……」",null,null,null],["82_TEXT","82_TEXT",null,null,null],["「ふひゅーっ……ふひゅっーっ……げほげほっ……」","「呼咻……呼咻……咳呵咳呵……」",null,null,null],["83_TEXT","83_TEXT",null,null,null],["「ほ、ほんと……む、り……ふひゅーっ……」","「真、真的……不、行了……呼咻……」",null,null,null],["84_TEXT","84_TEXT",null,null,null],["「これ、以上はぁ……おわらいじゃ……、\\n　なくなっちゃ………………」","「再这，样下去……就变成……、\\n　不是搞笑节目了………………」",null,null,null],["87_TEXT","87_TEXT",null,null,null],["「げぼっ………………ぎゅっ……」","「咳噗………………嘶……」",null,null,null],["88_TEXT","88_TEXT",null,null,null],["「ごぼぼっ……ごぼっ……ごぼっ……」","「咕嘟嘟……咕嘟……咕嘟……」",null,null,null],["91_TEXT","91_TEXT",null,null,null],["「はあ、はあ、はあ……」","「哈啊，哈啊，哈啊……」",null,null,null],["92_TEXT","92_TEXT",null,null,null],["「絶対いつかえらくなってぇ……、\\n　これやった奴に、復讐してやるぅ……ッ！」","「总有一天老娘一定要出人头地……、\\n　向搞这破事的人，报仇雪恨……！」",null,null,null]],"type":"","context":[["unique1111.uasset.csv/row/104","unique1111.uasset.csv/row/115","unique1111.uasset.csv/row/126","unique1111.uasset.csv/row/137","unique1111.uasset.csv/row/148","unique1111.uasset.csv/row/159","unique1111.uasset.csv/row/170","unique1111.uasset.csv/row/181","unique1111.uasset.csv/row/192","unique1111.uasset.csv/row/203","unique1111.uasset.csv/row/