,[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/06_Norimaki/unique1151.uasset.csv","tags":[],"progress":{"translated":88,"length":88,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/06_Norimaki/unique1161.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/06_Norimaki","basename":"unique1161.uasset.csv","extension":"csv","filename":"unique1161.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/06_Norimaki/unique1161.uasset.csv","data":[["unique1161","unique1161",null,null,null],["12_TEXT","12_TEXT",null,null,null],["「……しっかし、レトロな町並みだなあ」","「……不过话说回来，这复古的街景还真有味道啊」",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「一体、ここってどの辺なんだろ？\\n　関東とは思うんだけど」","「这里到底是哪一带来着？\\n　我觉得应该是在关东吧」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「色んなトコにロケ行ってるんだけど、\\n　全然知らない街だもんなあ」","「虽然到处跑外景，\\n　但这条街我完全不认识啊」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「……やっぱ海外資本の力なのかな」","「……果然是因为海外资本的力量吗」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「…………」","「…………」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「あ、エキストラさん！\\n　お疲れ様でーす！」","「啊，群众演员大哥！\\n　辛苦啦——！」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「（ビクッ）」","「（猛一哆嗦）」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「（目を合わさずに逃げていく）」","「（双眼对视后却逃走了）」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「……役者魂、すご。\\n　もしかして今も撮影されてる？」","「……演员之魂，真强。\\n　难道现在也在被拍着？」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「そういえばこういう映画あったよね。\\n　1人以外全員俳優の街みたいなやつ」","「说起来好像有这种电影对吧。\\n　除了一个人其他人全是演员的小镇那种」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「……もしかして、それ系のテレビなのか……？」","「……这莫非是，那种类型的电视节目……？」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「だとしたらのりまき、\\n　めちゃめちゃ重責を帯びているのでは」","「如果是那样的话，海苔卷她，\\n　岂不是肩负着超级重大的责任吗」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「ン？　あそこに見えるのは」","「嗯？　那边能看到的是」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「ディレクターさーん！　お疲れ様どぇーす！」","「导演——！　辛苦啦——斯！」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「……あ？　うん、あ。おつかれ」","「……啊？　嗯，哦。辛苦了」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「のりまきチョップー！」","「海苔卷手刀——！」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「やめい」","「住手啦」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「えんえん。ディレクターさんも塩対応。\\n　それでものりまきは負けません魔法少女だから。\\n　見ててね双子座にあるあてちの故郷の星」","「呜呜。导演先生也好冷淡。\\n　即使这样海苔卷也不会气馁，因为我是魔法少女嘛。\\n　要看着哦，在双子座那边，我故乡的星球」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「え、のりまきって天使なんじゃなかった？\\n　宇宙人なの？」","「欸，海苔卷不是天使吗？\\n　是外星人？」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「天使の星が宇宙にあるんですよ♪\\n　人類を生み出したのが異星の技術なんです♪」","「天使的星球就在宇宙里呀♪\\n　创造出人类的可是异星的科技哦♪」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「あ、しっかり練ってある……」","「哦，设定还挺严谨的嘛……」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「でもこういうサブカルノリが、\\n　民衆の大意に寄り添えていないのではという、\\n　厳しいご指摘もございまして……」","「但是也有人严厉地指出，\\n　这种亚文化的耍宝风格，\\n　是不是没有贴近广大人民群众的意愿呢……」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「あー……確かに喜ぶのは一部の人だけかもなあ」","「啊——……确实可能只有一小部分人会喜欢吧」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「でもあてち、負けません！\\n　だって――美少女だもん！」","「但是我，才不会输呢！\\n　因为――我可是美少女啊！」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「聞いて下さい、のりまき作詞作曲。\\n　『魔法少女に負けないで』」","「请听，海苔卷作词作曲。\\n　《不要输给魔法少女》」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「歌うな歌うな。トンチキな格好もあって、\\n　ちょっと恥ずいんだよ一緒に居るの」","「别唱别唱。再加上这身奇葩打扮，\\n　跟你在一块儿让我有点丢脸啦」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「なんですとーーー！？」","「你说什么——！？」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「そんで俺、急ぎの仕事あるから、\\n　あんま相手出来んのよな」","「而且我呢，有急活要干，\\n　没太有时间招呼你哦」",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「なんか最近困ったこととかある？」","「最近有没有什么烦心事儿呀？」",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「いえ、そういうのは特には。\\n　のりまき、サバイバル能力は激高なので」","「没，那方面倒是没有。\\n　我啊，生存能力可是超强的」",null,null,null],["47_TEXT","47_TEXT",null,null,null],["「そっか。そりゃよかった。\\n　んじゃ、またな～」","「是吗。那就好。\\n　那，回头见啦～」",null,null,null],["50_TEXT","50_TEXT",null,null,null],["「……」","「……」",null,null,null],["51_TEXT","51_TEXT",null,null,null],["「うぅ……一筋縄じゃいかなすぎるよ、\\n　この番組……」","「呜……真是没法轻易搞定啊，\\n　这档节目……」",null,null,null]],"type":"","context":[["unique1161.uasset.csv/row/96","unique1161.uasset.csv/row/107","unique1161.uasset.csv/row/118","unique1161.uasset.csv/row/129","unique1161.uasset.csv/row/140","unique1161.uasset.csv/row/151","unique1161.uasset.csv/row/162","unique1161.uasset.csv/row/173","unique1161.uasset.csv/row/200","unique1161.uasset.csv/row/211","unique1161.uasset.csv/row/222","unique1161.uasset.csv/row/233","unique1161.uasset.csv/row/244","unique1161.uasset.csv/row/255","unique1161.uasset.csv/row/266","unique1161.uasset.csv/row/277","unique1161.uasset.csv/row/288","unique1161.uasset.csv/row/315","unique1161.uasset.csv/row/326","unique1161.uasset.csv/row/337","unique1161.uasset.csv/row/348","unique1161.uasset.csv/row/359","unique1161.uasset.csv/row/370","unique1161.uasset.csv/row/381","unique1161.uasset.csv/row/392","unique1161.uasset.csv/row/403","unique1161.uasset.csv/row/414","unique1161.uasset.csv/row/425","unique1161.uasset.csv/row/436","unique1161.uasset.csv/row/447","unique1161.uasset.csv/row/458","unique1161.uasset.csv/row/469","unique1161.uasset.csv/row/496","unique1161.uasset.csv/row/507"],["unique1161.uasset.csv/row/97"],["unique1161.uasset.csv/row/98"],["unique1161.uasset.csv/row/108"],["unique1161.uasset.csv/row/109"],["unique1161.uasset.csv/row/119"],["unique1161.uasset.csv/row/120"],["unique1161.uasset.csv/row/130"],["unique1161.uasset.csv/row/131"],["unique1161.uasset.csv/row/141"],["unique1161.uasset.csv/row/142","unique1161.uasset.csv/row/246"],["unique1161.uasset.csv/row/152"],["unique1161.uasset.csv/row/153"],["unique1161.uasset.csv/row/163"],["unique1161.uasset.csv/row/164"],["unique1161.uasset.csv/row/174"],["unique1161.uasset.csv/row/175"],["unique1161.uasset.csv/row/201"],["unique1161.uasset.csv/row/202"],["unique1161.uasset.csv/row/212"],["unique1161.uasset.csv/row/213"],["uni