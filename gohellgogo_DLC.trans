t":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/03_Kenne/03_Kenne04.uasset.csv","tags":[],"progress":{"translated":73,"length":73,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/03_Kenne/03_Kenne05.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/03_Kenne","basename":"03_Kenne05.uasset.csv","extension":"csv","filename":"03_Kenne05.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/03_Kenne/03_Kenne05.uasset.csv","data":[["03_Kenne05","03_Kenne05",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「ういーっす。失礼しまーす」","「唔—嘶。打扰啦—」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「……む？」","「……嗯？」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「いつもなら懸衣サンが、\\n　退屈そうにほっつき歩いてんだけど」","「平时的话，悬衣小姐\\n　总会百无聊赖地晃来晃去的」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「居ない。\\n　……ってことは今日こそ、トイレを使う機会が！」","「可她却不在。\\n　……这么说，今天终于有机会用厕所了！」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「な、なんだ！？」","「什、什么！？」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「なにこれやばいやつ？　出た方がいいか？」","「这什么鬼？好不妙的样子？我先撤了比较好吗？」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「きゃーーーーーーーーーーーーーー！！」","「呀——————！！」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「！　今のは……懸衣サンの声？」","「！　刚才那是……悬衣小姐的声音？」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「懸衣さーん！　どこだー！？」","「悬衣小姐——！你在哪儿——！？」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「こっちかー！？　聞こえてたら、\\n　応えてー！」","「在这边吗——！？听得见的话，\\n　回我一声啊——！」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「……てか俺ここでうろついてて大丈夫か？\\n　なんかヤバそうな雰囲気だけど……」","「……话说我在这地方晃悠没事吧？\\n　总觉得气氛有点不妙啊……」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「おお、おお、ヤツシロくん！\\n　こりゃあ、まっこと、ええ所に現れたのう！」","「哦哦，哦哦，8246小弟弟！\\n　这可真是，来得正好呀！」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「……どういう状況？」","「……这是什么情况？」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「まーー深くは言えん！　深くは言えなんじゃけど！」","「哎呀——可不能说太细！虽然不能说太细！」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「なんか？　人体の？　実験？　とか？\\n　謎に動き出すほにゃらら？　とか」","「就是那种？人体？实验？之类的？\\n　莫名其妙启动的某某玩意儿？之类的？」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「一般の連中が入ったら記憶を脳ごと\\n　いかれるような場所なんじゃけどぉ、ここ」","「这里可是个普通人要是进来了，\\n　会把记忆连同脑子一起搞废的地方哦」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「記憶を脳ごといかれるとかいう、\\n　聞いたことない単語が怖すぎるんだが！」","「什么把记忆连同脑子一起搞废，\\n　这种闻所未闻的词也太吓人了吧！」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「委細承知しました。至急逃げますね、俺」","「详情了解了。我这就赶紧溜，告辞」",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「待ちぃ！　待ちんさい……！　そービビらんでよかろーが！\\n　大丈夫大丈夫！　うちは誰にもいわんけー！」","「慢着！你给我等等……！别那么怕嘛——！\\n　没事没事！我跟谁都不会说的——！」",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「……懸衣サンはどうして、そんな事に？」","「……悬衣小姐，怎么会掺和这种事？」",null,null,null],["47_TEXT","47_TEXT",null,null,null],["「ちぃーっとな？　ちぃーっとうっかりしてもうて。\\n　厳重にロックされた最終装置を作動させてな？」","「就稍微？稍微一个不留神啦。\\n　就启动了那个严密锁死的最终装置嘛？」",null,null,null],["48_TEXT","48_TEXT",null,null,null],["「……それ、本当にうっかり？」","「……那真的是，一个不留神？」",null,null,null],["50_TEXT","50_TEXT",null,null,null],["「ふふ」","「呵呵」",null,null,null],["51_TEXT","51_TEXT",null,null,null],["「なんかやろうとして、失敗したのは分かりました。\\n　……詳しく答えなくていいわ、俺も命が大事だし」","「我懂了，你打算做点什么，结果搞砸了。\\n　……不用详细回答了，我的小命也很要紧的」",null,null,null],["52_TEXT","52_TEXT",null,null,null],["「ええ子じゃ！」","「真是个懂事的娃！」",null,null,null],["53_TEXT","53_TEXT",null,null,null],["「じゃけぇ、そこの解除スイッチを押してくれんかのぉ？\\n　このままじゃ、うちの胸元が、ぶちやばいことに」","「所以嘛，能不能帮老婆子我按一下那边的解除开关？\\n　照这样下去，我这胸口，可就超要命了」",null,null,null],["54_TEXT","54_TEXT",null,null,null],["「……んー言うても、\\n　頑張って手を伸ばしたら自分でもいけそうじゃね？」","「……嗯——虽说如此，\\n　你要是再努努力伸长手，不也够得着吗？」",null,null,null],["55_TEXT","55_TEXT",null,null,null],["「もう結構頑張っとるわ！\\n　結果、肩ァいわしてもうてのぉ！」","「我已经够努力的了！\\n　结果就是，肩膀都搞伤啦！」",null,null,null],["56_TEXT","56_TEXT",null,null,null],["「ああ、懸衣サン、\\n　見るからに普段運動しなさそうだしな……」","「啊啊，悬衣小姐你，\\n　一看就是平时不怎么运动的……」",null,null,null],["57_TEXT","57_TEXT",null,null,null],["「運動？　なんだったかの、その言葉。\\n　確か原始的な生物だけが行う低俗な行動」","「运动？那词儿是啥意思来着。\\n　记得好像是只有原始生物才会做的低俗行为」",null,null,null],["58_TEXT","58_TEXT",null,null,null],["「この棒、どうしても外れませんか？」","「这根棒子，实在弄不开吗？」",null,null,null],["62_TEXT","62_TEXT",null,null,null],["「うわぁー！　真ん中の！　真ん中の棒をガタガタするな！\\n　うちの正中線を基軸に色んなとこがぷるぷる揺れるー！」","「呜哇——！别去晃中间那根！中间那根棒子！\\n　以我身体中线为轴，好多地方都跟着摇来晃去的——！」",null,null,null],["63_TEXT","63_TEXT",null,null,null],["「……ふっ。焦ってる懸衣サン、おもろ」","「……噗。慌神的悬衣小姐，有点逗」",null,null,null],["65_TEXT","65_TEXT",null,null,null],["「……きゅん」","「……心里一揪」",null,null,null],["66_TEXT","66_TEXT",null,null,null],["「やばい、内なるドM心をくすぐって、\\n　好感度を上げてしまった」","「不妙，这反而挑动了内心的抖M之魂，\\n　把好感度给刷上去了」",null,null,null],["67_TEXT","67_TEXT",null,null,null],["「意地悪はこのぐらいにして……、\\n　スイッチを押す代わりに要求が」","「捉弄你就到此为止……，\\n　作为按下开关的交换，我有个要求」",null,null,null],["69_TEXT","69_TEXT",null,null,null],["「な、なん。そういうことなら、\\n　うちは結婚するまではせんよ！？せんよ！」","「什、什么。要是那样的话，\\n　俺家在结婚前是绝不会干的哦！？绝不干的哦！」",null,null,null],["70_TEXT","70_TEXT",null,null,null],["「乙女見せなくていいから」","「不用展现你的少女心啦」",null,null,null],["71_TEXT","71_TEXT",null,null,null],["「前に頼んだ話と似てるんですが、今度は\\n　処分に回した亡者を、街に放せるようにしてほしくて」","「虽然和之前拜托你的事有点像，这次是希望\\n　你能把那些送去处分的亡者，放回到街上去」",null,null,null],["73_TEXT","73_TEXT",null,null,null],["「……なんじゃと？」","「……你说什么？」",null,null,null],["74_TEXT","74_TEXT",null,null,null],["「正気で言っとるんけ？\\n　それはこないだの事とは違いすぎる話じゃ」","「你是认真的吗？\\n　这跟之前那事可差太远了」",null,null,null],["75_TEXT","75_TEXT",null,null,null],["「途中で責め苦を止めるのと変わらん。\\n　それをしてお前には何になるん？」","「这就跟中途停止拷问一样。\\n　这么做对你有什么好处？」",null,null,null],["76_TEXT","76_TEXT",null,null,null],["「……んー」","「……嗯——」",null,null,null],["77_TEXT","77_TEXT",null,null,null],["「まさか、情か？」","「该不会，是动了情吧？」",null,null,null],["78_TEXT","78_TEXT",null,null,null],["「まあ……うん……。そんな、ところかな……」","「嘛……嗯……。差不多，就是这么回事吧……」",null,null,null],["79_TEXT","79_TEXT",null,null,null],["「全員は、そりゃ、無理だろうけど。\\n　せめて、俺と知り合ったやつとか……」","「所有人，那个，当然不可能。\\n　但至少，那些跟我认识的家伙……」",null,null,null],["80_TEXT","80_TEXT",null,null,null],["「情が湧いちゃったやつはさ」","「那些让我产生了感情的家伙啊」",null,null,null],["81_TEXT","81_TEXT",null,null,null],["「……なんとかしてやりてー。って」","「……想为他们做点什么。就是这样」",null,null,null],["83_TEXT","83_TEXT",null,null,null],["「………」","「………」",null,null,null],["84_TEXT","84_TEXT",null,null,null],["「ふん。つまらんやつ。社会的動物の、\\n　お手本のような、半端な行動じゃの」","「哼。无聊的家伙。简直就是社会性动物的\\n　典范，半吊子的行为啊」",null,null,null],["86_TEXT","86_TEXT",null,null,null],["「ま、良かろ」","「嘛，行吧」",null,null,null],["87_TEXT","87_TEXT",null,null,null],["「良いの？　これバレたら、\\n　懸衣サンも結構ヤバいんじゃ」","「可以吗？这事要是暴露了，\\n　悬衣小姐你也相当不妙吧」",null,null,null],["88_TEXT","88_TEXT",null,null,null],["「……ずっとここで、\\n　蒲焼のうなぎみたいにいるわけにもいかんけーの」","「……总不能一直待在这里，\\n　像条蒲烧鳗鱼似的一动不动对吧」",null,null,null],["90_TEXT","90_TEXT",null,null,null],["「それに、うちは、別に」","「而且，对俺家来说，也无所谓」",null,null,null],["91_TEXT","91_TEXT",null,null,null],["「…………」","「…………」",null,null,null],["92_TEXT","92_TEXT",null,null,null],["「まあ良い。さっさと、開放せい」","「好了行了。赶紧，把他们放了」",null,null,null],["102_TEXT","102_TEXT",null,null,null],["「ふぅー……何たる美しい自由。\\n　肩が……バキバキじゃ……」","「呼——……何等美妙的自由。\\n　肩膀……要散架了……」",null,null,null],["103_TEXT","103_TEXT",null,null,null],["「偶には運動とかいう悪魔の行事もやらんとの。\\n　ヤツシロくん。今度バドミントンでもするか」","「偶尔也得参加一下运动这种恶魔般的活动啊。\\n　8246老弟。下次要不要打打羽毛球？」",null,null,null],["104_TEXT","104_TEXT",null,null,null],["「お、俺と懸衣サンがバドミントンしてる図、\\n　全然思い浮かばね～～」","「我、我跟悬衣小姐打羽毛球的画面，\\n　完全想象不出来嘛～～」",null,null,null],["105_TEXT","105_TEXT",null,null,null],["「なんだ。……嫌なんけ」","「怎么。……不愿意啊」",null,null,null],["106_TEXT","106_TEXT",null,null,null],["「まあ……いいっすけど」","「嘛……也行啦」",null,null,null],["107_TEXT","107_TEXT",null,null,null],["「そうか。ふふ。じゃ、約束の。\\n　破ったらきさんの眼球をもらう」","「是吗。呵呵。那就说定了。\\n　敢反悔的话，就收了你小子的眼珠子」",null,null,null],["108_TEXT","108_TEXT",null,null,null],["「邪神との契約かよ！？」","「这是跟邪神的契约吗！？」",null,null,null],["109_TEXT","109_TEXT",null,null,null],["「……ふふ」","「……呵呵」",null,null,null]],"type":"","context":[["03_Kenne05.uasset.csv/row/104","03_Kenne05.uasset.csv/row/115","03_Kenne05.uasset.csv/row/126","03_Kenne05.uasset.csv/row/137","03_Kenne05.uasset.csv/row/172","03_Kenne05.uasset.csv/row/183","03_Kenne05.uasset.csv/row/202","03_Kenne05.uasset.csv/row/213","03_Kenne05.uasset.csv/row/272","03_Kenne05.uasset.csv/row/283","03_Kenne05.uasset.csv/row/294","03_Kenne05.uasset.csv/row/329","03_Kenne05.uasset.csv/row/340","03_Kenne05.uasset.csv/row/351","03_Kenne05.uasset.csv/row/362","03_Kenne05.uasset.csv/row/373","03_Kenne05.uasset.csv/row/384","03_Kenne05.uasset.csv/row/395","03_Kenne05.uasset.csv/row/414","03_Kenne05.uasset.csv/row/425","03_Kenne05.uasset.csv/row/436","03_Kenne05.uasset.csv/row/447","03_Kenne05.uasset.csv/row/466","03_Kenne05.uasset.csv/row/477","03_Kenne05.uasset.csv/row/488","03_Kenne05.uasset.csv/row/499","03_Kenne05.uasset.csv/row/510","03_Kenne05.uasset.csv/row/521","03_Kenne05.uasset.csv/row/532","03_Kenne05.uasset.csv/row/543","03_Kenne05.uasset.csv/row/554","03_Kenne05.uasset.csv/row/589","03_Kenne05.uasset.csv/row/600","03_Kenne05.uasset.csv/row/619","03_Kenne05.uasset.csv/row/630","03_Kenne05.uasset.csv/row/641","03_Kenne05.uasset.csv/row/660","03_Kenne05.uasset.csv/row/671","03_Kenne05.uasset.csv/row/682","03_Kenne05.uasset.csv/row/701","03_Kenne05.uasset.csv/row/712","03_Kenne05.uasse