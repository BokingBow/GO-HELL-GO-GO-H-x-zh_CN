XT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0561.uasset.csv","tags":[],"progress":{"translated":61,"length":61,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0571.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya","basename":"unique0571.uasset.csv","extension":"csv","filename":"unique0571.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0571.uasset.csv","data":[["unique0571","unique0571",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「もぐもぐ。歩きながら食べるアイスは、\\n　何でこうも旨いんだろう……」","「（嚼嚼）。边走边吃的冰棒，\\n怎么会这么好吃呢……」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「……ぅううう……ぅう……」","「……呜呜呜……呜……」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「……ン？」","「……嗯？」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「うぅうう……うぅうう……ぅう……」","「呜……呜呜……呜……」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「な、なんだ？　この獣みたいな唸り声。\\n　一体どこから――」","「什、什么声音？像野兽一样的呜咽声。\\n到底是从哪里――」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「うぅうう……ぅ……うぅ……はあ、はあ……。\\n　ぅ…………うぅう……」","「呜呜呜……呜……呜呜……哈啊、哈啊……。呜…………呜呜……」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「……芽ヰ？」","「……芽井？」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「ぁっ……や、ヤツシロ……さん。\\n　ほ、本日もごきげんうるわしう……ふぅー……」","「啊……八、八津……先生。今、今天也祝您心情愉快……呼……」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「……大丈夫か？　なんか凄く苦しそうだけど」","「……你没事吧？看起来好像很难受的样子」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「そ、そうですね……とても……苦しく……。\\n　これもまた私の負った、罪業なのでしょうね……」","「是、是啊……非常……难受……。这大概也是我背负的罪孽吧……」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「それより、ヤツシロさんは、ふぅー……。\\n　どうして……ふぅー……」","「比起那个，八津先生，您……呼……。为什么……呼……」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「……………………」","「……………………」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「……マジ、大丈夫？」","「……你真的没事？」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「ァっ、ほんと、大丈夫、デス」","「啊，真的，没事，啦」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「なんかヤバいならうち来る？\\n　事務所、近いし……」","「要是情况不妙的话要不要来我家？事务所很近的……」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「この状態で家にぃ！？！？」","「都这状态了还去你家！？！？」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「声デカ。いや事務所な。人いるし」","「嗓门真大。不，说的是事务所。有人在的」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「あ。そそそ、そうですよね。\\n　ぁ、やば、びっくりした衝撃で、奥に……ォっ」","「啊。是是是、是呢。啊，糟了，这惊吓的冲击下，深处……哦」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「……奥？」","「……深处？」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「何がですか？」","「什么深处？」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「……なんか言ったのは、そっちだよな？」","「……刚才那话，是你那边说的吧？」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「ふ……ふふ、ふふ……」","「呵……呵呵，呵呵……」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「わ、私……今……責め苦の、途中、でしてぇ……」","「我、我……现在……正受着折磨，到一半呢……」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「今？」","「现在？」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「はいぃ……。体内に、ですねー……。\\n　無害で、小さな、モンスター、を……ォっ」","「是的……。在体内，呢……。无害的，小小的，怪物，在……哦」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「やべ。そこで。暴れられたら。\\n　…………ぉ～～……」","「不好。在这时候。乱动的话。…………哦～～……」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「………………………………」","「………………………………」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「なんか行く所まで行ったな」","「感觉已经去了啊」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「本当、ですよねえ。……っ。全くこんな事を\\n　考えるヤツの、気がしれませんっ」","「真是的，说得没错呢。……。会想出这种事的人，\\n　我完全无法理解」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「……血走った目で、俺のこと見てない？」","「……你用那充血的眼睛，在看我吗？」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「まままま、まさかそんな」","「怎怎怎怎，怎么可能」",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「顔見知りに今の無様な姿を見られることに、\\n　興奮なんて抱くわけがありませんっ」","「被熟人看到现在这副狼狈样子，\\n　我怎么可能会觉得兴奋呢」",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「…………そうか。なんというか」","「………这样啊。该怎么说呢」",null,null,null],["47_TEXT","47_TEXT",null,null,null],["「……ブレないよな……この人……」","「……真是一如既往啊……这人……」",null,null,null]],"type":"","context":[["unique0571.uasset.csv/row/104","unique0571.uasset.csv/row/123","unique0571.uasset.csv/row/134","unique0571.uasset.csv/row/145","unique0571.uasset.csv/row/156","unique0571.uasset.csv/row/167","unique0571.uasset.csv/row/178","unique0571.uasset.csv/row/189","unique0571.uasset.csv/row/200","unique0571.uasset.csv/row/211","unique0571.uasset.csv/row/222","unique0571.uasset.csv/row/233","unique0571.uasset.csv/row/244","unique0571.uasset.csv/row/255","unique0571.uasset.csv/row/266","unique0571.uasset.csv/row/277","unique0571.uasset.csv/row/288","unique0571.uasset.csv/row/299","unique0571.uasset.csv/row/310","unique0571.uasset.csv/row/321","unique0571.uasset.csv/row/332","unique0571.uasset.csv/row/343","unique0571.uasset.csv/row/354","unique0571.uasset.csv/row/365","unique0571.uasset.csv/row/376","unique0571.uasset.csv/ro