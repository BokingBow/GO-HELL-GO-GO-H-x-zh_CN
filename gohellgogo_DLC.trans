D4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/04_Oshi/unique0931.uasset.csv","tags":[],"progress":{"translated":80,"length":80,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/04_Oshi/unique0941.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/04_Oshi","basename":"unique0941.uasset.csv","extension":"csv","filename":"unique0941.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/04_Oshi/unique0941.uasset.csv","data":[["unique0941","unique0941",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「もおぉー！　死ぬんだと思ったンですけど！\\n自分！　完全に！」","「真是的！我真以为自己要死了好吗！\\n我！真的差点！」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「良かったね無事に生きてて。\\nいや死んでるけど」","「太好了，你还活蹦乱跳的。\\n哎呀，虽说本来就是死的。」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「うるさいな、だから！」","「你烦不烦啊，都说了！」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「はあ……ホント散々でした。\\nこんなトコ、さっさとおさらばするであります」","「唉……倒大霉了。\\n这地方，我得赶紧拜拜了您嘞。」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「出来るもんなら全然、\\nやって頂いてもいいけどね」","「你真做得到的话，随你便咯，\\n我倒是完全不介意的。」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「それにしても、どこに行っても聞きますな。\\n自分と似ている、一ノ瀬という方のこと」","「话说回来，走到哪儿都能听到啊。\\n关于那个长得像我的，叫一之濑的人。」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「あぁ、そーおー？　まあ、似てるからね、ガチで」","「啊，是吗？不过嘛，因为真的很像嘛。」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「そんなに言うなら一度ぐらい、\\n会ってみたい物でありますな」","「既然都说到这份上了，\\n我真想见上她一面呢。」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「やめときなって」","「我劝你最好别。」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「ドッペルゲンガーって本物と出会ったら、\\n消えて無くなってしまうんだぞ」","「替身什么的，如果和本尊见面的话，\\n可是会消失得无影无踪的哦。」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「誰がドッペルゲンガーでありますか！」","「你说谁是替身啊！」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「ぐぬぬ、こうなったら是が非でも会ってやる」","「唔唔唔，都这样了，我无论如何都要见上一面。」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「いっそあっちを消したら、\\n二度と舐めた口きかれない……？」","「干脆把那边那个干掉，\\n是不是就再也不会听到那种小看人的话了……？」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「……多分勝てんぞ、お前じゃ」","「……你估计打不过她的。」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「ぴぎーーー！！」","「噗叽——！！」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「怒った時の叫びも……なんか……違うんだよな……」","「就连生气时的叫声……总觉得……也不太对啊……」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「段々許せなくなってきた、この不条理が」","「我越来越无法原谅这种荒唐事了」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「お疲れ様です」","「辛苦了。」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「ぎゃーーー！！」","「嘎——！！」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「何！　急に掴むなよ、服！！」","「干嘛！别突然拽我衣服啊！！」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「ほほほ、相変わらず元気ですな、お椎さん」","「呵呵呵，还是那么精神啊，椎小姐」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「ぶるぶるぶるぶる」","「抖抖抖抖抖」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「私はちょっと物を取りに来ただけなので。\\nそれでは」","「我只是过来拿点东西。\\n那就先告辞了」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「えーと、なんていうか」","「呃，该怎么说呢」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「……大丈夫そ？」","「……你还好吗？」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「えーーん！　こんなトコ、\\n　さっさとおさらばしてやりますーーー！！」","「呜哇——！这种鬼地方，\\n我要马上跟它说拜拜了——！！」",null,null,null]],"type":"","context":[["unique0941.uasset.csv/row/104","unique0941.uasset.csv/row/115","unique0941.uasset.csv/row/126","unique0941.uasset.csv/row/137","unique0941.uasset.csv/row/148","unique0941.uasset.csv/row/159","unique0941.uasset.csv/row/170","unique0941.uasset.csv/row/181","unique0941.uasset.csv/row/192","unique0941.uasset.csv/row/203","unique0941.uasset.csv/row/214","unique0941.uasset.csv/row/225","unique0941.uasset.csv/row/236","unique0941.uasset.csv/row/247","unique0941.uasset.csv/row/258","unique0941.uasset.csv/row/269","unique0941.uasset.csv/row/280","unique0941.uasset.csv/row/299","unique0941.uasset.csv/row/310","unique0941.uasset.csv/row/321","unique0941.uasset.csv/row/332","unique0941.uasset.csv/row/343","unique0941.uasset.csv/row/354","unique0941.uasset.csv/row/397","unique0941.uasset.csv/row/408","unique0941.uasset.csv/row/419"],["unique0941.uasset.csv/row/105"],["unique0941.uasset.csv/row/106"],["unique0941.uasset.csv/row/116"],["unique0941.uasset.csv/row/117"],["unique0941.uasset.csv/row/127"],["unique0941.uasset.csv/row/128"],["unique0941.uasset.csv/row/138"],["unique0941.uasset.csv/row/139"],["unique0941.uasset.csv/row/149"],["unique0941.uasset.csv/row/150"],["unique0941.uasset.csv/row/160"],["unique0941.uasset.csv/row/161"],["unique0941.uasset.csv/row/171"],["unique0941.uasset.csv/row/172"],["unique0941.uasset.csv/row/182"],["unique0941.uasset.csv/row/183"],["unique0941.uasset.csv/row/193"],["unique0941.uasset.csv/row/194"],["unique0941.uasset.csv/row/204"],["unique0941.uasset.csv/row/205"],["unique0941.uasset.csv/row/215"],["unique0941.uasset.csv/row/216"],["unique0941.uasset.csv/row/226"],["unique0941.uasset.csv/row/227"],["unique0941.uasset.csv/row/237"],["unique0941.uasset.csv/row/238"],["unique0941.uasset.csv/row/248"],["unique0941.uasset.csv/row/249"],["unique0941.uasset.csv/row/259"],["unique0941.uasset.csv/row/260"],["unique0941.uasset.csv/row/270"],["unique0941.uasset.csv/row/271"],["unique0941.uasset.csv/row/281"],["unique0941.uasset.csv/row/282"],["unique0941.uasset.csv/row/300"],["unique0941.uasset.csv/row/301"],["unique0941.uasset.csv/row/311"],["unique0941.uasset.csv/row/312"],["unique0941.uasset.csv/row/322"],["unique0941.uasset.csv/row/323"],["unique0941.uasset.csv/row/333"],["unique0941.uasset.csv/row/334"],["unique0941.uasset.csv/row/344"],["unique0941.uasset.csv/row/345"],["unique0941.uasset.csv/row/355"],["unique0941.uasset.csv/row/356"],["unique0941.uasset.csv/row/398"],["unique0941.uasset.csv/row/399"],["unique0941.uasset.csv/row/409"],["unique0941.uasset.csv/row/410"],["unique0941.uasset.csv/row/420"],["unique0941.uasset.csv/row/421"]],"parameters":[[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"row