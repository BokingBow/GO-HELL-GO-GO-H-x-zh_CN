2AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/02_Arakasegi/02_Arakasegi02.uasset.csv","tags":[],"progress":{"translated":101,"length":101,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/02_Arakasegi/02_Arakasegi03.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/02_Arakasegi","basename":"02_Arakasegi03.uasset.csv","extension":"csv","filename":"02_Arakasegi03.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/02_Arakasegi/02_Arakasegi03.uasset.csv","data":[["02_Arakasegi03","02_Arakasegi03",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「おーっす。遊びに来たぞー」","「喂——。我来找你玩了哦——！」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「だから来るなよ遊びに。\\n　買い物をしに来るんだよ」","「都说了别来玩。\\n　要说是来买东西的。」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「バトエンやろうぜー」","「来玩战斗铅笔吧——！」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「平日のオフにやんなバトエンを。\\n　休み時間とかにやれ」","「傻吗，平日的休息时间玩什么战斗铅笔。\\n　留到午休时候再玩啊。」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「アタシは忙しいんだっての。\\n　暇ならそこの段ボール取って」","「我都说了我很忙。\\n　你要是闲着就帮我把那边的纸箱拿过来。」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「おいおい、タダで俺を働かせるつもりか。\\n　資本主義の奴隷とは思えんな」","「喂喂，你打算让我白干活啊。\\n　我可不会当资本主义的奴隶。」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「だ、だりぃ～～。\\n　そのダル絡みなんとかならんの」","「烦、烦死了～～。\\n　你那死缠烂打的劲儿就没完了是吧」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「俺、気になる子には、\\n　変な絡みしてしまうタイプなんかも」","「我这人吧，对在意的姑娘，\\n　可能就会这样缠得奇奇怪怪的～」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「キモ。黙れ。カス。どっか行け」","「恶心。闭嘴。废物。滚一边去」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「はあもういい。自分でやるから」","「啊够了。我自己来」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「あーごめんごめん。手伝うって――」","「啊～抱歉抱歉。我帮你――」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「良いから！　さっさとどけ。\\n　……うん……しょっと…………へ？」","「不用！赶紧闪开。\\n　……嗯……嘿咻…………咦？」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「ん？」","「嗯？」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「なにこ……ひゃんっ！」","「这什么……呀啊！」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「っぴゃーーー！！\\n　なんこれ！　キモい！　キモいー！」","「咿呀————！！\\n　这什么鬼！恶心！恶心死了！」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「うお……マジで何……？\\n　なにこれ……生き物……？」","「呜哦……到底什么玩意儿……？\\n　这是什么……生物……？」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「なんか！　バイオ健康器具とか言って！\\n　制作会社がやけに推してた新商品！！」","「好像说是！叫什么生物科技保健器材！\\n　制作公司疯狂推销的新品！！」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「うげー気持ち悪ー。\\n　こんなもん売れるのか……？」","「噁——好恶心。\\n　这玩意儿能卖得出去……？」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「知らねーよ！\\n　そんなん知らねーってばー！」","「我哪知道！\\n　这种事我哪知道啦——！」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「ひゅぃいいん……っ。な、なんかっ。\\n　背中っ。背中、ゾワってしてっ」","「咿唔唔……呃、总觉得。\\n　背上。背上，一阵阵发毛……」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「きゅぅーー……っ。き、キモイーっ。\\n　ぞ、ゾワゾワしゅご……っ」","「呜——……呜。恶、恶心死了——。\\n　背、背上好、好发毛……」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「……なんつーかすごい光景だ」","「……该怎么说呢，真是难得一见的景象啊」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「つーかいつまで見てンだよ！？\\n　と、取ってよぉ！」","「话说你要看到什么时候啊！？\\n　快、快帮我拿掉啦！」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「ぎえ」","「呃噁」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「きもすぎる～～！！　見るのも触るのも無理ぃー！\\n　だから取って！　ヤツシロはやく！」","「实在太恶心了～～！！看都不想看摸也不想摸啊——！\\n　所以你快点！8246快帮我拿掉！」",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「…………」","「…………」",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「いや俺もあんま触りたくないんだけど」","「不不，我也不太想碰那玩意儿啊」",null,null,null],["47_TEXT","47_TEXT",null,null,null],["「こ、この恩知らずーー！！\\n　今まで散々モノ売ってやっただろ！？」","「你、你这个忘恩负义的家伙——！！\\n　之前我卖了你那么多东西不是！？」",null,null,null],["48_TEXT","48_TEXT",null,null,null],["「俺達が行ってきたのはフェアなトレード。\\n　そこに上下関係はまったくないと思わないか？」","「我们之间一直是公平交易。\\n　你不觉得里头完全不存在什么上下关系吗？」",null,null,null],["49_TEXT","49_TEXT",null,null,null],["「わぁーったよ！　わぁーった！！」","「知道了啦！知道了！！」",null,null,null],["50_TEXT","50_TEXT",null,null,null],["「――せんえん！」","「――一千日元！」",null,null,null],["51_TEXT","51_TEXT",null,null,null],["「…………なるほど」","「……原来如此」",null,null,null],["53_TEXT","53_TEXT",null,null,null],["「千円やるから！　だから、取っ……。\\n　うひぃいいっ！　の、のぼってきたぁっ」","「我给你一千日元！所以，快拿掉……。\\n　咿呀呀呀！爬、爬上来了……！」",null,null,null],["54_TEXT","54_TEXT",null,null,null],["「ちょ、そこ、だめっ、変なトコ、入ってくるなあ！」","「喂、那里、不行、别钻进奇怪的地方啊！」",null,null,null],["55_TEXT","55_TEXT",null,null,null],["「……どちらかというとこの光景を見続けるために、\\n　1000円払いたい気持ちになってきた」","「……与其这样，我倒是开始觉得，\\n　为了继续看这景象，掏个1000日元也值了」",null,null,null],["56_TEXT","56_TEXT",null,null,null],["「――5000円！！」","「――五千日元！！」",null,null,null],["57_TEXT","57_TEXT",null,null,null],["「……ココロ揺さぶられる値段になってきたな」","「……这价钱可就让人动摇了啊」",null,null,null],["58_TEXT","58_TEXT",null,null,null],["「5000円にこの前着てた、\\n　スクール水着を付けるというのはどうだ！？」","「在五千日元的基础上，\\n　再加一件你之前穿过的校园泳装，你看怎么样！？」",null,null,null],["59_TEXT","59_TEXT",null,null,null],["「はぁああああ！？　おまっ、キモっ！\\n　ンなもん、渡せるわけ……っ」","「哈啊啊啊啊啊！？你、恶不恶心！\\n　那种东西，怎么可能给你……呜」",null,null,null],["61_TEXT","61_TEXT",null,null,null],["「ぴぎゃーーー！！　せ、背中入ってきて！\\n　ホント無理！　ホント無理だから！！」","「咿呀咿呀————！！它、钻进背里来了！\\n　真的要不行了！真的要不行了啊！！」",null,null,null],["62_TEXT","62_TEXT",null,null,null],["「ゃ、やだ……っ。そんなとこ……ぴぃん！」","「不、不要……呜。那种地方……咿嗯！」",null,null,null],["63_TEXT","63_TEXT",null,null,null],["「ふっふっふ。どうすんだぁ？\\n　大人しく、渡すもん渡して……」","「呵、呵、呵。你要怎么办呢～？\\n　乖乖地，把该交的东西交出来……」",null,null,null],["64_TEXT","64_TEXT",null,null,null],["「…………ぇぐっ」","「……呜呃」",null,null,null],["65_TEXT","65_TEXT",null,null,null],["「えぐ？」","「呃？」",null,null,null],["66_TEXT","66_TEXT",null,null,null],["「えーーんっ。ぐすっ。ほ、ホント、無理なのっ。\\n　これ、気持ち悪いの、やなのっぐすっ」","「呜——嗯。抽泣。真、真的，不行啦。\\n　这个，好恶心，讨厌啦抽泣」",null,null,null],["67_TEXT","67_TEXT",null,null,null],["「ま、マジ泣き！？」","「真、真哭啊！？」",null,null,null],["68_TEXT","68_TEXT",null,null,null],["「取ってよぉヤツシロっ。えぇええんっぐすっっ。\\n　なんでもっ。なんでもするからぁっ……」","「帮我拿掉啦8246。呜呜呜抽泣。\\n　什么都行。让我做什么都行……」",null,null,null],["69_TEXT","69_TEXT",null,null,null],["「こ、怖いの。これ。やだからぁっ。\\n　ええええんっ……ぐす……」","「好、好怕。这个。讨厌啦。\\n　呜呜呜呜……抽泣……」",null,null,null],["70_TEXT","70_TEXT",null,null,null],["「ちょ、ちょっと待ってろ。\\n　すぐ取るから！」","「你、你先等一下。\\n　我马上就拿掉！」",null,null,null],["80_TEXT","80_TEXT",null,null,null],["「……」","「……」",null,null,null],["81_TEXT","81_TEXT",null,null,null],["82_TEXT","82_TEXT",null,null,null],["「えっと、その、やっと片付いたな、はは」","「呃，那个，总算收拾好了，哈哈」",null,null,null],["83_TEXT","83_TEXT",null,null,null],["「……ん」","「……嗯」",null,null,null],["84_TEXT","84_TEXT",null,null,null],["「これは？」","「这个呢？」",null,null,null],["85_TEXT","85_TEXT",null,null,null],["「……5000円。いるんだろ」","「……5000日元。你需要的吧」",null,null,null],["86_TEXT","86_TEXT",null,null,null],["「あ、あれは冗談みたいなモンでして」","「那、那只是个玩笑一样的东西」",null,null,null],["87_TEXT","87_TEXT",null,null,null],["88_TEXT","88_TEXT",null,null,null],["「……ホントすんませんでした」","「……真的非常抱歉」",null,null,null],["89_TEXT","89_TEXT",null,null,null],["90_TEXT","90_TEXT",null,null,null],["「買い物。……する？」","「买东西。……要去吗？」",null,null,null],["91_TEXT","91_TEXT",null,null,null],["「……何か買わせていただきます」","「……请让我买点什么吧」",null,null,null]],"type":"","context":[["02_Arakasegi03.uasset.csv/row/104","02_Arakasegi03.uasset.csv/row/115","02_Arakasegi03.uasset.csv/row/126","02_Arakasegi03.uasset.csv/row/137","02_Arakasegi03.uasset.csv/row/148","02_Arakasegi03.uasset.csv/row/1