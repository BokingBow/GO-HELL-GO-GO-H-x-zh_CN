AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/03_Kenne/03_Kenne02.uasset.csv","tags":[],"progress":{"translated":75,"length":75,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/03_Kenne/03_Kenne03.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/03_Kenne","basename":"03_Kenne03.uasset.csv","extension":"csv","filename":"03_Kenne03.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/03_Kenne/03_Kenne03.uasset.csv","data":[["03_Kenne03","03_Kenne03",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「今日こそはここのトイレを使ってやる……」","「今天一定要用上这里的厕所……」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「よーよーヤツシロくん。\\n　今日も下らない空と下らない世界じゃの～」","「哟哟八津同学～。\\n　今天也是无聊的天空与无聊的世界啊～」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「……懸衣サン。\\n　実はどっかから、見張ってたりします？」","「……悬衣小姐。\\n　您其实在哪个地方盯梢着吧？」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「あぁ？　そがなつまらんこと、\\n　何でぇうちがせにゃいけんのじゃぁ」","「啊？那种无聊的事，\\n　凭什么非得我去做啊」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「うちはくだらん事は好かん」","「我不喜欢无聊的事儿」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「へえ。休日とかは何して遊んでんすか」","「哦。那假日什么的你会玩些什么啊」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「おー先週は雀蜂の遺伝子と溝鼠の遺伝子を\\n　混ぜて新しい生物を作ったりしとったのー」","「哦哦——上周我在拿雀蜂的基因和沟鼠的基因\\n　混在一起造新生物来着——」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「ひっ『面白い』の定義が違いすぎる」","「咿！你这『有趣』的定义也太离谱了」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「……しかし、懸衣サンさ。\\n　俺も何度かこの建物に来ましたけど」","「……可是啊，悬衣小姐。\\n　我也来过这楼里好几次了」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「いつ来ても、だーれも居なくね？」","「无论什么时候来，不都一个人没有吗？」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「……まあのー」","「……嗯，是呢——」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「……」","「……」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「ここに処分で送られた亡者は、\\n　奥か別の階にでもいるの？」","「那些被送去处置的亡者，\\n　是在更里面还是别的楼层吗？」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「ああ。ここで魂の処置を受けて復活し、\\n　また責め苦を受けさせんといかんけぇのー」","「啊。在这里接受灵魂处置后复活，\\n　必须得让他们重新去受苦才行嘛——」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「地獄の良い所じゃけぇ。……死が無い。\\n　その御蔭で、何千年、何万年、責め苦を繰り返せる」","「地狱的好地方嘛。……没有死亡。\\n　多亏了这点，才能把折磨几千年、几万年地循环下去」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「馬鹿みたいな数字だよなあ」","「真是跟开玩笑一样的数字啊」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「カッカッカ。珍しく気が合うのぉ」","「嘎嘎嘎。难得跟我合得来嘛」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「ほいじゃけど、それが地獄じゃけぇね。\\n　延々延々、終わらんを続けんの」","「但是啊，这就是地狱嘛。\\n　要永远永远，把没有尽头的事情干下去」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「ふぅーん。あんま知らないけど、\\n　懸衣サン、つまんなそうに言うね」","「哼——嗯。我虽然不太懂，\\n　但悬衣小姐，你这口气听起来很不耐烦呢」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「そうだ。ちょっと思ったんだが」","「对了。我突然想到件事」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「一度処分に回した亡者、\\n　俺のとこに戻す事はできないか？」","「那些被转去处置过的亡者，\\n　能不能弄回我这儿来？」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「なんね？　そがいな」","「什么？　这种事儿」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「いや、処分に回したは良いものの、\\n　後で気が変わって……みたいな事が」","「不是，就是虽然送去处置了是挺好的，\\n　但过后又改主意了……像是这种事」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「ちょくちょくあってさ」","「常常会发生嘛」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「はっ。ぼけーっとしたやつじゃのぉ」","「哈。真是个愣头愣脑的家伙啊」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「お偉いさんなんすよね。\\n　何とかならん？」","「我好歹算个大人物吧。\\n　能不能想想办法？」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「地獄を律するうちに、ようそがいなこと言えたの？\\n　おどれが何言いよるか、分かっとるんかいのぉ？」","「你掌管着地狱的规矩，居然能说出这种话？\\n　你知不知道自己在说什么啊？」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「え？　あっ、いやー……それはー……はは」","「欸？　啊，不——……那是——……哈哈」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「じゃが、ま、よかろ」","「不过，嘛，好吧」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「えっ」","「诶」",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「うちはつまらんことは好かん」","「我不喜欢无聊的事」",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「面白そうなことなら、\\n　両の目ん玉ほじくってもやっちゃるけぇのー」","「只要是看起来有趣的事，\\n　就算挖出两只眼珠子我也会干——」",null,null,null],["47_TEXT","47_TEXT",null,null,null],["「面白いんすか？\\n　亡者を戻せることが？」","「有趣吗？\\n　把亡者弄回来这件事？」",null,null,null],["48_TEXT","48_TEXT",null,null,null],["「カカ。何も知らんで言いよったんけ」","「嘎嘎。原来你什么都不知道就开口了啊」",null,null,null],["49_TEXT","49_TEXT",null,null,null],["「……問題が起きた場合は、\\n　ぜーんぶ、きさんに被せる。OK?」","「……万一起了问题，\\n　全——都，要扣到你头上。OK?」",null,null,null],["50_TEXT","50_TEXT",null,null,null],["「あっ、きたねっ。\\n　なんかヤバい責任を追わせようとしてる！」","「啊，好脏！\\n　你想把什么不妙的责任推给我啊！」",null,null,null],["51_TEXT","51_TEXT",null,null,null],["「カカカ。言い出しっぺはおどれじゃ」","「嘎嘎嘎。先开口的是你自己嘛」",null,null,null],["52_TEXT","52_TEXT",null,null,null],["「はい決まりー。記録も残しとこ。\\n　うちはヤツシロとかいう卑劣な輩に脅されて～」","「好，就这么定了——。再留个记录。\\n　本人被一个叫8246的卑鄙家伙所胁迫～」",null,null,null],["53_TEXT","53_TEXT",null,null,null],["「ぐぬぬ、変な落とし穴に嵌まってしまったか」","「唔唔唔，我这是掉进奇怪的陷阱里了吗」",null,null,null]],"type":"","context":[["03_Kenne03.uasset.csv/row/112","03_Kenne03.uasset.csv/row/123","03_Kenne03.uasset.csv/row/134","03_Kenne03.uasset.csv/row/145","03_Kenne03.uasset.csv/row/156","03_Kenne03.uasset.csv/row/167","03_Kenne03.uasset.csv/row/178","03_Kenne03.uasset.csv/row/189","03_Kenne03.uasset.csv/row/200","03_Kenne03.uasset.csv/row/211","03_Kenne03.uasset.csv/row/222","03_Kenne03.uasset.csv/row/233","03_Kenne03.uasset.csv/row/244","03_Kenne03.uasset.csv/row/255","03_Kenne03.uasset.csv/row/266","03_Kenne03.uasset.csv/row/277","03_Kenne03.uasset.csv/row/288","03_Kenne03.uasset.csv/row/299","03_Kenne03.uasset.csv/row/310","03_Kenne03.uasset.csv/row/321","03_Kenne03.uasset.csv/row/332","03_Kenne03.uasset.csv/row/343","03_Kenne03.uasset.csv/row/354","03_Kenne03.uasset.csv/row/365","03_Kenne03.uasset.csv/row/376","03_Kenne03.uasset.csv/row/387","03_Kenne03.uasset.csv/row/398","03_Kenne03.uasset.csv/row/409","03_Kenne03.uasset.csv/row/420","03_Kenne03.uasset.csv/row/431","03_Kenne03.uasset.csv/row/442","03_Kenne03.uasset.csv/row/453","03_Kenne03.uasset.csv/row/464","03_Kenne03.uasset.csv/row/475","03_Kenne03