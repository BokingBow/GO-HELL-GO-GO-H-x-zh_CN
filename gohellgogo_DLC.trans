rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/05_Kamase/unique1071.uasset.csv","tags":[],"progress":{"translated":51,"length":51,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/04_Oshi/unique0901.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/04_Oshi","basename":"unique0901.uasset.csv","extension":"csv","filename":"unique0901.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/04_Oshi/unique0901.uasset.csv","data":[["unique0901","unique0901",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「ど、どういう事でありますか」","「这、这到底是怎么回事」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「ここが、地獄……！？」","「这里，就是地狱……！？」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「…………」","「…………」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「俄には信じがたい事であります。\\nしかし、自分が見た物は、一体……！」","「此事一时难以置信。\\n但是，在下亲眼所见之物，究竟是……！」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「……」","「……」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「……海賊版？」","「……盗版？」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「はい？　何がでしょうか」","「什么？　您说什么呢」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「いや別に」","「没什么」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「……パチモン？」","「……山寨货？」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「全く分からないけど、\\nすごく失礼な事を言われている気がする」","「完全听不懂，\\n但总觉得你在说非常失礼的话」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「ごめんごめん、\\n知り合いにすげー似てて」","「抱歉抱歉，\\n实在是跟我认识的人太像了」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「あはは、なんだあ。そうですかあ」","「啊哈哈，什么嘛。是这样啊」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「じゃあやっぱり、\\nめちゃめちゃ悪口でありますなあ！？」","「那果然，\\n全是坏话对吧！？」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「ケツは寧ろデカいんだがな……。\\n　何ていうか……惜しい……惜しい……」","「屁股倒是挺大的……。\\n　该怎么说呢……可惜……可惜……」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「人を殴る事が罪でなければ、\\n絶対に今、いってるのに……」","「要是打人不算犯罪，\\n我现在绝对已经动手了……」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「というわけで、お前のあだ名は『お椎』だ。\\nこれからよろしくね」","「就是这样，你的外号就叫『椎』了。\\n以后请多关照哦」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「お椎？　……おしい……惜しい……」","「椎？　……可惜……差一点……」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「惜しいからおしい！？\\nひえ～この人絶対友達少ない」","「因为可惜就叫椎！？\\n咿～这个人绝对没朋友」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「良く見たら友達が少なそうな顔してますし」","「仔细一看，你也长着一张没什么朋友的脸嘛」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「失礼だなキミ」","「你说这话可真没礼貌」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「よく言えたなそんな事が」","「亏你说得出口」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「自分はそんなにも、\\nあなたの知人に似ているのですか？」","「我就那么，\\n像你认识的人吗？」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「ああ、似てる。髪型とか、服装とか、\\n体型とか、カラーリングとか……」","「啊，很像。发型啦，服装啦，\\n体型啦，整体色调什么的……」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「ふうん、顔は？」","「哦～，那脸呢？」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「あ、見てぇ可愛いてんとう虫」","「啊，看，好可爱的瓢虫」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「ふふ、それはダンゴムシであります」","「呵呵，那是西瓜虫呀」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「そっか、惜しいなあ。うふふ」","「是吗，真可惜呢。唔呼呼」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「殺すぞ」","「我宰了你哦」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「冗談はこのぐらいにしておくとして」","「玩笑就开到这吧」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「こういう一見普通そうで内面が歪んだ人間が、\\n世界を段々駄目にしていくんでしょうな……」","「就是这种乍一看挺正常内心却扭曲的人，\\n在把世界一步步搞坏的吧……」",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「それじゃ落ちに行こっか、地獄の底」","「那我们往底下走吧，到地狱的深处」",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「ひぃいい。普通に極悪非道人～～」","「咿～～。彻头彻尾的极恶非道之人～～」",null,null,null]],"type":"","context":[["unique0901.uasset.csv/row/112","unique0901.uasset.csv/row/123","unique0901.uasset.csv/row/134","unique0901.uasset.csv/row/145","unique0901.uasset.csv/row/156","unique0901.uasset.csv/row/167","unique0901.uasset.csv/row/178","unique0901.uasset.csv/row/189","unique0901.uasset.csv/row/200","unique0901.uasset.csv/row/211","unique0901.uasset.csv/row/222","unique0901.uasset.csv/row/233","unique0901.uasset.csv/row/244","unique0901.uasset.csv/row/255","unique0901.uasset.csv/row/266","unique0901.uasset.csv/row/277","unique0901.uasset.csv/row/288","unique0901.uasset.csv/row/299","unique0901.uasset.csv/row/310","unique0901.uasset.csv/row/321","unique0901.uasset.csv/row/332","unique0901.uasset.csv/row/343","unique0901.uasset.csv/row/354","unique0901.uasset.csv/row/365","unique0901.uasset.csv/row/376","unique0901.uasset.csv/row/387","unique0901.uasset.csv/row/398","unique0901.uasset.csv/row/409","unique0901.uasse