"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0171.uasset.csv","tags":[],"progress":{"translated":55,"length":55,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0251.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya","basename":"unique0251.uasset.csv","extension":"csv","filename":"unique0251.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0251.uasset.csv","data":[["unique0251","unique0251",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「……はい」","「……好的。」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「失礼しまーす！　お待たせしました、\\n　鶏むねと鶏ささみの贅沢五穀米弁当です！」","「久等啦——！让您久等了，这是鸡胸肉和鸡里脊的豪华五谷米饭便当！」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「どーも。会計は会社に回して下さい」","「谢谢。账单请转给我们公司。」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「はーい！　お渡しこちらになります」","「好嘞——！这是给您的，请拿好。」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「……ん？」","「……嗯？」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「どうかしましたか？」","「怎么了？」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「いや。ふつうにビニール直で運んできたの？\\n　背中に背負ってるのからは出さないんだ」","「没什么。你居然是直接从塑料袋里拿过来的？不从你背上那个包里拿出来吗？」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「これは現世で受けた注文分なので！」","「既然这是我在现世接的单！」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「……現世で？」","「……在现世？」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「……どういうこと？」","「……究竟是怎么回事？」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「どうもこうもその言葉の通りとしか」","「什么怎么回事，就是字面那个意思啊。」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「こっちにきたのはどのぐらい前なの」","「你来这边大概多久了？」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「数週間ぐらい前かしら」","「大概几个星期前吧。」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「ナニの注文を受けたの」","「你接的是啥订单？」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「ん？　海鮮丼！」","「嗯？海鲜盖饭！」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「………………」","「………………」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「数週間前に受け取った海鮮丼を、\\n　今でも持ち歩き続けるってこと？」","「你是说，你到现在还一直随身带着\\n　几个星期前收到的海鲜盖饭？」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「時間も経ったし飛んだり跳ねたりしたけど、\\n　潰れてはいない、はず！」","「虽然过了点时间，又蹦又跳的，\\n　但应该，没有压烂掉！」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「それ頼んだおきゃくさん、\\n　たぶんもう忘れてる」","「点这份餐的那位客人，\\n　估计早都忘了这茬了。」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「関係ないわ！　ルールだもの！　お客様や神様が\\n　なんと言おうと、一度決めた事はやり通す！」","「无所谓！这是规矩嘛！不管客人和神明\\n　怎么说，一旦决定的就做到底！」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「それが私の生きる道なの。\\n　この街じゃ亡者とか変なこと言われるけど」","「这是我的人生之道。\\n　虽然在这条街上老被人叫亡灵或者奇怪的家伙。」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「へえ。絶対にあけないでね、その箱をここで」","「嘿。可千万别在这里打开啊，那个箱子。」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「大丈夫！　私もそんな勇気ない！」","「放心！我也没有那个胆量！」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「……もともと、うーぱーで働いてた？」","「……你原本，是在Uber Eats干的？」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「そうそう。よく知ってるわね。\\n　こんな田舎にうーぱーなんてないだろうに」","「对对。你知道的还挺清楚嘛。\\n　明明这种乡下地方根本不会有Uber Eats的。」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「いなか？」","「乡下？」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「そう。やばいわ、この辺。\\n　皆、ここが地獄だとか言い張って」","「可不咋地。这一带可真要命。\\n　大家，都硬说这里是地狱什么的。」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「……なんかそういう宗教？\\n　の街？　なんでしょ？」","「……这难道是什么宗教\\n　之类的街道吗？」",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「はっ。もしかしたらあなたも、\\n　その宗派の人！？　だったらごめん！」","「啊。难道说，你也是\\n　那个教派的人！？那可真不好意思！」",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「そういうのではないけれど」","「倒也不是那样的。」",null,null,null],["47_TEXT","47_TEXT",null,null,null],["「ここはほんとうに地獄だよ。\\n　みとめたら」","「这里，真的是地狱哦。\\n　只要你承认的话。」",null,null,null],["48_TEXT","48_TEXT",null,null,null],["「ひぃーっ！　典型的な狂信者！\\n　やっぱり信じているじゃない！」","「噫——！典型的狂热信徒！\\n　你果然还是信那套嘛！」",null,null,null],["49_TEXT","49_TEXT",null,null,null],["「…………」","「…………」",null,null,null],["50_TEXT","50_TEXT",null,null,null],["「ごめんけど私、宗派違うから。\\n　あなた達のお仲間にはなれない」","「但抱歉了，我属于不同的宗派。\\n　没法成为你们的伙伴。」",null,null,null],["51_TEXT","51_TEXT",null,null,null],["「まあなんでもいいや」","「嘛，怎样都无所谓了。」",null,null,null],["52_TEXT","52_TEXT",null,null,null],["「せなかに背負ってるゴミ、もうすてたら？」","「你背上背着的那个垃圾，不如扔了？」",null,null,null],["53_TEXT","53_TEXT",null,null,null],["「だからそれは無理！　ルールだもの。\\n　契約した仕事は投げ出せない」","「所以说了不行啊！这是规矩嘛。\\n　接了单的活儿，我就不能半途而废。」",null,null,null],["54_TEXT","54_TEXT",null,null,null],["「ふうん……現世向き。\\n　わたしはそーいうのがあってなかったから」","「嚯……你可真是适合现世。\\n　我啊，正是因为那种地方水土不服才来这的。」",null,null,null],["55_TEXT","55_TEXT",null,null,null],["「現世向き？　じゃああなたは地獄向きなの？」","「适合现世？那你是适合地狱啦？」",null,null,null],["56_TEXT","56_TEXT",null,null,null],["「まあね」","「差不多吧。」",null,null,null],["57_TEXT","57_TEXT",null,null,null],["「それは……なに？　洗脳がうまいとか、\\n　詐欺まがいの商法がうまいとか……？」","「那是……啥啊？擅长给人洗脑，\\n　还是擅长搞些欺诈传销的营生……？」",null,null,null],["58_TEXT","58_TEXT",null,null,null],["「そういうのじゃなくて」","「才不是那种的。」",null,null,null],["59_TEXT","59_TEXT",null,null,null],["「そ、そっか。非暗示側なのかしら。\\n　だったら簡単にカモにされるのが上手とか……？」","「是，是这样啊。那你是非暗示侧的吗。\\n　这样的话，难道是擅长当冤大头被宰的……？」",null,null,null],["60_TEXT","60_TEXT",null,null,null],["「この人とはなすの、だるいな」","「跟这家伙说话，可真累人啊。」",null,null,null],["61_TEXT","61_TEXT",null,null,null],["「そう？　私はよく喋っていると楽しくて、\\n　快活で元気な気立ての良い人って言われてたけど！」","「是吗？我倒是经常一聊起来就很开心，\\n　别人还总夸我是个活泼开朗、性格好的人呢！」",null,null,null],["62_TEXT","62_TEXT",null,null,null],["「……違う人種のにおいがしすぎる」","「……这闻起来太像另一种人了。」",null,null,null],["63_TEXT","63_TEXT",null,null,null],["「あなたはこんなところにまできて、\\n　アクセク働いてるの」","「你是为什么跑到这种地方来，\\n　忙忙碌碌地干活呢。」",null,null,null],["64_TEXT","64_TEXT",null,null,null],["「……たのしい？」","「……你开心吗？」",null,null,null],["65_TEXT","65_TEXT",null,null,null],["「ええ！　労働してると、いい汗かくもの！」","「欸！劳动之后，出一身汗可真舒服！」",null,null,null],["66_TEXT","66_TEXT",null,null,null],["「……そっ」","「……是这样吗。」",null,null,null],["67_TEXT","67_TEXT",null,null,null],["「きっちり働いて、きっちりお金貰って、\\n　きっちり頑張ると、生きてるぞって感じしない？」","「老老实实地干活，堂堂正正地挣钱，\\n　认认真真地努力，不觉得有种‘活着’的实感吗？」",null,null,null],["68_TEXT","68_TEXT",null,null,null],["「……だからもう、しんでるって、皆」","「……所以都说了，我们已经是死人了啦。」",null,null,null],["69_TEXT","69_TEXT",null,null,null],["「ご、ごめんなさい。地雷ふんじゃった？\\n　まだ良くわからなくて、宗義？　みたいなのが」","「对、对不起。我是不是踩到雷区了？\\n　我还没太搞明白，那个像宗义什么的？」",null,null,null],["70_TEXT","70_TEXT",null,null,null],["「……べつにどーでもいいよ」","「……随你怎么想都好啦。」",null,null,null],["71_TEXT","71_TEXT",null,null,null],["「って、いけない。そろそろ次の配達にいかないと」","「哎呀，不好。差不多该去送下一趟快递了。」",null,null,null],["72_TEXT","72_TEXT",null,null,null],["「こんな因習村さっさと脱出したいけど、\\n　先立つものがなくっちゃね」","「虽然想早点逃离这种老古板的村子，\\n　但没本钱可不行啊。」",null,null,null],["73_TEXT","73_TEXT",null,null,null],["「そうだあなた。ここが何県か知らない？\\n　やっぱり大分県なのかしら」","「对了，你啊。知不知道这里是哪个县？\\n　莫非是大分县？」",null,null,null],["74_TEXT","74_TEXT",null,null,null],["「さあね。そうなんじゃない」","「谁知道呢。大概是吧。」",null,null,null],["75_TEXT","75_TEXT",null,null,null],["「やっぱり！　通りでスーパーのサバが、\\n　やけに美味しいと思ったのよ」","「果然！怪不得超市里的青花鱼，\\n　好吃得不得了呢。」",null,null,null],["76_TEXT","76_TEXT",null,null,null],["「それじゃあありがとうございました！\\n　またのご利用をお待ちしております！」","「那就多谢惠顾了！\\n　期待您的再次光临！」",null,null,null],["79_TEXT","79_TEXT",null,null,null],["「……」","「……」",null,null,null],["80_TEXT","80_TEXT",null,null,null],["「はあ。なんかつかれた。お弁当たべよ」","「唉。总感觉好累。吃个便当吧。」",null,null,null]],"type":"","context":[["unique0251.uasset.csv/row/120","unique0251.uasset.csv/row/147","unique0251.uasset.csv/row/158","unique0251.uasset.csv/row/169","unique0251.uasset.csv/row/180","unique0251.uasset.csv/row/191","unique0251.uasset.csv/row/202","unique0251.uasset.csv/row/213","unique0251.uasset.csv/row/224","unique0251.uasset.csv/row/235","unique0251.uasset.csv/row/246","unique0251.uasset.csv/row/257