D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/05_Kamase/unique1051.uasset.csv","tags":[],"progress":{"translated":126,"length":126,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/05_Kamase/unique1061.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/05_Kamase","basename":"unique1061.uasset.csv","extension":"csv","filename":"unique1061.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/05_Kamase/unique1061.uasset.csv","data":[["unique1061","unique1061",null,null,null],["12_TEXT","12_TEXT",null,null,null],["「うおおおおおおおおお！！！！\\n　ランニングにも全・力ッ！！」","「唔哦哦哦哦哦哦哦哦！！！！\\n　跑步也要用尽·全・力！！」",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「うわー汗臭いやつが一瞬横を通ったような」","「哇——好像有个浑身汗臭的家伙一眨眼跑过去了。」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「あ、コーチ！　こんにちはー！」","「啊，教练！您好——！」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「げっ。戻ってきちまった！」","「呕。他又转回来了！」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「げっとはなんですか、げっとは」","「‘呕’是什么意思，‘呕’是几个意思？」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「お前ちょっと面倒くさいんだよ」","「你这家伙有点烦人诶。」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「いつも汗かいててちょっと臭いし」","「而且老是汗津津的，有点臭。」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「ふふふ。コーチ。それはどうかな？\\n　アタシの香りちゃんと嗅いだことないでしょ？」","「呵呵呵。教练。这可说不准哦？\\n　你应该没好好闻过人家的体香吧？」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「えっ」","「诶」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「まあまあ、ちょっと近こう寄りなさい」","「来来来，稍微凑近点儿。」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「な、なんだよ……？　くんくん……、\\n　こ、この匂いは……っ」","「干、干嘛啦……？嗅嗅……，\\n　这、这股味道是……唔！」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「めっちゃ女子の匂いーーーー！？」","「超好闻的女孩子的味道——！？」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「ふははは。アタシの汗、\\n　実はめっちゃいい匂いなんだぜ！」","「噗哈哈哈！老娘的汗，\\n　其实超级香的啦！」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「紳士なコーチはあえて匂わず、\\n　印象だけで語っていたようだが……」","「绅士做派的教练你呀，是故意不闻，\\n　光凭印象就瞎说一通的吧……」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「ぐぬぬ……何事も体験が大事だという\\n　教訓を得たぜ」","「唔唔唔……我得到一个教训，\\n　就是凡事都得实践出真知。」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「ほんならばいばい」","「那就拜拜咯。」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「待て待て待て待て。\\n　女子の匂いを嗅いでおいて、\\n　何もせずに帰るつもりか」","「站住站住站住站住。\\n　你让老子闻了女人的味道，\\n　想就这么啥也不干就走吗？」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「……わーったよ。なんだよ。\\n　1000円ぐらいで良い？」","「……知道了啦。干嘛啦。\\n　给你一千日元够了吧？」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「え。何で金なの。どういう思考。\\n　コーチ普段からパパ活とかしてる？」","「诶。为啥是钱。你这什么脑回路。\\n　教练你平日里是不是在搞干爹援交那一套？」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「え、じゃあ何」","「呃，那你想干嘛。」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「アタシといっしょに！\\n　天下取ろうぜ、この地獄で！」","「跟我一起！\\n　夺取天下吧，在这个地狱里！」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「ほんとヤダ」","「真心不要。」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「なんでだよぉー！　少しは考えろよぉー！」","「为什么啊——！你也稍微考虑一下啊——！」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「魑魅魍魎が跳梁跋扈するこの地獄で、\\n　拳１つ剣１つで成り上がっていく！」","「在这魑魅魍魉横行霸道的地狱里，\\n　凭一双拳头一把剑一步一步往上爬！」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「これこそ、\\n　男のサクセスストーリー！　だろ！？」","「这不就是，\\n　男人的成功传奇！不是吗！？」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「やだよそんなら未だ幸せな家庭を持つ的な\\n　男のサクセスする方がマシだよ」","「才不要呢，比起那种，还是拥有幸福家庭之类的\\n　作为一个男人的成功要更好吧」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「……えっ」","「……诶」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「……………………そっちにする？」","「……………………选那个吗？」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「な、なにがっ」","「什、什么啊」",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「…………ン～～？」","「…………嗯～～？」",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「や、やめろ。その含みのある瞳で、\\n　じっとりと俺を見つめるな」","「别、别这样。别用那种意味深长的眼神，\\n　直勾勾地盯着我」",null,null,null],["47_TEXT","47_TEXT",null,null,null],["「…………こーち……？」","「………教——练……？」",null,null,null],["48_TEXT","48_TEXT",null,null,null],["「ひらがなで俺を呼ぶなー！」","「别用撒娇的语气叫我——！」",null,null,null],["52_TEXT","52_TEXT",null,null,null],["「あー！　逃げたー！　待ってよコーチー！」","「啊——！　跑了——！　等等我呀，教练——！」",null,null,null]],"type":"","context":[["unique1061.uasset.csv/row/96","unique1061.uasset.csv/row/107","unique1061.uasset.csv/row/126","unique1061.uasset.csv/row/137","unique1061.uasset.csv/row/148","unique1061.uasset.csv/row/159","unique1061.uasset.csv/row/170","unique1061.uasset.csv/row/181","unique1061.uasset.csv/row/192","unique1061.uasset.csv/row/203","unique1061.uasset.csv/row/214","unique1061.uasset.csv/row/225","unique1061.uasset.csv/row/236","unique1061.uasset.csv/row/247","unique1061.uasset.csv/row/258","unique1061.uasset.csv/row/269","unique1061.uasset.csv/row/296","unique1061.uasset.csv/row/307","unique1061.uasset.csv/row/318","unique1061.uasset.csv/row/329","unique1061.uasset.csv/row/340","unique1061.uasset.csv/row/351","unique1061.uasset.csv/row/362","unique1061.uasset.csv/row/373","unique1061.uasset.csv/row/384","unique1061.uasset.csv/row/395","unique1061.uasset.csv/row/406","unique1061.uasset.csv/row/417","unique1061.uasset.csv/row/428","unique1061.uasset.csv/row/439","unique1061.uasset.csv/row/450","unique1061.uasset.csv/row/461","unique1061.uasset.csv/row/472","unique1061.uasset.csv/row/483","un