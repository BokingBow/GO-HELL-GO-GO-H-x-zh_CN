3B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/02_Arakasegi/02_Arakasegi01.uasset.csv","tags":[],"progress":{"translated":117,"length":117,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/02_Arakasegi/02_Arakasegi02.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/02_Arakasegi","basename":"02_Arakasegi02.uasset.csv","extension":"csv","filename":"02_Arakasegi02.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/02_Arakasegi/02_Arakasegi02.uasset.csv","data":[["02_Arakasegi02","02_Arakasegi02",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「うーっす。遊びに来たぞー」","「好——哟。我来玩啦——」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「遊びに来るな。買い物に来い」","「别来玩。来买东西」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「そうは言っても、\\n　今日は手持ちが無くってなぁ」","「话虽这么说，\\n　可我今天手头没钱啊」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「物々交換でも良いか」","「以物易物也行吗」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「…………」","「…………」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「どんなところにチャンスが転がってるかは\\n　わからないからな。一応聞いてやろう」","「谁也不知道机遇\\n　会藏在什么地方嘛。我就姑且听听看吧」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「よしきた。えーまず1つ目は」","「好嘞。嗯——首先第一件是」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「焼肉屋の帰りに貰ったガム」","「从烤肉店回来时送的泡泡糖」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「帰れ」","「回去吧你」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「しかも一月前のモンだからな。\\n　食べるのに勇気がいるぜ」","「而且还是一个多月前的了。\\n　要吃它可得有点勇气呢」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「度胸試しに……是非！」","「考验胆量……您不妨试试！」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「するなセールストークを。\\n　負け戦なんだよ最初から」","「别推销了。\\n　这从一开始就是场必输的仗好吧」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「じゃあ2つ目……なんかあったかな」","「那第二件……好像还有什么来着」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「どうせ下らない物が\\n　出てくるんだろうなあ」","「反正\\n　肯定又是些不上台面的破玩意儿吧」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「2つ目は金塊10kg」","「第二件是10公斤的金块」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「………………は？」","「………………哈？」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「――をかたどったチョコ」","「――造型的巧克力」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「お前さ……そんな暇なん？」","「我说你啊……就这么闲吗？」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「かわいいかわいいアラカセギに喜んで\\n　欲しくて用意してきたネタなのに」","「为了让我可爱的荒稼高兴，\\n　我可是特意准备了段子来的呀。」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「おまっ、ばっ、前回の雑な弄り、\\n　いまだに引きずってんじゃねーよ！」","「你、你这家伙，别老惦记着\\n　上次那种瞎胡闹的事啊！」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「アタシの方は忙しいわけ。\\n　金無し暇人の相手はしてらんねー」","「我可是很忙的。\\n　没空搭理没钱又闲的家伙。」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「ふうん忙しいの」","「哦，很忙啊。」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「最近はいろんな庁令がくるくる出たり、\\n　常に対応していかないとだからなあ」","「最近各种厅里的指令变来变去的，\\n　不随时应付着点可不行啊。」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「へえ。そりゃ大変そうだ」","「嘿。听起来够呛啊。」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「……他人事なの何？　お前んとここそ、\\n　その辺先読んでかねーとダメだろ」","「……你说得倒轻巧。你们家才更\\n　得把眼光放长远点吧。」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「……行き当たりばっかりのバカには\\n　どうしようもないか」","「……不过对你这种走一步算一步的傻瓜\\n　来说，可能也没辙吧。」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「うるせーぞスク水エプロンジト目ガールが」","「吵死了，你这个死库水围裙死鱼眼妹。」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「それは何。罵倒してるわけ」","「那算什么。是在骂我咯？」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「ふふ、どっちが良い？」","「呵呵，你觉得哪种说法比较好？」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「わからんけどさっさと帰って欲しい」","「我不知道，只希望你能赶紧回去。」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「お前って……まさか、ツンデレ」","「你这家伙……难道说，是傲娇？」",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「単に塩対応されてるのをツンとかデレとか\\n　言い出したらちょっと終わりだよ」","「要是我这纯属消极应付的态度，都能被说成\\n　什么傲啊娇的，那你可就真完蛋了。」",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「俺にももう少しデレてくれて良いんだぞ」","「你也可以对我再娇一点嘛。」",null,null,null],["47_TEXT","47_TEXT",null,null,null],["「はぁ…仕方がねーなあ。\\n　少しだけやってやるか鬱陶しいし」","「唉…真拿你没办法。\\n　就稍微陪你玩一下好了，吵得烦死人了。」",null,null,null],["48_TEXT","48_TEXT",null,null,null],["「ぉ意外な展開」","「哦，意外的展开。」",null,null,null],["49_TEXT","49_TEXT",null,null,null],["「――べ、別にヤツシロくんのために\\n　用意したわけじゃないんだからねっ」","「――别、别误会，我这可不是\\n　特意为8246君准备的！」",null,null,null],["50_TEXT","50_TEXT",null,null,null],["「な、何を用意してくれたんだ！？」","「你、你给我准备了什么！？」",null,null,null],["51_TEXT","51_TEXT",null,null,null],["「殺鼠剤」","「老鼠药。」",null,null,null],["52_TEXT","52_TEXT",null,null,null],["「デレてないじゃん」","「这不就是完全不娇嘛。」",null,null,null],["53_TEXT","53_TEXT",null,null,null],["「じゃあテトロドトキシン」","「那就河豚毒素。」",null,null,null],["54_TEXT","54_TEXT",null,null,null],["「殺意増したじゃん」","「这根本就是杀意更强了吧。」",null,null,null],["55_TEXT","55_TEXT",null,null,null],["「アタシは用意した自作のお弁当に、\\n　殺鼠剤を混ぜるタイプのツンデレ」","「我就是那种，会往亲手做的\\n　便当里拌老鼠药的傲娇类型。」",null,null,null],["56_TEXT","56_TEXT",null,null,null],["「そんなツンデレねーんだわ世界に」","「世界上可没有这种傲娇啊。」",null,null,null],["57_TEXT","57_TEXT",null,null,null],["「注文の多いやっちゃなー」","「你这家伙要求还真多啊——」",null,null,null],["58_TEXT","58_TEXT",null,null,null],["「料理に毒を混ぜるなっていう、\\n　シンプルな願いだけだが？」","「‘别往菜里下毒’，\\n　这算哪门子的高要求，就是个朴素的愿望吧？」",null,null,null],["59_TEXT","59_TEXT",null,null,null],["「そんな口だけのはんかものじゃあ、\\n　アラカセギちゃんルートにはいけねえな」","「光嘴上说说的半吊子\\n　可进不了荒稼妹子路线哦。」",null,null,null],["60_TEXT","60_TEXT",null,null,null],["「毒耐性必要なんだ、\\n　アラカセギちゃんルート……」","「想进荒稼妹子路线，\\n　还得需要毒属性耐性啊……」",null,null,null],["61_TEXT","61_TEXT",null,null,null],["「はー時間無駄にした」","「哈——真是浪费时间。」",null,null,null],["63_TEXT","63_TEXT",null,null,null],["「それよりなんか買い物あるんだろ。\\n　はよ金を使うだけ使って帰れ」","「比起这个，你不是还要买东西吗。\\n　赶紧把钱花光了走人。」",null,null,null],["64_TEXT","64_TEXT",null,null,null],["「後半、そっちも若干、\\n　ノリノリだったくね……？」","「后半段，你不也稍微\\n　玩得挺起劲吗……？」",null,null,null]],"type":"","context":[["0