_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0161.uasset.csv","tags":[],"progress":{"translated":49,"length":49,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0171.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya","basename":"unique0171.uasset.csv","extension":"csv","filename":"unique0171.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0171.uasset.csv","data":[["unique0171","unique0171",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「………………」","「………………」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「げっ」","「呕。」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「…………こそこそ」","「……偷偷摸摸」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「あっ」","「啊。」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「やべっ」","「卧槽！」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「こら待てぃ！　おめ今目があったやろがい！」","「喂站住！你这不刚跟我对上眼了吗！」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「あ、あれー。ウテナじゃん。\\n　おひさ～～」","「啊，哎呀呀。这不是乌蒂娜嘛。好久不见～～」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「今逃げた？　逃げたよね？\\n　飲酒検問かよ」","「刚才想跑吧？肯定想跑了对吧？你当是查酒驾呢？」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「……ニゲテナイヨ」","「……木有跑啊。」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「嘘下手か」","「这谎撒得也太烂了。」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「だってお前よぉ！\\n　この前会った時エグい金額奢らせたじゃん！」","「还不是因为你啊！上次见面的时候让我请了那么贵的一顿！」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「そうだっけ？　覚えてなっ。\\n　てかやっぱ器ちっちゃ」","「有吗？我不记得了。话说你还真是小气。」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「でももうそういうのは良いんだよ。\\n　金とかはかなりいい感じでさあ」","「不过那些都无所谓啦。钱什么的我现在可是滋润得很呢。」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「あ、そうなん。そりゃ良かったね」","「啊，是嘛。那挺好啊。」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「むしろサぁ～。\\n　あんた、金、欲しくね？」","「不如说嘿～。你，想不想要钱？」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「そりゃ欲しいけど。\\n　なに。良い話あんの」","「想要是当然想要。怎么，有好事儿？」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「あるある超ある。あんさぁ。\\n　ニシワキさんって有名な占い師さんが居てね」","「有有有，超有的。跟你说啊。有个叫西胁先生的有名占卜师。」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「ニシワキさん」","「西胁先生？」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「そう！　何とか様って言う神様の、\\n　生まれ変わりの人なんだけどさあ！」","「没错！听说是位叫‘某某大人’的神明转世来的呢！」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「その人から買った御札がすごいの。\\n　もう効果てきめん」","「从他那儿请的护身符可厉害了。简直是立竿见影。」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「付いてた悪魔とかがぜーんぶ、\\n　消え去っちゃって。金運グンて上がるんだ」","「缠身的恶魔啥的统统都消失不见了。财运嗖地一下就上来了。」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「……なんかヤバめの商売に\\n　巻き込まれてないか？」","「……你是不是给卷进什么不得了的买卖里了？」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「え？　いや、うちは幸せだけど。\\n　幸せって言わなきゃ幸せにならないし」","「啊？没，我倒是挺幸福的啊。人不说自己幸福可就没法变幸福了。」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「あっまあこれもニシワキさんの教えなんだけど」","「啊，嘛，这话也是西胁先生教的啦。」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「ひ、ひぇ～～」","「呀，呀啊～～」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「今時間ある？　そこの喫茶店でちょっと話そっか」","「现在有空吗？去那边咖啡店聊一下呗？」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「……心の底から謹んでお断りしときます」","「……请容我打心底里恭敬地拒绝您。」",null,null,null]],"type":"","context":[["unique0171.uasset.csv/row/104","unique0171.uasset.csv/row/115","unique0171.uasset.csv/row/126","unique0171.uasset.csv/row/137","unique0171.uasset.csv/row/148","unique0171.uasset.csv/row/167","unique0171.uasset.csv/row/178","unique0171.uasset.csv/row/189","unique0171.uasset.csv/row/200","unique0171.uasset.csv/row/211","unique0171.uasset.csv/row/222","unique0171.uasset.csv/row/233","unique0171.uasset.csv/row/244","unique0171.uasset.csv/row/255","unique0171.uasset.csv/row/266","unique0171.uasset.csv/row/277","unique0171.uasset.csv/row/288","unique0171.uasset.csv/row/299","unique0171.uasset.csv/row/310","unique0171.uasset.csv/row/321","unique0171.uasset.csv/row/332","unique0171.uasset.csv/row/343","unique0171.uasset.csv/row/354","unique0171.uasset.csv/row/365","unique0171.uasset.csv/row/376","unique0171.uasset.csv/row/387","unique0171.uasset.csv/row/398"],["unique0171.uasset.csv/row/105"],["unique0171.uasset.csv/row/106"],["unique0171.uasset.csv/row/116"],["unique0171.uasset.csv/row/117"],["unique0171.uasset.csv/row/127"],["unique0171.uasset.csv/row/128"],["unique0171.uasset.csv/row/138"],["unique0171.uasset.csv/row/139"],["unique0171.uasset.csv/row/149"],["unique0171.uasset.csv/row/150"],["unique0171.uasset.csv/row/168"],["unique0171.uasset.csv/row/169"],["unique0171.uasset.csv/row/179"],["unique0171.uasset.csv/row/180"],["unique0171.uasset.csv/row/190"],["unique0171.uasset.csv/row/191"],["unique0171.uasset.csv/row/201"],["unique0171.uasset.csv/row/202"],["unique0171.uasset.csv/row/212"],["unique0171.uasset.csv/row/213"],["unique0171.uasset.csv/row/223"],["unique0171.uasset.csv/row/224"],["unique0171.uasset.csv/row/234"],["unique0171.uasset.csv/row/235"],["unique0171.uasset.csv/row/245"],["unique0171.uasset.csv/row/246"],["unique0171.uasset.csv/row/256"],["unique0171.uasset.csv/row/257"],["unique0171.uasset.csv/row/267"],["unique0171.uasset.csv/row/268"],["unique0171.uasset.csv/row/278"],["unique0171.uasset.csv/row/279"],["unique0171.uasset.csv/row/289"],["unique0171.uasset.csv/row/290"],["unique0171.uasset.csv/row/300"],["unique0171.uasset.csv/row/301"],["unique0171.uasset.csv/row/311"],["unique0171.uasset.csv/row/312"],["unique0171.uasset.csv/row/322"],["unique0171.uasset.csv/row/323"],["unique0171.uasset.csv/row/333"],["unique0171.uasset.csv/row/334"],["unique0171.uasset.csv/row/344"],["unique0171.uasset.csv/row/345"],["unique0171.uasset.csv/row/355"],["unique0171.uasset.csv/row/356"],["unique0171.uasset.csv/row/366"],["unique0171.uasset.csv/row/367"],["unique0171.uasset.csv/row/377"],["unique0171.uasset.csv/row/378"],["unique0171.uasset.csv/row/388"],["unique0171.uasset.csv/row/389"],["unique0171.uasset.csv/row/399"],["unique0171.uasset.csv/row/400"]],"parameters":[[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D