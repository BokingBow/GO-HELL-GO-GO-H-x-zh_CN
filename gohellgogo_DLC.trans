nfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/01_Main/01_04_MEzz.uasset.csv","tags":[],"progress":{"translated":172,"length":172,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/01_Main/01_05_Kiriku.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/01_Main","basename":"01_05_Kiriku.uasset.csv","extension":"csv","filename":"01_05_Kiriku.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/01_Main/01_05_Kiriku.uasset.csv","data":[["01_05_Kiriku","01_05_Kiriku",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「ふんふんふーん」","「哼哼哼～～」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「……さっきからうるさい。なにしてんの」","「……从刚才起就吵死人了。你在干嘛？」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「千羽鶴をな、折っていたのだ。\\n噂に聞く所、鶴を千羽折ると願いが叶うらしい」","「我在折千纸鹤。\\n　听传闻说，折够一千只纸鹤愿望就能实现。」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「きっと鶴を千羽追った瞬間、\\nドラゴンが現れて願いを叶えてくれる」","「肯定是在追完一千只鹤的瞬间，\\n　神龙就会现身，实现愿望吧。」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「……何かいうべき？」","「……我应该对此说点什么吗？」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「夢を見るのは子どもの特権かと思われます」","「鄙人以为，做梦大概是小孩的特权。」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「ぱりぱり。はーお菓子おいしー」","「嘎吱嘎吱。啊—点心真好吃～」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「くぉらきりくー！　いるかオラー！」","「喂—切陆—！在不在，喂—！」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「なに。声でか」","「干嘛。声音真大。」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「でかもペガもねーんだわオラ！\\nサイケクラッシャーかますぞコラ！」","「大不大还有你那屁话管个鸟用，喂！\\n　小心我给你来个迷幻粉碎拳，混蛋！」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「おーおーおーきりくさんよぉ。\\n少食の癖に随分いきましたのぉ！」","「哦—哦—哦—切陆小姐哟。\\n　明明吃得很少，票子花得倒不少啊！」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「口くさ。何の話？」","「嘴好臭。你在说什么事？」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「……今、口臭いって言ったか？」","「……你刚才，说我嘴巴臭？」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「まあまあまあ、そこは良いじゃないですか」","「嘛嘛嘛，那件事就先放一边不好吗。」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「きりく！　てめー、\\n商店街の中華屋で会社のツケで食っただろ！」","「切陆！你这混蛋，\\n　在商店街的中餐馆拿公司的钱挂账吃白食了吧！」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「やべ、見つかったか」","「糟，被发现了。」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「しかも常習犯っちゅう話じゃないですかぁ？\\n　ワレぃコラ！」","「而且听说你还是个惯犯，是吧？\\n　你小子，混蛋！」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「だって、わたしはここの従業員。」","「因为，我是这里的员工。」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「食費は経費でおちるでしょ」","「伙食费走经费报销，也行吧。」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「ていうかいいじゃんそのぐらい。\\n小さいんじゃないの、うつわ」","「再说，这点小事算什么嘛。\\n　不是挺小的吗，器量。」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「世間知らずの小便臭ぇジャリガキが知った風な口して、\\n人間の器量語ってんじゃねえぞコラ！」","「你这个没见过世面、乳臭未干的小丫头片子，\\n　别在这不懂装懂地谈论人的器量，混蛋！」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「こちとら中華屋のおじさんが急に\\n襲ってきて小便漏らす程ビビったんだぞコラ！」","「我们这边可是被中餐馆大爷突然袭击，\\n　吓得连尿都漏出来了，混蛋！」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「！　いそいそ」","「！赶紧赶紧」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「そこ、お湯を沸かす準備はしなくてよろしい。\\nいわゆる比喩表現という奴だから」","「那个，用不着忙着去烧水。\\n　这就是所谓的比喻说法。」",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「うぅ……しょんぼりさせて頂きます……」","「呜……那就请让我消沉一下……」",null,null,null],["47_TEXT","47_TEXT",null,null,null],["「きりくサンよぉ、\\nこの落とし前はどうつけるんだぁああん」","「切陆小姐哟，\\n　你说这事儿该怎么收场，嗯？」",null,null,null],["48_TEXT","48_TEXT",null,null,null],["「……そこまで怒らなくていいじゃん」","「……也用不着气成那样嘛。」",null,null,null],["49_TEXT","49_TEXT",null,null,null],["「なに。どうしたらいいの。おかねはないから」","「干嘛。那你说怎么办。要钱我可没有。」",null,null,null],["50_TEXT","50_TEXT",null,null,null],["「それなら、そりゃー。\\n体で払ってもらうしかねえだろうがよ」","「既然这样，那当然只好——\\n　让你用身子来付了吧。」",null,null,null],["51_TEXT","51_TEXT",null,null,null],["「と・こ・ろ・で」","「顺・便・一・提」",null,null,null],["52_TEXT","52_TEXT",null,null,null],["「！」","「！」",null,null,null],["53_TEXT","53_TEXT",null,null,null],["「～♪」","「～♪」",null,null,null],["54_TEXT","54_TEXT",null,null,null],["「聞く所によると、\\nホシは他にも数名居るって事だったが」","「根据我听到的消息，\\n　同伙好像还有好几个人在啊。」",null,null,null],["55_TEXT","55_TEXT",null,null,null],["「先生怒らないので、正直に挙手」","「老师我不会发火，所以请老实举手。」",null,null,null],["56_TEXT","56_TEXT",null,null,null],["「は、はぁ～い……」","「好，好的……」",null,null,null],["57_TEXT","57_TEXT",null,null,null],["「なんと、怒られないのか！\\nでは、はいなのだ！」","「什么，居然不会挨骂！\\n那我要举手！」",null,null,null],["59_TEXT","59_TEXT",null,null,null],["「てめえらまとめてカラダだカラダ！\\nさっさと支度してこいやコラ！！」","「你们这帮家伙全都给我去卖弄色相！赶紧去准备，快点！！」",null,null,null],["61_TEXT","61_TEXT",null,null,null],["「ひぃ～んっ」","「咿——！」",null,null,null],["62_TEXT","62_TEXT",null,null,null],["「ヤツシロのうそつきー！」","「八津郎你这个骗子——！」",null,null,null],["63_TEXT","63_TEXT",null,null,null],["「はあ、だる……」","「哈啊，好烦……」",null,null,null],["69_TEXT","69_TEXT",null,null,null],["「はあ……ほんと、だる……！」","「哈啊……真是的，烦死了……！」",null,null,null],["78_TEXT","78_TEXT",null,null,null],["「A卓さん、回鍋肉に酸辣湯。\\n山盛り豆板醤トッピングで！」","「A桌，回锅肉和酸辣汤。多到冒尖的豆瓣酱加料！」",null,null,null],["79_TEXT","79_TEXT",null,null,null],["「激安ピリ辛満漢全席酒池肉林ランチ、へいおまちー！」","「超低价香辣满汉全席酒池肉林午餐，来咯——！」",null,null,null],["80_TEXT","80_TEXT",null,null,null],["「はあはあ、何なのここ。人おおすぎ……」","「呼哧呼哧，这什么鬼地方。人太多了……」",null,null,null],["81_TEXT","81_TEXT",null,null,null],["「休んでる暇ないよ！\\n北京ダック17分割いっちょうー！」","「没空休息！北京烤鸭十七分割，来一份——！」",null,null,null],["82_TEXT","82_TEXT",null,null,null],["「中華の魔眼、起動します」","「中华魔眼，启动。」",null,null,null],["86_TEXT","86_TEXT",null,null,null],["「……10歩ゆずって、異常な仕事量はいいとして」","「……退一万步讲，就算这不正常的工作量暂且不说」",null,null,null],["87_TEXT","87_TEXT",null,null,null],["「この趣味全開の衣装はなんなの……」","「这堆暴露癖好的服装又是怎么回事……」",null,null,null],["88_TEXT","88_TEXT",null,null,null],["「きゃーお衣装とってもかわいいー！」","「呀——服装超级可爱——！」",null,null,null],["91_TEXT","91_TEXT",null,null,null],["「ギャラリーに人気なのもむかつくし……」","「在路人里这么受欢迎也让人火大……」",null,null,null],["92_TEXT","92_TEXT",null,null,null],["「そりゃお前、謝罪の気持ちよ。\\n謝罪の気持ちと露出量は比例すんだよ」","「那当然是代表我的歉意啊。道歉的诚意和暴露程度是成正比的啊。」",null,null,null],["93_TEXT","93_TEXT",null,null,null],["「いみわかんない事いってるやつもいるし……」","「还有人说些莫名其妙的话……」",null,null,null],["94_TEXT","94_TEXT",null,null,null],["「オラ、ガキどもビシバシ働んかいコレぃ！」","「喂，你们这群小鬼还不给我麻利地干活！」",null,null,null],["97_TEXT","97_TEXT",null,null,null],["「あぁーもう」","「啊啊——真是够了」",null,null,null],["102_TEXT","102_TEXT",null,null,null],["「ロシアン中華まんセット、おまちしましたー！」","「俄罗斯轮盘中式包子套餐，久等了——！」",null,null,null],["103_TEXT","103_TEXT",null,null,null],["「昼からそんな飲みサーの副菜みたいなの\\n食べる人たちがいるんだ……」","「大中午的还真有人吃这种像拼酒局下酒小菜一样的东西啊……」",null,null,null],["104_TEXT","104_TEXT",null,null,null],["「もぐもぐ。……！　この肉まん、\\n釘食ってるんかと思うぐらい辛いぞ！」","「嚼嚼。……！这肉包，辣得我以为自己咬到了钉子呢！」",null,null,null],["105_TEXT","105_TEXT",null,null,null],["「そこ、つまみ食いしてんじゃねえ！」","「那边那个，不准偷吃！」",null,null,null],["106_TEXT","106_TEXT",null,null,null],["「七草家系がゆを注文したひと、だれ？\\nふうん。……はい」","「七草家系粥是哪位点的？哼……给。」",null,null,null],["107_TEXT","107_TEXT",null,null,null],["「接客業舐めてんじゃねえぞ！\\n笑って！　きりく笑って！　媚び！」","「别看不起服务业啊！给我笑！切陆，笑起来！讨好客人！」",null,null,null],["108_TEXT","108_TEXT",null,null,null],["「完璧な営業スマイルは学習済みです。にっこり」","「完美的营业微笑我已经掌握了。笑脸。」",null,null,null],["109_TEXT","109_TEXT",null,null,null],["「……いや、マスクだし」","「……不对，你还戴着口罩呢。」",null,null,null],["110_TEXT","110_TEXT",null,null,null],["「目が笑ってないんだよ目が。\\nもっと楽しそうにー！　はい、声出してー！」","「我是说眼睛里没笑意啊，眼睛。要显得更开心一点！来，喊出声——！」",null,null,null],["113_TEXT","113_TEXT",null,null,null],["「……あいつあとで絶対ボコす」","「……回头绝对要狠狠揍那混蛋一顿。」",null,null,null],["115_TEXT","115_TEXT",null,null,null],["「ひぃーピークタイム終わってるのに、\\n客足が全然途絶えないよぉー！」","「噫——高峰期明明都过了，客流量却完全没见少啊——！」",null,null,null],["116_TEXT","116_TEXT",null,null,null],["「豚足みじん切り、お願いします」","「猪脚切末，麻烦你了。」",null,null,null],["118_TEXT","118_TEXT",null,null,null],["「オラオラオラオラオラオラ！」","「哦啦哦啦哦啦哦啦哦啦哦啦！」",null,null,null],["119_TEXT","119_TEXT",null,null,null],["「店長！　優秀なバイトから提案がある。\\nランチでカレーフェアを開催しないか？」","「店长！作为优秀员工我有个提案。午餐时段我们搞个咖喱特卖会怎么样？」",null,null,null],["122_TEXT","122_TEXT",null,null,null],["「……叉焼担々麺セット、おまちしました」","「……叉烧担担面套餐，久等了。」",null,null,null],["123_TEXT","123_TEXT",null,null,null],["「声の小さい黒マスクのやつがおんなあ！」","「那个说话声小的黑口罩混蛋在磨蹭什么呢！」",null,null,null],["126_TEXT","126_TEXT",null,null,null],["「……叉焼担々麺せっと、おまちしました！」」","「……叉烧担担面套——餐，久等了！」",null,null,null],["127_TEXT","127_TEXT",null,null,null],["「いいぞ、ビジョンが見えてきた。\\nこの店をゆくゆくはトップレス中華屋として買収」","「不错，我看到前景了。将来我要把这家店收购下来，做成裸着上身的中餐馆。」",null,null,null],["128_TEXT","128_TEXT",null,null,null],["「昼はただの中華屋、\\n夜は夢の遊園地にしていけば」","「白天就是普通中餐馆，晚上把它变成梦幻游乐园的话」",null,null,null],["129_TEXT","129_TEXT",null,null,null],["「掴めるかもしれない、ビッグドリーム」","「说不定就能抓住，大梦想。」",null,null,null],["130_TEXT","130_TEXT",null,null,null],["「地に足のついておらん計画だなあ。\\n一緒に千羽鶴でも折らんか？」","「真是异想天开的计划啊。要不要一起来折千纸鹤？」",null,null,null],["131_TEXT","131_TEXT",null,null,null],["「トップレスとか絶対ならないですからね！？」","「我绝对不会变成无上装什么的啊！？」",null,null,null],["132_TEXT","132_TEXT",null,null,null],["「七面鳥のロースト、お待ちしましたー！\\n　…………にっこり」","「烤火鸡，久等了——！\\n　…………嘻嘻」",null,null,null],["133_TEXT","133_TEXT",null,null,null],["「それはにっこりというか、むっつり」","「你那不叫嘻嘻，叫闷骚吧」",null,null,null],["134_TEXT","134_TEXT",null,null,null],["「……ぶっすりいってやろうか、こいつ」","「……要不要狠狠捅这家伙一刀呢」",null,null,null]],"type":"","context":[["01_05_Kiriku.uasset.csv/row/112","01_05_Kiriku.uasset.csv/row/139","01_05_Kiriku.uasset.csv/row/150","01_05_Kiriku.uasset.csv/row/161","01_05_Kiriku.uasset.csv/row/172","01_05_Kiriku.uasset.csv/row/183","01_05_Kiriku.uasset.csv/row/194","01_05_Kiriku.uasset.csv/row/229","01_05_Kiriku.uasset.csv/row/240","01_05_Kiriku.uasset.csv/row/251","01_05_Kiriku.uasset.csv/row/270","01_05_Kiriku.uasset.csv/row/281","01_05_Kiriku.uasset.csv/row/292","01_05_Kiriku.uasset.csv/row/303","01_05_Kiriku.uasset.csv/row/322","01_05_Kiriku.uasset.csv/row/333","01_05_Kiriku.uasset.csv/row/344","01_05_Kiriku.uasset.csv/row/355","01_05_Kiriku.uasset.csv/row/366","01_05_Kiriku.uasset.csv/row/377","01_05_Kiriku.uasset.csv/row/388","01_05_Kiriku.uasset.csv/row/399","01_05_Kiriku.uasset.csv/row/410","01_05_Kiriku.uasset.csv/row/421","01_05_Kiriku.uasset.csv/row/432","01_05_Kiriku.uasset.csv/row/451","01_05_Kiriku.uasset.csv/row/462","01_05_Kiriku.uasset.csv/row/473","01_05_Kiriku.uasset.csv/row/484","01_05_Kiriku.uasset.csv/row/495","01_05_Kiriku.uasset.csv/row/506","01_05_Kiriku.uasset.csv/row/517","01_05_Kiriku.uasset.csv/row/528","01_05_Kiriku.uasset.csv/row/539","01_05_Kiriku.uasset.csv/row/550","01_05_Kiriku.uasset.csv/row/561","01_05_Kiriku.uasset.csv/row/580","01_05_Kiriku.uasset.csv/row/599","01_05_Kiriku.uasset.csv/row/610","01_05_Kiriku.uasset.csv/row/621","01_05_Kiriku.uasset.csv/row/672","01_05_Kiriku.uasset.csv/row/747","01_05_Kiriku.uasset.csv/row/758","01_05_Kiriku.uasset.csv/row/769","01_05_Kiriku.uasset.csv/row/780","01_05_Kiriku.uasset.csv/row/791","01_05_Kiriku.uasset.csv/row/826","01_05_Kiriku.uasset.csv/ro