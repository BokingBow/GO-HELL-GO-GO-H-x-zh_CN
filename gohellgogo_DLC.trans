T_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/04_Oshi/unique0911.uasset.csv","tags":[],"progress":{"translated":87,"length":87,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/04_Oshi/unique0911B.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/04_Oshi","basename":"unique0911B.uasset.csv","extension":"csv","filename":"unique0911B.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/04_Oshi/unique0911B.uasset.csv","data":[["unique0911B","unique0911B",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「くぅっ……ふぅ……っ。\\n何なんでありますかっ、針山地獄て……！？」","「呃……呼……。\\n什么鬼啊，针山地狱……！？」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「こんな事して、何が楽しいか、\\n謎すぎるのですが……っ！」","「干这种事，乐趣何在，\\n也太让人费解了……！」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「とにかく、生き、残る……ッ！」","「总之，活，活下去……！」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「ひぃいいっ。危なっ。ギリギリ～～！」","「咿～～。好险。差点就～～！」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「ゆっくり、伸びてくる針を……、\\n的確に、避けていく……」","「把慢慢，伸过来的针……，\\n精准地，躲开……」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「慎重にぃ……慎重にぃ……」","「小心点……小心点……」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「ひぃっ。時には大胆にぃっ！」","「咿～。偶尔也要大胆点～！」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「ふぅー……っ、ふぅー……っ。\\n　これ、握力、かなり、使う……」","「呼——……呼——……。\\n　这个，相当，费握力……」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「……体力配分……気をつけ、ないと……」","「……体力分配……必须，注意……」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「ま、負けるかぁ～～……っ」","「我，我怎么会输呢——……」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「生にしかとしがみ、ついてぇ……っ」","「死死地，抓住生命……不放手……」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「パチモン扱いした連中をぉ、\\n　見返してやる～～～！！」","「我要让那些把我当冒牌货的家伙们，\\n　刮目相看——！！」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「ふぅー……ふぅー……ぉっ！\\n　う、腕、痛ぁ……」","「呼——……呼——……哇！\\n　胳、胳膊，好痛……」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「これ、一体、いつまで……ふぅー……続ければ……」","「这到底，要持续……呼——……到什么时候……」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「ド……根性～～～～！！」","「凭……毅力——！！」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「ぐぉおおおおおお！！\\n　負けるかぁ～～～～！！」","「唔哦哦哦哦哦哦哦！！\\n　怎么会输呢——！！」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「ひ、左手側の針が迫って来てる～！\\n　ひぃー、怖ぁ……じょ、徐々に来て……」","「呀，左边的针逼过来了～！\\n　咿——，好可怕……慢、慢慢过来了……」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「ぬおぉぉおおお！！\\n　ふんぐぅううううう！！」","「喝啊啊啊啊啊！！\\n　哼唔唔唔唔唔唔！！」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「おぉっ……ほぉおおおおおおおおおお！！」","「哦……嚯噢噢噢噢噢噢噢噢噢！！」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["『すいませーん。力む声、\\n　もうちょっと何とかならないですかー？』","『不好意思——。你使劲儿时那个叫声，\\n　能不能再想想办法啊——？』",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「何とかって何でありますか！？\\n　ふんぬぅうううううううう！！」","「想办法是要想什么办法啊！？\\n　哼嗯唔唔唔唔唔唔唔唔！！」",null,null,null],["45_TEXT","45_TEXT",null,null,null],["『そういう所が惜しいんだよなあ……』","『就是这点让人觉得可惜啊……』",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「よくわかんないけどうるさいよ！」","「虽然听不太懂但你好吵啊！」",null,null,null],["49_TEXT","49_TEXT",null,null,null],["「って、まず……っ。\\n　ツッコんでたら、力が……っ」","「话说，首先……呃。\\n　光顾着吐槽，力气就……」",null,null,null],["50_TEXT","50_TEXT",null,null,null],["「ず、ずり落ちたらまずい！\\n　本当に！　洒落にならないタイプのまずさ！」","「滑、滑下去可不妙了！\\n真的不妙！是那种开不得玩笑的不妙啊！」",null,null,null],["51_TEXT","51_TEXT",null,null,null],["「ぬぅううううん！！\\n　ち、力を入れろぉ！　心を燃やせぇ！！」","「唔噢噢噢噢嗯！！\\n　使、使劲儿啊！燃烧内心啊！！」",null,null,null],["55_TEXT","55_TEXT",null,null,null],["「ていうかなんか、\\nぬるぬるしてきたのですが！？」","「话说回来，好像有什么东西\\n变得滑溜溜的了啊！？」",null,null,null],["56_TEXT","56_TEXT",null,null,null],["『ここから伸びてくる針には、\\nオイルが散布されています』","『从现在开始伸出来的这些针，\\n表面都喷洒了润滑油哦』",null,null,null],["57_TEXT","57_TEXT",null,null,null],["「何でぇ！？　嫌がらせに抜かりが無さすぎる！」","「搞什么鬼！？这恶心人的招数也太滴水不漏了吧！」",null,null,null],["58_TEXT","58_TEXT",null,null,null],["「これって、何の意味があるんです！？」","「这、这到底有什么意义啊！？」",null,null,null],["59_TEXT","59_TEXT",null,null,null],["『……？　手が滑って、刺さりやすくなる？』","『……？手一滑，不就更容易扎进去了吗？』",null,null,null],["61_TEXT","61_TEXT",null,null,null],["「そりゃあそうでしょうねえ！」","「那当然了啦！」",null,null,null],["63_TEXT","63_TEXT",null,null,null],["「はあ、はあ、もう、握力、が……っ、ほん、とに……！」","「哈啊，哈啊，我已经，握力，要……真的，要到……」",null,null,null],["65_TEXT","65_TEXT",null,null,null],["「ふんぬおぉおおおおお！！\\n負けない！　負けないでありますーー！！」","「哼嗯唔噢噢噢噢噢噢噢！！\\n我才不会输！绝对不会输的——！！」",null,null,null]],"type":"","context":[["unique0911B.uasset.csv/row/104","unique0911B.uasset.csv/row/115","unique0911B.uasset.csv/row/126","unique0911B.uasset.csv/row/145","unique0911B.uasset.csv/row/156","unique0911B.uasset.csv/row/167","unique0911B.uasset.csv/row/178","unique0911B.uasset.csv/row/205","unique0911B.uasset.csv/row/216","unique0911B.uasset.csv/row/235","unique0911B.uasset.csv/row/246","unique0911B.uasset.csv/row/257","unique0911B.uasset.csv/row/268","unique0911B.uasset.csv/row/279","unique0911B.uasset.csv/row/306","unique0911B.uasset.csv/row/317","unique0911B.uasset.csv/row/336","unique0911B.uasset.csv/row/363","unique0911B.uasset.csv/row/390","unique0911B.uasset.csv/row/401","unique0911B.uasset.csv/row/412","unique0911B.uasset.csv/row/423","unique0911B.uasset.csv/row/434","unique0911B.uasset.csv/row/461","unique0911B.uasset.csv/row/472","unique0911B.uasset.csv/row/483","unique0911B.uasset.csv/row/518","unique0911B.uasset.csv/row/529","unique0911B.uasset.csv/row/540","unique0911B.uasset.csv/row/551","unique0911B.uasset.csv/row/562","unique0911B.uasset.csv/row/581","unique0911B.uasset.csv/row/600","unique0911B.uasset.csv/row/619"],["unique0911B.uasset.csv/row/105"],["unique0911B.uasset.csv/row/106"],["unique0911B.uasset.csv/row/116"],["unique0911B.uasset.csv/row/117"],["unique0911B.uasset.csv/row/127"],["unique0911B.uasset.csv/row/128"],["unique0911B.uasset.csv/row/146"],["unique0911B.uasset.csv/row/147"],["unique0911B.uasset.csv/row/157"],["unique0911B.uasset.csv/row/158"],["unique0911B.uasset.csv/row/168"],["unique0911B.uasset.csv/row/169"],["unique0911B.uasset.csv/row/179"],["unique0911B.uasset.csv/row/180"],["unique0911B.uasset.csv/row/206"],["unique0911B.uasset.csv/row/207"],["unique0911B.uasset.csv/row/217"],["unique0911B.uasset.csv/row/218"],["unique0911B.uasset.csv/row/236"],["unique0911B.uasset.csv/row/237"],["unique0911B.uasset.csv/row/247"],["unique0911B.uasset.csv/row/248"],["unique0911B.uasset.csv/row/258"],["unique0911B.uasset.csv/row/259"],["