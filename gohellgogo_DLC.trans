],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0261.uasset.csv","tags":[],"progress":{"translated":57,"length":57,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0271.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya","basename":"unique0271.uasset.csv","extension":"csv","filename":"unique0271.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0271.uasset.csv","data":[["unique0271","unique0271",null,null,null],["12_TEXT","12_TEXT",null,null,null],["「はあ。……一旦、最近の悩みを聞いてくれない？」","「唉。……那个，能先听我聊聊最近的烦恼吗？」",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「絵に書いたような藪から棒だな」","「这可真是典型的没头没脑啊」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「何？　なんか趣味でも始めたとか？」","「怎么？你开始搞什么爱好了？」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「趣味はねえ、とりあえず散歩を始めてみた」","「爱好嘛，总之我开始散步了」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「へえ、健康的でいいじゃん」","「哦，挺健康的，不错啊」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「今は仕事でも走り回ってるのに、\\n　歩く理由って何？　って自問してるとこ」","「现在工作就得跑个不停，\\n我正扪心自问，那走路的理由是什么？」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「向いてない趣味だったんだ……」","「原来是个不适合你的爱好啊……」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「なんか……ジグソーパズルとかしてみたら」","「要不……试试拼图什么的？」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「……楽しいわけ？　そんなの」","「……那玩意儿，能有意思吗？」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「わからんけど、老後とかにジグソーパズルが\\n　趣味ですって言う老人とかを見ると」","「我也不清楚，但看到那些上了年纪\\n说自己爱好是拼图的老人时」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「豊かな生活だな……って思う」","「我就会觉得……真是安逸的生活啊」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「……………………わからんでもないかも」","「……………………也许，也不是不能理解」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「まあ趣味は置いとくとして、\\n　悩みはちゃんと別にあるのよ」","「哎，爱好先放一边，\\n烦恼是有别的，正经的烦恼啊」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「ずばり背中に入ってる配達中のもの、\\n　そろそろ諦めようかなと思って」","「直说吧，背上那个正在配送的东西，\\n我想是不是差不多该放弃了」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「まだ入ったままだったのかよ！\\n　……何だっけ？　海鮮丼？」","「居然还在背上吗！\\n……是什么来着？海鲜丼？」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「うん。でも開けるの怖くて。\\n　あ、そうだ、売ってあげようか」","「嗯。但我怕打开。\\n啊，对了，我卖给你吧」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「いらねえよ！」","「谁要啊！」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「半額でも良いから！」","「半价就行了！」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「お前確実に腐りきった海鮮丼が\\n　半額は舐めてるだろ資本主義を！」","「你拿肯定烂透了的玩意儿\\n半价糊弄人，是在藐视资本主义吧！」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「うぅ……せちがらい社会」","「呜……这冷冰冰的社会」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「でも、中身がどうなってるか、\\n　ちょっとだけ……気にならない？」","「但是，里面到底变成什么样了，\\n你就不好奇……哪怕一点点吗？」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「ぅっ」","「唔」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「かれこれほにゃらら週間も密閉された、\\n　海鮮丼の今現在――」","「封印了大概那个啥星期之久的，\\n海鲜丼的此时此刻――」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「私はここまでくるとちょっとした生態系ぐらいは\\n　築いていると思うのよね」","「我觉得到了这个地步，里头差不多\\n都能建立个小生态系统了」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「そんなバカな」","「怎么可能」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「……見てみたくない？」","「……你不想看看吗？」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「…………」","「…………」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「100円で良いわよ」","「100日元就好哦」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「……（ちゃりーん）」","「……（叮铃～）」",null,null,null],["48_TEXT","48_TEXT",null,null,null],["「………………………………」","「………………………………」",null,null,null],["51_TEXT","51_TEXT",null,null,null],["「ぎゃーーーーーーー！！！！」","「啊啊啊啊啊啊啊啊啊！！！！」",null,null,null]],"type":"","context":[["unique0271.uasset.csv/row/96","unique0271.uasset.csv/row/107","unique0271.uasset.csv/row/118","unique0271.uasset.csv/row/129","unique0271.uasset.csv/row/140","unique0271.uasset.csv/row/151","unique0271.uasset.csv/row/162","unique0271.uasset.csv/row/173","unique0271.uasset.csv/row/184","unique0271.uasset.csv/row/195","unique0271.uasset.csv/row/206","unique0271.uasset.csv/row/217","unique0271.uasset.csv/row/228","unique0271.uasset.csv/row/239","unique0271.uasset.csv/row/250","unique0271.uasset.csv/row/261","unique0271.uasset.csv/row/272","unique0271.uasset.csv/row/283","unique0271.uasset.csv/row/294","unique0271.uasset.csv/row/305","unique0271.uasset.csv/row/316","unique0271.uasset.csv/row/327","unique0271.uasset.csv/row/338","unique0271.uasset.csv/row/349","unique0271.uasset.csv/row/360","unique0271.uasset.csv/row/371","unique0271.uasset.csv/row/382","unique0271.uasset.csv/row/393","unique0271.uasset.csv/row/404","unique0271.uasset.csv/row/471","unique0271.uasset.csv/row/498"],["unique0271.uasset.csv/row/97"],["unique0271.uasset.csv/row/98"],["unique0271.uasset.csv/row/108"],["unique0271.uasset.csv/row/109"],["unique0271.uasset.csv/row/119"],["unique0271.uasset.csv/row/120"],["unique0271.uasset.csv/row/130"],["unique0271.uasset.csv/row/131"],["unique0271.uasset.csv/row/141"],["unique0271.uasset.csv/row/142"],["unique0271.uasset.