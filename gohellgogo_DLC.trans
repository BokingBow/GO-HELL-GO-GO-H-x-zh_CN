unique0571.uasset.csv/row/389"],["unique0571.uasset.csv/row/399"],["unique0571.uasset.csv/row/400"],["unique0571.uasset.csv/row/410"],["unique0571.uasset.csv/row/411"],["unique0571.uasset.csv/row/421"],["unique0571.uasset.csv/row/422"],["unique0571.uasset.csv/row/432"],["unique0571.uasset.csv/row/433"],["unique0571.uasset.csv/row/443"],["unique0571.uasset.csv/row/444"],["unique0571.uasset.csv/row/454"],["unique0571.uasset.csv/row/455"],["unique0571.uasset.csv/row/465"],["unique0571.uasset.csv/row/466"],["unique0571.uasset.csv/row/476"],["unique0571.uasset.csv/row/477"]],"parameters":[[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"},{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_1"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0571.uasset.csv","tags":[],"progress":{"translated":69,"length":69,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0651.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya","basename":"unique0651.uasset.csv","extension":"csv","filename":"unique0651.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/07_Mouzya/unique0651.uasset.csv","data":[["unique0651","unique0651",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「どおおおりゃあああああああああ！！」","「咿呀啊啊啊啊啊啊啊啊啊啊啊！！」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「な、なんだ！？」","「什、什么！？」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「こォらぁああ！　でてこい責任者ァ！\\n　言いたい事が、あるんだよォ！」","「喂喂喂喂！给我出来，负责人！\\n　我有话要说啊！」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「……どなたでござるか？」","「……阁下是哪位？」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「ただの怒れる一市民よ！\\n　逆にアンタは誰なわけ！？」","「只是个愤怒的市民！\\n　倒要问你是谁啊！？」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「拙者は留守番の薄……」","「在下是看家的薄……」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「――と思ったけど名前とか、どうでも良かったァ！」","「――不过我想了想，名字什么的，都无所谓了！」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「むむ……」","「唔唔……」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「私はねえ！　地獄がどうとか亡者がどうとか\\n　意味わかんない話でこの街に拉致られて！」","「我啊！被那些什么地狱啦死者啦\\n　莫名其妙的话强行拉到这个城市！」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「なんかさんざんひンどいことされて、\\n　ひ～～っしに耐えてたと思ったら！」","「等我好不容易忍着\\n　那些乱七八糟的过分事情的时候！」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「急に何も持たずにほっぽりだされて、\\n　はいさよならってどういうつもりよ！？」","「突然就什么都没带就被丢掉大街上，\\n　一句好再见是什么意思啊！？」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「なるほど。つまりお主は……」","「原来如此。也就是说阁下是……」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["「この事務所は！　客人にお茶も無いのかしら！？」","「这间事务所！连杯茶都没有给客人的吗！？」",null,null,null],["28_TEXT","28_TEXT",null,null,null],["「……しばし待って居てくだされ。\\n　粗茶で良ければ」","「……请稍等片刻。粗茶一杯，若不嫌弃的话」",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「あーそう？　話が早いのは助かる！」","「啊——是吗？能这么爽快真是帮大忙了！」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「どうぞ。茶菓子もせんべいでよければ」","「请用。茶点只有仙贝，还望别嫌弃。」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「お煎餅大好き！　なーによもー！\\n　あなた、結構気が利くじゃない！」","「我最爱仙贝了！什么嘛，你也——！\\n 你这人，还挺会来事儿的嘛！」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["「全くねーバリバリ。本当にねごくごく。\\n　大変だったんだからね今までごっくん」","「真是的——咔嚓咔嚓。真的呢——咕咚咕咚。\\n　之前可折腾死我了——咕噜。」",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「はあ。苦労してきたのですな」","「哦呀。看来您吃了不少苦头呢。」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「そういやあいつは？　あの作業着の\\n　冴えない系主人公みたいなやつ」","「对了，那家伙呢？那个穿着工装、\\n 一脸衰样的男主角似的家伙。」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「社長ですか。小用ですので、\\n　いま暫くお待ちいただければ……」","「您是说社长吗？他去方便了，\\n　还得请您稍等片刻……」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「ふぅーんまあそれだったら待たせてもらうわ。\\n　仕方がないわねえ忙しいのに」","「哼——嗯，行吧，那我就等等好了。\\n　没办法啦，明明我这么忙的。」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「この後何か用事がおありで？」","「您之后是还有什么安排吗？」",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「え？　ナンパ？　キモ。\\n　私、枯れ専じゃないのよね」","「啊？搭讪？恶心。\\n 我可不是大叔控。」",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「でもまあ少し遊ぶぐらいならしてあげる。\\n　スイーツバイキングとかで良いなら」","「不过呢，稍微陪我玩玩还是可以的。\\n　要是请我吃甜品自助什么的就行。」",null,null,null],["47_TEXT","47_TEXT",null,null,null],["「は、はは……まあそれは置いておくとして」","「哈、哈哈……那个嘛，就先不提了。」",null,null,null],["48_TEXT","48_TEXT",null,null,null],["「まだなのあいつは？\\n　私もうお腹へっちゃったんですけど」","「那家伙还没来吗？\\n　我肚子都快饿扁了耶。」",null,null,null],["49_TEXT","49_TEXT",null,null,null],["「え。さっきおせんべ食べてたのに」","「咦。您刚才不是吃了仙贝吗。」",null,null,null],["50_TEXT","50_TEXT",null,null,null],["「あんたね、小鳥の餌じゃないんだから。\\n　あんなの、食事のうちにも入らないわ！」","「我说你，我又不是吃鸟食的。\\n　那玩意儿，根本不算正经吃饭！」",null,null,null],["51_TEXT","51_TEXT",null,null,null],["「……確か棚の隅に、\\n　まんじゅうが残っていたような」","「……我记得架子角落里，\\n　好像还剩了点包子。」",null,null,null],["52_TEXT","52_TEXT",null,null,null],["「おまんじゅう！？　大好き！\\n　はやく！　はやく！」","「包子！？我最喜欢了！\\n 快点！快点！」",null,null,null],["53_TEXT","53_TEXT",null,null,null],["「ちょっとお待ちくだされ……」","「请您稍等片刻……」",null,null,null],["59_TEXT","59_TEXT",null,null,null],["「……あっ」","「……啊。」",null,null,null],["60_TEXT","60_TEXT",null,null,null],["62_TEXT","62_TEXT",null,null,null],["「……」","「……」",null,null,null],["65_TEXT","65_TEXT",null,null,null],["「に、逃げた……！\\n　どう見ても面倒くさそうだからって！」","「溜、溜了……！\\n　明显是看我太难缠了吧！」",null,null,null],["66_TEXT","66_TEXT",null,null,null],["「ちょっとー！　まだー！？\\n　こっち餓えて果てそうなんですけど！」","「喂——！还没好吗——！？\\n 这边可是快要饿死了耶！」",null,null,null],["67_TEXT","67_TEXT",null,null,null],["「おまわりさーん！　ここにいたいけな少女を\\n　飢えさせる極悪人がいまーす！」","「警察叔叔——！这里有个快要把可怜少女\\n 活活饿死的大恶人——！」",null,null,null],["68_TEXT","68_TEXT",null,null,null],["「この借りは高くつきますよ……！」","「这笔账，我会让你加倍还的……！」",null,null,null],["74_TEXT","74_TEXT",null,null,null],["「はいはい、待ってくだされ……。\\n　こちらがご所望の品になります」","「来了来了，请您稍等……。\\n　这是您要的东西。」",null,null,null],["75_TEXT","75_TEXT",null,null,null],["「わーいありがとー！\\n　……でも小さい。もっとないの？」","「哇——谢谢——！\\n　……不过好小啊。没有了吗？」",null,null,null],["76_TEXT","76_TEXT",null,null,null],["「……そこまで腹が減っているなら、\\n　何か拙者が作ろうか」","「……您要是饿成这样，\\n　要不鄙人给您做点什么吧。」",null,null,null],["77_TEXT","77_TEXT",null,null,null],["「え。いいのっ。\\n　でもそこまでお世話になるわけには！」","「咦。可以吗。\\n　但也不用这么麻烦你啦！」",null,null,null],["78_TEXT","78_TEXT",null,null,null],["「……そうでござるか。では」","「……这样啊。那好吧。」",null,null,null],["79_TEXT","79_TEXT",null,null,null],["「なんてウッソー！　絶対もらうに決まってるじゃない！\\n　えー何があるの？　私、ガッツリ系が良い！」","「才怪——骗你的啦！怎么可能不要嘛！\\n 诶——有什么呀？我要那种能填饱肚子的！」",null,null,null],["80_TEXT","80_TEXT",null,null,null],["「ではヤキソバでもどうでござるか。\\n　少し時間はかかろうが……」","「那，来份炒面如何？\\n　不过得花点时间就是了……」",null,null,null],["81_TEXT","81_TEXT",null,null,null],["「ヤキソバ大好き！　ぜひお願い！\\n　あ、目玉焼きも乗っけてね！」","「炒面我最喜欢了！务必拜托了！\\n 啊，再给我加个荷包蛋哦！」",null,null,null],["82_TEXT","82_TEXT",null,null,null],["「ははは。勿論でござる。\\n　ごゆるりと食べていきなされ」","「哈哈哈。那是自然。\\n　请您就安心慢慢吃吧。」",null,null,null],["83_TEXT","83_TEXT",null,null,null],["「きっとこのまま待っていれば、\\n　社長も来る筈ですので」","「我想您就这样再等一会儿，\\n　社长肯定也该回来了。」",null,null,null],["84_TEXT","84_TEXT",null,null,null],["（社長がトイレに隠れてやりすごすつもりだ。\\n　……そうはいかんぞ）","（社长打算躲在厕所里蒙混过去。\\n　……想得美）",null,null,null],["85_TEXT","85_TEXT",null,null,null],["「えへへー。ごはん、まだかなー！」","「嘿嘿嘿。饭还没好吗～！」",null,null,null]],"type":"","context":[["unique0651.uasset.csv/row/120","unique0651.uasset.csv/row/131","unique0651.uasset.csv/row/142","unique0651.uasset.csv/row/153","unique0651.uasset.csv/row/164","unique0651.uasset.csv/row/175","unique0651.uasset.csv/row/186","unique0651.uasset.csv/row/197","unique0651.uasset.csv/row/208","unique0651.uasset.csv/row/219","unique0651.uasset.csv/row/230","unique0651.uasset.csv/row/241","unique0651.uasset.csv/row/252","unique0651.uasset.csv/row/263","unique0651.uasset.csv/row/274","unique0651.uasset.csv/row/341","unique0651.uasset.csv/row/352","unique0651.uasset.csv/row/363","unique0651.uasset.csv/row/374","unique0651.uasset.csv/row/385","unique0651.uasset.csv/row/396","unique0651.uasset.csv/row/407","unique0651.uasset.csv/row/418","unique0651.uasset.csv/row/429","unique0651.uasset.csv/row/440","unique0651.uasset.csv/row/451","unique0651.uasset.csv/row/462","unique0651.uasset.csv/row/473","unique0651.uasset.csv/row/484","uniq