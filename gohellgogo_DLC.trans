EXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_2"}],[{"rowInfoText":"TEXT_24_C669B6D2463B2D1232AD4DBFD3C8D513_3"}]],"relPath":"AnzuAppend/01/DataTable/Scenario/04_Oshi/unique0961.uasset.csv","tags":[],"progress":{"translated":57,"length":57,"percent":100},"originalFormat":"Autogenerated TRANS obj","indexIsBuilt":false},"AnzuAppend/01/DataTable/Scenario/04_Oshi/unique0971.uasset.csv":{"dirname":"data/AnzuAppend/01/DataTable/Scenario/04_Oshi","basename":"unique0971.uasset.csv","extension":"csv","filename":"unique0971.uasset","path":"data/AnzuAppend/01/DataTable/Scenario/04_Oshi/unique0971.uasset.csv","data":[["unique0971","unique0971",null,null,null],["13_TEXT","13_TEXT",null,null,null],["「ぐぬぬぬぬぬぬぬ……」","「唔呶呶呶呶呶呶……」",null,null,null],["14_TEXT","14_TEXT",null,null,null],["「なに。またなんかあったの」","「怎么。又出什么事了吗？」",null,null,null],["15_TEXT","15_TEXT",null,null,null],["「また間違えられたんでありますよー！\\n　しかも『本物の方がやっぱ可愛いね』とか\\n　陰口まで叩かれて！」","「我又被认错了呀—！\\n　而且还有人背后说坏话，什么\\n『果然还是真货更可爱呢』之类的！」",null,null,null],["16_TEXT","16_TEXT",null,null,null],["「あぁー。そりゃ凹むな」","「啊—。那确实很受打击啊」",null,null,null],["17_TEXT","17_TEXT",null,null,null],["「べそべそ。そうですよう」","「抽抽搭搭。就是啊」",null,null,null],["18_TEXT","18_TEXT",null,null,null],["「……この格好がいけないんですかね。\\n　自分のアイデンティティだと思ってましたけど」","「……是不是我这身打扮不行啊。\\n　我还觉得这是我的身份象征呢」",null,null,null],["19_TEXT","19_TEXT",null,null,null],["「カラーリングも被ってるそうだし、\\n　いっそ個性的な物に変えようかしら」","「听说发色也撞了，\\n　要不干脆换个有个性的造型吧？」",null,null,null],["20_TEXT","20_TEXT",null,null,null],["「や、やめろー！」","「别、别啊—！」",null,null,null],["21_TEXT","21_TEXT",null,null,null],["「なんで」","「为什么？」",null,null,null],["22_TEXT","22_TEXT",null,null,null],["「……だってその格好、とっても似合ってるから」","「……因为你这身打扮，真的非常合适啊」",null,null,null],["23_TEXT","23_TEXT",null,null,null],["「えへへー。そうでありますかー？」","「诶嘿嘿—。是这样吗—？」",null,null,null],["24_TEXT","24_TEXT",null,null,null],["「そこまで言うなら、\\n　仕方ないでありますなー」","「既然你都这么说了，\\n　那就没办法了呀—」",null,null,null],["25_TEXT","25_TEXT",null,null,null],["「……ン？　あそこにおしゃれなヘアサロンが」","「……嗯？那边有家时髦的美发沙龙啊」",null,null,null],["26_TEXT","26_TEXT",null,null,null],["「そうだ。髪型を大きく変えてみようかな。\\n　いっそ、ショートにしてみるとか」","「对了。要不我彻底换个发型试试吧。\\n　干脆，剪个短发什么的」",null,null,null],["27_TEXT","27_TEXT",null,null,null],["28_TEXT","28_TEXT",null,null,null],["29_TEXT","29_TEXT",null,null,null],["「だってその髪型、とっても似合ってるから」","「因为那个发型，真的非常合适你啊」",null,null,null],["30_TEXT","30_TEXT",null,null,null],["「………………」","「………………」",null,null,null],["31_TEXT","31_TEXT",null,null,null],["「そんな疑いの目で俺を見るな」","「别用那种怀疑的眼神看我啊」",null,null,null],["32_TEXT","32_TEXT",null,null,null],["「だってヤツシロ殿って自分のこと、\\n　劣化コピーぐらいに考えてますよね？」","「因为8246大人你呀，是不是把自己当成\\n　劣化复制品差不多的存在了？」",null,null,null],["33_TEXT","33_TEXT",null,null,null],["「そんな人権意識の低いこと、\\n　俺が思うだなんてマサカ」","「我怎么可能会有那么低\\n　人权意识的想法呢，怎么可能嘛」",null,null,null],["34_TEXT","34_TEXT",null,null,null],["「はーー！？　地獄の鬼が、\\n　亡者に向かってなにほざいているんです！？」","「哈——！？你这地狱的恶鬼，\\n　对着亡者胡说八道些什么呢！？」",null,null,null],["35_TEXT","35_TEXT",null,null,null],["「正直に言って下さい正直に。\\n　自分、怒りませんから」","「老实交代，坦白从宽。\\n　我，是不会生气的」",null,null,null],["36_TEXT","36_TEXT",null,null,null],["「だって、惜しいところがいいんじゃん！」","「因为，那点残缺感才恰到好处嘛！」",null,null,null],["37_TEXT","37_TEXT",null,null,null],["「……はい？」","「……嗯？」",null,null,null],["38_TEXT","38_TEXT",null,null,null],["「ある意味めちゃめちゃ個性だぞ。\\n　ほらモノマネ芸人とかもいるわけじゃん」","「从某种意义上讲那超有个性的好吗。\\n　你看，不也有模仿艺人嘛」",null,null,null],["39_TEXT","39_TEXT",null,null,null],["40_TEXT","40_TEXT",null,null,null],["「それに、1番の問題もある」","「而且，还有一个最大的问题」",null,null,null],["41_TEXT","41_TEXT",null,null,null],["「……なんでありますか？」","「……是什么呀？」",null,null,null],["42_TEXT","42_TEXT",null,null,null],["「ただのポッと出のユニークキャラに、\\n　これ以上割く差分なんて無いんだ」","「对一个不过是半路杀出的独特角色，\\n　可没那么多差分素材再分给她了」",null,null,null],["43_TEXT","43_TEXT",null,null,null],["「ピキっ」","「啪叽」",null,null,null],["44_TEXT","44_TEXT",null,null,null],["「だからコレ以上は大人しく、\\n　二号ちゃんの立場を享受してもろて……」","「所以啊，你就别再折腾，乖乖\\n　享受你二号小妹的立场吧……」",null,null,null],["45_TEXT","45_TEXT",null,null,null],["「うわああああああああああああ！！！\\n　ぶっ飛ばす！　もう全員全部ぶっとばす！！」","「呜哇啊啊啊啊啊啊啊啊啊啊！！！\\n　揍飞你！所有的一切全都揍飞！！」",null,null,null],["46_TEXT","46_TEXT",null,null,null],["「ぎゃあー！　錯乱した！！\\n　おまわりさん！　おまわりさーん！！」","「哎呀—！她发狂了！！\\n　警察叔叔！警察叔叔—！！」",null,null,null],["47_TEXT","47_TEXT",null,null,null],["「全員ッ！　海の藻屑にしてやらぁあああああああ！！」","「所有人！！全把你们变成海里的藻屑啊啊啊啊啊啊！！」",null,null,null]],"type":"","context":[["unique0971.uasset.csv/row/104","unique0971.uasset.csv/row/115","unique0971.uasset.csv/row/126","unique0971.uasset.csv/row/137","unique0971.uasset.csv/row/148","unique0971.uasset.csv/row/159","unique0971.uasset.csv/row/170","unique0971.uasset.csv/row/181","unique0971.uasset.csv/row/192","unique0971.uasset.csv/row/203","unique0971.uasset.csv/row/214","unique0971.uasset.csv/row/225","unique0971.uasset.csv/row/236","unique0971.uasset.csv/row/247","unique0971.uasset.csv/row/258","unique0971.uasset.csv/row/269","unique0971.uasset.csv/row/280","unique0971.uasset.csv/row